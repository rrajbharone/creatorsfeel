<script>
  const setupDiscordBioGenerator = () => {
    const descInput = document.getElementById('desc-input') as HTMLInputElement;
    const toneSelect = document.getElementById('tone-select') as HTMLSelectElement;

    // Checkboxes
    const emojiCheck = document.getElementById('emoji-check') as HTMLInputElement;
    const sparkleCheck = document.getElementById('sparkle-check') as HTMLInputElement;
    const linkCheck = document.getElementById('link-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');
    const generateMoreBtn = document.getElementById('generate-more-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-bios-container');

    // Mockup targets
    const discordBioText = document.getElementById('discord-bio-text');

    // Local tracking arrays
    let currentShuffledTemplates: string[] = [];
    let currentTemplateIndex = 0;

    const buildShuffledPool = () => {
      const hobbies = (descInput?.value || '').trim();
      const tone = toneSelect?.value || 'gaming';

      // Extract details
      const details = hobbies.split(',').map(d => d.trim()).filter(d => d.length > 0);
      const h1 = details[0] || 'chatting';
      const h2 = details[1] || 'gaming';
      const h3 = details[2] || 'chilling';

      const templates: string[] = [];

      // Expanded tone-specific pools (15 templates each)
      if (tone === 'gaming') {
        templates.push(
          `✧ Gaming is life | Maining ${h1} | Add me to play 🎮`,
          `Apex predator in ${h1}. Carrying teams in ${h2}. GG only! 🏆`,
          `Competitive ${h1} player. Powered by coffee & bad decisions. ☕`,
          `Just a ${h1} enthusiast who loves ${h2}. | Let's queue! 🎮`,
          `Living in the ${h1} lobby. | DM for server invite ⚡`,
          `Leveling up in ${h1} | ${h2} speedrunner | DM to queue 🎮`,
          `Esports athlete | Focus: ${h1} & ${h2} | Let's play! 🏆`,
          `Ranked grind on ${h1} | ${h2} specialist | GG vibes ⚡`,
          `✧ ${h1} main | Casual ${h2} enjoyer | DM me 🎮`,
          `clutching rounds in ${h1} | sleeping is for the weak 💀`,
          `on that ${h1} grindset | ${h2} and chilling | discord user 🎮`,
          `fps champion // main game: ${h1} // lobby hosts only 🏆`,
          `gaming is my therapy | currently grinding ${h1} 🎮`,
          `✧ no mercy in ${h1} | ${h2} speedrunner | discord friend ✧`,
          `just here to play ${h1} and drink cold brew ☕🎮`
        );
      } else if (tone === 'cozy') {
        templates.push(
          `✦ cozy vibes only ✦ loves ${h1} & soft music ✦ ☕`,
          `dreaming of ${h1} ✦ tea lover ✦ let's chill ☁️`,
          `just a soft soul enjoying ${h1} and cozying up with ${h2} ✿`,
          `haze & stardust. chill sessions of ${h1} 🌙`,
          `calm days, cozy nights, and plenty of ${h1} 🌾`,
          `cozy room, warm coffee, and quiet games of ${h1} ☕`,
          `stargazing ✦ reading books ✦ relaxing with ${h1} ✿`,
          `soft blanket & ${h1} kind of day ✦ chill space 🌙`,
          `✦ rainy days, warm tea, and exploring ${h1} ✿`,
          `living in a cozy bubble ✦ obsessed with ${h1} ☁️`,
          `✿ flower garden keeper ✿ quiet thoughts about ${h1} ✦`,
          `cozy pixel art & ${h1} soundtracks ✦ warm vibes ☕`,
          `✦ simple things: hot chocolate, thick books, and ${h1} ✿`,
          `dusk and twilight ✦ peaceful gaming with ${h1} 🌙`,
          `✿ lavender tea and gentle sessions of ${h1} ✦`
        );
      } else if (tone === 'cyber') {
        templates.push(
          `[system]: logging ${h1} protocol // ping: low // developer 💻`,
          `netrunner status: code, coffee, and ${h1}. 🤖`,
          `glitching through ${h1} systems. // matrix hacker 🌐`,
          `matrix.log: loves ${h1} & building ${h2} modules. 👾`,
          `cyberpunk soul | network programmer | dev of ${h1} ⚡`,
          `hardware hacker | testing ${h1} scripts | system: active 🤖`,
          `decrypted data: ${h1} lover & ${h2} coder 💻`,
          `rebooting system... running ${h1} client version 1.0 🌐`,
          `[error]: too much code, not enough ${h1} // tech life 💻`,
          `digital nomad // developing in ${h1} // cyber world 🌐`,
          `terminal active // pinging ${h1} servers // matrix host 🤖`,
          `cyberpunk aesthetic | coder of ${h1} | tech core ⚡`,
          `building web tools with ${h1} | coffee powered dev 💻`,
          `[status]: code execution of ${h1} complete // dev life 🤖`,
          `network node active // sharing tech & ${h1} designs 🌐`
        );
      } else if (tone === 'witty') {
        templates.push(
          `Professionally lazy. Expert in ${h1} and making bad puns. 🫠`,
          `Loves ${h1} but ${h2} loves me more. Don't add me. ⛔`,
          `My hobbies include ${h1} and regretting my life choices. 💀`,
          `I put the 'pro' in procrastination and ${h1}. 🏆`,
          `Here for the memes and ${h1} updates. DM at your own risk. 👀`,
          `Warning: Contains trace amounts of ${h1} and sarcasm. ⚠️`,
          `Under construction. Just like my skill level in ${h1}. 🫠`,
          `Sponsoring coffee companies since I started ${h1}. ☕`,
          `I'm not short, I'm just concentrated awesome and ${h1}. 💀`,
          `Currently avoiding responsibilities by playing ${h1}. 🫠`,
          `Professional overthinker | Niche expert in ${h1} 💀`,
          `My brain has 47 open tabs, and 46 are about ${h1}. 🫠`,
          `I speak fluent sarcasm and ${h1} references. ⚠️`,
          `Error 404: Bio not found. Too busy playing ${h1}. 💀`,
          `Loves ${h1} and ignoring my laundry. 🫠`
        );
      } else {
        // Professional
        templates.push(
          `Product Designer & developer. Focused on ${h1} projects. 💼`,
          `Web Developer | Tech builder | Passionate about ${h1} 💻`,
          `Designing products at day, exploring ${h1} at night. 🏢`,
          `Building digital products. Reach out for collaborations in ${h1} 🤝`,
          `Business inquiries only. Passionate developer of ${h1} 📈`,
          `Creative engineering & dev operations // focused on ${h1} 💼`,
          `Building modern web platforms and exploring ${h1} architecture 💻`,
          `UX Consultant | Tech content creator | Niche: ${h1} 🏢`,
          `Software Engineer // Specializing in ${h1} and clean code 💻`,
          `Founder & Tech Director // Building systems with ${h1} 📈`,
          `Innovating client platforms // developer of ${h1} tools 🤝`,
          `Tech Consultant | Helping startups scale using ${h1} 🏢`,
          `Developer Relations Engineer // Speaking about ${h1} tech 💻`,
          `Open source contributor // current projects: ${h1} 💼`,
          `Engineering lead // managing product builds for ${h1} 📈`
        );
      }

      // Shuffle array helper
      currentShuffledTemplates = [...templates].sort(() => Math.random() - 0.5);
      currentTemplateIndex = 0;
    };

    // Format modifiers helper
    const formatBio = (base: string) => {
      const includeEmojis = emojiCheck?.checked;
      const includeSparkles = sparkleCheck?.checked;
      const includeLinks = linkCheck?.checked;

      let text = base;
      
      // Emojis injection
      if (!includeEmojis) {
        // Remove emoji characters
        text = text.replace(/[\u2000-\u32FF]|[\uD83C-\uDDFE][\uDC00-\uDFFF]/g, '');
      }

      // Sparkles injection
      if (includeSparkles) {
        text = `✦ ${text} ✦`;
      }

      // Links injection
      if (includeLinks) {
        text = `${text} | links: cf.gg`;
      }

      // Clean double separators and trim to 190 characters
      return text.trim().substring(0, 190);
    };

    // Initial clean generation
    const generateList = () => {
      buildShuffledPool();
      
      // Select first 5 templates
      const selectedTemplates = currentShuffledTemplates.slice(0, 5);
      currentTemplateIndex = 5;

      const finalBios = selectedTemplates.map(t => formatBio(t));

      // Render to DOM
      if (container) {
        container.innerHTML = finalBios.map((b, i) => {
          return `
            <div class="bio-card" data-bio="${b}">
              <p class="bio-text-display">${b}</p>
              <div class="bio-action-row">
                <span class="bio-char-count">${b.length} / 190 Chars</span>
                <button class="chip-btn">Copy Bio</button>
              </div>
            </div>
          `;
        }).join('');
      }

      // Display results section
      resultsWrapper?.classList.remove('hidden');

      // Default the mockup bio to the first generated result
      if (discordBioText && finalBios.length > 0) {
        discordBioText.textContent = finalBios[0];
      }
    };

    // Append 5 more bios
    const appendMoreBios = () => {
      if (currentShuffledTemplates.length === 0) {
        buildShuffledPool();
      }

      // Check boundary bounds
      if (currentTemplateIndex >= currentShuffledTemplates.length) {
        // If we ran out, reshuffle
        const oldIndex = currentTemplateIndex;
        buildShuffledPool();
      }

      const nextTemplates = currentShuffledTemplates.slice(currentTemplateIndex, currentTemplateIndex + 5);
      currentTemplateIndex += 5;

      const finalBios = nextTemplates.map(t => formatBio(t));

      // Render append
      if (container) {
        const appendHtml = finalBios.map((b, i) => {
          return `
            <div class="bio-card" data-bio="${b}">
              <p class="bio-text-display">${b}</p>
              <div class="bio-action-row">
                <span class="bio-char-count">${b.length} / 190 Chars</span>
                <button class="chip-btn">Copy Bio</button>
              </div>
            </div>
          `;
        }).join('');
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();
      
      // Scroll down to results section
      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    generateMoreBtn?.addEventListener('click', () => {
      appendMoreBios();
    });

    // Handle copying individual bio chips and update mockup preview
    container?.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.bio-card');
      if (!card) return;

      const bio = card.getAttribute('data-bio') || '';

      // Update Mockup card preview
      if (discordBioText) {
        discordBioText.textContent = bio;
      }

      // Copy to clipboard
      navigator.clipboard.writeText(bio).then(() => {
        const btn = card.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy Bio';
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener('click', () => {
      if (descInput) descInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Initialize list
    generateList();
  };

  setupDiscordBioGenerator();
  document.addEventListener('astro:after-swap', setupDiscordBioGenerator);
</script>
