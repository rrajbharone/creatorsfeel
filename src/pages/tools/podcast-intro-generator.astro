<script>
  const setupPodcastIntroGenerator = () => {
    const showNameInput = document.getElementById('show-name-input') as HTMLInputElement;
    const hostNameInput = document.getElementById('host-name-input') as HTMLInputElement;
    const topicInput = document.getElementById('topic-input') as HTMLInputElement;
    const styleSelect = document.getElementById('style-select') as HTMLSelectElement;

    const musicCheck = document.getElementById('music-check') as HTMLInputElement;
    const sponsorCheck = document.getElementById('sponsor-check') as HTMLInputElement;
    const ctaCheck = document.getElementById('cta-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');
    const generateMoreBtn = document.getElementById('generate-more-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-intros-container');

    // Mockup targets
    const mockupShowHeader = document.getElementById('mockup-show-header');
    const mockupScriptBody = document.getElementById('mockup-script-body');

    // Templates database
    const templatesByStyle: Record<string, string[]> = {
      punchy: [
        `Welcome to {showName}! I am your host, {hostName}. Today, we are breaking down {topic}. Let us dive straight in!`,
        `Boom! You are tuned into {showName} with {hostName}. Today's episode is all about {topic}. No fluff, just pure insights!`,
        `Welcome back to {showName}! I am {hostName}, and on this episode, we tackle {topic}. Fasten your seatbelts!`
      ],
      conversational: [
        `Hey everyone, welcome back to {showName}! I am {hostName}. Today I am super excited to talk about {topic}. Grab a cup of coffee and let us hang out!`,
        `Welcome to another episode of {showName}! I am {hostName}. In today's chat, we are diving deep into {topic}. Thanks for spending your time with us today!`,
        `Hey there! Thanks for tuning into {showName} with {hostName}. Today we are breaking down {topic} step by step. Let us get into it!`
      ],
      teaser: [
        `What if everything you knew about {topic} was wrong? Welcome to {showName} with {hostName}. In today's episode, we unwrap the truth behind this topic.`,
        `Imagine scaling your results with one simple tweak in {topic}. I am {hostName}, and on today's episode of {showName}, we reveal how to make it happen.`,
        `The secret to mastering {topic} is simpler than you think. Welcome to {showName}! I am {hostName}, and today we reveal the full story.`
      ],
      corporate: [
        `Welcome to {showName}, the show for industry leaders. Hosted by {hostName}. Today's executive briefing covers {topic}.`,
        `This is {showName}, bringing you strategic analysis on {topic}. I am {hostName}, your host for today's session.`,
        `Welcome to {showName}. Hosted by {hostName}, this episode evaluates key frameworks for {topic}.`
      ]
    };

    let currentShuffledPool: string[] = [];
    let currentPoolIndex = 0;

    const buildShuffledPool = () => {
      const showName = (showNameInput?.value || '').trim() || 'The Tech Chronicles';
      const hostName = (hostNameInput?.value || '').trim() || 'Alex & Sarah';
      const topic = (topicInput?.value || '').trim() || 'building SaaS with John Doe';
      const style = styleSelect?.value || 'punchy';

      const includeMusic = musicCheck?.checked;
      const includeSponsor = sponsorCheck?.checked;
      const includeCta = ctaCheck?.checked;

      const baseTemplates = templatesByStyle[style] || templatesByStyle['punchy'];
      const generatedSet = new Set<string>();

      let iterations = 0;
      while (generatedSet.size < 40 && iterations < 200) {
        iterations++;
        const index = Math.floor(Math.random() * baseTemplates.length);
        let text = baseTemplates[index]
          .replace(/{showName}/g, showName)
          .replace(/{hostName}/g, hostName)
          .replace(/{topic}/g, topic);

        if (includeMusic) {
          text = `[Upbeat Intro Music Fades In]\n\n${text}\n\n[Music Fades to Background]`;
        }

        if (includeSponsor) {
          text += `\n\n[Sponsor Message]: This episode is brought to you by our sponsor. Check out the link in our show notes for 20% off!`;
        }

        if (includeCta) {
          text += `\n\nBefore we begin, make sure to hit that subscribe button on Spotify and Apple Podcasts!`;
        }

        generatedSet.add(text);
      }

      currentShuffledPool = Array.from(generatedSet).sort(() => Math.random() - 0.5);
      currentPoolIndex = 0;
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledPool();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      const showNameVal = (showNameInput?.value || '').trim() || 'The Tech Chronicles';
      const hostNameVal = (hostNameInput?.value || '').trim() || 'Alex & Sarah';

      if (container) {
        container.innerHTML = selected.map(s => {
          return `
            <div class="intro-card" data-text="${encodeURIComponent(s)}">
              <div class="intro-text">${s}</div>
              <button class="chip-btn">Copy Script</button>
            </div>
          `;
        }).join('');
      }

      resultsWrapper?.classList.remove('hidden');

      // Default mockup text
      if (mockupShowHeader) {
        mockupShowHeader.textContent = `${showNameVal} • Hosted by ${hostNameVal}`;
      }
      if (mockupScriptBody && selected.length > 0) {
        mockupScriptBody.innerHTML = selected[0].replace(/\n/g, '<br />');
      }
    };

    // Append 5 more unique items
    const appendMoreTitles = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledPool();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledPool();
      }

      const next = currentShuffledPool.slice(currentPoolIndex, currentPoolIndex + 5);
      currentPoolIndex += 5;

      if (container) {
        const appendHtml = next.map(s => {
          return `
            <div class="intro-card" data-text="${encodeURIComponent(s)}">
              <div class="intro-text">${s}</div>
              <button class="chip-btn">Copy Script</button>
            </div>
          `;
        }).join('');
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    generateMoreBtn?.addEventListener('click', () => {
      appendMoreTitles();
    });

    // Handle copying individual intro cards and update mockup preview
    container?.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.intro-card');
      if (!card) return;

      const rawText = decodeURIComponent(card.getAttribute('data-text') || '');

      // Update mockup sidebar
      if (mockupScriptBody) {
        mockupScriptBody.innerHTML = rawText.replace(/\n/g, '<br />');
      }

      // Copy to clipboard
      navigator.clipboard.writeText(rawText).then(() => {
        const btn = card.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy Script';
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener('click', () => {
      if (showNameInput) showNameInput.value = '';
      if (hostNameInput) hostNameInput.value = '';
      if (topicInput) topicInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-generate initial list
    generateList();
  };

  setupPodcastIntroGenerator();
  document.addEventListener('astro:after-swap', setupPodcastIntroGenerator);
</script>
