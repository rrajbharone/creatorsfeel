<script>
  const setupLinkedinGenerator = () => {
    // Inputs
    const templateSelect = document.getElementById('template-select') as HTMLSelectElement;
    const nameInput = document.getElementById('input-name') as HTMLInputElement;
    const titleInput = document.getElementById('input-title') as HTMLInputElement;
    const skillsInput = document.getElementById('input-skills') as HTMLInputElement;
    const achievementInput = document.getElementById('input-achievement') as HTMLTextAreaElement;
    const generateBtn = document.getElementById('btn-generate');

    // Live Mockup targets
    const mockName = document.getElementById('mock-name');
    const mockHeadline = document.getElementById('mock-headline');

    // Outputs
    const textV1 = document.getElementById('text-v1');
    const textV2 = document.getElementById('text-v2');
    const textV3 = document.getElementById('text-v3');
    const textV4 = document.getElementById('text-v4');
    const textV5 = document.getElementById('text-v5');

    // Badges
    const badgeV1 = document.getElementById('badge-v1');
    const badgeV2 = document.getElementById('badge-v2');
    const badgeV3 = document.getElementById('badge-v3');
    const badgeV4 = document.getElementById('badge-v4');
    const badgeV5 = document.getElementById('badge-v5');

    // Emojis helper
    const emojiBtns = document.querySelectorAll('.btn-emoji');
    emojiBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetFieldId = btn.getAttribute('data-field');
        if (!targetFieldId) return;
        const targetField = document.getElementById(targetFieldId) as HTMLInputElement | HTMLTextAreaElement;
        if (targetField) {
          const emoji = btn.textContent || '';
          targetField.value += (targetField.value.endsWith(' ') || targetField.value === '' ? '' : ' ') + emoji;
          targetField.focus();
        }
      });
    });

    // Preset data (12 Options)
    const presets = {
      student_cs: {
        name: "Alex Mercer",
        title: "Computer Science Major at Stanford University",
        skills: "Python, Java, React, Algorithms",
        achievement: "Building open-source developer tools & teaching 500+ student developers"
      },
      student_biz: {
        name: "Emily Chen",
        title: "MBA Candidate at Harvard Business School",
        skills: "Financial Modeling, Venture Capital, Corporate Strategy",
        achievement: "Consulted for two Fortune 500 tech companies on market entry"
      },
      engineer_sw: {
        name: "Sarah Connor",
        title: "Senior Full Stack Engineer",
        skills: "React, Node.js, Next.js, System Architecture",
        achievement: "Scaled SaaS platform core database to handle 5M+ active users"
      },
      engineer_devops: {
        name: "Marcus Wright",
        title: "DevOps & Cloud Architect",
        skills: "AWS, Kubernetes, CI/CD, Terraform",
        achievement: "Automated container pipelines to reduce server deployment time by 80%"
      },
      manager_product: {
        name: "Diana Prince",
        title: "Senior Product Manager",
        skills: "Product Roadmapping, Agile, User Research, SQL",
        achievement: "Launched mobile banking app features reaching 2M+ active clients"
      },
      doctor_clinical: {
        name: "Dr. Gregory House",
        title: "Specialist Pediatric Cardiologist",
        skills: "Clinical Care, Heart Surgery, Cardiovascular Research",
        achievement: "Pioneered clinical trials for minimally invasive pediatric therapies"
      },
      nurse_practitioner: {
        name: "Clara Barton",
        title: "Family Nurse Practitioner (FNP-C)",
        skills: "Primary Care, Patient Advocacy, Chronic Disease Management",
        achievement: "Managed outpatient health clinics serving 10k+ local residents"
      },
      businessman_founder: {
        name: "Elon Musk",
        title: "Founder & Venture Entrepreneur",
        skills: "Product Strategy, Seed Funding, SaaS scaling",
        achievement: "Bootstrapped three software startups to $15M combined ARR"
      },
      marketing_specialist: {
        name: "Grace Hopper",
        title: "Digital Marketing Specialist",
        skills: "SEO, Google Analytics, Copywriting, Paid Ads",
        achievement: "Increased organic inbound leads by 120% using content marketing"
      },
      designer_uxui: {
        name: "Ada Lovelace",
        title: "Senior UX/UI Designer",
        skills: "Figma, User Research, Wireframing, Prototyping",
        achievement: "Redesigned checkout flows to decrease cart abandonment by 35%"
      },
      financial_analyst: {
        name: "Warren Buffett",
        title: "Senior Financial Analyst",
        skills: "Equity Research, Valuations, Portfolio Management",
        achievement: "Advised on M&A portfolio transactions valued at $50M+"
      },
      hr_specialist: {
        name: "Sheryl Sandberg",
        title: "HR & Talent Acquisition Lead",
        skills: "Technical Recruiting, Employer Branding, Employee Relations",
        achievement: "Built and scaled engineering teams from 10 to 150+ staff"
      }
    };

    // Load presets
    templateSelect?.addEventListener('change', () => {
      const val = templateSelect.value as keyof typeof presets;
      if (val && presets[val]) {
        const data = presets[val];
        nameInput.value = data.name;
        titleInput.value = data.title;
        skillsInput.value = data.skills;
        achievementInput.value = data.achievement;
        generateHeadlines();
      }
    });

    const updateLengthBadge = (badge: HTMLElement | null, length: number) => {
      if (!badge) return;
      badge.textContent = `${length} / 220`;
      badge.className = 'char-badge';
      if (length <= 220) {
        badge.classList.add('badge-valid');
      } else {
        badge.classList.add('badge-warn');
      }
    };

    const generateHeadlines = () => {
      const name = nameInput.value.trim() || 'Jane Doe';
      const title = titleInput.value.trim();
      const skillsRaw = skillsInput.value.trim();
      const achievement = achievementInput.value.trim();

      if (mockName) mockName.textContent = name;

      if (!title || !skillsRaw || !achievement) {
        if (mockHeadline) mockHeadline.textContent = 'Please fill out your Title, Skills, and Achievement parameters...';
        return;
      }

      const skillsList = skillsRaw.split(',').map(s => s.trim()).filter(Boolean);

      // Variation 1: SEO & Keyword-Rich
      const h1 = `${title} | Specialized in ${skillsList.slice(0, 3).join(' · ')} | ${achievement.slice(0, 50)}...`;
      // Variation 2: Value-Driven Outcome
      const h2 = `${title} - Helping companies leverage ${skillsList[0] || 'technology'} to ${achievement.toLowerCase()}`;
      // Variation 3: Traditional & Classic
      const h3 = `${title} | Expert in ${skillsList.slice(0, 4).join(', ')}`;
      // Variation 4: Creative & Punchy
      const h4 = `${title} 🚀 ${skillsList.slice(0, 2).join(' · ')} | ${achievement}`;
      // Variation 5: Bold Authority Pitch
      const h5 = `${title} | ${achievement} | Tech: ${skillsList.join(', ')}`;

      // Update text outputs
      if (textV1) textV1.textContent = h1.slice(0, 220);
      if (textV2) textV2.textContent = h2.slice(0, 220);
      if (textV3) textV3.textContent = h3.slice(0, 220);
      if (textV4) textV4.textContent = h4.slice(0, 220);
      if (textV5) textV5.textContent = h5.slice(0, 220);

      // Update badges
      updateLengthBadge(badgeV1, h1.length);
      updateLengthBadge(badgeV2, h2.length);
      updateLengthBadge(badgeV3, h3.length);
      updateLengthBadge(badgeV4, h4.length);
      updateLengthBadge(badgeV5, h5.length);

      // Update live mockup
      if (mockHeadline) {
        mockHeadline.textContent = h1.length > 220 ? h1.slice(0, 217) + '...' : h1;
      }
    };

    generateBtn?.addEventListener('click', generateHeadlines);

    // Initial load: trigger student CS preset
    if (templateSelect) {
      templateSelect.value = "student_cs";
      const event = new Event('change');
      templateSelect.dispatchEvent(event);
    } else {
      titleInput.value = "Full Stack Engineer";
      skillsInput.value = "React, Node.js, AWS Cloud";
      achievementInput.value = "Building scalable cloud architectures and high-performance Web Apps";
      generateHeadlines();
    }

    // Clipboard Copy Handler
    const copyBtns = document.querySelectorAll('.btn-copy');
    const toast = document.getElementById('toast-notify');

    copyBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId) return;
        const targetText = document.getElementById(targetId)?.textContent;
        if (targetText && targetText !== 'Fill out the fields to generate...') {
          navigator.clipboard.writeText(targetText).then(() => {
            if (toast) {
              toast.classList.remove('hidden');
              setTimeout(() => {
                toast.classList.add('hidden');
              }, 2000);
            }
          });
        }
      });
    });
  };

  setupLinkedinGenerator();
  document.addEventListener('astro:after-swap', setupLinkedinGenerator);
</script>
