---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is a LinkedIn headline and why is it important?",
    answer: "Your LinkedIn headline is the text below your name on your profile. It is the most important element for search optimization (LinkedIn SEO) and click-through rates. A compelling headline helps you stand out in recruiter search results and user comments."
  },
  {
    question: "What is the character limit for a LinkedIn headline?",
    answer: "The official character limit for a LinkedIn headline is 220 characters. However, on mobile devices, only the first 60-80 characters are shown before getting truncated in feed cards. Place your most important keywords and job titles first."
  },
  {
    question: "How does the LinkedIn search algorithm index headlines?",
    answer: "LinkedIn indexes headlines heavily for target search queries. To rank higher, incorporate high-volume keywords, hard skills, and toolsets directly into your headline using separators like vertical bars (|) or bullet points."
  },
  {
    question: "Should I use emojis in my LinkedIn headline?",
    answer: "Yes, using 1 or 2 relevant professional emojis (like 🚀, 💡, or 💻) can draw visual attention to your profile in search results. Avoid over-stuffing emojis, as it can detract from readability and look unprofessional."
  }
];
---

<ToolLayout
  title="AI LinkedIn Headline Generator - Pre-built Profile Templates"
  description="Generate highly professional, SEO-optimized LinkedIn headlines instantly. Includes pre-built templates for students, engineers, doctors, and entrepreneurs."
  toolName="LinkedIn Headline Generator"
  toolDescription="Customize your LinkedIn headline using AI-driven formula variations. Populate pre-built templates, preview character limits, and view your mockup in real-time."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <div class="calc-grid">
      <!-- Input form panel -->
      <section class="calc-form-box" aria-label="Headline Parameters Form">
        <!-- Template Quick-Selection -->
        <div class="form-group">
