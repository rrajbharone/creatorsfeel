<script>
  const setupDiscordServerNameGenerator = () => {
    const seedInput = document.getElementById("seed-input") as HTMLInputElement;
    const nicheSelect = document.getElementById(
      "niche-select",
    ) as HTMLSelectElement;
    const formatSelect = document.getElementById(
      "format-select",
    ) as HTMLSelectElement;

    // Actions
    const generateBtn = document.getElementById("generate-btn");
    const resetBtn = document.getElementById("reset-btn");
    const generateMoreBtn = document.getElementById("generate-more-btn");

    // Layout slots
    const resultsWrapper = document.getElementById("results-wrapper");
    const container = document.getElementById("generated-servers-container");

    // Mockup targets
    const mockupServerName = document.getElementById("mockup-server-name");
    const mockupServerBubble = document.getElementById("mockup-server-bubble");

    // Niche structures database
    const serverNiches: Record<
      string,
      { prefixes: string[]; suffixes: string[]; decorators: string[] }
    > = {
      gaming: {
        prefixes: [
          "apex",
          "vortex",
          "lethal",
          "tactical",
          "esports",
          "nexus",
          "arena",
          "clan",
          "squad",
        ],
        suffixes: [
          "gg",
          "hq",
          "zone",
          "clan",
          "gaming",
          "esports",
          "nexus",
          "guild",
          "hub",
        ],
        decorators: ["🎮", "🏆", "⚡", "🔥"],
      },
      community: {
        prefixes: [
          "social",
          "central",
          "house",
          "town",
          "metro",
          "plaza",
          "haven",
          "world",
          "society",
        ],
        suffixes: [
          "hub",
          "lounge",
          "club",
          "central",
          "community",
          "town",
          "nexus",
          "square",
          "corner",
        ],
        decorators: ["💬", "👋", "🌍", "🏠"],
      },
      aesthetic: {
        prefixes: [
          "cozy",
          "luna",
          "haze",
          "cloud",
          "mist",
          "soft",
          "calm",
          "dusk",
          "blossom",
          "peach",
        ],
        suffixes: [
          "cafe",
          "lounge",
          "dream",
          "bloom",
          "garden",
          "space",
          "cottage",
          "oasis",
          "haze",
        ],
        decorators: ["✦", "✧", "✿", "🪐", "☁️"],
      },
      anime: {
        prefixes: [
          "otaku",
          "senpai",
          "tokyo",
          "shibuya",
          "akiba",
          "chibi",
          "neko",
          "manga",
          "kawaii",
        ],
        suffixes: [
          "nexus",
          "guild",
          "cafe",
          "lounge",
          "society",
          "club",
          "district",
          "world",
          "otaku",
        ],
        decorators: ["🪐", "🌸", "🦊", "🎋"],
      },
      study: {
        prefixes: [
          "study",
          "code",
          "geek",
          "dev",
          "science",
          "math",
          "campus",
          "scholar",
          "library",
        ],
        suffixes: [
          "hub",
          "lab",
          "club",
          "guild",
          "academy",
          "lounge",
          "center",
          "room",
          "study",
        ],
        decorators: ["📚", "💻", "💡", "📈"],
      },
    };

    // Unicode font maps for styles
    const unicodeFonts: Record<string, string> = {
      a: "𝖺",
      b: "𝖻",
      c: "𝖼",
      d: "𝖽",
      e: "𝖾",
      f: "𝖿",
      g: "𝗀",
      h: "𝗁",
      i: "𝗂",
      j: "𝗃",
      k: "𝗄",
      l: "𝗅",
      m: "𝗆",
      n: "𝗇",
      o: "𝗈",
      p: "𝗉",
      q: "𝗊",
      r: "𝗋",
      s: "𝗌",
      t: "𝗍",
      u: "𝗎",
      v: "𝗏",
      w: "𝗐",
      x: "𝗑",
      y: "𝗒",
      z: "𝗓",
      A: "𝖠",
      B: "𝖡",
      C: "𝖢",
      D: "𝖣",
      E: "𝖤",
      F: "𝖥",
      G: "𝖦",
      H: "𝖧",
      I: "𝖨",
      J: "𝖩",
      K: "𝖪",
      L: "𝖫",
      M: "𝖬",
      N: "𝖭",
      O: "𝖮",
      P: "𝖯",
      Q: "𝖰",
      R: "𝖱",
      S: "𝖲",
      T: "𝖳",
      U: "𝖴",
      V: "𝖵",
      W: "𝖶",
      X: "𝖷",
      Y: "𝖸",
      Z: "𝖹",
    };

    const convertToUnicode = (str: string) => {
      return str
        .split("")
        .map((char) => unicodeFonts[char] || char)
        .join("");
    };

    let currentShuffledPool: string[] = [];
    let currentPoolIndex = 0;

    const buildShuffledNames = () => {
      const seed = (seedInput?.value || "").trim();
      const niche = nicheSelect?.value || "gaming";
      const format = formatSelect?.value || "symbols";

      const database = serverNiches[niche] || serverNiches["gaming"];
      const generatedSet = new Set<string>();

      const applyFormat = (prefix: string, body: string, suffix: string) => {
        let text = "";
        const dec =
          database.decorators[
            Math.floor(Math.random() * database.decorators.length)
          ] || "";

        // Clean spacing or format preferences
        if (format === "spaces") {
          const raw = `${prefix} ${body} ${suffix}`.trim().replace(/\s+/g, " ");
          text = raw.split("").join(" ").replace(/\s+/g, " ");
        } else if (format === "font") {
          const raw = `${prefix} ${body} ${suffix}`.trim().replace(/\s+/g, " ");
          text = convertToUnicode(raw);
        } else if (format === "symbols") {
          text = `${dec} ${prefix} ${body} ${suffix} ${dec}`
            .trim()
            .replace(/\s+/g, " ");
        } else {
          // Clean
          text = `${prefix} ${body} ${suffix}`.trim().replace(/\s+/g, " ");
        }

        return text.substring(0, 100);
      };

      // Generate a pool of 50 possible unique variations
      let iterations = 0;
      while (generatedSet.size < 50 && iterations < 300) {
        iterations++;
        const pIndex = Math.floor(Math.random() * database.prefixes.length);
        const sIndex = Math.floor(Math.random() * database.suffixes.length);

        const prefix = database.prefixes[pIndex];
        const suffix = database.suffixes[sIndex];

        let formatted = "";
        const pattern = Math.floor(Math.random() * 3);
        if (pattern === 0 && seed) {
          formatted = applyFormat(prefix, seed, "");
        } else if (pattern === 1 && seed) {
          formatted = applyFormat("", seed, suffix);
        } else {
          formatted = applyFormat(prefix, seed || "lobby", suffix);
        }

        if (formatted.length >= 2) {
          generatedSet.add(formatted);
        }
      }

      currentShuffledPool = Array.from(generatedSet).sort(
        () => Math.random() - 0.5,
      );
      currentPoolIndex = 0;
    };

    const updateMockupBubble = (name: string) => {
      if (!mockupServerBubble) return;

      // Extract cleaned initials (letters and numbers only)
      const clean = name.replace(/[^a-zA-Z0-9\s]/g, "").trim();
      const parts = clean.split(/\s+/).filter((w) => w.length > 0);
      let initials = "";

      if (parts.length >= 2) {
        initials = (parts[0][0] || "") + (parts[1][0] || "");
      } else if (parts.length === 1 && parts[0].length >= 2) {
        initials = parts[0].substring(0, 2);
      } else {
        initials = name.substring(0, 2);
      }

      mockupServerBubble.textContent = initials.toUpperCase();
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledNames();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      if (container) {
        container.innerHTML = selected
          .map((s) => {
            return `
            <div class="server-chip" data-name="${s}">
              <span class="server-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
          })
          .join("");
      }

      resultsWrapper?.classList.remove("hidden");

      // Default the mockup server name to the first generated result
      if (mockupServerName && selected.length > 0) {
        mockupServerName.textContent = selected[0];
        updateMockupBubble(selected[0]);
      }
    };

    // Append 5 more unique names
    const appendMoreNames = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledNames();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledNames();
      }

      const next = currentShuffledPool.slice(
        currentPoolIndex,
        currentPoolIndex + 5,
      );
      currentPoolIndex += 5;

      if (container) {
        const appendHtml = next
          .map((s) => {
            return `
            <div class="server-chip" data-name="${s}">
              <span class="server-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
          })
          .join("");
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener("click", () => {
      generateList();

      const resultsSection = document.getElementById("results-wrapper");
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });

    generateMoreBtn?.addEventListener("click", () => {
      appendMoreNames();
    });

    // Handle copying individual server name chips and update mockup preview
    container?.addEventListener("click", (e) => {
      const chip = (e.target as HTMLElement).closest(".server-chip");
      if (!chip) return;

      const name = chip.getAttribute("data-name") || "";

      // Update mockup sidebar
      if (mockupServerName) {
        mockupServerName.textContent = name;
      }
      updateMockupBubble(name);

      // Copy to clipboard
      navigator.clipboard.writeText(name).then(() => {
        const btn = chip.querySelector(".chip-btn") as HTMLElement;
        if (btn) {
          btn.textContent = "Copied! ✓";
          setTimeout(() => {
            btn.textContent = "Copy";
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener("click", () => {
      if (seedInput) seedInput.value = "";
      resultsWrapper?.classList.add("hidden");
    });

    // Auto-generate initial list
    generateList();
  };

  setupDiscordServerNameGenerator();
  document.addEventListener(
    "astro:after-swap",
    setupDiscordServerNameGenerator,
  );
</script>
