---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is a YouTube Clickbait Title Generator and how does it help creators?",
    answer: "A YouTube Clickbait Title Generator is a video marketing tool that leverages psychological curiosity gaps, emotional triggers, and high-CTR power words to create compelling, attention-grabbing titles that encourage viewers to click."
  },
  {
    question: "Is using clickbait titles bad for my YouTube channel?",
    answer: "Misleading clickbait (promising something in the title that never appears in the video) harms your channel by increasing viewer bounce rates. However, 'ethical clickbait'—using high-curiosity phrasing that your video actually delivers on—is essential for high Click-Through Rates (CTR)."
  },
  {
    question: "How long should a YouTube clickbait title be?",
    answer: "The ideal length for a YouTube title is between 50 and 70 characters. Titles under 70 characters ensure your full title is visible on mobile screens without getting truncated."
  },
  {
    question: "Should I use ALL CAPS or emojis in my YouTube titles?",
    answer: "Using selective ALL CAPS power words (like SECRET, NEVER, or WARNING) and 1 to 2 relevant emojis boosts visual contrast in YouTube recommendation feeds, increasing click-through rates by up to 25%."
  },
  {
    question: "Is this YouTube Clickbait Title Generator free to use?",
    answer: "Yes, our YouTube Clickbait Title Generator is 100% free with unlimited title generations, emotion filters, power word add-ons, and live mobile video card previews."
  }
];
---

<ToolLayout
  title="YouTube Clickbait Title Generator - High-CTR Video Title Ideas"
  description="Generate viral, high-CTR YouTube clickbait titles. Leverage curiosity gaps, power words, and emotion filters to boost video views and clicks."
  toolName="YouTube Clickbait Title Generator"
  toolDescription="Create high-converting, attention-grabbing YouTube titles. Filter by emotion vibe, customize power words, and preview live YouTube mobile video cards."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Generator Inputs -->
      <div class="calc-form-column">
        <div class="calc-form">
          <!-- Topic / Seed Concept Input -->
          <div class="form-group">
            <label for="seed-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.375 8.75c0 1.105-1.123 2-2.5 2s-2.5-.895-2.5-2 1.123-2 2.5-2 2.5.895 2.5 2Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
              </svg>
              Video Topic or Seed Concept
            </label>
            <input type="text" id="seed-input" class="form-input" placeholder="e.g. iPhone 16, day in the life, crypto crash" value="iPhone 16" />
          </div>

          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
            <!-- Clickbait Vibe Select -->
            <div class="form-group">
              <label for="vibe-select" class="icon-label">Clickbait Vibe</label>
              <select id="vibe-select" class="form-input" style="height: 48px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0 12px; color: var(--color-text);">
                <option value="shock">Extreme Curiosity & Shock</option>
                <option value="urgent">Dramatic & Urgent</option>
                <option value="secret">Secret & Hidden Knowledge</option>
                <option value="challenge">Challenge & Impossible</option>
                <option value="reaction">High-Energy & Reaction</option>
              </select>
            </div>

            <!-- Target Audience Select -->
            <div class="form-group">
              <label for="audience-select" class="icon-label">Target Niche</label>
              <select id="audience-select" class="form-input" style="height: 48px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0 12px; color: var(--color-text);">
                <option value="tech">Tech & Gadgets</option>
                <option value="gaming">Gaming & Streams</option>
                <option value="lifestyle">Vlogs & Lifestyle</option>
                <option value="finance">Finance & Business</option>
                <option value="general">General YouTube</option>
              </select>
            </div>
          </div>

          <!-- Formatting Checkboxes -->
          <div style="display: flex; flex-direction: column; gap: 0.75rem; background: var(--color-bg-alt); padding: 0.75rem 1rem; border-radius: 12px; border: 1px solid var(--color-border);">
            <span style="font-size: 0.72rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Title Formatting Add-ons</span>
            
            <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.88rem;">
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="caps-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Include ALL CAPS Power Words (SECRET, NEVER, STOP)
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="emojis-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Include Emojis (😱, 🔥, 🚨)
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="brackets-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Include Brackets & Hooks ([SHOCKING], (DON'T BUY))
              </label>
            </div>
          </div>

          <!-- Actions -->
          <div class="form-actions">
            <button type="button" id="generate-btn" class="calc-btn">Generate Clickbait Titles</button>
            <button type="button" id="reset-btn" class="calc-btn-secondary">Reset Inputs</button>
          </div>
        </div>
      </div>

      <!-- Right Column: Live Mockup Card -->
      <div class="calc-editor-column">
        <!-- Live YouTube Mobile Video Card Preview Mockup -->
        <div class="youtube-mobile-card glass" style="background: #0f0f0f; color: #ffffff; border-radius: 16px; overflow: hidden; max-width: 320px; margin: 0 auto; width: 100%; border: 1px solid #272727; text-align: left; box-shadow: var(--shadow-md); font-family: var(--font-body); padding: 1rem;">
          <!-- Simulated Video Thumbnail Container -->
          <div style="position: relative; width: 100%; height: 160px; background: linear-gradient(135deg, #1e1e24, #0f0f0f); border-radius: 12px; overflow: hidden; margin-bottom: 0.75rem; border: 1px solid #272727; display: flex; align-items: center; justify-content: center;">
            <div style="text-align: center;">
              <span style="font-size: 2.2rem; display: block;">😱</span>
              <span style="font-size: 0.72rem; font-weight: 800; color: #ff0000; letter-spacing: 1px; text-transform: uppercase;">[SHOCKING REVEAL]</span>
            </div>
            <!-- Duration Pill -->
            <span style="position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,0.85); color: #ffffff; font-size: 0.65rem; font-weight: 700; padding: 2px 6px; border-radius: 4px;">
              12:45
            </span>
          </div>

          <!-- Video Details Row -->
          <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
            <!-- Channel Avatar -->
            <div style="width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #6366f1, #ec4899); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 800; color: #ffffff; flex-shrink: 0;">
              CF
            </div>
            <!-- Title & Metadata -->
            <div style="display: flex; flex-direction: column; gap: 4px; min-width: 0;">
              <!-- Title updating live -->
              <span id="mockup-title-text" style="font-size: 0.82rem; font-weight: 700; color: #ffffff; line-height: 1.35; max-height: 2.7em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                I Tested the iPhone 16 for 24 Hours... [DON'T BUY THIS] 😱
              </span>
              <div style="font-size: 0.68rem; color: #aaaaaa; display: flex; gap: 6px; align-items: center;">
                <span>CreatorsFeel</span>
                <span>•</span>
                <span>450K views</span>
                <span>•</span>
                <span>2 hours ago</span>
              </div>
            </div>
          </div>

          <!-- CTR & Length Indicator Footer -->
          <div style="margin-top: 0.85rem; background: #181818; border-radius: 8px; padding: 0.5rem 0.75rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.7rem;">
            <span style="color: #aaaaaa;">CTR Potential:</span>
            <span id="ctr-status-tag" style="font-weight: 800; color: #2ba640;">🔥 High CTR (64 chars)</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Generated Results Section -->
    <div id="results-wrapper" class="hidden" style="margin-top: 2rem; border-top: 1px dashed var(--color-border); padding-top: 1.5rem;">
