<script>
  const setupYoutubeClickbaitTitleGenerator = () => {
    const seedInput = document.getElementById('seed-input') as HTMLInputElement;
    const vibeSelect = document.getElementById('vibe-select') as HTMLSelectElement;
    const audienceSelect = document.getElementById('audience-select') as HTMLSelectElement;

    const capsCheck = document.getElementById('caps-check') as HTMLInputElement;
    const emojisCheck = document.getElementById('emojis-check') as HTMLInputElement;
    const bracketsCheck = document.getElementById('brackets-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');
    const generateMoreBtn = document.getElementById('generate-more-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-titles-container');

    // Mockup targets
    const mockupTitleText = document.getElementById('mockup-title-text');
    const ctrStatusTag = document.getElementById('ctr-status-tag');

    // Vibe Modifiers & Hooks
    const vibeTemplates: Record<string, { hooks: string[], capsWords: string[], emojis: string[] }> = {
      shock: {
        hooks: ['I Can\'t Believe This Happened to', 'The Truth About', 'I Tested', 'Why Everyone is Wrong About'],
        capsWords: ['[SHOCKING]', 'DON\'T BUY THIS', 'EXPOSED', 'NEVER DO THIS'],
        emojis: ['😱', '🤯', '🚨', '❌']
      },
      urgent: {
        hooks: ['STOP Doing This With Your', 'Do THIS Before It\'s Too Late for', 'The Urgent Warning About', 'Why You Need to Fix Your'],
        capsWords: ['[WARNING]', 'URGENT', 'STOP NOW', 'FINAL NOTICE'],
        emojis: ['🚨', '⚠️', '🔥', '🛑']
      },
      secret: {
        hooks: ['The Hidden Feature in', 'Secret Trick to Master', 'What They Aren\'t Telling You About', 'The 1% Secret to'],
        capsWords: ['[SECRET]', 'HIDDEN TRICK', 'CONFIDENTIAL', 'MUST WATCH'],
        emojis: ['🤫', '🔑', '💡', '⚡']
      },
      challenge: {
        hooks: ['I Spent 24 Hours Testing', 'Can You Really Master', 'I Tried the Ultimate Challenge for', 'Surviving 7 Days With'],
        capsWords: ['[IMPOSSIBLE]', '24 HOUR CHALLENGE', 'SURVIVED', 'HARDCORE'],
        emojis: ['🔥', '🏆', '🎯', '💪']
      },
      reaction: {
        hooks: ['My Honest Reaction to', 'Testing Viral Hacks for', 'This Changed Everything About', 'Is This the Ultimate'],
        capsWords: ['[MUST SEE]', 'CRAZY REACTION', 'LEGENDARY', 'INSANE'],
        emojis: ['😱', '🎉', '💥', '✨']
      }
    };

    let currentShuffledPool: string[] = [];
    let currentPoolIndex = 0;

    const buildShuffledPool = () => {
      const topic = (seedInput?.value || '').trim() || 'iPhone 16';
      const vibe = vibeSelect?.value || 'shock';

      const allowCaps = capsCheck?.checked;
      const allowEmojis = emojisCheck?.checked;
      const allowBrackets = bracketsCheck?.checked;

      const data = vibeTemplates[vibe] || vibeTemplates['shock'];
      const generatedSet = new Set<string>();

      const formatTitle = (hook: string, caps: string, emoji: string) => {
        let t = `${hook} ${topic}`;

        if (allowBrackets) {
          t = `${t} ${caps}`;
        } else if (allowCaps) {
          t = `${t} (${caps.replace(/[[\]]/g, '')})`;
        }

        if (allowEmojis) {
          t = `${t} ${emoji}`;
        }

        return t.replace(/\s+/g, ' ').trim();
      };

      let iterations = 0;
      while (generatedSet.size < 50 && iterations < 300) {
        iterations++;
        const hIndex = Math.floor(Math.random() * data.hooks.length);
        const cIndex = Math.floor(Math.random() * data.capsWords.length);
        const eIndex = Math.floor(Math.random() * data.emojis.length);

        const hook = data.hooks[hIndex];
        const caps = data.capsWords[cIndex];
        const emoji = data.emojis[eIndex];

        const formatted = formatTitle(hook, caps, emoji);
        if (formatted.length >= 10) {
          generatedSet.add(formatted);
        }
      }

      currentShuffledPool = Array.from(generatedSet).sort(() => Math.random() - 0.5);
      currentPoolIndex = 0;
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledPool();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      if (container) {
        container.innerHTML = selected.map(s => {
          return `
            <div class="title-chip" data-title="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy Title</button>
            </div>
          `;
        }).join('');
      }

      resultsWrapper?.classList.remove('hidden');

      // Default mockup text
      if (selected.length > 0) {
        if (mockupTitleText) mockupTitleText.textContent = selected[0];
        if (ctrStatusTag) {
          ctrStatusTag.textContent = `🔥 High CTR (${selected[0].length} chars)`;
        }
      }
    };

    // Append 5 more unique items
    const appendMoreTitles = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledPool();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledPool();
      }

      const next = currentShuffledPool.slice(currentPoolIndex, currentPoolIndex + 5);
      currentPoolIndex += 5;

      if (container) {
        const appendHtml = next.map(s => {
          return `
            <div class="title-chip" data-title="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy Title</button>
            </div>
          `;
        }).join('');
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    generateMoreBtn?.addEventListener('click', () => {
      appendMoreTitles();
    });

    // Handle copying individual title cards and update mockup preview
    container?.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest('.title-chip');
      if (!chip) return;

      const titleVal = chip.getAttribute('data-title') || '';

      // Update mockup sidebar
      if (mockupTitleText) {
        mockupTitleText.textContent = titleVal;
      }

      if (ctrStatusTag) {
        ctrStatusTag.textContent = `🔥 High CTR (${titleVal.length} chars)`;
      }

      // Copy to clipboard
      navigator.clipboard.writeText(titleVal).then(() => {
        const btn = chip.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy Title';
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener('click', () => {
      if (seedInput) seedInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-generate initial list
    generateList();
  };

  setupYoutubeClickbaitTitleGenerator();
  document.addEventListener('astro:after-swap', setupYoutubeClickbaitTitleGenerator);
</script>
