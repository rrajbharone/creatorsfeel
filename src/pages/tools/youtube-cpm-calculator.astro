<script>
  const setupYoutubeCpmCalculator = () => {
    const viewsInput = document.getElementById('views-input') as HTMLInputElement;
    const monetizedPctInput = document.getElementById('monetized-pct-input') as HTMLInputElement;
    const nicheSelect = document.getElementById('niche-select') as HTMLSelectElement;
    const cpmRateInput = document.getElementById('cpm-rate-input') as HTMLInputElement;

    // Actions
    const calculateBtn = document.getElementById('calculate-btn');
    const resetBtn = document.getElementById('reset-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');

    // Stat targets
    const statGrossRevenue = document.getElementById('stat-gross-revenue');
    const statNetPayout = document.getElementById('stat-net-payout');
    const statYtShare = document.getElementById('stat-yt-share');
    const statCreatorRpm = document.getElementById('stat-creator-rpm');

    // Mockup targets
    const mockupNetRevenue = document.getElementById('mockup-net-revenue');
    const mockupGrossCpm = document.getElementById('mockup-gross-cpm');
    const mockupCreatorRpm = document.getElementById('mockup-creator-rpm');
    const mockupYoutubeShare = document.getElementById('mockup-youtube-share');

    // Update CPM rate input when niche dropdown changes
    nicheSelect?.addEventListener('change', () => {
      const val = nicheSelect.value;
      if (val !== 'custom' && cpmRateInput) {
        cpmRateInput.value = parseFloat(val).toFixed(2);
        runCalculation();
      }
    });

    const runCalculation = () => {
      const totalViews = Math.max(100, parseFloat(viewsInput?.value || '100000') || 100000);
      const monetizedPct = Math.min(100, Math.max(5, parseFloat(monetizedPctInput?.value || '60') || 60));
      const cpmRate = Math.max(0.1, parseFloat(cpmRateInput?.value || '12.00') || 12.00);

      // Math
      const monetizedViews = totalViews * (monetizedPct / 100);
      const grossRevenue = (monetizedViews / 1000) * cpmRate;
      const netPayout = grossRevenue * 0.55;
      const ytShare = grossRevenue * 0.45;
      const creatorRpm = (netPayout / totalViews) * 1000;

      // Update overview stat cards
      if (statGrossRevenue) statGrossRevenue.textContent = `$${grossRevenue.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      if (statNetPayout) statNetPayout.textContent = `$${netPayout.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      if (statYtShare) statYtShare.textContent = `$${ytShare.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      if (statCreatorRpm) statCreatorRpm.textContent = `$${creatorRpm.toFixed(2)}`;

      // Update mockup card
      if (mockupNetRevenue) mockupNetRevenue.textContent = `$${netPayout.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      if (mockupGrossCpm) mockupGrossCpm.textContent = `$${cpmRate.toFixed(2)}`;
      if (mockupCreatorRpm) mockupCreatorRpm.textContent = `$${creatorRpm.toFixed(2)}`;
      if (mockupYoutubeShare) mockupYoutubeShare.textContent = `$${ytShare.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

      resultsWrapper?.classList.remove('hidden');
    };

    calculateBtn?.addEventListener('click', () => {
      runCalculation();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    resetBtn?.addEventListener('click', () => {
      if (viewsInput) viewsInput.value = '100000';
      if (monetizedPctInput) monetizedPctInput.value = '60';
      if (cpmRateInput) cpmRateInput.value = '12.00';
      runCalculation();
    });

    // Auto-run initial calculation
    runCalculation();
  };

  setupYoutubeCpmCalculator();
  document.addEventListener('astro:after-swap', setupYoutubeCpmCalculator);
</script>
