<script>
  const setupTagGenerator = () => {
    const titleInput = document.getElementById(
      "video-title",
    ) as HTMLInputElement;
    const categorySelect = document.getElementById(
      "video-category",
    ) as HTMLSelectElement;
    const shortsCheckbox = document.getElementById(
      "include-shorts",
    ) as HTMLInputElement;

    const submitBtn = document.getElementById("calc-submit-btn");
    const resetBtn = document.getElementById("calc-reset-btn");
    const copyBtn = document.getElementById("copy-tags-btn");

    const emptyBox = document.getElementById("res-empty-box");
    const activeBox = document.getElementById("res-active-box");

    const tagsCountVal = document.getElementById("res-tags-count");
    const charCountVal = document.getElementById("res-char-count");
    const chipsWrapper = document.getElementById("tags-chips-wrapper");

    let currentTags: string[] = [];

    const updateTagsLayout = () => {
      if (!chipsWrapper || !tagsCountVal || !charCountVal) return;

      if (currentTags.length === 0) {
        emptyBox?.classList.remove("hidden");
        activeBox?.classList.add("hidden");
        return;
      }

      // Generate HTML chips
      chipsWrapper.innerHTML = currentTags
        .map(
          (tag, idx) => `
        <div class="tag-chip" data-idx="${idx}">
          <span>${tag}</span>
          <span class="tag-chip-delete">&times;</span>
        </div>
      `,
        )
        .join("");

      // Add delete click handlers
      const chips = chipsWrapper.querySelectorAll(".tag-chip");
      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const idx = parseInt(chip.getAttribute("data-idx") || "0");
          currentTags.splice(idx, 1);
          updateTagsLayout();
        });
      });

      // Update counters
      const totalChars = currentTags.join(", ").length;
      tagsCountVal.textContent = `${currentTags.length} Tags`;
      charCountVal.textContent = `${totalChars} / 500 Characters`;

      if (totalChars > 500) {
        charCountVal.className = "grade-badge";
        charCountVal.style.color = "var(--color-danger)";
        charCountVal.style.background = "rgba(220, 38, 38, 0.1)";
      } else {
        charCountVal.className = "grade-badge grade-low";
        charCountVal.style.color = "";
        charCountVal.style.background = "";
      }
    };

    const generateTagsList = () => {
      const rawTitle = titleInput?.value.trim() || "";
      if (!rawTitle) {
        return alert("Please enter a video title or main topic.");
      }

      const category = categorySelect?.value || "general";
      const includeShorts = shortsCheckbox?.checked || false;

      // Clean up title
      const titleWords = rawTitle
        .toLowerCase()
        .replace(/[^\w\s]/g, "")
        .split(/\s+/)
        .filter((w) => w.length > 2);
      const mainKeyword = rawTitle.replace(/[^\w\s]/g, "").trim();

      const tagsSet = new Set<string>();

      // Add primary exact match
      tagsSet.add(mainKeyword.toLowerCase());

      // Add base components
      if (titleWords.length >= 2) {
        tagsSet.add(titleWords.slice(0, 3).join(" "));
        tagsSet.add(titleWords.slice(-3).join(" "));
        tagsSet.add(`${titleWords[0]} ${titleWords[1]}`);
      }
      if (titleWords.length >= 3) {
        tagsSet.add(`${titleWords[0]} ${titleWords[2]}`);
        tagsSet.add(titleWords.slice(0, 4).join(" "));
      }

      // Add custom variants
      tagsSet.add(`${mainKeyword.toLowerCase()} tutorial`);
      tagsSet.add(`${mainKeyword.toLowerCase()} guide`);
      tagsSet.add(`${mainKeyword.toLowerCase()} for beginners`);
      tagsSet.add(`${mainKeyword.toLowerCase()} tips`);
      tagsSet.add(`best ${mainKeyword.toLowerCase()}`);
      tagsSet.add(`${mainKeyword.toLowerCase()} in 2026`);
      tagsSet.add(`${mainKeyword.toLowerCase()} tips and tricks`);
      tagsSet.add(`how to do ${mainKeyword.toLowerCase()}`);
      tagsSet.add(`learn ${mainKeyword.toLowerCase()}`);
      tagsSet.add(`${mainKeyword.toLowerCase()} walkthrough`);

      // Add category templates (expanded to 15 items each)
      const categoryTemplates: Record<string, string[]> = {
        tech: [
          "tech video",
          "technology tutorial",
          "unboxing",
          "gadget review",
          "how to tech",
          "software guide",
          "tech setup",
          "tech review",
          "latest tech",
          "cool gadgets",
          "tech support",
          "electronics",
          "consumer tech",
          "tech news",
          "device test",
        ],
        cooking: [
          "cooking tutorial",
          "recipe video",
          "how to cook",
          "easy recipes",
          "cooking vlog",
          "home cooking",
          "delicious food",
          "quick meals",
          "culinary skills",
          "how to bake",
          "food channel",
          "chef tips",
          "dinner ideas",
          "healthy cooking",
          "meal prep",
        ],
        gaming: [
          "gaming video",
          "gameplay walkthrough",
          "lets play",
          "gaming setup",
          "funny gaming moments",
          "gaming guide",
          "new game",
          "gaming channel",
          "pro gamer",
          "game review",
          "esports",
          "twitch stream",
          "console gaming",
          "pc gaming",
          "best games",
        ],
        finance: [
          "personal finance",
          "business tips",
          "how to make money",
          "investing guide",
          "entrepreneurship",
          "side hustle",
          "financial freedom",
          "make money online",
          "passive income",
          "investing for beginners",
          "wealth building",
          "money saving tips",
          "budgeting hacks",
          "online business",
          "startup strategies",
        ],
        fitness: [
          "fitness routine",
          "workout vlog",
          "gym exercises",
          "healthy lifestyle",
          "lose weight",
          "bodybuilding tips",
          "home workout",
          "muscle building",
          "diet tips",
          "weight loss guide",
          "cardio routine",
          "gym motivation",
          "personal trainer",
          "stretch workout",
          "fitness hacks",
        ],
        general: [
          "video tutorial",
          "vlog",
          "tips and tricks",
          "how to",
          "educational video",
          "new video",
          "content creator",
          "online guide",
          "step by step",
          "explained",
          "tips tutorial",
          "best practices",
          "creative skills",
          "insights",
          "walkthrough",
        ],
      };

      const templates =
        categoryTemplates[category] || categoryTemplates.general;
      templates.forEach((t) => tagsSet.add(t));

      // Add short words (without size limit threshold)
      titleWords.forEach((word) => {
        if (word.length > 3) {
          tagsSet.add(word);
        }
      });

      // Add shorts tags
      if (includeShorts) {
        tagsSet.add("#shorts");
        tagsSet.add("youtube shorts");
        tagsSet.add("shorts feed");
        tagsSet.add("shorts video");
        tagsSet.add("trending shorts");
      }

      // Convert set to array and stay within 500 characters
      let tempTags = Array.from(tagsSet);
      let runningCharLen = 0;
      const finalTagsList: string[] = [];

      for (const tag of tempTags) {
        // factoring in comma separation character length
        const extraLen = finalTagsList.length > 0 ? 2 : 0;
        if (runningCharLen + tag.length + extraLen <= 499) {
          finalTagsList.push(tag);
          runningCharLen += tag.length + extraLen;
        } else {
          // Continue greedy search to pack smaller tags in remaining characters
          continue;
        }
      }

      currentTags = finalTagsList;

      // Activate box displays
      if (emptyBox) emptyBox.classList.add("hidden");
      if (activeBox) activeBox.classList.remove("hidden");

      updateTagsLayout();

      // Smooth scroll to the results section
      const resultsWrapper = document.getElementById("results-wrapper");
      if (resultsWrapper) {
        resultsWrapper.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
    };

    const resetGenerator = () => {
      if (titleInput) titleInput.value = "";
      if (categorySelect) categorySelect.selectedIndex = 3; // Finance
      if (shortsCheckbox) shortsCheckbox.checked = false;
      currentTags = [];
      updateTagsLayout();
    };

    const copyTagsToClipboard = () => {
      if (currentTags.length === 0) return;
      const commaSeparated = currentTags.join(", ");

      navigator.clipboard.writeText(commaSeparated).then(() => {
        const originalHTML = copyBtn ? copyBtn.innerHTML : "";
        if (copyBtn) {
          copyBtn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="var(--color-success)" style="width: 16px; height: 16px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span style="color: var(--color-success)">Copied!</span>
          `;
          setTimeout(() => {
            copyBtn.innerHTML = originalHTML;
          }, 2000);
        }
      });
    };

    submitBtn?.addEventListener("click", generateTagsList);
    resetBtn?.addEventListener("click", resetGenerator);
    copyBtn?.addEventListener("click", copyTagsToClipboard);
  };

  setupTagGenerator();
  document.addEventListener("astro:after-swap", setupTagGenerator);
</script>
