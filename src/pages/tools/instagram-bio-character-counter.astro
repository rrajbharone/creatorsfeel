    -webkit-overflow-scrolling: touch;
    display: block;
    width: 100%;
    box-sizing: border-box;
  }

  /* Toast Notification */
  .toast-notification {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gradient-brand);
    color: var(--color-text-inverse);
