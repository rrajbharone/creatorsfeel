  }

  .insight-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .hidden {
    display: none !important;
  }

  /* Responsive Rules */
  .tab-short {
    display: inline;
  }

  .tab-long {
    display: none;
  }

  @media (min-width: 640px) {
    .tab-short {
      display: none;
    }

    .tab-long {
      display: inline;
    }

    .form-actions {
      flex-direction: row;
    }

    .calc-btn, .calc-btn-secondary {
      flex: 1;
    }
  }

  /* Formula and Table responsiveness fixes */
  .formula-box {
    background: var(--color-bg-alt);
    padding: 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin: 1.25rem 0;
    font-family: monospace;
    font-size: clamp(0.85rem, 3.2vw, 1.1rem);
    text-align: center;
    overflow-x: auto;
    white-space: nowrap;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  .table-responsive {
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1.5rem 0;
    box-sizing: border-box;
  }

  code {
    white-space: pre-wrap;
    word-break: break-all;
  }

  /* Mobile styling overrides to remove nested borders and make results high-contrast & responsive */
  @media (max-width: 767px) {
    .calc-results {
      padding: 1.25rem !important;
      background: var(--color-bg-alt) !important;
      border: 1.5px solid var(--color-border) !important;
    }

    .results-active {
      gap: 1rem !important;
    }

    .rate-range-box, 
    .breakdown-box, 
    .insight-box {
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      padding: 0 !important;
      margin: 0 !important;
      border-radius: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
    }

    .rate-range-box {
      text-align: center !important;
      padding-bottom: 0.75rem !important;
      border-bottom: 1px dashed var(--color-border) !important;
    }

    .breakdown-box {
      border-bottom: 1px dashed var(--color-border) !important;
      padding-bottom: 0.75rem !important;
    }

    .breakdown-title {
      border-bottom: none !important;
      padding-bottom: 0 !important;
      margin-bottom: 0.5rem !important;
    }

    .insight-box {
      padding: 0.5rem 0 0 !important;
    }
  }

  /* Responsive Rules */
  @media (min-width: 1024px) {
    .calc-grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      align-items: start;
    }
  }
</style>

<script>
  const setupBioCounter = () => {
    // Selectors
    const textarea = document.getElementById('bio-textarea') as HTMLTextAreaElement;
    
    // Actions
    const btnUpper = document.getElementById('btn-uppercase');
    const btnLower = document.getElementById('btn-lowercase');
    const btnClear = document.getElementById('btn-clear');
    const btnSubmit = document.getElementById('calc-submit-btn');
    const btnCopyMain = document.getElementById('btn-copy-main');

    // Outputs
    const resCharCount = document.getElementById('res-char-count');
    const charProgressBar = document.getElementById('char-progress-bar');
    const resCharStatus = document.getElementById('res-char-status');

    // Audit checklist outputs
    const valLineBreaks = document.getElementById('val-line-breaks');
    const valEmojis = document.getElementById('val-emojis');
    const valCta = document.getElementById('val-cta');
    const valMentions = document.getElementById('val-mentions');

    const iconLineBreaks = document.getElementById('icon-line-breaks');
    const iconEmojis = document.getElementById('icon-emojis');
    const iconCta = document.getElementById('icon-cta');
    const iconMentions = document.getElementById('icon-mentions');

    const resInsightDesc = document.getElementById('res-insight-desc');

    // Font Previews
    const previewBold = document.getElementById('font-preview-bold');
    const previewItalic = document.getElementById('font-preview-italic');
    const previewMonospace = document.getElementById('font-preview-monospace');
    const previewDouble = document.getElementById('font-preview-double');
    const previewGothic = document.getElementById('font-preview-gothic');
    const toast = document.getElementById('font-toast');
    const fontItems = document.querySelectorAll('.font-item');

    if (!textarea) return;

    // Unicode mapping offset constants
    const mapUnicode = (text: string, type: string): string => {
      const charCodes: Record<string, { A: number; a: number; '0'?: number }> = {
        bold: { A: 120276, a: 120302, '0': 120812 },
        italic: { A: 120328, a: 120354 },
        doubleStruck: { A: 120120, a: 120146, '0': 120782 },
        gothic: { A: 120068, a: 120094 },
        monospace: { A: 120432, a: 120458, '0': 120822 }
      };

      const map = charCodes[type];
      if (!map) return text;

      return Array.from(text).map(char => {
        const code = char.charCodeAt(0);
        if (code >= 65 && code <= 90) { // A-Z
          return String.fromCodePoint(map.A + (code - 65));
        } else if (code >= 97 && code <= 122) { // a-z
          return String.fromCodePoint(map.a + (code - 97));
        } else if (code >= 48 && code <= 57 && map['0'] !== undefined) { // 0-9
          return String.fromCodePoint(map['0'] + (code - 48));
        }
        return char;
      }).join('');
    };

    // Emojis regex matcher
    const emojiRegex = /[\uD800-\uDBFF][\uDC00-\uDFFF]|\u261D|\u270C|[\u2700-\u27BF]|[\u2600-\u26FF]|[\u2190-\u21FF]/g;

    // Perform audit
    const updateAudit = () => {
      const text = textarea.value || '';
      const charLen = text.length;

      // 1. Character count display & progress bar
      if (resCharCount) resCharCount.textContent = `${charLen} / 150`;
      
      const pct = Math.min(100, (charLen / 150) * 100);
      if (charProgressBar) {
        charProgressBar.style.width = `${pct}%`;
        if (charLen > 150) {
          charProgressBar.style.background = 'var(--color-danger)';
        } else if (charLen > 130) {
          charProgressBar.style.background = 'var(--color-warning)';
        } else {
          charProgressBar.style.background = 'var(--gradient-brand)';
        }
      }

      if (resCharStatus) {
        if (charLen > 150) {
          resCharStatus.textContent = `${charLen - 150} Over Limit`;
          resCharStatus.style.color = 'var(--color-danger)';
        } else {
          resCharStatus.textContent = `${150 - charLen} Remaining`;
          resCharStatus.style.color = 'var(--color-brand)';
        }
      }

      // 2. Lines break audit (instagram bio limit is recommended <= 5 lines)
      const lines = text.split('\n');
      const linesCount = text === '' ? 0 : lines.length;
      if (valLineBreaks) valLineBreaks.textContent = `${linesCount} / 5 lines`;
      if (iconLineBreaks) {
        if (linesCount > 5) {
          iconLineBreaks.textContent = '⚠️';
          iconLineBreaks.style.color = 'var(--color-warning)';
        } else if (linesCount > 0) {
          iconLineBreaks.textContent = '✅';
          iconLineBreaks.style.color = 'var(--color-success)';
        } else {
          iconLineBreaks.textContent = '⚪';
        }
      }

      // 3. Emojis Count
      const emojiMatches = text.match(emojiRegex) || [];
      const emojiCount = emojiMatches.length;
      if (valEmojis) valEmojis.textContent = `${emojiCount} emojis`;
      if (iconEmojis) {
        if (emojiCount > 6) {
          iconEmojis.textContent = '⚠️';
        } else if (emojiCount > 0) {
          iconEmojis.textContent = '✅';
        } else {
          iconEmojis.textContent = '⚪';
        }
      }

      // 4. CTA auditor (checking for link pointer phrases or pointing down/right icons)
      const hasCta = /👇|⬇️|👇🏻|👇🏼|👇🏽|👇🏾|👇🏿|link|below|website|click|grab|get|shop|here/i.test(text);
      if (valCta) valCta.textContent = hasCta ? 'CTA Hook Active' : 'No CTA pointer';
      if (iconCta) {
        if (hasCta) {
          iconCta.textContent = '✅';
          iconCta.style.color = 'var(--color-success)';
        } else if (text !== '') {
          iconCta.textContent = '⚠️';
          iconCta.style.color = 'var(--color-warning)';
        } else {
          iconCta.textContent = '⚪';
        }
      }

      // 5. Handles/Mentions count
      const mentionMatches = text.match(/@\w+|#\w+/g) || [];
      const mentionCount = mentionMatches.length;
      if (valMentions) valMentions.textContent = `${mentionCount} tags / links`;
      if (iconMentions) {
        if (mentionCount > 3) {
          iconMentions.textContent = '⚠️';
        } else if (mentionCount > 0) {
          iconMentions.textContent = '✅';
        } else {
          iconMentions.textContent = '⚪';
        }
      }

      // 6. Font Generator Preview Updates
      const sampleText = text.trim() === '' ? 'Preview Font' : text.slice(0, 40) + (text.length > 40 ? '...' : '');
      if (previewBold) previewBold.textContent = mapUnicode(sampleText, 'bold');
      if (previewItalic) previewItalic.textContent = mapUnicode(sampleText, 'italic');
      if (previewMonospace) previewMonospace.textContent = mapUnicode(sampleText, 'monospace');
      if (previewDouble) previewDouble.textContent = mapUnicode(sampleText, 'doubleStruck');
      if (previewGothic) previewGothic.textContent = mapUnicode(sampleText, 'gothic');

      // 7. Update Analyst Insights
      if (resInsightDesc) {
        if (text === '') {
          resInsightDesc.textContent = 'Type your bio details in the input block to review profile quality suggestions.';
        } else if (charLen > 150) {
          resInsightDesc.textContent = `Your bio exceeds the limit by ${charLen - 150} characters. Instagram will reject edits. Try removing extra filler words or replacing word sentences with compact emojis.`;
        } else if (linesCount > 5) {
          resInsightDesc.textContent = 'Warning: You have used more than 5 lines. Instagram might truncate your bio on smaller phone screens. Condense lines to fit within 5 lines total.';
        } else if (!hasCta) {
          resInsightDesc.textContent = 'Insight: You are missing a clear call-to-action (CTA). Add a phrase like "Check link 👇" before your profile link to encourage click-through conversions.';
        } else {
          resInsightDesc.textContent = 'Excellent! Your bio fits under the character threshold, uses a clean line layout, and contains an active CTA hook. Ready to copy-paste to Instagram!';
        }
      }
    };

    // Text modifiers
    btnUpper?.addEventListener('click', () => {
      textarea.value = textarea.value.toUpperCase();
      updateAudit();
    });

    btnLower?.addEventListener('click', () => {
      textarea.value = textarea.value.toLowerCase();
      updateAudit();
    });

    btnClear?.addEventListener('click', () => {
      textarea.value = '';
      updateAudit();
    });

    // Copy original bio
    btnCopyMain?.addEventListener('click', () => {
      if (textarea.value.trim() === '') {
        alert('Please enter bio text first.');
        return;
      }
      textarea.select();
      navigator.clipboard.writeText(textarea.value);
      alert('Copied bio to clipboard!');
    });

    // Audit and Scroll down to results
    btnSubmit?.addEventListener('click', () => {
      updateAudit();
      setTimeout(() => {
        const resultsBox = document.getElementById('results-wrapper');
        if (resultsBox) {
          const headerOffset = 90;
          const elementPosition = resultsBox.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        }
      }, 50);
    });

    // Real-time audit triggers on typing
    textarea.addEventListener('input', updateAudit);

    // Font Items copy handler
    fontItems.forEach(item => {
      item.addEventListener('click', () => {
        const fontType = item.getAttribute('data-font-type') || 'bold';
        const rawText = textarea.value.trim() === '' ? 'CreatorsFeel' : textarea.value;
        const styledText = mapUnicode(rawText, fontType);

        navigator.clipboard.writeText(styledText).then(() => {
          if (toast) {
            toast.textContent = `Copied ${fontType.toUpperCase()} styled text!`;
            toast.classList.remove('hidden');
            setTimeout(() => {
              toast.classList.add('hidden');
            }, 1500);
          }
        });
      });
    });

    // Initial load run
    updateAudit();
  };

  setupBioCounter();
  document.addEventListener('astro:after-swap', setupBioCounter);
</script>
