  }

  /* Insight Box Styling */
  .insight-box {
    padding: 1.25rem;
    border-radius: var(--radius-md);
  }

  .insight-title {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
