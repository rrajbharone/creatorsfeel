---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is the character limit for an Instagram bio?",
    answer: "The official character limit for an Instagram bio is exactly 150 characters. This limit includes letters, numbers, spaces, punctuation, and emojis. Exceeding this limit will prevent you from saving your profile edits."
  },
  {
    question: "Do spaces and emojis count toward the character limit?",
    answer: "Yes, spaces count as one character. Emojis also count, but be aware that some complex emojis (such as skin tone variations or family groups) utilize multiple Unicode code points and may count as 2 to 4 characters in Instagram's system."
  },
  {
    question: "How do you add line breaks to an Instagram bio?",
    answer: "You can write your bio with line breaks directly inside our tool and copy it. Instagram allows up to 5-6 line breaks in a bio on mobile screens before truncating it with a 'more' button. Ensure your lines are short so they do not wrap automatically."
  },
  {
    question: "Can you use different fonts in your Instagram bio?",
    answer: "Yes, you can use stylized fonts using our built-in Unicode Font Generator. Because these characters are mathematical symbols in Unicode, they copy-paste directly into Instagram's profile fields. Use them sparingly (e.g. for keywords or your name) to ensure readability."
  },
  {
    question: "Do hashtags and profile links count in the 150 limit?",
    answer: "Yes, any `@username` or `#hashtag` links you place in your bio count toward the 150-character limit. However, the single website link field (the clickable URL) has its own separate input and does not count toward the 150 characters."
  }
];

const breadcrumbs = [
  { name: 'Home', item: '/' },
  { name: 'Tools', item: '/tools' },
  { name: 'Instagram Bio Character Counter', item: '/tools/instagram-bio-character-counter' }
];

const canonicalUrl = "https://creatorsfeel.com/tools/instagram-bio-character-counter";
---

<ToolLayout
  title="Instagram Bio Character Counter - Text Limit Auditor"
  description="Count characters for your Instagram bio in real-time. Style your bio with bold or italic fonts, verify line break limits, and optimize profile CTAs."
  toolName="Instagram Bio Character Counter"
  toolDescription="Format and audit your Instagram profile bio. Verify the 150-character limit, count lines/emojis, and generate copy-pasteable custom fonts."
  category="Writing Tools"
  faqs={faqs}
>


  <!-- Interactive Counter Interface -->
  <div slot="calculator" class="calc-card glass">
    <div class="calc-grid">
      <!-- Input Panel -->
      <div class="counter-input-section">
        <div class="form-group">
          <label for="bio-textarea">Write or Paste Your Bio</label>
          <div class="textarea-wrapper">
            <textarea 
              id="bio-textarea" 
              class="form-textarea" 
              placeholder="Type your Instagram bio here... e.g. 👇
🚀 Helping creators build profitable brands
💡 Daily tips on digital analytics
🔗 Grab my monetization kits below!"
              maxlength="300"
              rows="6"
            ></textarea>
            <div class="textarea-actions">
              <button type="button" id="btn-uppercase" class="text-action-btn">UPPER</button>
              <button type="button" id="btn-lowercase" class="text-action-btn">lower</button>
              <button type="button" id="btn-clear" class="text-action-btn-danger">Clear</button>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="button" id="calc-submit-btn" class="calc-btn">Audit Bio Quality</button>
          <button type="button" id="btn-copy-main" class="calc-btn-secondary">Copy Bio</button>
        </div>

        <!-- Font Generator Panel -->
        <div class="font-generator-box">
          <h4 class="font-box-title">Fancy Unicode Fonts Generator</h4>
          <p class="font-box-helper text-muted">Click any variation below to copy it directly to your clipboard:</p>
          
          <div class="fonts-list">
            <div class="font-item" data-font-type="bold" role="button" tabindex="0" title="Click to copy Bold text">
              <span class="font-label">Bold Sans:</span>
              <span class="font-preview" id="font-preview-bold">-</span>
            </div>
            <div class="font-item" data-font-type="italic" role="button" tabindex="0" title="Click to copy Italic text">
              <span class="font-label">Italic Sans:</span>
              <span class="font-preview" id="font-preview-italic">-</span>
            </div>
            <div class="font-item" data-font-type="monospace" role="button" tabindex="0" title="Click to copy Monospace text">
              <span class="font-label">Monospace:</span>
              <span class="font-preview" id="font-preview-monospace">-</span>
            </div>
            <div class="font-item" data-font-type="doubleStruck" role="button" tabindex="0" title="Click to copy Double-Struck text">
              <span class="font-label">Double-Struck:</span>
              <span class="font-preview" id="font-preview-double">-</span>
            </div>
            <div class="font-item" data-font-type="gothic" role="button" tabindex="0" title="Click to copy Gothic text">
              <span class="font-label">Fraktur/Gothic:</span>
              <span class="font-preview" id="font-preview-gothic">-</span>
            </div>
          </div>
          <div class="toast-notification hidden" id="font-toast">Copied styled font to clipboard!</div>
        </div>
      </div>

      <!-- Results & Metrics Audit Panel -->
      <div class="calc-results" id="results-wrapper">
        <div class="rate-range-box" id="progress-card">
          <h4 class="rate-label">Characters Used</h4>
          <div class="rate-range" id="res-char-count">0 / 150</div>
          
          <!-- Visual progress bar -->
          <div class="progress-bar-container">
            <div class="progress-bar-fill" id="char-progress-bar" style="width: 0%;"></div>
          </div>
          <div class="grade-badge" id="res-char-status">150 Remaining</div>
        </div>

        <!-- Metrics Audit list -->
        <div class="breakdown-box">
          <h4 class="breakdown-title">Instagram Bio Guidelines Audit</h4>
          <div class="breakdown-list">
            <!-- Line breaks check -->
            <div class="audit-item" id="audit-line-breaks">
              <div class="audit-meta">
                <span class="audit-icon" id="icon-line-breaks">⚪</span>
                <span class="audit-label">Line Count:</span>
              </div>
              <span class="audit-value" id="val-line-breaks">0 / 5 lines</span>
            </div>

            <!-- Emojis count -->
            <div class="audit-item" id="audit-emojis">
              <div class="audit-meta">
                <span class="audit-icon" id="icon-emojis">⚪</span>
                <span class="audit-label">Emojis Count:</span>
              </div>
              <span class="audit-value" id="val-emojis">0 used</span>
            </div>

            <!-- CTA hook check -->
            <div class="audit-item" id="audit-cta">
              <div class="audit-meta">
                <span class="audit-icon" id="icon-cta">⚪</span>
                <span class="audit-label">Call-to-Action (CTA):</span>
              </div>
              <span class="audit-value" id="val-cta">No CTA detected</span>
            </div>

            <!-- Mentions & handles check -->
            <div class="audit-item" id="audit-mentions">
              <div class="audit-meta">
                <span class="audit-icon" id="icon-mentions">⚪</span>
                <span class="audit-label">Mentions & Tags:</span>
              </div>
              <span class="audit-value" id="val-mentions">0 tags</span>
            </div>
          </div>
        </div>

        <!-- Analyst Insights -->
        <div class="insight-box glass">
          <h4 class="insight-title">Bio Conversion Insights</h4>
          <p id="res-insight-desc" class="insight-desc">Type your bio details in the input block to review profile quality suggestions.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Educational SEO Content -->
  <div slot="about">
    <h2>What is the Instagram Bio Character Limit?</h2>
    <p>
      An Instagram profile bio is your digital elevator pitch. It has a strict limit of **150 characters**. This length constraint forces creators, influencers, and brands to pack maximum value, brand message, and conversion links into a concise statement.
    </p>
    <p>
      This character limit includes letters, numbers, spaces, punctuation marks, line breaks, and emojis.
    </p>

    <h2>Why Spacing and Emojis Matter</h2>
    <ul>
      <li><strong>Spaces Count:</strong> Just like letters, empty spaces count as characters. When organizing your bio, avoid placing extra spaces to pad or align text.</li>
      <li><strong>Line Breaks Count:</strong> Every time you hit "Enter" to create a new line, it counts as 1 character in Instagram's limit calculations.</li>
      <li><strong>Emoji Codes:</strong> Emojis are essential visual elements. However, in Unicode, standard emojis might take up 1-2 character spaces, while complex emojis (like flags, skin tones, or groups) can require up to 4 character slots.</li>
    </ul>

    <h2>Formula for a High-Converting Bio</h2>
    <p>
      An optimized bio doesn't just describe what you do; it drives action. The standard formula used by leading social media agencies is:
    </p>
    <div class="formula-box">
      Bio = (Value Hook) + (Social Proof/Authority) + (Call to Action pointing 👇)
    </div>

    <h3>Step-by-Step Breakdown:</h3>
    <ol style="margin-left: 1.5rem; margin-bottom: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; color: var(--color-text-muted);">
      <li><strong>The Hook:</strong> Clear statement answering who you are and what you do. E.g. <em>"Helping B2B SaaS brands scale organically."</em></li>
      <li><strong>The Authority:</strong> Why should people follow you? E.g. <em>"7+ Years in Growth Marketing"</em> or <em>"Featured in Forbes."</em></li>
      <li><strong>The CTA:</strong> Tell users exactly what to do. E.g. <em>"Grab the free templates below 👇"</em>.</li>
    </ol>

    <h2>Instagram Bio Checklist and Rules</h2>
    <p>
      To prevent your bio from getting cut off or looking cluttered on mobile screens, keep these guidelines in mind:
    </p>
    <div class="table-responsive">
      <table style="width: 100%; min-width: 550px; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
        <thead>
          <tr style="border-bottom: 2px solid var(--color-border); background: var(--color-bg-alt);">
            <th style="padding: 0.75rem;">Metric</th>
            <th style="padding: 0.75rem;">Recommended Limit</th>
            <th style="padding: 0.75rem;">Why it Matters</th>
            <th style="padding: 0.75rem;">Risk of Exceeding</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: 0.75rem; font-weight: 600;">Characters Used</td>
            <td style="padding: 0.75rem;">130 - 150 characters</td>
            <td style="padding: 0.75rem;">Maximizes descriptive keyword space.</td>
            <td style="padding: 0.75rem; color: var(--color-danger);">Cannot save profile modifications.</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: 0.75rem; font-weight: 600;">Line Count</td>
            <td style="padding: 0.75rem;">4 - 5 lines max</td>
            <td style="padding: 0.75rem;">Keeps layout structured on mobile screens.</td>
            <td style="padding: 0.75rem; color: var(--color-warning);">Truncates bio with a "more" button.</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: 0.75rem; font-weight: 600;">Emojis Used</td>
            <td style="padding: 0.75rem;">2 - 4 emojis</td>
            <td style="padding: 0.75rem;">Breaks up text visually, drawing interest.</td>
            <td style="padding: 0.75rem; color: var(--color-text-muted);">Too many emojis feel cluttered/unprofessional.</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: 0.75rem; font-weight: 600;">CTA Mentions</td>
            <td style="padding: 0.75rem;">At least 1 pointer (👇)</td>
            <td style="padding: 0.75rem;">Guides audience eyes directly to the URL link.</td>
            <td style="padding: 0.75rem; color: var(--color-danger);">Lower click-through rates on landing page links.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2>How to Style Fonts in Instagram Bios</h2>
    <p>
      Using bold or italic fonts can draw attention to your brand's name or core value hooks. You can type your name inside our Unicode Font Generator, copy the stylized text, and paste it into the name or bio fields on Instagram.
    </p>
    <p>
      <strong>Pro Tip:</strong> Use styled fonts selectively (only 1 or 2 words). Some screen readers for visually impaired users cannot translate Unicode mathematical characters, meaning excessive usage will make your bio inaccessible to parts of your audience.
    </p>
  </div>
</ToolLayout>

<style>
  .calc-card {
    padding: var(--space-md);
    border-radius: var(--radius-lg);
    max-width: 100%;
    box-sizing: border-box;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2.5rem;
    max-width: 100%;
  }

  .counter-input-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 100%;
    box-sizing: border-box;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .textarea-wrapper {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: all var(--transition-fast);
  }

  .textarea-wrapper:focus-within {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
  }

  .form-textarea {
    width: 100%;
    background: transparent;
    border: none;
    padding: 1rem;
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    resize: vertical;
    outline: none;
    line-height: 1.5;
  }

  .textarea-actions {
    display: flex;
    justify-content: flex-end;
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    padding: 0.35rem 0.5rem;
    gap: 0.35rem;
  }

  .text-action-btn {
    font-size: 0.7rem;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    cursor: pointer;
    font-weight: 600;
    transition: all var(--transition-fast);
  }

  .text-action-btn:hover {
    color: var(--color-text);
    border-color: var(--color-brand);
  }

  .text-action-btn-danger {
    font-size: 0.7rem;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-danger);
    border: 1px solid transparent;
    cursor: pointer;
    font-weight: 600;
    transition: all var(--transition-fast);
  }

  .text-action-btn-danger:hover {
    background: rgba(239, 68, 68, 0.08);
    border-color: rgba(239, 68, 68, 0.2);
  }

  .form-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .calc-btn {
    height: 48px;
    background: var(--gradient-brand);
    color: var(--color-text-inverse);
