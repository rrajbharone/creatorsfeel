<script>
  const setupUrlSlugGenerator = () => {
    const valueInput = document.getElementById('value-input') as HTMLInputElement;
    const separatorSelect = document.getElementById('separator-input') as HTMLSelectElement;
    const stopWordsCheck = document.getElementById('stop-words-check') as HTMLInputElement;
    const numbersCheck = document.getElementById('numbers-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // Google Preview Mockup Elements
    const mockupSlugDisplay = document.getElementById('mockup-slug-display');

    // Sandbox workspace
    const sandboxInput = document.getElementById('sandbox-input') as HTMLTextAreaElement;
    const sandboxCounter = document.getElementById('sandbox-counter');
    const progressBarFill = document.getElementById('progress-bar-fill');
    const copyActiveBtn = document.getElementById('copy-active-btn');
    const clearSandboxBtn = document.getElementById('clear-sandbox-btn');

    // Alternative Displays
    const opt1Val = document.getElementById('opt-1-val');
    const opt2Val = document.getElementById('opt-2-val');
    const opt3Val = document.getElementById('opt-3-val');

    const opt1Badge = document.getElementById('opt-1-badge');
    const opt2Badge = document.getElementById('opt-2-badge');
    const opt3Badge = document.getElementById('opt-3-badge');

    // Clean Stop words helper list
    const STOP_WORDS = new Set([
      'a', 'about', 'above', 'after', 'again', 'against', 'all', 'am', 'an', 'and', 'any', 'are', 'arent',
      'as', 'at', 'be', 'because', 'been', 'before', 'being', 'below', 'between', 'both', 'but', 'by',
      'cant', 'cannot', 'could', 'couldnt', 'did', 'didnt', 'do', 'does', 'doesnt', 'doing', 'dont',
      'down', 'during', 'each', 'few', 'for', 'from', 'further', 'had', 'hadnt', 'has', 'hasnt', 'have',
      'havent', 'having', 'he', 'hed', 'hell', 'hes', 'her', 'here', 'heres', 'hers', 'herself', 'him',
      'himself', 'his', 'how', 'hows', 'i', 'id', 'ill', 'im', 'ive', 'if', 'in', 'into', 'is', 'isnt',
      'it', 'its', 'itself', 'lets', 'me', 'more', 'most', 'mustnt', 'my', 'myself', 'no', 'nor', 'not',
      'of', 'off', 'on', 'once', 'only', 'or', 'other', 'ought', 'our', 'ours', 'ourselves', 'out', 'over',
      'own', 'same', 'shant', 'she', 'shed', 'shell', 'shes', 'should', 'shouldnt', 'so', 'some', 'such',
      'than', 'that', 'thats', 'the', 'their', 'theirs', 'them', 'themselves', 'then', 'there', 'theres',
      'these', 'they', 'theyd', 'theyll', 'theyre', 'theyve', 'this', 'those', 'through', 'to', 'too',
      'under', 'until', 'up', 'very', 'was', 'wasnt', 'we', 'wed', 'well', 'were', 'weve', 'werent',
      'what', 'whats', 'when', 'whens', 'where', 'wheres', 'which', 'while', 'who', 'whos', 'whom',
      'why', 'whys', 'with', 'wont', 'would', 'wouldnt', 'you', 'youd', 'youll', 'youre', 'youve',
      'your', 'yours', 'yourself', 'yourselves'
    ]);

    // Sanitization logic helper
    const slugify = (text: string, sep: string, removeStop: boolean, removeNum: boolean): string => {
      // 1. Lowercase & Normalize diacritics
      let str = text.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');

      // 2. Remove special characters (keep words and spaces)
      str = str.replace(/[^a-z0-9\s-]/g, '');

      // 3. Split into words
      let words = str.split(/\s+/).filter(w => w.length > 0);

      // 4. Filter Stop Words
      if (removeStop) {
        words = words.filter(w => !STOP_WORDS.has(w));
      }

      // 5. Filter numbers
      if (removeNum) {
        words = words.filter(w => !/^\d+$/.test(w));
      }

      // 6. Join using separator
      return words.join(sep);
    };

    // Live Sandbox update
    const updateSandbox = () => {
      const text = sandboxInput?.value || '';
      const len = text.length;

      // Update Mockup Slug
      if (mockupSlugDisplay) {
        mockupSlugDisplay.textContent = text || 'your-page-slug';
      }

      // Update counters
      if (sandboxCounter) {
        sandboxCounter.textContent = `${len} / 60`;
        sandboxCounter.style.color = len > 60 ? '#f59e0b' : 'var(--color-text-muted)';
      }

      // Update progress bar
      if (progressBarFill) {
        const percent = Math.min((len / 60) * 100, 100);
        progressBarFill.style.width = `${percent}%`;
        
        if (len > 80) {
          progressBarFill.style.backgroundColor = '#ef4444'; // too long
        } else if (len > 60) {
          progressBarFill.style.backgroundColor = '#f59e0b'; // warning
        } else {
          progressBarFill.style.backgroundColor = 'var(--color-brand)';
        }
      }
    };
    sandboxInput?.addEventListener('input', updateSandbox);

    // Dynamic generation
    const generateSlugs = () => {
      const val = (valueInput?.value || '').trim();
      const sep = separatorSelect?.value || '-';
      const removeStop = stopWordsCheck?.checked || false;
      const removeNum = numbersCheck?.checked || false;

      if (!val) {
        alert("Please enter a title or string to slugify.");
        return;
      }

      // Generate 3 variations
      // A. Optimized (based on current checkboxes)
      const slugA = slugify(val, sep, removeStop, removeNum);
      
      // B. Exact Match (all words kept, numbers kept)
      const slugB = slugify(val, sep, false, false);

      // C. Ultra Short (top 3 key words, stop words removed)
      let wordsA = val.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').split(/\s+/).filter(w => w.length > 0 && !STOP_WORDS.has(w));
      if (removeNum) {
        wordsA = wordsA.filter(w => !/^\d+$/.test(w));
      }
      const slugC = wordsA.slice(0, 3).join(sep);

      // Populate Sandbox with Option A
      if (sandboxInput) {
        sandboxInput.value = slugA;
        updateSandbox();
      }

      // Update Suggestion displays
      const options = [slugA, slugB, slugC];
      const vals = [opt1Val, opt2Val, opt3Val];
      const badges = [opt1Badge, opt2Badge, opt3Badge];

      options.forEach((opt, idx) => {
        const vBlock = vals[idx];
        const bBlock = badges[idx];

        if (vBlock) vBlock.textContent = opt;
        if (bBlock) {
          const len = opt.length;
          bBlock.textContent = `${len} / 60`;
          bBlock.style.color = len > 60 ? '#f59e0b' : '';
        }
      });

      // Scroll directly to the results / editor sandbox column
      const editorCol = document.querySelector('.calc-editor-column');
      if (editorCol) {
        editorCol.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    generateBtn?.addEventListener('click', generateSlugs);

    // Load to sandbox buttons
    document.querySelectorAll('.load-sandbox-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId || !sandboxInput) return;
        const textBlock = document.getElementById(targetId);
        if (textBlock) {
          sandboxInput.value = textBlock.textContent || '';
          updateSandbox();
        }
      });
    });

    // Direct copies buttons
    document.querySelectorAll('.copy-direct-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId) return;
        const textBlock = document.getElementById(targetId);
        const text = textBlock?.textContent || '';
        if (!text) return;

        navigator.clipboard.writeText(text).then(() => {
          const originalText = btn.textContent;
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = originalText;
          }, 1500);
        });
      });
    });

    // Sandbox Copy
    copyActiveBtn?.addEventListener('click', () => {
      const text = sandboxInput?.value || '';
      if (!text) return alert("Sandbox is empty!");
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyActiveBtn.textContent;
        copyActiveBtn.textContent = 'Copied to Clipboard! ✓';
        setTimeout(() => {
          copyActiveBtn.textContent = originalText;
        }, 1500);
      });
    });

    // Clear Sandbox
    clearSandboxBtn?.addEventListener('click', () => {
      if (sandboxInput) {
        sandboxInput.value = '';
        updateSandbox();
      }
    });

    // Reset Fields
    resetBtn?.addEventListener('click', () => {
      if (valueInput) valueInput.value = '';
      if (sandboxInput) sandboxInput.value = '';
      updateSandbox();
    });

    // Initialize
    updateSandbox();
  };

  setupUrlSlugGenerator();
  document.addEventListener('astro:after-swap', setupUrlSlugGenerator);
</script>
