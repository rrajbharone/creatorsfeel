<script>
  const setupPodcastNameGenerator = () => {
    const seedInput = document.getElementById('seed-input') as HTMLInputElement;
    const nicheSelect = document.getElementById('niche-select') as HTMLSelectElement;
    const formatSelect = document.getElementById('format-select') as HTMLSelectElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');
    const generateMoreBtn = document.getElementById('generate-more-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-names-container');

    // Mockup targets
    const mockupShowTitle = document.getElementById('mockup-show-title');
    const mockupCoverArt = document.getElementById('mockup-cover-art');

    // Vibe Templates Database
    const vibesData: Record<string, { prefixes: string[], suffixes: string[] }> = {
      tech: {
        prefixes: ['The Tech', 'Digital', 'Future', 'Code &', 'Silicon', 'Binary', 'Next Gen', 'Cyber'],
        suffixes: ['Chronicles', 'Lab', 'Daily', 'Uncut', 'Insights', 'Talks', 'Network', 'Decoded']
      },
      crime: {
        prefixes: ['True', 'Cold Case', 'Midnight', 'Dark Side of', 'Unsolved', 'Secret', 'Shadow'],
        suffixes: ['Files', 'Mysteries', 'Chronicles', 'Uncut', 'Report', 'Investigations', 'Confessions']
      },
      mindset: {
        prefixes: ['The Mindful', 'Optimal', 'Daily', 'Inner', 'Peak', 'Balanced', 'Rewired'],
        suffixes: ['Mindset', 'Life', 'Flow', 'Habits', 'Podcast', 'Project', 'Hour']
      },
      pop: {
        prefixes: ['Pop Culture', 'The Casual', 'Late Night', 'Overthinking', 'Off the Cuff', 'Screen'],
        suffixes: ['Unfiltered', 'Show', 'Radio', 'Rants', 'Banter', 'Lounge', 'Cast']
      },
      arts: {
        prefixes: ['The Creative', 'Storyteller', 'Art &', 'Narrative', 'Ink &', 'Voice of'],
        suffixes: ['Canvas', 'Studio', 'Journal', 'Collective', 'Chronicles', 'Sessions']
      }
    };

    let currentShuffledPool: string[] = [];
    let currentPoolIndex = 0;

    const buildShuffledPool = () => {
      const topic = (seedInput?.value || '').trim();
      const niche = nicheSelect?.value || 'tech';
      const format = formatSelect?.value || 'clean';

      const database = vibesData[niche] || vibesData['tech'];
      const generatedSet = new Set<string>();

      const applyFormat = (prefix: string, body: string, suffix: string) => {
        let text = '';
        const topicVal = body || 'Tech';

        if (format === 'show') {
          text = `${prefix} ${topicVal} Show`;
        } else if (format === 'uncut') {
          text = `${prefix} ${topicVal} Uncut`;
        } else {
          text = `${prefix} ${topicVal} ${suffix}`;
        }

        // Clean extra spaces and trim to 50 characters max limit
        return text.replace(/\s+/g, ' ').trim().substring(0, 50);
      };

      // Generate a pool of 50 possible unique variations
      let iterations = 0;
      while (generatedSet.size < 50 && iterations < 300) {
        iterations++;
        const pIndex = Math.floor(Math.random() * database.prefixes.length);
        const sIndex = Math.floor(Math.random() * database.suffixes.length);

        const prefix = database.prefixes[pIndex] || 'The';
        const suffix = database.suffixes[sIndex] || 'Show';

        const formatted = applyFormat(prefix, topic, suffix);
        if (formatted.length >= 4) {
          generatedSet.add(formatted);
        }
      }

      currentShuffledPool = Array.from(generatedSet).sort(() => Math.random() - 0.5);
      currentPoolIndex = 0;
    };

    const updateMockupAvatar = (showName: string) => {
      if (!mockupCoverArt) return;
      const clean = showName.replace(/[^a-zA-Z0-9]/g, '').trim();
      const initials = clean.substring(0, 2).toUpperCase();
      mockupCoverArt.textContent = initials || 'PC';
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledPool();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      if (container) {
        container.innerHTML = selected.map(s => {
          return `
            <div class="title-chip" data-name="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
        }).join('');
      }

      resultsWrapper?.classList.remove('hidden');

      // Default the mockup title to the first generated result
      if (mockupShowTitle && selected.length > 0) {
        mockupShowTitle.textContent = selected[0];
        updateMockupAvatar(selected[0]);
      }
    };

    // Append 5 more unique titles
    const appendMoreTitles = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledPool();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledPool();
      }

      const next = currentShuffledPool.slice(currentPoolIndex, currentPoolIndex + 5);
      currentPoolIndex += 5;

      if (container) {
        const appendHtml = next.map(s => {
          return `
            <div class="title-chip" data-name="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
        }).join('');
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    generateMoreBtn?.addEventListener('click', () => {
      appendMoreTitles();
    });

    // Handle copying individual title chips and update mockup preview
    container?.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest('.title-chip');
      if (!chip) return;

      const titleVal = chip.getAttribute('data-name') || '';

      // Update mockup sidebar
      if (mockupShowTitle) {
        mockupShowTitle.textContent = titleVal;
      }
      updateMockupAvatar(titleVal);

      // Copy to clipboard
      navigator.clipboard.writeText(titleVal).then(() => {
        const btn = chip.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy';
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener('click', () => {
      if (seedInput) seedInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-generate initial list
    generateList();
  };

  setupPodcastNameGenerator();
  document.addEventListener('astro:after-swap', setupPodcastNameGenerator);
</script>
