---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "How does a Brand Deal Calculator estimate pricing?",
    answer: "A brand deal calculator uses platform-specific baseline CPM (Cost Per Mille) averages. These baselines are multiplied by your average video views or post impressions, then adjusted by niche value, engagement rate multipliers, and deliverable formats (like a dedicated YouTube video versus an integrated mention)."
  },
  {
    question: "What are the typical CPM baselines for each platform?",
    answer: "Average industry CPMs vary: YouTube commands a premium ($25 - $45 CPM) due to search value and long video lifespans; Instagram Reels average $30 - $60 CPM; TikTok views are highly algorithm-driven and quick-lived, typically averaging $10 - $25 CPM."
  },
  {
    question: "How do deliverable formats (Dedicated vs. Integrated) affect my rate?",
    answer: "A dedicated video (where the entire content is focused on the sponsor) is priced at 100% of your rate. An integrated mention (a 30 to 60-second segment within a regular video) requires less custom scripting and is usually priced at 40% to 60% of a dedicated video's rate."
  },
  {
    question: "Should I base my rates on my follower count or average views?",
    answer: "You should always base your baseline rates on your average views. Followers only measure past reach, whereas average views reflect active audience impressions and are what brands look for when pricing campaigns."
  }
];
---

<ToolLayout
  title="Brand Deal Calculator - Influencer Sponsorship Rates Tool"
  description="Calculate your brand deal sponsorship rates for YouTube, TikTok, and Instagram. Free online influencer pricing calculator with custom platform benchmarks."
  toolName="Brand Deal Calculator"
  toolDescription="Determine your sponsored campaign rates. Toggle between YouTube, TikTok, and Instagram to calculate authentic pricing ranges and export brand pitch templates."
  category="Calculators"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Platform tab list -->
    <div class="calculator-mode-selector" role="tablist" aria-label="Platform Selector">
      <button type="button" class="mode-tab active" data-platform="youtube" role="tab" aria-selected="true" aria-controls="calc-form-container">
        <span>YouTube</span>
      </button>
      <button type="button" class="mode-tab" data-platform="tiktok" role="tab" aria-selected="false" aria-controls="calc-form-container">
        <span>TikTok</span>
      </button>
      <button type="button" class="mode-tab" data-platform="instagram" role="tab" aria-selected="false" aria-controls="calc-form-container">
        <span>Instagram</span>
      </button>
    </div>

    <div class="calc-grid" id="calc-form-container">
      <!-- Input fields -->
      <form class="calc-form" id="brand-deal-form" onsubmit="return false;">
        <input type="hidden" id="active-platform" value="youtube" />

        <div class="form-group">
          <div class="label-header">
            <label for="audience-count" class="icon-label" id="audience-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
              Subscriber Count
            </label>
          </div>
          <input type="number" id="audience-count" class="form-input" placeholder="e.g., 50000" min="100" step="1" required />
          <span class="input-helper" id="audience-helper">Your total YouTube subscribers.</span>
        </div>

        <div class="form-group">
          <div class="label-header">
            <label for="avg-views" class="icon-label" id="views-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
              Average Views
            </label>
          </div>
          <input type="number" id="avg-views" class="form-input" placeholder="e.g., 8000 (leave blank to estimate)" min="1" step="1" />
          <span class="input-helper" id="views-helper">The typical number of views per video (defaults to 15% of subscribers if blank).</span>
        </div>

        <div class="form-group">
          <div class="label-header">
            <label for="deliverable-format" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
              </svg>
              Deliverable Format
            </label>
          </div>
          <select id="deliverable-format" class="form-input">
            <!-- YouTube options by default -->
            <option value="youtube_dedicated" selected>Dedicated Video (100% Sponsorship)</option>
            <option value="youtube_integrated">Integrated Mention (30s - 60s Segment)</option>
          </select>
        </div>

        <div class="form-group">
          <div class="label-header">
            <label for="niche-category" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a1.125 1.125 0 0 0 1.591 0l4.318-4.318a1.125 1.125 0 0 0 0-1.591L9.568 3.659A2.25 2.25 0 0 0 7.977 3Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 7.5h.008v.008H6V7.5Z" />
              </svg>
              Content Niche / Category
            </label>
          </div>
          <select id="niche-category" class="form-input">
            <option value="lifestyle" selected>Lifestyle, Fashion, & Art (Standard)</option>
            <option value="business">Business, Finance, & Tech (Premium)</option>
            <option value="fitness">Health, Fitness, & Food (Mid-Tier)</option>
            <option value="entertainment">Gaming & Entertainment (Low-CPM)</option>
          </select>
        </div>

        <div class="form-group">
          <div class="label-header">
            <label for="engagement-rate" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.34 18.062 18 21m-2.66-2.938a7.478 7.478 0 0 0 1.256-4.242A7.472 7.472 0 0 0 9 6.25a7.472 7.472 0 0 0-7.592 7.57 7.461 7.461 0 0 0 1.256 4.242L0 21m15.34-2.938A7.476 7.476 0 0 0 16.5 13.75c0-4.14-3.36-7.5-7.5-7.5h-.012c-4.137 0-7.488 3.353-7.488 7.47a7.473 7.473 0 0 0 1.156 3.968l1.455-1.597a5.525 5.525 0 0 1-.611-2.371c0-3.053 2.477-5.529 5.525-5.529h.012c3.048 0 5.525 2.476 5.525 5.53a5.523 5.523 0 0 1-.611 2.37l1.455 1.598Z" />
              </svg>
              Engagement Rate (%)
            </label>
          </div>
          <input type="number" id="engagement-rate" class="form-input" placeholder="e.g., 2.5" min="0.1" max="50" step="0.1" value="2.5" required />
          <span class="input-helper">Your average engagement rate (standard: 1.5% - 3.5%).</span>
        </div>

        <div class="form-actions">
          <button type="button" id="calc-submit-btn" class="calc-btn" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            Calculate Deal Value
          </button>
          <button type="button" id="calc-reset-btn" class="calc-btn-secondary" style="width: 100%;">Reset Form</button>
        </div>
      </form>

      <!-- Outputs Display -->
      <div class="calc-results" id="results-wrapper">
        <div class="empty-state text-center" id="res-empty-box">
          <svg class="empty-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <h3>Awaiting Price Analysis</h3>
          <p class="text-muted">Fill out your platform stats and click Calculate to estimate your brand deal market values.</p>
        </div>

        <div class="results-active hidden" id="res-active-box">
          <div class="rate-range-box">
            <h4 class="rate-label" id="res-primary-label">Sponsorship Value</h4>
            <div class="rate-range" id="res-rate-range">$0 - $0</div>
            <div class="grade-badge grade-low" id="res-tier-badge">Micro-Influencer</div>
          </div>

          <div class="breakdown-box">
            <h4 class="breakdown-title">Pricing Benchmarks Breakdown</h4>
            <div class="breakdown-list">
              <div class="breakdown-item">
                <span class="breakdown-label">Estimated Views/Impressions:</span>
                <span class="breakdown-val" id="res-views-val">-</span>
              </div>
              <div class="breakdown-item">
                <span class="breakdown-label">Suggested Cost Per View (CPV):</span>
                <span class="breakdown-val" id="res-cpv-val">-</span>
              </div>
              <div class="breakdown-item">
                <span class="breakdown-label">Calculated CPM Rate:</span>
                <span class="breakdown-val" id="res-cpm-val">-</span>
              </div>
            </div>
          </div>

          <!-- Brands pitch template -->
          <div class="pitch-container glass">
            <div class="pitch-header">
              <h5 class="pitch-title">Brands Outreach Template</h5>
              <button type="button" class="copy-pitch-btn" id="copy-pitch-btn" title="Copy template text">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 16px; height: 16px;">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.25M16.5 5.25h.008v.008H16.5V5.25Zm-3 0h.008v.008h-.008V5.25Zm-3 0h.008v.008h-.008V5.25Zm-3 0h.008v.008h-.008V5.25Zm-3 0h.008v.008h-.008V5.25ZM9 10.5c0-.621.504-1.125 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125v10.5c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V10.5Z" />
                </svg>
                Copy Pitch
              </button>
            </div>
            <textarea class="pitch-textbox" id="pitch-output" readonly rows="7"></textarea>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="editorial-content">
    <h2>Determining Your Sponsored Brand Deal Value</h2>
    <div style="margin: 1.5rem 0; background: var(--color-bg-alt); padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); border-left: 4px solid var(--color-brand);">
      <p style="margin: 0; font-weight: 600; font-size: 0.95rem;">
        💡 <strong>Want to optimize your metrics?</strong> Read our comprehensive guide on <a href="/blog/brand-deal-calculator-guide" style="color: var(--color-brand); text-decoration: underline;">Brand Deal Pricing Guidelines & Sponsorship Negotiation Strategies</a> to learn how to price dedicated integrations, account for production complexity, and negotiate pitches.
      </p>
    </div>

    <p>
      Negotiating with brands requires knowing your worth. Influencers often struggle to establish standard rates, resulting in leaving money on the table. Our <strong>influencer brand deal calculator</strong> handles calculations across YouTube, TikTok, and Instagram to offer realistic and authentic rates.
    </p>
    <p>
      Calculations account for the unique strengths of each social network:
    </p>
    <ul>
      <li><strong>YouTube Brand Deals:</strong> Commends higher CPMs ($25 - $45) because long-form video content has lasting search engine reach. An <strong>integrated mention</strong> is generally priced lower than a full <strong>dedicated video</strong>.</li>
      <li><strong>Instagram Brand Deals:</strong> Instagram Reels are pushed algorithmically, while Story slides are best suited for driving direct conversions with links.</li>
      <li><strong>TikTok Brand Deals:</strong> Views are highly volatile, hence CPM baselines ($10 - $25) are lower, but high-virality potential compensates for the lower rates.</li>
    </ul>

    <div class="formula-box">
      Base Price = (Average Views * Baseline CPM * Niche Multiplier * Format Multiplier) / 1000
    </div>

    <h2>Factors that Influence Sponsorship Value</h2>
    <p>
      Your baseline rates calculated by our tool are further adjusted by:
    </p>
    <ol style="margin-left: 1.5rem; margin-bottom: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; color: var(--color-text-muted);">
      <li><strong>Audience Engagement:</strong> Active communities (engagement rate >4%) show high intent, adding a 1.2x premium multiplier.</li>
      <li><strong>Premium Niches:</strong> Business, Tech, and Finance niches target high-LTV buyers, translating to a 1.5x pricing increase.</li>
      <li><strong>Deliverable complexity:</strong> Video editing, scripting, usage rights, and brand exclusivity will add to your final invoice amount.</li>
    </ol>
  </div>
</ToolLayout>

<style>
  /* Enforce rounded corners on the entire tool card and give it clean outer padding */
  .calc-card {
    padding: 2.5rem !important;
    border-radius: 24px !important;
    box-sizing: border-box;
    max-width: 100%;
  }

  .calculator-mode-selector {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    background: var(--color-bg-alt);
    padding: 0.35rem;
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .mode-tab {
    flex: 1;
    text-align: center;
    padding: 0.6rem 0.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .mode-tab:hover {
    color: var(--color-text);
  }

  .mode-tab.active {
    background: var(--color-bg);
    color: var(--color-brand);
    box-shadow: var(--shadow-sm);
  }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    max-width: 100%;
  }

  .calc-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 100%;
    box-sizing: border-box;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 100%;
    box-sizing: border-box;
  }

  .label-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .icon-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .field-icon {
    width: 18px;
    height: 18px;
    color: var(--color-brand);
    flex-shrink: 0;
  }

  select.form-input {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke='%236366f1' stroke-width='2'%3E%3Cpath stroke-linecap='round' stroke-linejoin='round' d='M19.5 8.25l-7.5 7.5-7.5-7.5'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1.25rem;
    padding-right: 2.5rem !important;
    cursor: pointer;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .calc-btn-secondary {
    height: 48px;
    background: transparent;
    border: 1.5px solid var(--color-border);
    color: var(--color-text);
    font-weight: 600;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .calc-btn-secondary:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-alt);
  }

  .calc-results {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 380px;
    padding: 2.25rem;
    border-radius: 20px !important;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    gap: 1.75rem;
    box-sizing: border-box;
    max-width: 100%;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .empty-icon {
    width: 48px;
    height: 48px;
    color: var(--color-text-muted);
  }

  .results-active {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  .rate-range-box {
    text-align: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    box-sizing: border-box;
    width: 100%;
  }

  .rate-label {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .rate-range {
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 800;
    color: var(--color-brand);
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .grade-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    border-radius: var(--radius-full);
    text-transform: uppercase;
  }

  .grade-low {
    background: rgba(99, 102, 241, 0.1);
    color: var(--color-brand);
  }

  .breakdown-box {
    width: 100%;
  }

  .breakdown-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .breakdown-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .breakdown-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
  }

  .breakdown-label {
    color: var(--color-text-muted);
  }

  .breakdown-val {
    font-weight: 600;
    color: var(--color-text);
  }

  .pitch-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    box-sizing: border-box;
  }

  .pitch-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .pitch-title {
    font-size: 0.9rem;
    font-weight: 700;
    margin: 0;
  }

  .copy-pitch-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-brand);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: opacity var(--transition-fast);
  }

  .copy-pitch-btn:hover {
    opacity: 0.8;
  }

  .pitch-textbox {
    width: 100%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.75rem;
    font-size: 0.85rem;
    font-family: var(--font-body);
    line-height: 1.5;
    color: var(--color-text);
    resize: none;
    box-sizing: border-box;
  }

  .formula-box {
    background: var(--color-bg-alt);
    padding: 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin: 1.25rem 0;
    font-family: monospace;
    font-size: clamp(0.85rem, 3.2vw, 1.1rem);
    text-align: center;
    overflow-x: auto;
    white-space: nowrap;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  .hidden {
    display: none !important;
  }

  /* Responsive Mobile Overrides */
  @media (max-width: 767px) {
    .calc-card {
      padding: 1.25rem !important;
      border-radius: 18px !important;
    }

    .form-actions {
      flex-direction: column;
      gap: 0.75rem;
    }

    .calc-results {
      padding: 0 !important;
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      gap: 1.5rem !important;
      margin-top: 0.5rem !important;
      min-height: auto;
    }

    .breakdown-box {
      border-bottom: 1px dashed var(--color-border) !important;
      padding-bottom: 1rem !important;
    }

    .rate-range-box,
    .pitch-container {
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      border-radius: 0 !important;
      box-shadow: none !important;
      width: 100% !important;
    }

    .rate-range-box {
      border-bottom: 1px dashed var(--color-border) !important;
      padding-bottom: 1rem !important;
      align-items: center !important;
    }
  }

  @media (min-width: 1024px) {
    .calc-grid {
      grid-template-columns: 1.2fr 1fr;
      align-items: start;
      gap: 2.5rem;
    }
  }

  /* Slotted editorial heading spacing fixes */
  .editorial-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    color: var(--color-text);
  }
</style>

<script>
  const setupBrandDealCalculator = () => {
    // Mode selectors
    const platformTabs = document.querySelectorAll('.mode-tab');
    const activePlatformInput = document.getElementById('active-platform') as HTMLInputElement;

    // Form inputs
    const audienceField = document.getElementById('audience-count') as HTMLInputElement;
    const viewsField = document.getElementById('avg-views') as HTMLInputElement;
    const deliverableSelect = document.getElementById('deliverable-format') as HTMLSelectElement;
    const nicheSelect = document.getElementById('niche-category') as HTMLSelectElement;
    const engagementField = document.getElementById('engagement-rate') as HTMLInputElement;

    // Helper text strings
    const audienceLabel = document.getElementById('audience-label');
    const audienceHelper = document.getElementById('audience-helper');
    const viewsHelper = document.getElementById('views-helper');

    // Buttons
    const submitBtn = document.getElementById('calc-submit-btn');
    const resetBtn = document.getElementById('calc-reset-btn');
    const copyPitchBtn = document.getElementById('copy-pitch-btn');

    // Display blocks
    const emptyBox = document.getElementById('res-empty-box');
    const activeBox = document.getElementById('res-active-box');

    // Outputs
    const primaryLabel = document.getElementById('res-primary-label');
    const rateRangeVal = document.getElementById('res-rate-range');
    const tierBadge = document.getElementById('res-tier-badge');

    const viewsVal = document.getElementById('res-views-val');
    const cpvVal = document.getElementById('res-cpv-val');
    const cpmVal = document.getElementById('res-cpm-val');
    const pitchTextbox = document.getElementById('pitch-output') as HTMLTextAreaElement;

    // Platform-specific deliverable formats database mapping
    const formatsMap: Record<string, Array<{val: string; text: string}>> = {
      youtube: [
        {val: 'youtube_dedicated', text: 'Dedicated Video (100% Sponsor Focus)'},
        {val: 'youtube_integrated', text: 'Integrated Mention (30s - 60s Segment)'}
      ],
      tiktok: [
        {val: 'tiktok_dedicated', text: 'Dedicated TikTok Video (Full review)'},
        {val: 'tiktok_mention', text: 'Short Integration / Audio placement'}
      ],
      instagram: [
        {val: 'instagram_reel', text: 'Dedicated Instagram Reel'},
        {val: 'instagram_story', text: '3-Frame Story Sequence (with link)'},
        {val: 'instagram_carousel', text: 'Carousel Post (Photo + Slides)'}
      ]
    };

    // Platform UI modifications
    platformTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        platformTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const platform = tab.getAttribute('data-platform') || 'youtube';
        if (activePlatformInput) activePlatformInput.value = platform;

        // Update Labels and helper descriptions
        if (platform === 'youtube') {
          if (audienceLabel) audienceLabel.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg> Subscriber Count`;
          if (audienceHelper) audienceHelper.textContent = "Your total YouTube subscribers.";
          if (viewsHelper) viewsHelper.textContent = "The typical number of views per video (defaults to 15% of subscribers if blank).";
        } else if (platform === 'tiktok') {
          if (audienceLabel) audienceLabel.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg> Follower Count`;
          if (audienceHelper) audienceHelper.textContent = "Your total TikTok followers.";
          if (viewsHelper) viewsHelper.textContent = "The typical views per TikTok clip (defaults to 12% of followers if blank).";
        } else {
          if (audienceLabel) audienceLabel.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg> Follower Count`;
          if (audienceHelper) audienceHelper.textContent = "Your total Instagram followers.";
          if (viewsHelper) viewsHelper.textContent = "Average views/impressions based on format (15% for Reels, 5% for Stories if blank).";
        }

        // Repopulate deliverable formats select list
        if (deliverableSelect) {
          deliverableSelect.innerHTML = '';
          const opts = formatsMap[platform] || [];
          opts.forEach(o => {
            const el = document.createElement('option');
            el.value = o.val;
            el.textContent = o.text;
            deliverableSelect.appendChild(el);
          });
        }

        resetCalculator(false);
      });
    });

    const calculateRates = () => {
      const platform = activePlatformInput?.value || 'youtube';
      const audience = parseFloat(audienceField?.value) || 0;
      let views = parseFloat(viewsField?.value) || 0;
      const deliverable = deliverableSelect?.value || '';
      const niche = nicheSelect?.value || 'lifestyle';
      const engagement = parseFloat(engagementField?.value) || 2.5;

      if (audience < 100) {
        return alert("Please enter a valid follower or subscriber count (minimum 100).");
      }

      // Default views if left blank
      if (!views || views <= 0) {
        if (platform === 'youtube') {
          views = Math.round(audience * 0.15);
        } else if (platform === 'tiktok') {
          views = Math.round(audience * 0.12);
        } else {
          // Instagram views default based on format
          if (deliverable === 'instagram_story') {
            views = Math.round(audience * 0.05);
          } else if (deliverable === 'instagram_carousel') {
            views = Math.round(audience * 0.10);
          } else {
            views = Math.round(audience * 0.15);
          }
        }
      }

      // Platform CPM parameters
      let baseCpm = 25;
      if (platform === 'youtube') baseCpm = 35;
      else if (platform === 'tiktok') baseCpm = 18;
      else if (platform === 'instagram') baseCpm = 30;

      // Deliverable type format multipliers
      let formatMultiplier = 1.0;
      let formatLabel = "Dedicated Content";
      
      if (deliverable === 'youtube_integrated') {
        formatMultiplier = 0.5;
        formatLabel = "Integrated Mention";
      } else if (deliverable === 'tiktok_mention') {
        formatMultiplier = 0.4;
        formatLabel = "Sound Integration";
      } else if (deliverable === 'instagram_story') {
        formatMultiplier = 0.6; // Story sequence is lighter
        formatLabel = "Story Sequence";
      } else if (deliverable === 'instagram_carousel') {
        formatMultiplier = 0.8;
        formatLabel = "Carousel Post";
      }

      // Niche multipliers
      let nicheMultiplier = 1.0;
      let nicheName = "Lifestyle";
      if (niche === 'business') {
        nicheMultiplier = 1.5;
        nicheName = "Business & Finance";
      } else if (niche === 'fitness') {
        nicheMultiplier = 1.2;
        nicheName = "Fitness & Food";
      } else if (niche === 'entertainment') {
        nicheMultiplier = 0.8;
        nicheName = "Entertainment";
      }

      // Engagement multipliers
      let engagementMultiplier = 1.0;
      if (engagement < 1.5) {
        engagementMultiplier = 0.85;
      } else if (engagement > 4.0) {
        engagementMultiplier = 1.2;
      }

      // Calculate CPM & CPV
      const calculatedCpm = baseCpm * nicheMultiplier * formatMultiplier * engagementMultiplier;
      const calculatedCpv = calculatedCpm / 1000;

      // Pricing Ranges
      const midPointPrice = (views * calculatedCpm) / 1000;
      const lowEstimate = Math.max(15, Math.round(midPointPrice * 0.85));
      const highEstimate = Math.max(20, Math.round(midPointPrice * 1.15));

      // Influencer Tier Badge
      let tierName = "Micro-Influencer";
      if (audience >= 500000) tierName = "Mega-Influencer";
      else if (audience >= 100000) tierName = "Macro-Influencer";
      else if (audience >= 10000) tierName = "Mid-Tier";
      else if (audience < 1000) tierName = "Nano-Influencer";

      // Render Outputs
      if (emptyBox) emptyBox.classList.add('hidden');
      if (activeBox) activeBox.classList.remove('hidden');

      const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
      if (primaryLabel) primaryLabel.textContent = `${capitalize(platform)} Deal Value (${formatLabel})`;
      if (rateRangeVal) rateRangeVal.textContent = `$${lowEstimate.toLocaleString()} - $${highEstimate.toLocaleString()}`;
      if (tierBadge) {
        tierBadge.textContent = tierName;
        tierBadge.className = 'grade-badge grade-low';
      }

      if (viewsVal) viewsVal.textContent = views.toLocaleString();
      if (cpvVal) cpvVal.textContent = `$${calculatedCpv.toFixed(3)}`;
      if (cpmVal) cpmVal.textContent = `$${calculatedCpm.toFixed(2)}`;

      // Generate Pitch Template
      const platformUserTerm = platform === 'youtube' ? 'subscribers' : 'followers';
      const pitchText = `Subject: Brand Partnership Inquiry: @YourHandle x [Brand Name]

Hi [Brand Name] Team,

I've been following your recent campaigns and love your product line! I'm a content creator in the ${nicheName} niche on ${capitalize(platform)}. I have built an active audience of ${audience.toLocaleString()} ${platformUserTerm} with an average engagement rate of ${engagement.toFixed(1)}%.

I'd love to partner with you to promote your brand. Based on my average metrics of ${views.toLocaleString()} views per post, my baseline rates for a ${formatLabel} on ${capitalize(platform)} is estimated around $${lowEstimate.toLocaleString()} - $${highEstimate.toLocaleString()}.

Here is a quick summary of my profile stats:
- Audience size: ${audience.toLocaleString()} ${platformUserTerm}
- Average Views: ${views.toLocaleString()}
- Engagement Rate: ${engagement.toFixed(1)}%

Let me know if you would like me to send over my full media kit to discuss potential package deals!

Best regards,
[Your Name]
@YourHandle`;

      if (pitchTextbox) pitchTextbox.value = pitchText;

      // Smooth scroll to the results section
      const resultsWrapper = document.getElementById('results-wrapper');
      if (resultsWrapper) {
        resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    const resetCalculator = (clearInputs = true) => {
      if (clearInputs) {
        if (audienceField) audienceField.value = '';
        if (viewsField) viewsField.value = '';
        if (deliverableSelect) deliverableSelect.selectedIndex = 0;
        if (nicheSelect) nicheSelect.selectedIndex = 0;
        if (engagementField) engagementField.value = '2.5';
      }

      if (emptyBox) emptyBox.classList.remove('hidden');
      if (activeBox) activeBox.classList.add('hidden');
    };

    // Copy to clipboard
    const copyPitchToClipboard = () => {
      if (!pitchTextbox) return;
      pitchTextbox.select();
      pitchTextbox.setSelectionRange(0, 99999);
      navigator.clipboard.writeText(pitchTextbox.value).then(() => {
        const originalText = copyPitchBtn ? copyPitchBtn.innerHTML : '';
        if (copyPitchBtn) {
          copyPitchBtn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="var(--color-success)" style="width: 16px; height: 16px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span style="color: var(--color-success)">Copied!</span>
          `;
          setTimeout(() => {
            copyPitchBtn.innerHTML = originalText;
          }, 2000);
        }
      });
    };

    submitBtn?.addEventListener('click', calculateRates);
    resetBtn?.addEventListener('click', () => resetCalculator(true));
    copyPitchBtn?.addEventListener('click', copyPitchToClipboard);
  };

  setupBrandDealCalculator();
  document.addEventListener('astro:after-swap', setupBrandDealCalculator);
</script>
