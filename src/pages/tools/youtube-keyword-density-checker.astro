<script>
  const setupYoutubeKeywordDensityChecker = () => {
    const descInput = document.getElementById('description-input') as HTMLTextAreaElement;
    const targetInput = document.getElementById('target-keyword-input') as HTMLInputElement;

    const excludeStopwordsCheck = document.getElementById('exclude-stopwords-check') as HTMLInputElement;
    const minLengthCheck = document.getElementById('min-length-check') as HTMLInputElement;

    // Actions
    const analyzeBtn = document.getElementById('analyze-btn');
    const resetBtn = document.getElementById('reset-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');

    // Stat targets
    const statTotalWords = document.getElementById('stat-total-words');
    const statUniqueWords = document.getElementById('stat-unique-words');
    const statTargetDensity = document.getElementById('stat-target-density');
    const statSpamRisk = document.getElementById('stat-spam-risk');

    // Mockup targets
    const mockupDescText = document.getElementById('mockup-desc-text');
    const charCounterTag = document.getElementById('char-counter-tag');
    const targetStatusTag = document.getElementById('target-status-tag');

    // Tables
    const table1Word = document.getElementById('table-1word-container');
    const table2Word = document.getElementById('table-2word-container');
    const table3Word = document.getElementById('table-3word-container');

    const stopWords = new Set([
      'the', 'be', 'to', 'of', 'and', 'a', 'in', 'that', 'have', 'i',
      'it', 'for', 'not', 'on', 'with', 'he', 'as', 'you', 'do', 'at',
      'this', 'but', 'his', 'by', 'from', 'they', 'we', 'say', 'her', 'she',
      'or', 'an', 'will', 'my', 'one', 'all', 'would', 'there', 'their', 'what',
      'so', 'up', 'out', 'if', 'about', 'who', 'get', 'which', 'go', 'me'
    ]);

    const runDensityAnalysis = () => {
      const text = descInput?.value || '';
      const targetKw = (targetInput?.value || '').trim().toLowerCase();

      const excludeStop = excludeStopwordsCheck?.checked;
      const minLength = minLengthCheck?.checked;

      // Clean text into tokens
      const rawWords = text.toLowerCase().replace(/[^a-z0-9\s]/g, ' ').split(/\s+/).filter(Boolean);
      const totalWordCount = rawWords.length;

      if (charCounterTag) {
        charCounterTag.textContent = `${text.length} / 5000 chars`;
      }

      if (totalWordCount === 0) {
        resultsWrapper?.classList.add('hidden');
        return;
      }

      // Filtered words for n-gram frequency
      const filteredWords = rawWords.filter(w => {
        if (minLength && w.length < 3) return false;
        if (excludeStop && stopWords.has(w)) return false;
        return true;
      });

      const uniqueWords = new Set(filteredWords).size;

      // 1-Word Frequencies
      const freq1: Record<string, number> = {};
      filteredWords.forEach(w => {
        freq1[w] = (freq1[w] || 0) + 1;
      });

      // 2-Word Frequencies (Bigrams)
      const freq2: Record<string, number> = {};
      for (let i = 0; i < rawWords.length - 1; i++) {
        const w1 = rawWords[i];
        const w2 = rawWords[i + 1];
        if (excludeStop && (stopWords.has(w1) && stopWords.has(w2))) continue;
        const phrase = `${w1} ${w2}`;
        freq2[phrase] = (freq2[phrase] || 0) + 1;
      }

      // 3-Word Frequencies (Trigrams)
      const freq3: Record<string, number> = {};
      for (let i = 0; i < rawWords.length - 2; i++) {
        const w1 = rawWords[i];
        const w2 = rawWords[i + 1];
        const w3 = rawWords[i + 2];
        const phrase = `${w1} ${w2} ${w3}`;
        freq3[phrase] = (freq3[phrase] || 0) + 1;
      }

      // Target Keyword Count Calculation
      let targetCount = 0;
      if (targetKw) {
        const regex = new RegExp(targetKw.replace(/[-/\\^$*+?.()|[\]{}]/g, '\\$&'), 'gi');
        const matches = text.match(regex);
        targetCount = matches ? matches.length : 0;
      }

      const targetDensityPct = totalWordCount > 0 ? ((targetCount / totalWordCount) * 100) : 0;

      // Update overview stats
      if (statTotalWords) statTotalWords.textContent = totalWordCount.toString();
      if (statUniqueWords) statUniqueWords.textContent = uniqueWords.toString();
      if (statTargetDensity) statTargetDensity.textContent = `${targetDensityPct.toFixed(1)}%`;

      if (statSpamRisk) {
        if (targetDensityPct > 5.0) {
          statSpamRisk.textContent = 'High Spam Risk ⚠️';
          statSpamRisk.style.color = '#ef4444';
        } else if (targetDensityPct > 3.0) {
          statSpamRisk.textContent = 'Moderate Risk ⚡';
          statSpamRisk.style.color = '#f59e0b';
        } else {
          statSpamRisk.textContent = 'Safe Zone ✓';
          statSpamRisk.style.color = '#16a34a';
        }
      }

      if (targetStatusTag) {
        targetStatusTag.textContent = `${targetDensityPct.toFixed(1)}% (${targetDensityPct > 5 ? 'High Risk ⚠️' : 'Safe Zone ✓'})`;
        targetStatusTag.style.color = targetDensityPct > 5 ? '#ef4444' : '#2ba640';
      }

      // Update Live Mockup Highlight Text
      if (mockupDescText) {
        if (targetKw && targetCount > 0) {
          const escKw = targetKw.replace(/[-/\\^$*+?.()|[\]{}]/g, '\\$&');
          const highlightHtml = text.replace(new RegExp(`(${escKw})`, 'gi'), `<mark style="background: rgba(99, 102, 241, 0.35); color: #6366f1; padding: 0 4px; border-radius: 3px; font-weight: 700;">$1</mark>`);
          mockupDescText.innerHTML = highlightHtml;
        } else {
          mockupDescText.textContent = text;
        }
      }

      // Render Tables Helper
      const renderTable = (elem: HTMLElement | null, obj: Record<string, number>) => {
        if (!elem) return;
        const sorted = Object.entries(obj).sort((a, b) => b[1] - a[1]).slice(0, 5);
        if (sorted.length === 0) {
          elem.innerHTML = '<span style="font-size: 0.78rem; color: var(--color-text-muted);">No data.</span>';
          return;
        }
        elem.innerHTML = sorted.map(([phrase, count]) => {
          const pct = ((count / totalWordCount) * 100).toFixed(1);
          return `
            <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.78rem; background: var(--color-bg); padding: 6px 10px; border-radius: 8px; border: 1px solid var(--color-border);">
              <span style="font-weight: 700; color: var(--color-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 60%;">${phrase}</span>
              <span style="color: var(--color-text-muted); font-size: 0.72rem;">${count}x (${pct}%)</span>
            </div>
          `;
        }).join('');
      };

      renderTable(table1Word, freq1);
      renderTable(table2Word, freq2);
      renderTable(table3Word, freq3);

      resultsWrapper?.classList.remove('hidden');
    };

    analyzeBtn?.addEventListener('click', () => {
      runDensityAnalysis();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    resetBtn?.addEventListener('click', () => {
      if (descInput) descInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-run initial analysis
    runDensityAnalysis();
  };

  setupYoutubeKeywordDensityChecker();
  document.addEventListener('astro:after-swap', setupYoutubeKeywordDensityChecker);
</script>
