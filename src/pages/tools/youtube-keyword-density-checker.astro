          <div id="table-2word-container" style="display: flex; flex-direction: column; gap: 8px;">
            <!-- Dynamic 2-word list -->
          </div>
        </div>

        <!-- 3-Word Density Table -->
        <div style="background: var(--color-bg-alt); padding: 1.25rem; border-radius: 16px; border: 1px solid var(--color-border);">
