---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is the optimal keyword density for YouTube video descriptions?",
    answer: "The ideal keyword density for YouTube descriptions is between 1% and 3%. This means your primary keyword should appear 2 to 4 times in a 250 to 300-word description. Exceeding 5% density can trigger YouTube's keyword stuffing spam filters."
  },
  {
    question: "Can YouTube penalize videos for keyword stuffing in descriptions?",
    answer: "Yes, YouTube's search and discovery algorithm actively flags descriptions that contain lists of repetitive keywords or unnatural phrasing. Over-optimizing metadata can result in lower search rankings or removal from recommendation feeds."
  },
  {
    question: "How does keyword density differ between 1-word, 2-word, and 3-word phrases?",
    answer: "Single-word density measures individual word frequency (e.g., 'gaming'), while 2-word and 3-word phrase density tracks exact multi-word search queries (e.g., 'gaming PC' or 'best gaming PC build'). Tracking multi-word phrases ensures your target long-tail keywords are balanced."
  },
  {
    question: "Does YouTube check transcript text for keyword density?",
    answer: "Yes, YouTube automatically transcribes spoken audio into closed captions. Spoken keyword density affects your video's semantic context, so saying your target keywords naturally during your video presentation improves search indexing."
  },
  {
    question: "Is this YouTube Keyword Density Checker free to use?",
    answer: "Yes, our YouTube Keyword Density Checker is 100% free with unlimited text analysis, 1 to 3-word phrase breakdowns, spam risk detection, and live description card previews."
  }
];
---

<ToolLayout
  title="YouTube Keyword Density Checker - Free Video Description Audit Tool"
  description="Analyze YouTube video description keyword density, total word count, 1-3 word phrase frequencies, and spam risk levels to avoid keyword stuffing."
  toolName="YouTube Keyword Density Checker"
  toolDescription="Audit YouTube video descriptions for keyword density and frequency. Prevent keyword stuffing penalties, analyze 1-3 word phrases, and optimize video metadata."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Analyzer Inputs -->
      <div class="calc-form-column">
        <div class="calc-form">
          <!-- Text Area Input for YouTube Description -->
          <div class="form-group">
            <label for="description-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
              YouTube Video Description Text
            </label>
            <textarea id="description-input" class="form-input" rows="7" style="height: auto; padding: 12px; font-family: var(--font-body); font-size: 0.9rem; resize: vertical;" placeholder="Paste your YouTube video description or transcript text here...">In this video, we show you how to build a gaming PC step by step for beginners. Building a gaming PC can be intimidating, but our complete gaming PC build guide breaks down every component you need. Learn how to choose the right CPU, GPU, motherboard, and RAM for your custom gaming PC. We cover budget gaming PC options as well as high-end gaming PC builds.</textarea>
          </div>

          <!-- Target Keyword Input -->
          <div class="form-group">
            <label for="target-keyword-input" class="icon-label">
              Target Keyword (Optional)
            </label>
            <input type="text" id="target-keyword-input" class="form-input" placeholder="e.g. gaming PC" value="gaming PC" />
          </div>

          <!-- Filter Controls -->
          <div style="display: flex; flex-direction: column; gap: 0.75rem; background: var(--color-bg-alt); padding: 0.75rem 1rem; border-radius: 12px; border: 1px solid var(--color-border);">
            <span style="font-size: 0.72rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Analysis Settings</span>
            
            <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.88rem;">
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="exclude-stopwords-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Exclude Common Stop Words (the, and, is, for, in)
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="min-length-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Ignore Words Under 3 Characters
              </label>
            </div>
          </div>

          <!-- Actions -->
          <div class="form-actions">
            <button type="button" id="analyze-btn" class="calc-btn">Analyze Density</button>
            <button type="button" id="reset-btn" class="calc-btn-secondary">Clear Text</button>
          </div>
        </div>
      </div>

      <!-- Right Column: Live Video Description Mockup Card -->
      <div class="calc-editor-column">
        <!-- Live YouTube Video Description Mockup -->
        <div class="youtube-desc-card glass" style="background: #0f0f0f; color: #ffffff; border-radius: 16px; overflow: hidden; max-width: 320px; margin: 0 auto; width: 100%; border: 1px solid #272727; text-align: left; box-shadow: var(--shadow-md); font-family: var(--font-body); padding: 1.25rem;">
          <!-- Top Header -->
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; border-bottom: 1px solid #272727; padding-bottom: 0.5rem;">
            <span style="font-size: 0.72rem; font-weight: 800; color: #ff0000; text-transform: uppercase; display: flex; align-items: center; gap: 4px;">
              📺 YouTube Description Preview
            </span>
            <span id="char-counter-tag" style="font-size: 0.68rem; background: #272727; color: #aaaaaa; padding: 2px 8px; border-radius: 10px; font-weight: 700;">
              342 / 5000 chars
            </span>
          </div>

          <!-- Description Text Preview with Target Highlight -->
          <div id="mockup-desc-text" style="font-size: 0.78rem; line-height: 1.5; color: #f1f1f1; max-height: 180px; overflow-y: auto; background: #181818; padding: 0.75rem; border-radius: 10px; border: 1px solid #272727;">
            In this video, we show you how to build a <mark style="background: rgba(99, 102, 241, 0.35); color: #6366f1; padding: 0 4px; border-radius: 3px; font-weight: 700;">gaming PC</mark> step by step for beginners. Building a <mark style="background: rgba(99, 102, 241, 0.35); color: #6366f1; padding: 0 4px; border-radius: 3px; font-weight: 700;">gaming PC</mark> can be intimidating, but our complete...
          </div>

          <!-- Target Keyword Status Footer -->
          <div style="margin-top: 0.75rem; background: #181818; border-radius: 8px; padding: 0.6rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.72rem;">
            <span style="color: #aaaaaa;">Target Density:</span>
            <span id="target-status-tag" style="font-weight: 800; color: #2ba640;">2.4% (Safe Zone ✓)</span>
          </div>
