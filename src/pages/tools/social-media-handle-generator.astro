<script>
  const setupSocialMediaHandleGenerator = () => {
    const seedInput = document.getElementById('seed-input') as HTMLInputElement;
    const platformSelect = document.getElementById('platform-select') as HTMLSelectElement;
    const vibeSelect = document.getElementById('vibe-select') as HTMLSelectElement;

    const underscoreCheck = document.getElementById('underscore-check') as HTMLInputElement;
    const periodCheck = document.getElementById('period-check') as HTMLInputElement;
    const numbersCheck = document.getElementById('numbers-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');
    const generateMoreBtn = document.getElementById('generate-more-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-handles-container');

    // Mockup targets
    const mockupHandleText = document.getElementById('mockup-handle-text');
    const mockupDisplayName = document.getElementById('mockup-display-name');
    const mockupPlatformTag = document.getElementById('mockup-platform-tag');
    const mockupAvatarBubble = document.getElementById('mockup-avatar-bubble');

    // Platform character limits
    const platformLimits: Record<string, number> = {
      universal: 15,
      twitter: 15,
      tiktok: 24,
      instagram: 30,
      youtube: 30
    };

    // Vibe Modifiers
    const vibeModifiers: Record<string, { prefixes: string[], suffixes: string[] }> = {
      clean: {
        prefixes: ['iam', 'the', 'real', 'hey', 'its', 'my'],
        suffixes: ['official', 'hq', 'studio', 'co', 'life', 'daily']
      },
      aesthetic: {
        prefixes: ['soft', 'lunar', 'velvet', 'vibe', 'aura', 'cloud'],
        suffixes: ['notes', 'vibes', 'realm', 'mood', 'space', 'journal']
      },
      official: {
        prefixes: ['official', 'the', 'real', 'meet', 'connect'],
        suffixes: ['official', 'verified', 'page', 'brand', 'media', 'network']
      },
      gaming: {
        prefixes: ['cyber', 'pixel', 'neo', 'shadow', 'hyper', 'apex'],
        suffixes: ['play', 'gaming', 'gg', 'zone', 'vault', 'quest']
      },
      short: {
        prefixes: ['go', 'be', 'im', 'mr', 'ms', 'dr'],
        suffixes: ['on', 'up', 'in', 'ex', 'io', 'ai']
      }
    };

    let currentShuffledPool: string[] = [];
    let currentPoolIndex = 0;

    const buildShuffledPool = () => {
      const seed = (seedInput?.value || '').toLowerCase().replace(/[^a-z0-9]/g, '') || 'alex';
      const platform = platformSelect?.value || 'universal';
      const vibe = vibeSelect?.value || 'clean';

      const allowUnderscore = underscoreCheck?.checked;
      const allowPeriod = periodCheck?.checked && (platform === 'instagram' || platform === 'youtube');
      const allowNumbers = numbersCheck?.checked;

      const maxLen = platformLimits[platform] || 15;
      const modifiers = vibeModifiers[vibe] || vibeModifiers['clean'];

      const generatedSet = new Set<string>();

      const formatHandle = (prefix: string, body: string, suffix: string) => {
        let sep = '';
        if (allowUnderscore) sep = '_';
        else if (allowPeriod) sep = '.';

        let numStr = '';
        if (allowNumbers) {
          numStr = Math.floor(Math.random() * 89 + 10).toString();
        }

        const choice = Math.floor(Math.random() * 4);
        let raw = '';

        if (choice === 0) raw = `${prefix}${sep}${body}`;
        else if (choice === 1) raw = `${body}${sep}${suffix}`;
        else if (choice === 2) raw = `${prefix}${sep}${body}${sep}${suffix}`;
        else raw = `${body}${numStr}`;

        // Ensure max length compliance
        let handle = raw.substring(0, maxLen);
        if (handle.endsWith('_') || handle.endsWith('.')) {
          handle = handle.slice(0, -1);
        }
        return `@${handle}`;
      };

      let iterations = 0;
      while (generatedSet.size < 50 && iterations < 300) {
        iterations++;
        const pIndex = Math.floor(Math.random() * modifiers.prefixes.length);
        const sIndex = Math.floor(Math.random() * modifiers.suffixes.length);

        const prefix = modifiers.prefixes[pIndex];
        const suffix = modifiers.suffixes[sIndex];

        const formatted = formatHandle(prefix, seed, suffix);
        if (formatted.length >= 4) {
          generatedSet.add(formatted);
        }
      }

      currentShuffledPool = Array.from(generatedSet).sort(() => Math.random() - 0.5);
      currentPoolIndex = 0;
    };

    const updateMockupAvatar = (seedName: string) => {
      if (!mockupAvatarBubble) return;
      const clean = seedName.replace(/[^a-zA-Z0-9]/g, '').trim();
      const initials = clean.substring(0, 2).toUpperCase();
      mockupAvatarBubble.textContent = initials || 'AL';
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledPool();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      const seedVal = (seedInput?.value || '').trim() || 'Alex';
      const platformVal = platformSelect?.value || 'universal';

      if (container) {
        container.innerHTML = selected.map(s => {
          return `
            <div class="title-chip" data-name="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy Handle</button>
            </div>
          `;
        }).join('');
      }

      resultsWrapper?.classList.remove('hidden');

      // Default mockup text
      if (mockupDisplayName) {
        mockupDisplayName.textContent = `${seedVal.charAt(0).toUpperCase() + seedVal.slice(1)} Creator`;
      }
      if (mockupPlatformTag) {
        mockupPlatformTag.textContent = platformVal.charAt(0).toUpperCase() + platformVal.slice(1);
      }
      if (mockupHandleText && selected.length > 0) {
        mockupHandleText.textContent = selected[0];
      }
      updateMockupAvatar(seedVal);
    };

    // Append 5 more unique handles
    const appendMoreTitles = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledPool();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledPool();
      }

      const next = currentShuffledPool.slice(currentPoolIndex, currentPoolIndex + 5);
      currentPoolIndex += 5;

      if (container) {
        const appendHtml = next.map(s => {
          return `
            <div class="title-chip" data-name="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy Handle</button>
            </div>
          `;
        }).join('');
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    generateMoreBtn?.addEventListener('click', () => {
      appendMoreTitles();
    });

    // Handle copying individual handle chips and update mockup preview
    container?.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest('.title-chip');
      if (!chip) return;

      const handleVal = chip.getAttribute('data-name') || '';

      // Update mockup sidebar
      if (mockupHandleText) {
        mockupHandleText.textContent = handleVal;
      }

      // Copy to clipboard
      navigator.clipboard.writeText(handleVal).then(() => {
        const btn = chip.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy Handle';
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener('click', () => {
      if (seedInput) seedInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-generate initial list
    generateList();
  };

  setupSocialMediaHandleGenerator();
  document.addEventListener('astro:after-swap', setupSocialMediaHandleGenerator);
</script>
