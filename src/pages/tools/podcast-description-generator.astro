</style>

<script>
  const setupPodcastDescriptionGenerator = () => {
    const showTitleInput = document.getElementById('show-title-input') as HTMLInputElement;
    const topicInput = document.getElementById('topic-input') as HTMLInputElement;
    const audienceInput = document.getElementById('audience-input') as HTMLInputElement;
    const toneSelect = document.getElementById('tone-select') as HTMLSelectElement;

    const timestampsCheck = document.getElementById('timestamps-check') as HTMLInputElement;
    const ctaCheck = document.getElementById('cta-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');
    const generateMoreBtn = document.getElementById('generate-more-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-descriptions-container');

    // Mockup targets
    const mockupShowHeader = document.getElementById('mockup-show-header');
    const mockupDescriptionBody = document.getElementById('mockup-description-body');

    // Templates database
    const templatesByTone: Record<string, string[]> = {
      conversational: [
        `Welcome back to {showTitle}! In this episode, we dive deep into {topic}. Whether you are a dedicated listener or joining us for the first time, this episode is packed with practical tips for {audience}. Tune in for an engaging breakdown!`,
        `Hey everyone! On today's episode of {showTitle}, we are talking all about {topic}. We break down the key strategies that every {audience} needs to know right now. Grab your coffee and press play!`,
        `What is the real story behind {topic}? On this episode of {showTitle}, we unwrap the facts and share actionable advice tailored for {audience}. Do not miss these insights!`
      ],
      professional: [
        `In this edition of {showTitle}, we examine the fundamentals of {topic}. Designed specifically for {audience}, this episode analyzes current industry trends, operational frameworks, and strategic insights.`,
        `Welcome to {showTitle}. Today's discussion focuses on {topic} and its impact on {audience}. Join us as we evaluate key metrics, best practices, and expert methodologies.`,
        `Strategic insights on {topic}: In this episode of {showTitle}, we deliver an authoritative breakdown tailored for {audience}. Learn how to optimize your approach today.`
      ],
      story: [
        `Behind every success lies a story. In this episode of {showTitle}, we explore the journey of {topic}. Discover how {audience} can overcome challenges and find breakthroughs.`,
        `Have you ever wondered what happens when you master {topic}? On today's episode of {showTitle}, we share compelling stories and lessons built for {audience}.`,
        `Uncovering the unexpected: On this episode of {showTitle}, we dive into the fascinating world of {topic}. A must-listen episode for curious {audience} everywhere.`
      ],
      energetic: [
        `Get ready! In this action-packed episode of {showTitle}, we are tackling {topic} at full speed! If you are part of {audience}, this episode is going to blow your mind!`,
        `Welcome to the ultimate episode of {showTitle}! Today we are leveling up your knowledge on {topic}. Perfect for ambitious {audience} ready to win!`,
        `Fire up your headphones! {showTitle} is back with an epic episode on {topic}. Tailored exclusively for driven {audience}!`
      ]
    };

    let currentShuffledPool: string[] = [];
    let currentPoolIndex = 0;

    const buildShuffledPool = () => {
      const showTitle = (showTitleInput?.value || '').trim() || 'The Tech Chronicles';
      const topic = (topicInput?.value || '').trim() || 'AI tools and automation strategies';
      const audience = (audienceInput?.value || '').trim() || 'creators & tech fans';
      const tone = toneSelect?.value || 'conversational';

      const includeTimestamps = timestampsCheck?.checked;
      const includeCta = ctaCheck?.checked;

      const baseTemplates = templatesByTone[tone] || templatesByTone['conversational'];
      const generatedSet = new Set<string>();

      const timestampsBlock = `\n\n📌 Episode Timestamps:\n00:00 - Introduction & Highlights\n04:15 - Deep Dive into ${topic}\n18:30 - Key Takeaways for ${audience}\n28:00 - Q&A and Wrap Up`;
      const ctaBlock = `\n\n⭐ Enjoying the show? Please leave us a 5-star review on Apple Podcasts and Spotify, and subscribe for weekly episodes!`;

      let iterations = 0;
      while (generatedSet.size < 40 && iterations < 200) {
        iterations++;
        const index = Math.floor(Math.random() * baseTemplates.length);
        let text = baseTemplates[index]
          .replace(/{showTitle}/g, showTitle)
          .replace(/{topic}/g, topic)
          .replace(/{audience}/g, audience);

        if (includeTimestamps) {
          text += timestampsBlock;
        }

        if (includeCta) {
          text += ctaBlock;
        }

        generatedSet.add(text);
      }

      currentShuffledPool = Array.from(generatedSet).sort(() => Math.random() - 0.5);
      currentPoolIndex = 0;
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledPool();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      const showTitleVal = (showTitleInput?.value || '').trim() || 'The Tech Chronicles';

      if (container) {
        container.innerHTML = selected.map(s => {
          return `
            <div class="description-card" data-text="${encodeURIComponent(s)}">
              <div class="description-text">${s}</div>
              <button class="chip-btn">Copy Show Notes</button>
            </div>
          `;
        }).join('');
      }

      resultsWrapper?.classList.remove('hidden');

      // Default mockup text
      if (mockupShowHeader) {
        mockupShowHeader.textContent = showTitleVal;
      }
      if (mockupDescriptionBody && selected.length > 0) {
        mockupDescriptionBody.textContent = selected[0];
      }
    };

    // Append 5 more unique items
    const appendMoreTitles = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledPool();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledPool();
      }

      const next = currentShuffledPool.slice(currentPoolIndex, currentPoolIndex + 5);
      currentPoolIndex += 5;

      if (container) {
        const appendHtml = next.map(s => {
          return `
            <div class="description-card" data-text="${encodeURIComponent(s)}">
              <div class="description-text">${s}</div>
              <button class="chip-btn">Copy Show Notes</button>
            </div>
          `;
        }).join('');
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    generateMoreBtn?.addEventListener('click', () => {
      appendMoreTitles();
    });

    // Handle copying individual description cards and update mockup preview
    container?.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.description-card');
      if (!card) return;

      const rawText = decodeURIComponent(card.getAttribute('data-text') || '');

      // Update mockup sidebar
      if (mockupDescriptionBody) {
        mockupDescriptionBody.textContent = rawText;
      }

      // Copy to clipboard
      navigator.clipboard.writeText(rawText).then(() => {
        const btn = card.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy Show Notes';
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener('click', () => {
      if (showTitleInput) showTitleInput.value = '';
      if (topicInput) topicInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-generate initial list
    generateList();
  };

  setupPodcastDescriptionGenerator();
  document.addEventListener('astro:after-swap', setupPodcastDescriptionGenerator);
</script>
