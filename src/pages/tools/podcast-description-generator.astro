---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is the recommended length for a podcast description?",
    answer: "For show-level descriptions, Apple Podcasts allows up to 4,000 characters, but keeping the main summary within the first 150 to 200 characters is critical. For individual episode descriptions, aim for 150 to 300 words including timestamps and links."
  },
  {
    question: "How do podcast descriptions impact audio SEO?",
    answer: "Spotify and Apple Podcasts index keywords in show descriptions and episode notes. Including relevant keywords like your topic, guest names, and niche concepts helps your podcast rank higher in directory search results."
  },
  {
    question: "What should I include in my episode show notes?",
    answer: "A great episode description includes a compelling 2-sentence hook summary, key takeaway bullet points, episode timestamps, links mentioned in the audio, and a call-to-action (CTA) encouraging subscribers to leave a review."
  },
  {
    question: "Can I use timestamps in my podcast episode descriptions?",
    answer: "Yes, adding timestamps (e.g. 02:15 - Introduction, 10:45 - Main Topic) helps listeners jump to specific topics and is supported on Apple Podcasts, Spotify, and YouTube Music."
  },
  {
    question: "Does this generator support both show descriptions and episode descriptions?",
    answer: "Yes, you can use this tool to write overarching channel/show summaries as well as individual episode show notes by adjusting your topic and tone inputs."
  }
];
---

<ToolLayout
  title="Podcast Description Generator - Show Notes & Summaries"
  description="Generate engaging, SEO-friendly podcast descriptions and episode show notes. Optimize channel summaries for Spotify and Apple Podcasts directories."
  toolName="Podcast Description Generator"
  toolDescription="Create search-optimized podcast show notes and channel descriptions. Customize tone, add timestamps, and preview live mobile episode cards."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Generator Inputs -->
      <div class="calc-form-column">
        <div class="calc-form">
          <!-- Show Title Input -->
          <div class="form-group">
            <label for="show-title-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
              </svg>
              Podcast Show Title
            </label>
            <input type="text" id="show-title-input" class="form-input" placeholder="e.g. The Tech Chronicles, Mindset Uncut" value="The Tech Chronicles" />
          </div>

          <!-- Topic / Episode Summary Input -->
          <div class="form-group">
            <label for="topic-input" class="icon-label">Topic or Episode Summary</label>
            <input type="text" id="topic-input" class="form-input" placeholder="e.g. AI tools and automation strategies" value="AI tools and automation strategies" />
          </div>

          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
            <!-- Target Audience Input -->
            <div class="form-group">
              <label for="audience-input" class="icon-label">Target Audience</label>
              <input type="text" id="audience-input" class="form-input" style="height: 48px;" placeholder="e.g. creators, developers" value="creators & tech fans" />
            </div>

            <!-- Tone Select -->
            <div class="form-group">
              <label for="tone-select" class="icon-label">Tone & Style</label>
              <select id="tone-select" class="form-input" style="height: 48px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0 12px; color: var(--color-text);">
                <option value="conversational">Engaging & Conversational</option>
                <option value="professional">Professional & Authoritative</option>
                <option value="story">Story-Driven & Intriguing</option>
                <option value="energetic">Energetic & Fun</option>
              </select>
            </div>
          </div>

          <!-- Formatting Checkboxes -->
          <div style="display: flex; flex-direction: column; gap: 0.75rem; background: var(--color-bg-alt); padding: 0.75rem 1rem; border-radius: 12px; border: 1px solid var(--color-border);">
            <span style="font-size: 0.72rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Show Notes Add-ons</span>
            
            <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.88rem;">
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="timestamps-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Include Episode Timestamps Placeholder
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="cta-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Include Subscribe & Review Call to Action (CTA)
              </label>
            </div>
          </div>

          <!-- Actions -->
          <div class="form-actions">
            <button type="button" id="generate-btn" class="calc-btn">Generate Descriptions</button>
            <button type="button" id="reset-btn" class="calc-btn-secondary">Reset Inputs</button>
          </div>
        </div>
      </div>

      <!-- Right Column: Live Mockup Card -->
      <div class="calc-editor-column">
        <!-- Live Apple Podcasts / Spotify Episode Card Mockup -->
        <div class="podcast-episode-card glass" style="background: #121212; color: #ffffff; border-radius: 16px; overflow: hidden; max-width: 320px; margin: 0 auto; width: 100%; border: 1px solid #282828; text-align: left; box-shadow: var(--shadow-md); font-family: var(--font-body); padding: 1.25rem;">
          <!-- Top Episode Info -->
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; border-bottom: 1px solid #282828; padding-bottom: 0.5rem;">
            <span style="font-size: 0.7rem; font-weight: 800; color: #1db954; text-transform: uppercase;">Ep. 42 • Live Preview</span>
            <span style="font-size: 0.68rem; color: #b3b3b3;">34 mins</span>
          </div>

          <!-- Show Title -->
          <span id="mockup-show-header" style="font-size: 0.78rem; font-weight: 700; color: #6366f1; display: block; margin-bottom: 4px;">
            The Tech Chronicles
          </span>

          <!-- Description text updating live -->
          <div id="mockup-description-body" style="font-size: 0.78rem; color: #e0e0e0; line-height: 1.45; max-height: 140px; overflow-y: auto; padding-right: 4px; font-family: var(--font-body);">
            Welcome to The Tech Chronicles! In this episode, we explore AI tools and automation strategies. Tune in for actionable tips designed for creators & tech fans.
          </div>
        </div>
      </div>
    </div>

    <!-- Generated Results Section -->
    <div id="results-wrapper" class="hidden" style="margin-top: 2rem; border-top: 1px dashed var(--color-border); padding-top: 1.5rem;">
      <h3 style="font-size: 1.05rem; font-weight: 800; text-transform: uppercase; color: var(--color-text); margin: 0 0 1rem 0; display: flex; align-items: center; gap: 0.5rem;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 20px; height: 20px; color: var(--color-brand);">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
        </svg>
        Suggested Podcast Descriptions
      </h3>

      <div class="usernames-grid" id="generated-descriptions-container">
        <!-- Results dynamic content goes here -->
      </div>

      <div style="display: flex; justify-content: center; margin-top: 1.5rem;">
        <button type="button" id="generate-more-btn" class="calc-btn" style="max-width: 200px; padding: 0 1.5rem;">Generate More</button>
      </div>
    </div>
  </div>

  <div slot="about" class="editorial-content">
    <h2>Podcast Description Generator: Write Search-Optimized Show Notes</h2>
    <div style="margin: 1.5rem 0; background: var(--color-bg-alt); padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); border-left: 4px solid var(--color-brand);">
      <p style="margin: 0; font-weight: 600; font-size: 0.95rem; line-height: 1.5;">
        🎙️ <strong>Looking to generate catchy podcast show titles?</strong> Use our free <a href="/tools/podcast-name-generator" style="color: var(--color-brand); text-decoration: underline;">Podcast Name Generator</a> to craft high-recall show titles for Apple Podcasts and Spotify.
      </p>
    </div>

    <h3>Introduction</h3>
    <p>
      In the competitive audio landscape, your podcast description serves as the ultimate pitch to potential listeners. When users search Apple Podcasts, Spotify, or Google Podcasts, your show summary is what convinces them to press play. Structuring clear, keyword-rich show notes is vital for driving audio discoverability and turning casual listeners into loyal subscribers. Our free <strong>podcast description generator</strong> helps creators craft engaging, search-optimized episode notes and channel summaries in seconds.
    </p>

    <h3>How to Use This Tool</h3>
    <p>
      To write and audit custom podcast descriptions in real-time, follow these simple directions:
    </p>
    <ol>
      <li><strong>Podcast Show Title:</strong> Enter your official show or channel title.</li>
      <li><strong>Topic / Summary:</strong> Enter the primary episode subject or key discussion points.</li>
      <li><strong>Target Audience:</strong> Define your primary audience (e.g. creators, tech enthusiasts).</li>
      <li><strong>Tone & Style:</strong> Select a writing voice (Conversational, Professional, Story-Driven, or Energetic).</li>
      <li><strong>Show Notes Add-ons:</strong> Select toggles to include timestamps or call-to-action (CTA) text.</li>
      <li><strong>Generate List:</strong> Click <strong>Generate Descriptions</strong> to view 15 custom options.</li>
      <li><strong>Preview & Copy:</strong> Click any description card to preview it inside the Apple Podcasts & Spotify episode mockup, and copy it instantly. Click <strong>Generate More</strong> to append 5 more options.</li>
    </ol>

    <h3>What is Podcast Description</h3>
    <p>
      A <strong>podcast description</strong> (or show notes summary) is the text overview attached to your podcast RSS feed. It gives prospective listeners an overview of your channel or episode, highlighting key topics, guest bios, and resource links. Writing compelling <strong>podcast descriptions</strong> involves placing your main value proposition in the first two sentences, as directory feeds crop long text blocks. If you also run an email broadcast, you can craft matching subject lines using our <a href="/tools/newsletter-title-generator">Newsletter Title Generator</a>.
    </p>

    <h3>How Does It Work?</h3>
    <p>
      The generator processes your episode details through structured audio SEO frameworks:
    </p>
    <ul>
      <li><strong>Hook Generation:</strong> Creates an immediate summary sentence highlighting your primary topic and audience benefit.</li>
      <li><strong>Tone Alignment:</strong> Formats the language to match conversational, authoritative, or energetic styles.</li>
      <li><strong>Formatting Add-ons:</strong> Automatically appends structured timestamp placeholders (e.g. `00:00 - Intro`) and rating call-to-action text.</li>
    </ul>

    <h3>How To Use</h3>
    <p>
      Using our generator is easy. Simply fill out your show title, episode topic, and target audience, pick your desired tone style, and click generate. Clicking any description updates the live card mockup, allowing you to preview how your show notes look on mobile player feeds before copying. If you publish video podcasts on YouTube, you can also verify your video title lengths with our <a href="/tools/youtube-title-length-checker">YouTube Title Length Checker</a>.
    </p>

    <h3>Who Should Use This Tool?</h3>
    <p>
      This generator is designed for:
    </p>
    <ul>
      <li><strong>Indie Podcasters:</strong> Saving time on weekly show notes writing while maintaining consistent quality.</li>
      <li><strong>Podcast Producers & Editors:</strong> Writing optimized episode descriptions for client RSS feeds across Spotify and Apple Podcasts.</li>
      <li><strong>Content Creators:</strong> Repurposing audio recordings into structured episode summaries and show notes.</li>
    </ul>
  </div>
</ToolLayout>

<style>
  /* Base Layout Config */
  .calc-card {
    padding: 2.25rem !important;
    border-radius: 24px !important;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .calc-form-column, .calc-editor-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
  }

  .calc-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .form-input {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
  }

  .icon-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .field-icon {
    width: 18px;
    height: 18px;
    color: var(--color-brand);
    flex-shrink: 0;
  }

  .form-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .calc-btn-secondary {
    height: 48px;
    background: transparent;
    border: 1.5px solid var(--color-border);
    color: var(--color-text);
