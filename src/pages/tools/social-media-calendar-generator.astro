---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is a social media content calendar?",
    answer: "A social media content calendar is a schedule of your upcoming posts, organized by date, platform, format, and content category. It helps creators maintain posting consistency and align content with marketing goals."
  },
  {
    question: "How far in advance should I plan my social media calendar?",
    answer: "Most creators and brands plan their calendars 2 to 4 weeks in advance. This provides enough time to write captions, design graphics, shoot video footage, and schedule posts without last-minute stress."
  },
  {
    question: "Can I customize the generated content ideas?",
    answer: "Yes. By clicking on any calendar day cell, the content idea automatically loads into the active Sandbox editor. You can refine the prompt, add hashtags, insert emojis, and copy the customized caption."
  },
  {
    question: "How do I export the generated calendar to Excel or Notion?",
    answer: "Click the 'Export Calendar' button at the bottom of the suggestions box. This copies a structured list (CSV format) of your 14-day content plan to your clipboard, which you can paste directly into Notion, Excel, or Google Sheets."
  },
  {
    question: "Is this social media planner free to use?",
    answer: "Yes, our calendar generator is 100% free, runs locally in your browser, and requires no registration or account sign-up."
  }
];
---

<ToolLayout
  title="Social Media Calendar Generator - Free Content Planner"
  description="Generate custom 14-day social media content calendars. Plan posts for Instagram, TikTok, LinkedIn, YouTube, and Twitter with free templates."
  toolName="Social Media Calendar Generator"
  toolDescription="Generate a custom 14-day content planning calendar based on your niche and frequency. Plan video hooks, caption ideas, and platform schedules instantly."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Settings and Input Forms -->
      <div class="calc-form-column">
        <form class="calc-form" id="generator-form" onsubmit="return false;">
          <!-- Topic/Niche -->
          <div class="form-group">
            <label for="value-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
              </svg>
              What is your content niche / topic?
            </label>
            <input type="text" id="value-input" class="form-input" placeholder="e.g. digital marketing, baking tips, coding tutorials" value="baking tips" required />
          </div>

          <!-- Platforms Selection (Checkboxes) -->
          <div class="form-group" style="gap: 0.75rem;">
            <label class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              Target Platforms
            </label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; padding-left: 0.25rem;">
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; font-weight: 600; color: var(--color-text); cursor: pointer;">
                <input type="checkbox" class="platform-check" value="Instagram" checked style="accent-color: var(--color-brand);" /> Instagram
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; font-weight: 600; color: var(--color-text); cursor: pointer;">
                <input type="checkbox" class="platform-check" value="TikTok" checked style="accent-color: var(--color-brand);" /> TikTok
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; font-weight: 600; color: var(--color-text); cursor: pointer;">
                <input type="checkbox" class="platform-check" value="YouTube" checked style="accent-color: var(--color-brand);" /> YouTube
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; font-weight: 600; color: var(--color-text); cursor: pointer;">
                <input type="checkbox" class="platform-check" value="LinkedIn" style="accent-color: var(--color-brand);" /> LinkedIn
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; font-weight: 600; color: var(--color-text); cursor: pointer;">
                <input type="checkbox" class="platform-check" value="Twitter" style="accent-color: var(--color-brand);" /> Twitter/X
              </label>
            </div>
          </div>

          <!-- Posting Frequency -->
          <div class="form-group">
            <label for="frequency-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              Weekly Posting Frequency
            </label>
            <select id="frequency-input" class="form-input" style="height: 48px; border-radius: 8px;">
              <option value="2">2 Posts per Week (Alternating)</option>
              <option value="3" selected>3 Posts per Week (Standard)</option>
              <option value="7">7 Posts per Week (Daily Action)</option>
            </select>
          </div>

          <!-- Start Date -->
          <div class="form-group">
            <label for="date-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
              Calendar Start Date
            </label>
            <input type="date" id="date-input" class="form-input" style="height: 48px;" value="2026-07-12" />
          </div>

          <div class="form-actions">
            <button type="button" id="generate-btn" class="calc-btn" style="width: 100%;">Generate Calendar</button>
            <button type="button" id="calc-reset-btn" class="calc-btn-secondary" style="width: 100%;">Reset Fields</button>
          </div>
        </form>
      </div>

      <!-- Right Column: Interactive 14-Day Calendar & Active Sandbox Editor -->
      <div class="calc-editor-column">
        <!-- Interactive 14-Day Calendar Grid Preview -->
        <div class="calendar-preview glass" style="border: 1.5px solid var(--color-border); border-radius: 20px; padding: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; background: var(--color-bg-alt);">
          <span style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; border-bottom: 1px dashed var(--color-border); padding-bottom: 0.35rem; display: block; text-align: left;">Interactive 14-Day Content Grid (Click Day to Load)</span>
          
          <div id="calendar-grid-container" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; max-height: 250px; overflow-y: auto; padding-right: 0.25rem;">
            <!-- Generated day cards will inject here -->
            <div class="day-card active" style="background: var(--color-bg); border: 1.5px solid var(--color-brand); border-radius: 8px; padding: 0.5rem; text-align: left; cursor: pointer; transition: all var(--transition-fast);">
              <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.7rem; font-weight: 700; color: var(--color-text-muted); margin-bottom: 0.25rem;">
                <span>Day 1 (Jul 12)</span>
                <span style="background: var(--color-brand); color: white; padding: 1px 4px; border-radius: 3px; font-size: 0.6rem;">Instagram</span>
              </div>
              <p style="margin: 0; font-size: 0.78rem; font-weight: 600; color: var(--color-text); line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">Behind-the-scenes baking workflow</p>
            </div>
            <!-- Additional sample cards -->
          </div>
        </div>

        <!-- Sandbox Active Workspace Editor -->
        <div class="sandbox-box glass">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
            <span style="font-size: 0.75rem; font-weight: 700; color: var(--color-text); text-transform: uppercase;">Active Idea Sandbox</span>
            <span id="sandbox-counter" style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted);">92 / 500 Chars</span>
          </div>
          
          <textarea id="sandbox-input" class="form-input" style="height: 90px; resize: none; line-height: 1.4; font-size: 0.92rem; font-family: inherit;" placeholder="Click a calendar day above to load its template..."></textarea>

          <!-- Visual character progress bar -->
          <div class="progress-bar-container" style="background: var(--color-border); height: 6px; border-radius: 4px; overflow: hidden; margin: 0.5rem 0;">
            <div id="progress-bar-fill" style="width: 18.4%; height: 100%; background: var(--color-brand); transition: all var(--transition-fast);"></div>
          </div>

          <!-- Quick Emoji Panel -->
          <div style="display: flex; flex-direction: column; gap: 0.25rem; margin-top: 0.5rem;">
            <span style="font-size: 0.65rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Insert Emoji:</span>
            <div class="emoji-selector-panel" id="emoji-picker-container">
              <button type="button" class="emoji-btn">📅</button>
              <button type="button" class="emoji-btn">✍️</button>
              <button type="button" class="emoji-btn">🚀</button>
              <button type="button" class="emoji-btn">💡</button>
              <button type="button" class="emoji-btn">🔥</button>
              <button type="button" class="emoji-btn">👏</button>
              <button type="button" class="emoji-btn">💯</button>
              <button type="button" class="emoji-btn">👀</button>
              <button type="button" class="emoji-btn">👇</button>
              <button type="button" class="emoji-btn">👍</button>
            </div>
          </div>

          <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
            <button type="button" id="copy-active-btn" class="calc-btn" style="flex: 1.2; height: 42px; font-size: 0.85rem;">Copy Day Idea</button>
            <button type="button" id="clear-sandbox-btn" class="calc-btn-secondary" style="flex: 0.8; height: 42px; font-size: 0.85rem;">Clear</button>
          </div>
        </div>

        <!-- Suggestions Drawer Panel (with export action) -->
        <div class="suggestions-drawer" id="suggestions-box" style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
          <h4 style="margin: 0; font-size: 0.9rem; font-weight: 700; color: var(--color-text); text-transform: uppercase; border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem;">Spreadsheet Export Area</h4>
          
          <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            <div class="option-card" style="padding: 0.75rem;">
              <p style="margin: 0; font-size: 0.78rem; font-weight: 600; color: var(--color-text-muted); line-height: 1.4;">
                You can copy the entire 14-day Content Calendar schedule in CSV format below, perfect for dropping into Excel, Google Sheets, or Notion database calendars.
              </p>
            </div>
            <button type="button" id="export-calendar-btn" class="calc-btn" style="height: 40px; font-size: 0.85rem; background: var(--gradient-brand);">Export Calendar (Copy CSV)</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="editorial-content">
    <h2>Social Media Calendar Generator: Organize Your Content Planner Niche</h2>
    <div style="margin: 1.5rem 0; background: var(--color-bg-alt); padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); border-left: 4px solid var(--color-brand);">
      <p style="margin: 0; font-weight: 600; font-size: 0.95rem;">
        📅 <strong>Looking to structure a consistent posting routine?</strong> Read our comprehensive strategy guide on <a href="/blog/social-media-calendar-generator-guide" style="color: var(--color-brand); text-decoration: underline;">Social Media Content Calendars & Planning Strategy</a> to learn how to audit engagement, balance video formats, and schedule content ahead.
      </p>
    </div>

    <h3>Introduction</h3>
    <p>
      Consistency is the absolute key to building a successful channel and growing your audience. However, deciding what to post every day can feel overwhelming. This free <strong>social media calendar generator</strong> creates a structured 14-day schedule of post prompts, platform distribution badges, and format suggestions, allowing you to plan campaigns effortlessly.
    </p>

    <h3>How to Use This Tool</h3>
    <p>
      To build your custom planner, follow these instructions:
    </p>
    <ol>
      <li><strong>Define Topic Niche:</strong> Input your target category or industry (e.g. "baking tips", "finance advice").</li>
      <li><strong>Select Platforms:</strong> Check the boxes for the social networks where you want to post.</li>
      <li><strong>Define Frequency:</strong> Select whether you want to post 2 times a week, 3 times a week, or daily.</li>
      <li><strong>Generate Plan:</strong> Click <strong>Generate Calendar</strong> to build the 14-day content grid.</li>
      <li><strong>Refine & Export:</strong> Click individual days to edit prompts in the Active Sandbox, add emojis, and export the entire CSV list.</li>
    </ol>

    <h3>What is Instagram line Break Generator? (Social Media Calendar Generator)</h3>
    <p>
      Note: If you were searching for paragraph spacer formatting tools, check out our <a href="/tools/instagram-line-break-generator" style="color: var(--color-brand); text-decoration: underline;">Instagram Line Break Generator</a>. A <strong>social media calendar generator</strong>, however, is a digital content planner. It maps out post schedules, identifies high-performing formats, and schedules consistent outreach loops across channels.
    </p>

    <h3>How Does It Work?</h3>
    <p>
      The calendar generator uses a structured sequencing database to distribute ideas:
    </p>
    <ul>
      <li><strong>Date calculation:</strong> Steps forward day-by-day from your chosen start date, assigning posts according to your frequency.</li>
      <li><strong>Platform rotation:</strong> Loops through your checked platforms to maintain a balanced channel presence.</li>
      <li><strong>Category scheduling:</strong> Distributes content formats (e.g. Reels/Shorts, Carousels, text posts) and theme types (Educational, Behind-the-scenes, Promotional).</li>
    </ul>

    <h3>Example Calculation</h3>
    <p>
      Let's look at how the tool budgets a 3 post-per-week content schedule:
    </p>
    <p>
      <strong>Selected Inputs:</strong><br />
      ✦ Niche: "baking tips"<br />
      ✦ Platforms: Instagram, YouTube, TikTok<br />
      ✦ Frequency: 3 posts per week (14-day budget = 6 posts total)
    </p>
    <p>
      <strong>Tool Allocation Output:</strong><br />
      ✦ Post 1 (Day 1 - Jul 12): Instagram Reel $\rightarrow$ "Showcase a behind-the-scenes baking workflow"<br />
      ✦ Post 2 (Day 3 - Jul 14): TikTok Video $\rightarrow$ "Quick 15-second recipe tutorial"<br />
      ✦ Post 3 (Day 5 - Jul 16): YouTube Short $\rightarrow$ "Highlight a common ingredient mistake"<br />
      ✦ Post 4 (Day 8 - Jul 19): Instagram Post $\rightarrow$ "Share a high-value ingredient measurement chart"<br />
      ✦ Post 5 (Day 10 - Jul 21): TikTok Video $\rightarrow$ "Review your favorite baking equipment tools"<br />
      ✦ Post 6 (Day 12 - Jul 23): YouTube Short $\rightarrow$ "Baking questions Q&A session"
    </p>
    <p>
      This sequence distributes the workload evenly across the 14 days, providing a balanced, multi-platform presence.
    </p>

    <h3>Who Should Use This Tool?</h3>
    <p>
      This <strong>free social media planner</strong> is designed for:
    </p>
    <ul>
      <li><strong>Content Creators:</strong> Organizing multi-platform schedules ahead of shoot days.</li>
      <li><strong>Social Media Consultants:</strong> Drafting content calendars for clients.</li>
      <li><strong>E-commerce Brands:</strong> Aligning product promotions with education calendars.</li>
      <li><strong>Bloggers & Writers:</strong> Structuring article promotions on social channels.</li>
    </ul>
  </div>
</ToolLayout>

<style>
  /* Base Layout Config */
  .calc-card {
    padding: 2.25rem !important;
    border-radius: 24px !important;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    box-sizing: border-box !important;
