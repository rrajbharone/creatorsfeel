<script>
  interface PostIdea {
    day: number;
    dateStr: string;
    platform: string;
    idea: string;
  }

  const setupSocialMediaCalendarGenerator = () => {
    const valueInput = document.getElementById('value-input') as HTMLInputElement;
    const frequencySelect = document.getElementById('frequency-input') as HTMLSelectElement;
    const dateInput = document.getElementById('date-input') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // Calendar grid
    const calendarGrid = document.getElementById('calendar-grid-container');

    // Sandbox workspace
    const sandboxInput = document.getElementById('sandbox-input') as HTMLTextAreaElement;
    const sandboxCounter = document.getElementById('sandbox-counter');
    const progressBarFill = document.getElementById('progress-bar-fill');
    const copyActiveBtn = document.getElementById('copy-active-btn');
    const clearSandboxBtn = document.getElementById('clear-sandbox-btn');
    const exportBtn = document.getElementById('export-calendar-btn');

    // Calendar generated memory store
    let generatedPosts: PostIdea[] = [];

    // Helper dates formatting
    const formatDate = (date: Date): string => {
      const options: Intl.DateTimeFormatOptions = { month: 'short', day: 'numeric' };
      return date.toLocaleDateString('en-US', options);
    };

    // Live Sandbox update
    const updateSandbox = () => {
      const text = sandboxInput?.value || '';
      const len = text.length;

      // Update counters
      if (sandboxCounter) {
        sandboxCounter.textContent = `${len} / 500`;
      }

      // Update progress bar
      if (progressBarFill) {
        const percent = Math.min((len / 500) * 100, 100);
        progressBarFill.style.width = `${percent}%`;
        progressBarFill.style.backgroundColor = len > 500 ? '#ef4444' : 'var(--color-brand)';
      }
    };
    sandboxInput?.addEventListener('input', updateSandbox);

    // Active card highlight loader
    const selectDay = (idx: number) => {
      document.querySelectorAll('.day-card').forEach((card, cIdx) => {
        if (cIdx === idx) {
          card.classList.add('active');
        } else {
          card.classList.remove('active');
        }
      });

      const post = generatedPosts[idx];
      if (post && sandboxInput) {
        sandboxInput.value = `📅 Date: ${post.dateStr}\n📱 Platform: ${post.platform}\n💡 Idea: ${post.idea}`;
        updateSandbox();
      }
    };

    // Dynamic generation
    const generateCalendar = () => {
      const niche = (valueInput?.value || '').trim();
      const frequency = parseInt(frequencySelect?.value || '3', 10);
      const startDateVal = dateInput?.value || '2026-07-12';

      if (!niche) {
        alert("Please enter your niche/topic.");
        return;
      }

      // Get platforms list from checked elements
      const platformChecks = document.querySelectorAll('.platform-check:checked');
      const platforms = Array.from(platformChecks).map(el => (el as HTMLInputElement).value);
      if (platforms.length === 0) {
        alert("Please select at least one target platform.");
        return;
      }

      // Predefined prompt template pool matching niches
      const ideaPool = [
        `Behind-the-scenes workflow sharing key tools used in ${niche}`,
        `Step-by-step tutorial sharing a top secret tip for ${niche}`,
        `Highlighting a very common beginner mistake in ${niche} & how to avoid it`,
        `Q&A session: Answering your most asked questions about ${niche}`,
        `Myth-busting: Deconstructing a common misconception about ${niche}`,
        `Before vs After case study showing progression in ${niche}`,
        `Share a high-value resource list or cheatsheet for ${niche}`,
        `Showcasing your favorite tools/equipment you use daily for ${niche}`,
        `Interactive challenge: Ask your audience to share their thoughts on ${niche}`,
        `A quick motivation tip or success quote related to ${niche}`
      ];

      // Build 14-Day Calendar Schedule
      const startDate = new Date(startDateVal);
      generatedPosts = [];
      
      // Clear container
      if (calendarGrid) calendarGrid.innerHTML = '';

      let postCount = 0;
      let platformIdx = 0;
      let ideaIdx = 0;

      // Posting days based on frequency (frequency: 2 -> posts on Day 1, 4, 8, 11 etc. frequency: 3 -> posts on 1, 3, 5, 8, 10, 12. frequency: 7 -> daily)
      let activeDays: Set<number> = new Set();
      if (frequency === 2) {
        activeDays = new Set([0, 3, 7, 10]);
      } else if (frequency === 3) {
        activeDays = new Set([0, 2, 4, 7, 9, 11]);
      } else {
        activeDays = new Set(Array.from({ length: 14 }, (_, i) => i));
      }

      for (let i = 0; i < 14; i++) {
        const currentDate = new Date(startDate);
        currentDate.setDate(startDate.getDate() + i);

        if (activeDays.has(i)) {
          const platform = platforms[platformIdx % platforms.length];
          const idea = ideaPool[ideaIdx % ideaPool.length];
          const dateStr = formatDate(currentDate);

          generatedPosts.push({
            day: i + 1,
            dateStr,
            platform,
            idea
          });

          // Build Card DOM element
          const cardIndex = generatedPosts.length - 1;
          const dayCard = document.createElement('div');
          dayCard.className = `day-card ${cardIndex === 0 ? 'active' : ''}`;
          dayCard.setAttribute('style', 'background: var(--color-bg); border: 1.5px solid var(--color-border); border-radius: 10px; padding: 0.75rem; text-align: left; cursor: pointer; transition: all var(--transition-fast);');
          
          dayCard.innerHTML = `
            <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.7rem; font-weight: 700; color: var(--color-text-muted); margin-bottom: 0.25rem;">
              <span>Day ${i + 1} (${dateStr})</span>
              <span style="background: var(--color-brand); color: white; padding: 1px 6px; border-radius: 3px; font-size: 0.58rem; font-weight: 700; text-transform: uppercase;">${platform}</span>
            </div>
            <p style="margin: 0; font-size: 0.78rem; font-weight: 600; color: var(--color-text); line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${idea}</p>
          `;

          dayCard.addEventListener('click', () => selectDay(cardIndex));
          if (calendarGrid) calendarGrid.appendChild(dayCard);

          platformIdx++;
          ideaIdx++;
        }
      }

      // Initialize Sandbox with Day 1
      if (generatedPosts.length > 0) {
        selectDay(0);
      }

      // Scroll directly to the results / editor sandbox column
      const editorCol = document.querySelector('.calc-editor-column');
      if (editorCol) {
        editorCol.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    generateBtn?.addEventListener('click', generateCalendar);

    // Emoji click inserter
    const emojiContainer = document.getElementById('emoji-picker-container');
    emojiContainer?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.emoji-btn');
      if (!btn || !sandboxInput) return;
      
      const emoji = btn.textContent || '';
      const start = sandboxInput.selectionStart;
      const end = sandboxInput.selectionEnd;
      const val = sandboxInput.value;

      sandboxInput.value = val.substring(0, start) + emoji + val.substring(end);
      sandboxInput.selectionStart = sandboxInput.selectionEnd = start + emoji.length;
      sandboxInput.focus();
      updateSandbox();
    });

    // Sandbox Copy
    copyActiveBtn?.addEventListener('click', () => {
      const text = sandboxInput?.value || '';
      if (!text) return alert("Sandbox editor is empty!");
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyActiveBtn.textContent;
        copyActiveBtn.textContent = 'Copied to Clipboard! ✓';
        setTimeout(() => {
          copyActiveBtn.textContent = originalText;
        }, 1500);
      });
    });

    // CSV Planner Exporter
    exportBtn?.addEventListener('click', () => {
      if (generatedPosts.length === 0) return alert("Please generate a calendar first.");

      // Construct clean structured CSV text
      let csv = 'Day,Date,Platform,Content Prompt Idea\n';
      generatedPosts.forEach(post => {
        const sanitizedIdea = post.idea.replace(/"/g, '""');
        csv += `${post.day},"${post.dateStr}","${post.platform}","${sanitizedIdea}"\n`;
      });

      navigator.clipboard.writeText(csv).then(() => {
        const originalText = exportBtn.textContent;
        exportBtn.textContent = 'CSV Copied to Clipboard! ✓';
        setTimeout(() => {
          exportBtn.textContent = originalText;
        }, 1800);
      });
    });

    // Clear Sandbox
    clearSandboxBtn?.addEventListener('click', () => {
      if (sandboxInput) {
        sandboxInput.value = '';
        updateSandbox();
      }
    });

    // Reset Fields
    resetBtn?.addEventListener('click', () => {
      if (valueInput) valueInput.value = '';
      if (sandboxInput) sandboxInput.value = '';
      updateSandbox();
    });

    // Initialize date input default to today
    const today = new Date().toISOString().split('T')[0];
    if (dateInput) dateInput.value = today;

    // Run first sample generate
    generateCalendar();
  };

  setupSocialMediaCalendarGenerator();
  document.addEventListener('astro:after-swap', setupSocialMediaCalendarGenerator);
</script>
