---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is an Instagram Money Calculator?",
    answer: "An Instagram Money Calculator is an online tool that estimates how much money a creator can charge for sponsored posts, Stories, and Reels. It uses followers, average engagement rates, and industry niche multipliers to calculate realistic rate sheets."
  },
  {
    question: "How does engagement rate affect sponsored post rates?",
    answer: "Brands pay for attention and actions, not just follower counts. A creator with a high engagement rate (e.g. 5%+) can charge a premium because their followers are active, which translates to higher conversion rates for the brand."
  },
  {
    question: "Why do some niches pay more than others?",
    answer: "Niches like Finance, Tech, and Luxury Beauty target high-value consumers. Brands in these sectors have larger margins and customer lifetime values, allowing them to pay creators higher sponsorships compared to generalized niches like memes."
  },
  {
    question: "How do I calculate my engagement rate?",
    answer: "To calculate your engagement rate, sum the total likes and comments on your last 10 to 15 posts, divide that by the number of posts to get your average, then divide that average by your total follower count and multiply by 100."
  }
];
---

<ToolLayout
  title="Instagram Money Calculator - Sponsored Post Rate Estimator"
  description="Calculate your Instagram account value and sponsored post rates. Free online Instagram followers money calculator with niche and engagement multipliers."
  toolName="Instagram Money Calculator"
  toolDescription="Estimate your Instagram sponsorship earnings. Input your followers, engagement rate, and niche to generate realistic rates for posts, Stories, and Reels."
  category="Calculators"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <div class="calc-grid" id="calc-form-container">
      <!-- Input fields -->
      <form class="calc-form" id="instagram-money-form" onsubmit="return false;">
        <div class="form-row-2">
          <div class="form-group">
            <div class="label-header">
              <label for="follower-count" class="icon-label">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
                Follower Count
              </label>
            </div>
            <input type="number" id="follower-count" class="form-input" placeholder="e.g., 25000" min="100" step="1" required />
          </div>

          <div class="form-group">
            <div class="label-header">
              <label for="engagement-rate" class="icon-label">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.34 18.062 18 21m-2.66-2.938a7.478 7.478 0 0 0 1.256-4.242A7.472 7.472 0 0 0 9 6.25a7.472 7.472 0 0 0-7.592 7.57 7.461 7.461 0 0 0 1.256 4.242L0 21m15.34-2.938A7.476 7.476 0 0 0 16.5 13.75c0-4.14-3.36-7.5-7.5-7.5h-.012c-4.137 0-7.488 3.353-7.488 7.47a7.473 7.473 0 0 0 1.156 3.968l1.455-1.597a5.525 5.525 0 0 1-.611-2.371c0-3.053 2.477-5.529 5.525-5.529h.012c3.048 0 5.525 2.476 5.525 5.53a5.523 5.523 0 0 1-.611 2.37l1.455 1.598Z" />
                </svg>
                Engagement Rate (%)
              </label>
            </div>
            <input type="number" id="engagement-rate" class="form-input" placeholder="e.g., 3.5" min="0.1" max="100" step="0.01" value="3.0" required />
          </div>
        </div>

        <div class="form-group">
          <div class="label-header">
            <label for="niche-multiplier" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a1.125 1.125 0 0 0 1.591 0l4.318-4.318a1.125 1.125 0 0 0 0-1.591L9.568 3.659A2.25 2.25 0 0 0 7.977 3Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 7.5h.008v.008H6V7.5Z" />
              </svg>
              Account Niche Category
            </label>
          </div>
          <select id="niche-multiplier" class="form-input">
            <option value="1.6">Business, Finance & Tech (1.6x)</option>
            <option value="1.3">Beauty, Luxury & Fashion (1.3x)</option>
            <option value="1.2">Food, Cooking & Travel (1.2x)</option>
            <option value="1.1" selected>Lifestyle, Fitness & Health (1.1x)</option>
            <option value="0.6">Memes, Humor & Fan Pages (0.6x)</option>
            <option value="1.0">General / Other (1.0x)</option>
          </select>
        </div>

        <div class="form-actions">
          <button type="button" id="calc-submit-btn" class="calc-btn" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            Calculate Sponsored Rates
          </button>
          <button type="button" id="calc-reset-btn" class="calc-btn-secondary" style="width: 100%;">Reset Form</button>
        </div>
      </form>

      <!-- Outputs Display -->
      <div class="calc-results" id="results-wrapper">
        <div class="empty-state text-center" id="res-empty-box">
          <svg class="empty-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <h3>Awaiting Account Metrics</h3>
          <p class="text-muted">Enter your follower count and engagement statistics to calculate your rate sheet benchmarks.</p>
        </div>

        <div class="results-active hidden" id="res-active-box">
          <div class="rate-range-box">
            <h4 class="rate-label">Est. Sponsored Post Rate</h4>
            <div class="rate-range" id="res-post-val">$0.00</div>
            <div class="grade-badge grade-low" id="res-range-val">$0 - $0 range</div>
          </div>

          <div class="breakdown-box">
            <h4 class="breakdown-title">Estimated Sponsorship Rates</h4>
            <div class="breakdown-list">
              <div class="breakdown-item">
                <span class="breakdown-label">Instagram Reel Rate:</span>
                <span class="breakdown-val" id="res-reel-val">-</span>
              </div>
              <div class="breakdown-item">
                <span class="breakdown-label">Instagram Story Rate:</span>
                <span class="breakdown-val" id="res-story-val">-</span>
              </div>
              <div class="breakdown-item">
                <span class="breakdown-label">Projected Yearly Income:</span>
                <span class="breakdown-val" id="res-yearly-val" style="color: var(--color-brand); font-weight: 700;">-</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="editorial-content">
    <h2>Guide: How to Use the Instagram Money Calculator</h2>
    <p>
      Sponsorship pricing is a challenge for digital creators. If you want to know <strong>how much money can i make on instagram calculator</strong>, this tool provides a clear estimation. By evaluating followers, engagement metrics, and niche categories, it builds a data-backed starting benchmark for negotiating sponsored placements.
    </p>

    <div class="step-guide">
      <div class="step-item">
        <h3>Step 1: Enter Follower Count</h3>
        <p>Type your current follower count in the field. This establishes the baseline reach of your account (using a CPM-based calculation).</p>
      </div>

      <div class="step-item">
        <h3>Step 2: Input Average Engagement Rate</h3>
        <p>Input your engagement percentage. The <strong>instagram followers money calculator</strong> scales rates up if your community is active, adding a premium for high engagement rates.</p>
      </div>

      <div class="step-item">
        <h3>Step 3: Select Account Niche</h3>
        <p>Pick your primary content niche. Advertisers pay premiums for targeted audiences (e.g. Tech or Business), while general audience pages have lower multipliers.</p>
      </div>

      <div class="step-item">
        <h3>Step 4: Calculate Rate Sheet</h3>
        <p>Click the calculate button. The tool instantly lists custom rates for standard posts, Stories, and Reels, alongside a projected yearly income estimation.</p>
      </div>
    </div>

    <h2>Key Features of the Instagram Account Money Calculator</h2>
    <p>
      This <strong>instagram account money calculator</strong> is built around real-world creator marketing campaigns:
    </p>
    <ul>
      <li><strong>Engagement Rate Modifiers:</strong> Accounts with above-average engagement rates (over 3%) receive a progressive pricing premium.</li>
      <li><strong>Niche Pricing Benchmarks:</strong> Automatically adjusts estimates based on category profit margins.</li>
      <li><strong>Format-Specific Rates:</strong> Provides separate outputs for standard posts, Stories, and Reels.</li>
    </ul>

    <h2>Benefits of Using a Free Instagram Money Calculator</h2>
    <p>
      This <strong>free instagram money calculator</strong> helps you:
    </p>
    <ol>
      <li><strong>Stop Undercharging:</strong> Guides creators in charging premiums for high-effort formats like Reels.</li>
      <li><strong>Structure Negotiations:</strong> Provides data-backed rates to reference during brand negotiations.</li>
      <li><strong>Forecast Growth:</strong> Lets you test how increasing followers or engagement rate impacts your earning potential.</li>
    </ol>

    <h2>Link to Detailed Optimization Guide</h2>
    <div style="margin: 1.5rem 0; background: var(--color-bg-alt); padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); border-left: 4px solid var(--color-brand);">
      <p style="margin: 0; font-weight: 600; font-size: 0.95rem;">
        💡 <strong>Want to scale your influencer earnings?</strong> Read our comprehensive guide on <a href="/blog/instagram-money-calculator-guide" style="color: var(--color-brand); text-decoration: underline;">Instagram Influencer Sponsored Post Rates & Negotiation Strategies</a> to learn how to pitch brands, calculate engagement rates manually, and structure campaign packages.
      </p>
    </div>
  </div>
</ToolLayout>

<style>
  /* Enforce rounded corners on the entire tool card and give it clean outer padding */
  .calc-card {
    padding: 2.5rem !important;
    border-radius: 24px !important;
    box-sizing: border-box;
    max-width: 100%;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    max-width: 100%;
  }

  .calc-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 100%;
    box-sizing: border-box;
  }

  .form-row-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 100%;
    box-sizing: border-box;
  }

  .label-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
  }

  .icon-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .field-icon {
    width: 18px;
    height: 18px;
    color: var(--color-brand);
    flex-shrink: 0;
  }

  select.form-input {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke='%236366f1' stroke-width='2'%3E%3Cpath stroke-linecap='round' stroke-linejoin='round' d='M19.5 8.25l-7.5 7.5-7.5-7.5'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1.25rem;
    padding-right: 2.5rem !important;
    cursor: pointer;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .calc-btn-secondary {
    height: 48px;
    background: transparent;
    border: 1.5px solid var(--color-border);
    color: var(--color-text);
    font-weight: 600;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .calc-btn-secondary:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-alt);
  }

  .calc-results {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 380px;
    padding: 2.25rem;
    border-radius: 20px !important;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    gap: 1.75rem;
    box-sizing: border-box;
    max-width: 100%;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .empty-icon {
    width: 48px;
    height: 48px;
    color: var(--color-text-muted);
  }

  .results-active {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  .rate-range-box {
    text-align: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    box-sizing: border-box;
    width: 100%;
  }

  .rate-label {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .rate-range {
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 800;
    color: var(--color-brand);
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .grade-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    border-radius: var(--radius-full);
    text-transform: uppercase;
  }

  .grade-low {
    background: rgba(99, 102, 241, 0.1);
    color: var(--color-brand);
  }

  .breakdown-box {
    width: 100%;
  }

  .breakdown-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .breakdown-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .breakdown-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
  }

  .breakdown-label {
    color: var(--color-text-muted);
  }

  .breakdown-val {
    font-weight: 600;
    color: var(--color-text);
  }

  /* Step guide styling */
  .step-guide {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 1.5rem 0;
  }

  .step-item {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    padding: 1.25rem;
    border-radius: var(--radius-md);
  }

  .step-item h3 {
    margin-top: 0 !important;
    font-size: 1.1rem;
    color: var(--color-brand);
    margin-bottom: 0.5rem;
  }

  .step-item p {
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .step-item ul {
    margin-bottom: 0 !important;
    margin-left: 1.25rem !important;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .hidden {
    display: none !important;
  }

  /* Responsive Mobile Overrides */
  @media (max-width: 767px) {
    .calc-card {
      padding: 1.25rem !important;
      border-radius: 18px !important;
    }

    .form-actions {
      flex-direction: column;
      gap: 0.75rem;
    }

    .calc-results {
      padding: 0 !important;
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      gap: 1.5rem !important;
      margin-top: 0.5rem !important;
      min-height: auto;
    }

    .breakdown-box {
      border-bottom: 1px dashed var(--color-border) !important;
      padding-bottom: 1rem !important;
    }

    .rate-range-box {
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      border-radius: 0 !important;
      box-shadow: none !important;
      width: 100% !important;
      border-bottom: 1px dashed var(--color-border) !important;
      padding-bottom: 1rem !important;
      align-items: center !important;
    }
  }

  @media (min-width: 768px) {
    .form-row-2 {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .calc-grid {
      grid-template-columns: 1.2fr 1fr;
      align-items: start;
      gap: 2.5rem;
    }
  }

  /* Slotted editorial heading spacing fixes */
  .editorial-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    color: var(--color-text);
  }
</style>

<script>
  const setupInstagramMoneyCalculator = () => {
    const followerInput = document.getElementById('follower-count') as HTMLInputElement;
    const engagementInput = document.getElementById('engagement-rate') as HTMLInputElement;
    const nicheSelect = document.getElementById('niche-multiplier') as HTMLSelectElement;

    const submitBtn = document.getElementById('calc-submit-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    const emptyBox = document.getElementById('res-empty-box');
    const activeBox = document.getElementById('res-active-box');

    const postVal = document.getElementById('res-post-val');
    const rangeVal = document.getElementById('res-range-val');
    const reelVal = document.getElementById('res-reel-val');
    const storyVal = document.getElementById('res-story-val');
    const yearlyVal = document.getElementById('res-yearly-val');

    const calculateEarnings = () => {
      const followers = parseFloat(followerInput?.value) || 0;
      const engagement = parseFloat(engagementInput?.value) || 3.0;
      const nicheMultiplier = parseFloat(nicheSelect?.value) || 1.0;

      if (followers < 100) {
        return alert("Please enter a valid follower count (minimum 100).");
      }

      // Base post rate calculation: $10 CPM baseline
      const basePostRate = followers * 0.01;

      // Engagement modifier (progressive weighting)
      // Clamped modifier between 0.5x and 3.0x to avoid anomalies
      let engagementModifier = 1.0 + (engagement - 3.0) / 10.0;
      engagementModifier = Math.max(0.5, Math.min(3.0, engagementModifier));

      // Calculate rates
      let postRate = basePostRate * engagementModifier * nicheMultiplier;
      postRate = Math.max(50, Math.round(postRate)); // Floor rate at $50

      const storyRate = Math.round(postRate * 0.40);
      const reelRate = Math.round(postRate * 1.35);

      // Annual projections (assuming 1 sponsored post & 1 sponsored reel per month)
      const annualEarnings = (postRate * 12) + (reelRate * 12);

      const lowRange = Math.round(postRate * 0.85);
      const highRange = Math.round(postRate * 1.15);

      // Render outputs
      if (emptyBox) emptyBox.classList.add('hidden');
      if (activeBox) activeBox.classList.remove('hidden');

      if (postVal) postVal.textContent = `$${postRate.toLocaleString()}`;
      if (rangeVal) rangeVal.textContent = `$${lowRange.toLocaleString()} - $${highRange.toLocaleString()} range`;

      if (reelVal) reelVal.textContent = `$${reelRate.toLocaleString()}`;
      if (storyVal) storyVal.textContent = `$${storyRate.toLocaleString()}`;
      if (yearlyVal) yearlyVal.textContent = `$${annualEarnings.toLocaleString()}`;

      // Smooth scroll to the results section
      const resultsWrapper = document.getElementById('results-wrapper');
      if (resultsWrapper) {
        resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    const resetCalculator = () => {
      if (followerInput) followerInput.value = '';
      if (engagementInput) engagementInput.value = '3.0';
      if (nicheSelect) nicheSelect.selectedIndex = 3; // Lifestyle

      if (emptyBox) emptyBox.classList.remove('hidden');
      if (activeBox) activeBox.classList.add('hidden');
    };

    submitBtn?.addEventListener('click', calculateEarnings);
    resetBtn?.addEventListener('click', resetCalculator);
  };

  setupInstagramMoneyCalculator();
  document.addEventListener('astro:after-swap', setupInstagramMoneyCalculator);
</script>
