<script>
  const setupDiscordEmojiGenerator = () => {
    const seedInput = document.getElementById("seed-input") as HTMLInputElement;
    const nicheSelect = document.getElementById(
      "niche-select",
    ) as HTMLSelectElement;
    const formatSelect = document.getElementById(
      "format-select",
    ) as HTMLSelectElement;

    // Actions
    const generateBtn = document.getElementById("generate-btn");
    const resetBtn = document.getElementById("reset-btn");
    const generateMoreBtn = document.getElementById("generate-more-btn");

    // Layout slots
    const resultsWrapper = document.getElementById("results-wrapper");
    const container = document.getElementById("generated-emojis-container");

    // Mockup targets
    const mockupEmojiDisplay = document.getElementById("mockup-emoji-display");

    // Emoji structure database
    const vibesData: Record<
      string,
      {
        graphicPrefixes: string[];
        graphicSuffixes: string[];
        kaomojis: string[];
      }
    > = {
      gaming: {
        graphicPrefixes: ["⚔️", "🎮", "🔥", "👾", "👑", "⚡"],
        graphicSuffixes: ["⚔️", "🎮", "🔥", "👾", "👑", "⚡"],
        kaomojis: [
          "(•_•)凸",
          "(*_*)ノ",
          "(⌐■_■)",
          "🎮 (ఠ_ఠ)",
          "(ʘ‿ʘ)ノ",
          "ᕙ(⇀‸↼)ᕗ",
          "t(-_-t)",
        ],
      },
      cozy: {
        graphicPrefixes: ["✿", "✧", "☕", "☁️", "🌙", "🍂"],
        graphicSuffixes: ["✿", "✧", "☕", "☁️", "🌙", "🍂"],
        kaomojis: [
          "(✿◠‿◠)",
          "(◡‿◡✿)",
          "(=^·^=)☕",
          "( ☁️ )",
          "( ´◡` )",
          "(*¯︶¯*)",
          "✿(◡‿◡)",
        ],
      },
      funny: {
        graphicPrefixes: ["🤪", "🫠", "💀", "🤡", "🤮", "💩"],
        graphicSuffixes: ["🤪", "🫠", "💀", "🤡", "🤮", "💩"],
        kaomojis: [
          "(°ロ°)",
          "¯\\_(ツ)_/¯",
          "( ͡° ͜ʖ ͡°)",
          "(╯°□°）╯",
          "┬──┬ ノ( ゜-゜ノ)",
          "ಠ_ಠ",
          "(;´༎ຶД༎ຶ`)",
        ],
      },
      cyber: {
        graphicPrefixes: ["🤖", "💻", "🌐", "📡", "🔋", "🔌"],
        graphicSuffixes: ["🤖", "💻", "🌐", "📡", "🔋", "🔌"],
        kaomojis: [
          "[🤖]",
          "Error(°_°)",
          "101(⌐■_■)",
          "(⚙️)",
          "(💻)",
          "[system_err]",
          "🤖(•_•)",
        ],
      },
      faces: {
        graphicPrefixes: ["😀", "😍", "😭", "😡", "😱", "😴"],
        graphicSuffixes: ["😀", "😍", "😭", "😡", "😱", "😴"],
        kaomojis: [
          "(❤ω❤)",
          "(=^･ω･^=)",
          "(*^ω^*)",
          "(〃▽〃)",
          "(>_<)",
          "(-_-)zzz",
          "ヽ(>_<)ノ",
        ],
      },
    };

    let currentShuffledPool: string[] = [];
    let currentPoolIndex = 0;

    const buildShuffledPool = () => {
      const seed = (seedInput?.value || "").trim();
      const niche = nicheSelect?.value || "gaming";
      const format = formatSelect?.value || "kaomoji";

      const database = vibesData[niche] || vibesData["gaming"];
      const generatedSet = new Set<string>();

      // Pre-populate templates based on layout choices
      const applyFormat = () => {
        const randIndex = Math.floor(Math.random() * database.kaomojis.length);
        const randKaomoji = database.kaomojis[randIndex] || "(⌐■_■)";

        const randPIndex = Math.floor(
          Math.random() * database.graphicPrefixes.length,
        );
        const randSIndex = Math.floor(
          Math.random() * database.graphicSuffixes.length,
        );

        const gp = database.graphicPrefixes[randPIndex] || "";
        const gs = database.graphicSuffixes[randSIndex] || "";

        let text = "";
        if (format === "kaomoji") {
          text = seed
            ? `${randKaomoji.substring(0, 4)}_${seed.toLowerCase()}_${randKaomoji.substring(4)}`
            : randKaomoji;
        } else if (format === "combo") {
          text = seed
            ? `${gp} ${seed.toLowerCase()} ${gs}`
            : `${gp} ${gs} ${gp}`;
        } else {
          // Badges
          text = seed
            ? `${gp} [${seed.toUpperCase()}] ${gs}`
            : `${gp} [HYPE] ${gs}`;
        }

        return text.trim().substring(0, 32); // Custom emojis naming bounds
      };

      // Generate a pool of 50 unique variations
      let iterations = 0;
      while (generatedSet.size < 50 && iterations < 300) {
        iterations++;
        const formatted = applyFormat();
        if (formatted.length >= 2) {
          generatedSet.add(formatted);
        }
      }

      currentShuffledPool = Array.from(generatedSet).sort(
        () => Math.random() - 0.5,
      );
      currentPoolIndex = 0;
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledPool();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      if (container) {
        container.innerHTML = selected
          .map((s) => {
            return `
            <div class="emoji-chip" data-name="${s}">
              <span class="emoji-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
          })
          .join("");
      }

      resultsWrapper?.classList.remove("hidden");

      // Default the mockup emoji display to the first result
      if (mockupEmojiDisplay && selected.length > 0) {
        mockupEmojiDisplay.textContent = selected[0];
      }
    };

    // Append 5 more unique emojis
    const appendMoreEmojis = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledPool();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledPool();
      }

      const next = currentShuffledPool.slice(
        currentPoolIndex,
        currentPoolIndex + 5,
      );
      currentPoolIndex += 5;

      if (container) {
        const appendHtml = next
          .map((s) => {
            return `
            <div class="emoji-chip" data-name="${s}">
              <span class="emoji-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
          })
          .join("");
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener("click", () => {
      generateList();

      const resultsSection = document.getElementById("results-wrapper");
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });

    generateMoreBtn?.addEventListener("click", () => {
      appendMoreEmojis();
    });

    // Handle copying individual emoji chips and update mockup preview
    container?.addEventListener("click", (e) => {
      const chip = (e.target as HTMLElement).closest(".emoji-chip");
      if (!chip) return;

      const emojiTextValue = chip.getAttribute("data-name") || "";

      // Update mockup sidebar
      if (mockupEmojiDisplay) {
        mockupEmojiDisplay.textContent = emojiTextValue;
      }

      // Copy to clipboard
      navigator.clipboard.writeText(emojiTextValue).then(() => {
        const btn = chip.querySelector(".chip-btn") as HTMLElement;
        if (btn) {
          btn.textContent = "Copied! ✓";
          setTimeout(() => {
            btn.textContent = "Copy";
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener("click", () => {
      if (seedInput) seedInput.value = "";
      resultsWrapper?.classList.add("hidden");
    });

    // Auto-generate initial list
    generateList();
  };

  setupDiscordEmojiGenerator();
  document.addEventListener("astro:after-swap", setupDiscordEmojiGenerator);
</script>
