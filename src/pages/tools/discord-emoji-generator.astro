---
import ToolLayout from "../../layouts/ToolLayout.astro";

const faqs = [
  {
    question: "What is the size limit for custom Discord emojis?",
    answer:
      "Custom Discord emojis must be under 256 KB in file size. They are ideally uploaded as square images (128x128 pixels).",
  },
  {
    question: "Can I use custom emojis in my Discord bio or username?",
    answer:
      "Yes, you can use standard Unicode emojis and custom Kaomojis in your bio or username. However, custom server emojis can only be displayed in text channels, status messages, or by Nitro subscribers.",
  },
  {
    question: "What is the difference between an emoji and a Kaomoji?",
    answer:
      "An emoji is a graphical glyph (like 🎮 or 🔥), while a Kaomoji is a Japanese-style text emoticon composed of standard keyboard characters (like (╯°□°）╯ or ʕ•ᴥ•ʔ).",
  },
  {
    question: "How do I upload custom emojis to my Discord server?",
    answer:
      "Go to Server Settings > Emoji, click 'Upload Emoji', and select your image files. Normal servers can upload up to 50 custom emojis initially, and more by boosting the server.",
  },
  {
    question: "Are animated custom emojis supported on Discord?",
    answer:
      "Yes, Discord supports animated custom emojis in GIF format. Members with Discord Nitro can use them globally across all servers.",
  },
];
---

<ToolLayout
  title="Discord Emoji Generator - Cool Custom Kaomojis & Combos"
  description="Generate cool, aesthetic, and funny custom Discord emojis and Kaomojis. Copy emoji combos and text badges for chat channels and bios."
  toolName="Discord Emoji Generator"
  toolDescription="Generate custom Kaomojis, text badges, and aesthetic emoji combinations. Preview outputs inside a live Discord chat message card."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Generator Inputs -->
      <div class="calc-form-column">
        <div class="calc-form">
          <!-- Seed Name Input -->
          <div class="form-group">
            <label for="seed-input" class="icon-label">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="field-icon"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z"
                ></path>
              </svg>
              Emoji Keyword / Vibe
            </label>
            <input
              type="text"
              id="seed-input"
              class="form-input"
              placeholder="e.g. cry, hype, cool, love"
              value="cool"
            />
          </div>

          <div
            style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;"
          >
            <!-- Emoji Niche Style -->
            <div class="form-group">
              <label for="niche-select" class="icon-label">Emoji Vibe</label>
              <select
                id="niche-select"
                class="form-input"
                style="height: 48px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0 12px; color: var(--color-text);"
              >
                <option value="gaming">Gaming / Streamer</option>
                <option value="cozy">Aesthetic / Cozy</option>
                <option value="funny">Meme / Funny</option>
                <option value="cyber">Tech / Cyberpunk</option>
                <option value="faces">Expression / Faces</option>
              </select>
            </div>

            <!-- Output Format -->
            <div class="form-group">
              <label for="format-select" class="icon-label">Format Style</label>
              <select
                id="format-select"
                class="form-input"
                style="height: 48px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0 12px; color: var(--color-text);"
              >
                <option value="kaomoji">Kaomoji Face (╯°□°）╯</option>
                <option value="combo">Emoji Combo (🔥🎮🔥)</option>
                <option value="badge">Text Badge ([HYPE])</option>
              </select>
            </div>
          </div>

          <!-- Actions -->
          <div class="form-actions">
            <button type="button" id="generate-btn" class="calc-btn"
              >Generate Emojis</button
            >
            <button type="button" id="reset-btn" class="calc-btn-secondary"
              >Reset Inputs</button
            >
          </div>
        </div>
      </div>

      <!-- Right Column: Live Mockup Card -->
      <div class="calc-editor-column">
        <!-- Live Discord Message Preview Card -->
        <div
          class="discord-message-preview glass"
          style="background: #36393f; color: #dcddde; border-radius: 16px; overflow: hidden; max-width: 320px; margin: 0 auto; width: 100%; border: 1px solid #202225; text-align: left; box-shadow: var(--shadow-md); display: flex; padding: 1.25rem; gap: 12px; font-family: var(--font-body);"
        >
          <!-- Mock Avatar -->
          <div
            style="width: 40px; height: 40px; border-radius: 50%; background: #5865f2; color: #ffffff; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 800; flex-shrink: 0; user-select: none;"
          >
            CF
          </div>

          <!-- Message Body -->
          <div
            style="display: flex; flex-direction: column; gap: 4px; min-width: 0;"
          >
            <!-- Header Block -->
            <div style="display: flex; align-items: center; gap: 6px;">
              <span
                style="color: #ffffff; font-weight: 700; font-size: 0.92rem; cursor: pointer;"
                >Creators Feel</span
              >
              <span
                style="background: #5865f2; color: #ffffff; font-size: 0.58rem; font-weight: 700; padding: 1px 4px; border-radius: 3px; text-transform: uppercase;"
                >Bot</span
              >
              <span style="color: #72767d; font-size: 0.72rem;"
                >Today at 12:43 PM</span
              >
            </div>

            <!-- Content text block -->
            <div
              style="font-size: 0.95rem; color: #dcddde; word-break: break-word; line-height: 1.4;"
            >
              Check out my custom emoji! <span
                id="mockup-emoji-display"
                style="color: #ffffff; font-weight: 800; background: rgba(88,101,242,0.15); padding: 2px 6px; border-radius: 4px;"
                >(⌐■_■)</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Generated Results Section -->
    <div
      id="results-wrapper"
      class="hidden"
      style="margin-top: 2rem; border-top: 1px dashed var(--color-border); padding-top: 1.5rem;"
    >
      <h3
        style="font-size: 1.05rem; font-weight: 800; text-transform: uppercase; color: var(--color-text); margin: 0 0 1rem 0; display: flex; align-items: center; gap: 0.5rem;"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          style="width: 20px; height: 20px; color: var(--color-brand);"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"
          ></path>
        </svg>
        Suggested Emojis & Combos
      </h3>

      <div class="usernames-grid" id="generated-emojis-container">
        <!-- Results dynamic content goes here -->
      </div>

      <div style="display: flex; justify-content: center; margin-top: 1.5rem;">
        <button
          type="button"
          id="generate-more-btn"
          class="calc-btn"
          style="max-width: 200px; padding: 0 1.5rem;">Generate More</button
        >
      </div>
    </div>
  </div>

  <div slot="about" class="editorial-content">
    <h2>Discord Emoji Generator: Design Custom Text Emotes & Combos</h2>
    <div
      style="margin: 1.5rem 0; background: var(--color-bg-alt); padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); border-left: 4px solid var(--color-brand);"
    >
      <p style="margin: 0; font-weight: 600; font-size: 0.95rem;">
        🪐 <strong
          >Looking to brand your community sidebar or channel rules?</strong
        > Try our free <a
          href="/tools/discord-server-name-generator"
          style="color: var(--color-brand); text-decoration: underline;"
          >Discord Server Name Generator</a
        > to generate cool, stylized server titles featuring aesthetic symbols.
      </p>
    </div>

    <h3>Introduction</h3>
    <p>
      In text channels, visual elements represent your speech cues. Custom
      emotes and graphic combos establish the tone of chats, announcements, and
      reactions. If you are moderating a community server, setting up stream
      updates, or looking to customize your chat profile, standard emojis can
      feel generic. Our free <strong>discord emoji generator</strong> constructs customized
      text emoticons (Kaomojis), graphic layouts, and brackets badges instantly. Use
      these styled combinations to add visual flair to your text chats.
    </p>

    <h3>How to Use This Tool</h3>
    <p>
      To draft and audit custom Discord emojis in real-time, follow these steps:
    </p>
    <ol>
      <li>
        <strong>Emoji Vibe:</strong> Enter a seed keyword describing your desired
        mood (e.g. happy, sleep, heart, hype).
      </li>
      <li>
        <strong>Category Selection:</strong> Select a theme category (Gaming, Cozy/Aesthetic,
        Meme, Cyberpunk, or Expressions).
      </li>
      <li>
        <strong>Output Layout:</strong> Choose between Japanese-style Kaomojis, stacked
        emoji combinations, or bracketed text badges.
      </li>
      <li>
        <strong>Generate List:</strong> Click <strong>Generate Emojis</strong> to view 15 distinct
        options.
      </li>
      <li>
        <strong>Interactive Audit:</strong> Click any badge to preview it in the Discord
        message chat bubble mockup, and copy it instantly. Click <strong>Generate More</strong>
        to append 5 more options.
      </li>
    </ol>

    <h3>What is Discord Emoji</h3>
    <p>
      A Discord Emoji is one of the most popular places to show off custom emoji
      layouts. Because bios are limited to 190 characters, using dense Unicode
      symbols and Kaomojis is a clever way to fit more personality into your
      profile card. Integrating these styles into both your user bio and server
      announcements builds a unified community theme. Our generator ensures that
      every text face and emoji layout is optimized for dark-mode screens,
      keeping your chat profile visually clean.
    </p>

    <h3>How Does It Work?</h3>
    <p>The generator merges your keyword seeds with character databases:</p>
    <ul>
      <li>
        <strong>Kaomoji Assembly:</strong> Compiles mouth, eye, and arm symbols to
        form expressive text faces.
      </li>
      <li>
        <strong>Emoji Stacking:</strong> Pairs your vibe keyword with thematic graphical
        emojis to create structured separators (e.g. `✨[Hype]✨` or `🔥🎮🔥`).
      </li>
      <li>
        <strong>Byte Checking:</strong> Audits character sizes to verify text faces
        display correctly across mobile and desktop apps.
      </li>
    </ul>

    <h3>Example Calculation</h3>
    <p>
      Let's look at how a custom emoji combination character budget is
      calculated:
    </p>
    <p>
      <strong>Input Seed Word:</strong> `"Hype"`<br />
      <strong>Emoji Vibe selected:</strong> `"Gaming / Streamer"`<br />
      <strong>Format selected:</strong> `"Custom Styled Badges"`
    </p>
    <p>
      <strong>Calculation Process:</strong><br />
      ✦ Base text: `"HYPE"` $\rightarrow$ <strong>4 characters</strong>.<br />
      ✦ Brackets: `"[` and `]"` $\rightarrow$ <strong>2 characters</strong>.<br
      />
      ✦ Gaming decorations: `"⚔️"` and `"⚔️"` $\rightarrow$ <strong
        >2 emojis</strong
      >.<br />
      ✦ Combined output: `"⚔️ [HYPE] ⚔️"` $\rightarrow$ <strong
        >12 characters</strong
      >.<br />
      ✦ UTF-16 character limit check: `12 < 32 characters` (custom upload name limits)
      or `12 < 190 characters` (profile bio limits).
    </p>
    <p>
      The output is `⚔️ [HYPE] ⚔️`, which fits easily within any Discord
      character budget.
    </p>

    <h3>Features</h3>
    <p>
      This <strong>free discord emoji generator</strong> offers several tools:
    </p>
    <ul>
      <li>
        <strong>Live Chat Message Preview:</strong> Review how your Kaomoji or emoji
        combo renders inside a realistic Discord message bubble.
      </li>
      <li>
        <strong>Generate More Button:</strong> Dynamically generate and append 5 more
        unique ideas.
      </li>
      <li>
        <strong>Cross-Platform Kaomoji Sets:</strong> Generates classic Japanese text
        emoticons that render correctly across all mobile operating systems.
      </li>
      <li>
        <strong>Tactile Pill-Shaped Buttons:</strong> Copy any combo instantly to
        your clipboard.
      </li>
    </ul>

    <h3>Who Should Use This Tool?</h3>
    <p>This generator is designed for:</p>
    <ul>
      <li>
        <strong>Streamers & Content Creators:</strong> Designing announcers and reaction
        commands for their community servers.
      </li>
      <li>
        <strong>Discord Server Admins:</strong> Creating custom channel header icons,
        role labels, and rules banners.
      </li>
      <li>
        <strong>Casual Chatters:</strong> Adding unique Kaomojis to stand out in active
        server channels.
      </li>
      <li>
        <strong>Cozy Profile Designers:</strong> Styling bios with soft, botanical
        emoji combinations.
      </li>
    </ul>
  </div>
</ToolLayout>

