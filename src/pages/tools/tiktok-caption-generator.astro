---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is the character limit for a TikTok caption?",
    answer: "TikTok has a caption character limit of 4,000 characters. This allows you to write long-form descriptions, micro-blogs, or include structured FAQs directly under your video."
  },
  {
    question: "How many hashtags should I use in my TikTok caption?",
    answer: "Under modern TikTok SEO best practices, it is recommended to use between 3 and 5 highly relevant hashtags. Avoid cluttering your caption with too many tags, as it can confuse the recommendation algorithm."
  },
  {
    question: "Does the TikTok caption layout support line breaks?",
    answer: "Yes, TikTok supports line breaks. Formatting your caption with clear line breaks and emojis significantly improves readability and user engagement."
  },
  {
    question: "Why does the tool show a 'see more' truncation in the mockup?",
    answer: "On TikTok's mobile app, captions that exceed 100 characters are automatically truncated with a '... see more' link overlaying the video player. Previewing this helps you ensure your primary hook is visible before truncation."
  },
  {
    question: "Is this TikTok Caption Generator free to use?",
    answer: "Yes, our caption generator is 100% free, runs locally in your browser, and requires no account creation or login details."
  }
];
---

<ToolLayout
  title="TikTok Caption Generator - Free TikTok Video Copy Maker"
  description="Generate cool and catchy TikTok captions instantly. Free online TikTok caption generator that structures your hooks, CTAs, and hashtags."
  toolName="TikTok Caption Generator"
  toolDescription="Create engaging video descriptions for your TikTok posts. Input your topic and goals to generate creative, aesthetic, or witty captions that grab attention."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Settings and Input Forms -->
      <div class="calc-form-column">
        <form class="calc-form" id="generator-form" onsubmit="return false;">
          <!-- Username Customize -->
          <div class="form-group">
            <label for="handle-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
              Profile @Handle
            </label>
            <input type="text" id="handle-input" class="form-input" placeholder="e.g. baking_creator" value="creators_feel" />
          </div>

          <!-- Video Topic/Description -->
          <div class="form-group">
            <label for="value-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
              </svg>
              What is your video about? (Topic)
            </label>
            <input type="text" id="value-input" class="form-input" placeholder="e.g. chocolate chip cookies recipe" value="easy chocolate cake recipe" required />
          </div>

          <!-- Call to Action -->
          <div class="form-group">
            <label for="cta-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
              </svg>
              Call to Action (CTA)
            </label>
            <input type="text" id="cta-input" class="form-input" placeholder="e.g. comment cake for the link 👇" value="save this for your weekend baking 👇" />
          </div>

          <!-- Tone Selection -->
          <div class="form-group">
            <label for="tone-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z" />
              </svg>
              Select Tone Style
            </label>
            <select id="tone-input" class="form-input" style="height: 48px; border-radius: 8px;">
              <option value="Witty">Catchy & Witty</option>
              <option value="Minimal">Aesthetic & Minimal</option>
              <option value="Educational" selected>Educational & Value</option>
            </select>
          </div>

          <div class="form-actions">
            <button type="button" id="generate-btn" class="calc-btn" style="width: 100%;">Generate Captions</button>
            <button type="button" id="calc-reset-btn" class="calc-btn-secondary" style="width: 100%;">Reset Fields</button>
          </div>
        </form>
      </div>

      <!-- Right Column: Interactive Sandbox Editor & Mobile Mockup -->
      <div class="calc-editor-column">
        <!-- Live Mobile Mockup Preview (TikTok Video Overlay style) -->
        <div class="phone-mockup glass" style="background: #000; border-color: #222; position: relative; height: 380px; overflow: hidden;">
          <!-- Mockup background representing a blurred video -->
          <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.8) 100%); z-index: 1;"></div>
          
          <!-- Sidebar icons on the right -->
          <div style="position: absolute; right: 10px; top: 90px; z-index: 2; display: flex; flex-direction: column; gap: 1rem; align-items: center; color: white;">
            <div style="display: flex; flex-direction: column; align-items: center; gap: 0.15rem;">
              <svg style="width: 24px; height: 24px; color: #ef4444;" fill="currentColor" viewBox="0 0 24 24"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <span style="font-size: 0.65rem; font-weight: 700;">14.2K</span>
            </div>
            <div style="display: flex; flex-direction: column; align-items: center; gap: 0.15rem;">
              <svg style="width: 24px; height: 24px; color: white;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48L4.5 21l3.75-1.5c1.1.256 2.27.375 3.75.375Z" /></svg>
              <span style="font-size: 0.65rem; font-weight: 700;">430</span>
            </div>
            <div style="display: flex; flex-direction: column; align-items: center; gap: 0.15rem;">
              <svg style="width: 24px; height: 24px; color: white;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314" /></svg>
              <span style="font-size: 0.65rem; font-weight: 700;">1.2K</span>
            </div>
            <!-- Spinning disc mockup -->
            <div style="width: 28px; height: 28px; border-radius: 50%; background: #222; border: 4px solid #444; margin-top: 0.5rem;"></div>
          </div>

          <!-- Bottom-left text overlay -->
          <div style="position: absolute; left: 15px; bottom: 15px; right: 55px; z-index: 2; color: white; display: flex; flex-direction: column; gap: 0.35rem; text-align: left;">
            <span style="font-weight: 800; font-size: 0.9rem;" id="mockup-handle-display">@creators_feel</span>
            <div style="font-size: 0.8rem; line-height: 1.4; max-height: 120px; overflow: hidden; word-break: break-word;">
              <p id="mockup-bio-text" style="margin: 0; display: inline; color: #fff;">Easy chocolate cake recipe! Save this for your weekend baking 👇 #cake #recipe #baking</p>
              <span id="mockup-see-more" class="hidden" style="color: #bbb; font-weight: 700; margin-left: 0.25rem; cursor: pointer;">... see more</span>
            </div>
            <span style="font-size: 0.72rem; color: #aaa; display: flex; align-items: center; gap: 0.25rem; margin-top: 0.25rem;">
              🎵 <span id="mockup-sound-display">creators_feel • Original Sound</span>
            </span>
          </div>
        </div>

        <!-- Sandbox Active Workspace Editor -->
        <div class="sandbox-box glass">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
            <span style="font-size: 0.75rem; font-weight: 700; color: var(--color-text); text-transform: uppercase;">Active Caption Editor</span>
            <span id="sandbox-counter" style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted);">90 / 4000</span>
          </div>
          
          <textarea id="sandbox-input" class="form-input" style="height: 90px; resize: none; line-height: 1.4; font-size: 0.92rem; font-family: inherit;" placeholder="Refine your caption copy here..."></textarea>

          <!-- Visual characters budget progress scale bar -->
          <div class="progress-bar-container" style="background: var(--color-border); height: 6px; border-radius: 4px; overflow: hidden; margin: 0.5rem 0;">
            <div id="progress-bar-fill" style="width: 2.25%; height: 100%; background: var(--color-brand); transition: all var(--transition-fast);"></div>
          </div>

          <!-- Quick Curated Emoji Picker Drawer -->
          <div style="display: flex; flex-direction: column; gap: 0.25rem; margin-top: 0.5rem;">
            <span style="font-size: 0.65rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Click to insert emoji:</span>
            <div class="emoji-selector-panel" id="emoji-picker-container">
              <button type="button" class="emoji-btn">👇</button>
              <button type="button" class="emoji-btn">📈</button>
              <button type="button" class="emoji-btn">✨</button>
              <button type="button" class="emoji-btn">🎂</button>
              <button type="button" class="emoji-btn">🍪</button>
              <button type="button" class="emoji-btn">🔥</button>
              <button type="button" class="emoji-btn">⬇️</button>
              <button type="button" class="emoji-btn">💡</button>
              <button type="button" class="emoji-btn">👀</button>
              <button type="button" class="emoji-btn">🙌</button>
            </div>
          </div>

          <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
            <button type="button" id="copy-active-btn" class="calc-btn" style="flex: 1.2; height: 42px; font-size: 0.85rem;">Copy Caption</button>
            <button type="button" id="clear-sandbox-btn" class="calc-btn-secondary" style="flex: 0.8; height: 42px; font-size: 0.85rem;">Clear</button>
          </div>
        </div>

        <!-- Suggestions Drawer Panel -->
        <div class="suggestions-drawer" id="suggestions-box" style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
          <h4 style="margin: 0; font-size: 0.9rem; font-weight: 700; color: var(--color-text); text-transform: uppercase; border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem;">Alternative Suggestions</h4>
          
          <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            <!-- Card Option 1 -->
            <div class="option-card">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
                <span class="opt-label">Option A (Witty & Hooky)</span>
                <span id="opt-1-badge" class="opt-badge">0 / 4000</span>
              </div>
              <p id="opt-1-val" class="opt-text">This easy chocolate cake recipe is dangerous. Save this for your weekend baking 👇 #cake #recipe #baking</p>
              <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                <button type="button" class="load-sandbox-btn mock-btn-mini" data-target="opt-1-val">Load to Sandbox</button>
                <button type="button" class="copy-direct-btn mock-btn-mini secondary" data-target="opt-1-val">Copy</button>
              </div>
            </div>

            <!-- Card Option 2 -->
            <div class="option-card">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
                <span class="opt-label">Option B (Educational & Value)</span>
                <span id="opt-2-badge" class="opt-badge">0 / 4000</span>
              </div>
              <p id="opt-2-val" class="opt-text">How to make an easy chocolate cake recipe. Save this for your weekend baking 👇 #baking #recipe #cook</p>
              <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                <button type="button" class="load-sandbox-btn mock-btn-mini" data-target="opt-2-val">Load to Sandbox</button>
                <button type="button" class="copy-direct-btn mock-btn-mini secondary" data-target="opt-2-val">Copy</button>
              </div>
            </div>

            <!-- Card Option 3 -->
            <div class="option-card">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
                <span class="opt-label">Option C (Minimalist Aesthetic)</span>
                <span id="opt-3-badge" class="opt-badge">0 / 4000</span>
              </div>
              <p id="opt-3-val" class="opt-text">easy chocolate cake recipe 🍰✨ | Save this for your weekend baking 👇 #cake #cook</p>
              <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                <button type="button" class="load-sandbox-btn mock-btn-mini" data-target="opt-3-val">Load to Sandbox</button>
                <button type="button" class="copy-direct-btn mock-btn-mini secondary" data-target="opt-3-val">Copy</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="editorial-content">
    <h2>TikTok Caption Generator: Write Search-Optimized Video Copy</h2>
    <div style="margin: 1.5rem 0; background: var(--color-bg-alt); padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); border-left: 4px solid var(--color-brand);">
      <p style="margin: 0; font-weight: 600; font-size: 0.95rem;">
        ✍️ <strong>Looking to optimize your video reach?</strong> Read our comprehensive strategy guide on <a href="/blog/tiktok-caption-generator-guide" style="color: var(--color-brand); text-decoration: underline;">TikTok Caption Ideas & Character Limit Optimization</a> to learn how to structure hook copy, position keywords, and boost discoverability.
      </p>
    </div>

    <h3>Introduction</h3>
    <p>
      Writing the perfect caption for your TikTok video is essential to capture attention and tell the recommendation algorithm what your content represents. This free <strong>tiktok caption generator</strong> allows you to design engaging video copy, generate relevant keywords and tags, and preview how your descriptions will look directly overlaying the mobile screen.
    </p>

    <h3>What is TikTok Caption Generator?</h3>
    <p>
      A <strong>tiktok bio generator</strong> is helpful for profiles, but a <strong>tiktok caption generator</strong> is designed specifically for video posts. By taking a topic and target call to action, this tool structures engaging templates that fit TikTok's layout perfectly.
    </p>

    <h3>How to Use This Tool</h3>
    <p>
      To write video copy, follow these instructions:
    </p>
    <ol>
      <li><strong>Select @Handle:</strong> Type your handle name to customize the mobile preview mockup.</li>
      <li><strong>Input Video Topic:</strong> Specify the topic of your post (e.g. "quick marketing tips" or "chocolate cookie recipe").</li>
      <li><strong>Input Call to Action (CTA):</strong> Add what you want viewers to do (e.g. "click link in bio" or "save for later").</li>
      <li><strong>Choose Style & Generate:</strong> Select a Catchy, Minimal, or Educational tone, and click <strong>Generate Captions</strong>.</li>
      <li><strong>Refine & Copy:</strong> Select a template to load into the active Sandbox, edit it with the emoji picker panel, and copy it to your clipboard.</li>
    </ol>

    <h3>How Does It Work?</h3>
    <p>
      The generator uses standard formatting templates to construct post copy:
    </p>
    <ul>
      <li><strong>Hook & Topic lines:</strong> Formulates the primary statement that immediately grabs viewer attention.</li>
      <li><strong>Call to Action (CTA) Hook:</strong> Directs viewers to interact with the post, visit links, or leave comments.</li>
      <li><strong>Hashtag Drawer:</strong> Injects relevant tags based on your topic (up to 5 tags for clean SEO search distribution).</li>
      <li><strong>Overlay Truncation Simulator:</strong> Shows you where the caption will be cut off with a "... see more" button on the screen.</li>
    </ul>

    <h3>Example Calculation</h3>
    <p>
      Let's look at how the generator budgets your caption layout:
    </p>
    <p>
      <strong>Input Values:</strong><br />
      ✦ Video Topic: "easy chocolate cake recipe"<br />
      ✦ Call to Action: "save this for your weekend baking 👇"
    </p>
    <p>
      <strong>Draft Layout Option:</strong><br />
      "Easy chocolate cake recipe! Save this for your weekend baking 👇 #cake #recipe #baking"<br />
      ✦ Total Character Count: <strong>92 characters</strong>.<br />
      ✦ Truncation Preview: Since the character count is below 100 characters, it will display fully on standard screens without being truncated behind the "... see more" link, ensuring the hook and CTA are immediately visible!
    </p>

    <h3>Who Should Use This Tool?</h3>
    <p>
      This <strong>free tiktok caption generator</strong> is designed for:
    </p>
    <ul>
      <li><strong>Creators & Influencers:</strong> Developing engaging hooks to boost completion rates.</li>
      <li><strong>Social Media Managers:</strong> Writing captions for client channels.</li>
      <li><strong>Brands & Marketers:</strong> Adding clear CTAs to drive product sales.</li>
      <li><strong>SEO Analysts:</strong> Targeting in-app search keywords in video descriptions.</li>
    </ul>
  </div>
</ToolLayout>

<style>
  /* Base Layout Config */
  .calc-card {
    padding: 2.25rem !important;
    border-radius: 24px !important;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .calc-form-column, .calc-editor-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
  }

  .calc-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-sizing: border-box !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .form-input {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
  }

  .icon-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .field-icon {
    width: 18px;
    height: 18px;
    color: var(--color-brand);
    flex-shrink: 0;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .calc-btn-secondary {
    height: 48px;
    background: transparent;
    border: 1.5px solid var(--color-border);
    color: var(--color-text);
    font-weight: 600;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .calc-btn-secondary:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-alt);
  }

  /* Smartphone Mockup CSS Styling */
  .phone-mockup {
    background: var(--color-bg-alt);
    border: 1.5px solid var(--color-border);
    border-radius: 28px;
    padding: 1.25rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    max-width: 320px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }

  .phone-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }

  .phone-name {
    font-weight: 700;
    font-size: 0.9rem;
    color: #fff !important;
  }

  .phone-icon-btn {
    width: 16px;
    height: 16px;
    color: #fff;
    cursor: pointer;
  }

  /* Sandbox Container CSS */
  .sandbox-box {
    border: 1px solid var(--color-border);
    padding: 1.25rem;
    border-radius: 16px;
    background: var(--color-bg-alt);
  }

  .emoji-selector-panel {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding-top: 0.25rem;
  }

  .emoji-btn {
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    border-radius: 4px;
    width: 32px;
    height: 32px;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
  }

  .emoji-btn:hover {
    background: var(--color-border);
    transform: scale(1.1);
  }

  /* Suggestion Cards CSS */
  .option-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .opt-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .opt-badge {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .opt-text {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.4;
    word-break: break-word;
  }

  .mock-btn-mini {
    height: 28px;
    padding: 0 0.75rem;
    border-radius: 4px;
    border: 1px solid var(--color-brand);
    background: var(--color-brand);
    color: white;
    font-weight: 600;
    font-size: 0.7rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .mock-btn-mini.secondary {
    border-color: var(--color-border);
    background: transparent;
    color: var(--color-text);
  }

  .mock-btn-mini.secondary:hover {
    background: var(--color-bg);
  }

  /* Slotted editorial heading spacing fixes */
  .editorial-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    color: var(--color-text);
  }

  /* Responsive Queries */
  @media (max-width: 767px) {
    .calc-card {
      padding: 1.25rem !important;
      border-radius: 18px !important;
    }
    
    .form-actions {
      flex-direction: column;
      gap: 0.75rem;
    }

    .phone-mockup {
      max-width: 100% !important;
      padding: 1rem !important;
    }
    
    .emoji-selector-panel {
      justify-content: center;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .calc-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .calc-grid {
      grid-template-columns: 1fr 1.1fr;
      align-items: start;
      gap: 2.25rem;
    }
  }
</style>

<script>
  const setupTiktokCaptionGenerator = () => {
    const handleInput = document.getElementById('handle-input') as HTMLInputElement;
    const valueInput = document.getElementById('value-input') as HTMLInputElement;
    const ctaInput = document.getElementById('cta-input') as HTMLInputElement;
    const toneSelect = document.getElementById('tone-input') as HTMLSelectElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // Phone Mockup Elements
    const mockupName = document.getElementById('mockup-name-display');
    const mockupHandle = document.getElementById('mockup-handle-display');
    const mockupBioText = document.getElementById('mockup-bio-text');
    const mockupSeeMore = document.getElementById('mockup-see-more');
    const mockupSound = document.getElementById('mockup-sound-display');

    // Sandbox workspace
    const sandboxInput = document.getElementById('sandbox-input') as HTMLTextAreaElement;
    const sandboxCounter = document.getElementById('sandbox-counter');
    const progressBarFill = document.getElementById('progress-bar-fill');
    const copyActiveBtn = document.getElementById('copy-active-btn');
    const clearSandboxBtn = document.getElementById('clear-sandbox-btn');

    // Alternative Displays
    const opt1Val = document.getElementById('opt-1-val');
    const opt2Val = document.getElementById('opt-2-val');
    const opt3Val = document.getElementById('opt-3-val');

    const opt1Badge = document.getElementById('opt-1-badge');
    const opt2Badge = document.getElementById('opt-2-badge');
    const opt3Badge = document.getElementById('opt-3-badge');

    // Live Handle Mockup Update
    const updateHandleMockup = () => {
      const handle = (handleInput?.value || 'creators_feel').trim().toLowerCase().replace(/\s+/g, '_');
      if (mockupName) mockupName.textContent = handle;
      if (mockupHandle) mockupHandle.textContent = `@${handle}`;
      if (mockupSound) mockupSound.textContent = `${handle} • Original Sound`;
    };
    handleInput?.addEventListener('input', updateHandleMockup);

    // Live Sandbox update
    const updateSandbox = () => {
      const text = sandboxInput?.value || '';
      const len = text.length;

      // Update Mockup Bio (Caption) with truncation simulation
      if (mockupBioText) {
        if (len > 100) {
          mockupBioText.textContent = text.substring(0, 100);
          mockupSeeMore?.classList.remove('hidden');
        } else {
          mockupBioText.textContent = text || 'Your video caption hook will display overlaying the player...';
          mockupSeeMore?.classList.add('hidden');
        }
      }

      // Update counters
      if (sandboxCounter) {
        sandboxCounter.textContent = `${len} / 4000`;
        sandboxCounter.style.color = len > 4000 ? '#ef4444' : 'var(--color-text-muted)';
      }

      // Update progress bar
      if (progressBarFill) {
        const percent = Math.min((len / 4000) * 100, 100);
        progressBarFill.style.width = `${percent}%`;
        
        if (len > 4000) {
          progressBarFill.style.backgroundColor = '#ef4444';
        } else if (percent > 85) {
          progressBarFill.style.backgroundColor = '#f59e0b';
        } else {
          progressBarFill.style.backgroundColor = 'var(--color-brand)';
        }
      }
    };
    sandboxInput?.addEventListener('input', updateSandbox);

    // Toggle expand mockup see more
    mockupSeeMore?.addEventListener('click', () => {
      if (mockupBioText && sandboxInput) {
        mockupBioText.textContent = sandboxInput.value;
        mockupSeeMore.classList.add('hidden');
      }
    });

    // Dynamic generation
    const generateCaptions = () => {
      const val = (valueInput?.value || '').trim();
      const cta = (ctaInput?.value || '').trim();
      const tone = toneSelect?.value || 'Educational';

      if (!val) {
        alert("Please specify your video topic.");
        return;
      }

      // Template generations (strictly respecting under 5 hashtags)
      let options = ['', '', ''];

      if (tone === 'Educational') {
        options[0] = `Here is how to make an ${val}. Save this for your weekend baking 👇 #baking #recipe #cook`;
        options[1] = `Everything you need to know about ${val} 💡. ${cta} #baking #cake #recipe`;
        options[2] = `Step-by-step: ${val.toUpperCase()} 🍰. ${cta} #recipe #cake`;
      } else if (tone === 'Witty') {
        options[0] = `This ${val} is dangerous. ${cta} #cake #recipe #baking`;
        options[1] = `Making ${val} is my therapy. ${cta} #cake #baking #hobby`;
        options[2] = `If you aren't making ${val}, what are you doing? 😂 ${cta} #recipe`;
      } else { // Minimal / Aesthetic
        options[0] = `${val} 💫 | ${cta} #baking #recipe`;
        options[1] = `slow morning making ${val} 🍰 • ${cta} #cake #aesthetic`;
        options[2] = `minimal ${val} recipe • ${cta} #recipe`;
      }

      // Populate Sandbox with Option 1
      if (sandboxInput) {
        sandboxInput.value = options[0];
        updateSandbox();
      }

      // Update Suggestion displays
      const vals = [opt1Val, opt2Val, opt3Val];
      const badges = [opt1Badge, opt2Badge, opt3Badge];

      options.forEach((opt, idx) => {
        const vBlock = vals[idx];
        const bBlock = badges[idx];

        if (vBlock) vBlock.textContent = opt;
        if (bBlock) {
          const len = opt.length;
          bBlock.textContent = `${len} / 4000`;
          bBlock.style.color = len > 4000 ? '#ef4444' : '';
        }
      });

      // Scroll directly to the results / editor sandbox column
      const editorCol = document.querySelector('.calc-editor-column');
      if (editorCol) {
        editorCol.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    generateBtn?.addEventListener('click', generateCaptions);

    // Emoji quick click inserter
    const emojiContainer = document.getElementById('emoji-picker-container');
    emojiContainer?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.emoji-btn');
      if (!btn || !sandboxInput) return;
      
      const emoji = btn.textContent || '';
      const start = sandboxInput.selectionStart;
      const end = sandboxInput.selectionEnd;
      const val = sandboxInput.value;

      sandboxInput.value = val.substring(0, start) + emoji + val.substring(end);
      
      // Reset cursor position
      sandboxInput.selectionStart = sandboxInput.selectionEnd = start + emoji.length;
      sandboxInput.focus();
      updateSandbox();
    });

    // Load to sandbox buttons
    document.querySelectorAll('.load-sandbox-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId || !sandboxInput) return;
        const textBlock = document.getElementById(targetId);
        if (textBlock) {
          sandboxInput.value = textBlock.textContent || '';
          updateSandbox();
        }
      });
    });

    // Direct copies buttons
    document.querySelectorAll('.copy-direct-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId) return;
        const textBlock = document.getElementById(targetId);
        const text = textBlock?.textContent || '';
        if (!text) return;

        navigator.clipboard.writeText(text).then(() => {
          const originalText = btn.textContent;
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = originalText;
          }, 1500);
        });
      });
    });

    // Sandbox Copy
    copyActiveBtn?.addEventListener('click', () => {
      const text = sandboxInput?.value || '';
      if (!text) return alert("Sandbox editor is empty!");
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyActiveBtn.textContent;
        copyActiveBtn.textContent = 'Copied to Clipboard! ✓';
        setTimeout(() => {
          copyActiveBtn.textContent = originalText;
        }, 1500);
      });
    });

    // Clear Sandbox
    clearSandboxBtn?.addEventListener('click', () => {
      if (sandboxInput) {
        sandboxInput.value = '';
        updateSandbox();
      }
    });

    // Reset Fields
    resetBtn?.addEventListener('click', () => {
      if (valueInput) valueInput.value = '';
      if (ctaInput) ctaInput.value = '';
      if (sandboxInput) sandboxInput.value = '';
      updateSandbox();
    });

    // Initialize
    updateHandleMockup();
    updateSandbox();
  };

  setupTiktokCaptionGenerator();
  document.addEventListener('astro:after-swap', setupTiktokCaptionGenerator);
</script>
