    border-radius: 24px !important;
    box-sizing: border-box;
    max-width: 100%;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    max-width: 100%;
  }

  .calc-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 100%;
    box-sizing: border-box;
  }

  .form-row-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 100%;
    box-sizing: border-box;
  }

  .label-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
  }

  .icon-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .field-icon {
    width: 18px;
    height: 18px;
    color: var(--color-brand);
    flex-shrink: 0;
  }

  .bullet-btn {
    width: 42px;
    height: 42px;
    font-size: 1.1rem;
    font-weight: 700;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
  }

  .bullet-btn:hover {
    border-color: var(--color-brand);
    background: rgba(99, 102, 241, 0.05);
