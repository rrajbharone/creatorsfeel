    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .calc-btn-secondary:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-alt);
  }

  .calc-results {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 380px;
    padding: 2.25rem;
    border-radius: 20px !important;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    gap: 1.75rem;
    box-sizing: border-box;
    max-width: 100%;
  }

  .step-guide {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 1.5rem 0;
  }

  .step-item {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    padding: 1.25rem;
    border-radius: var(--radius-md);
  }

  .step-item h3 {
    margin-top: 0 !important;
    font-size: 1.1rem;
    color: var(--color-brand);
    margin-bottom: 0.5rem;
  }

  .step-item p {
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .step-item ul {
    margin-bottom: 0 !important;
    margin-left: 1.25rem !important;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .hidden {
    display: none !important;
  }

  /* Responsive Mobile Overrides */
  @media (max-width: 767px) {
    .calc-card {
      padding: 1.25rem !important;
      border-radius: 18px !important;
    }

    .form-actions {
      flex-direction: column;
      gap: 0.75rem;
    }

    .calc-results {
      padding: 0 !important;
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      gap: 1.5rem !important;
      margin-top: 0.5rem !important;
      min-height: auto;
    }
  }

  @media (min-width: 768px) {
    .form-row-2 {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .calc-grid {
      grid-template-columns: 1.2fr 1fr;
      align-items: start;
      gap: 2.5rem;
    }
  }

  /* Slotted editorial heading spacing fixes */
  .editorial-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    color: var(--color-text);
  }
</style>

<script>
  const setupLinkedinFormatter = () => {
    const postInput = document.getElementById('post-input') as HTMLTextAreaElement;
    const charCountVal = document.getElementById('res-char-count');

    // Unicode stylizer inputs
    const stylizeInput = document.getElementById('stylize-input') as HTMLInputElement;
    const stylizeMode = document.getElementById('stylize-mode') as HTMLSelectElement;
    const stylizeOutput = document.getElementById('stylize-output') as HTMLInputElement;
    const copyStylizedBtn = document.getElementById('copy-stylized-btn');

    // Bullet points Quick action buttons
    const bulletButtons = document.querySelectorAll('.bullet-btn');
    const doubleSpaceBtn = document.getElementById('double-space-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // LinkedIn mockup preview elements
    const visiblePreview = document.getElementById('preview-text-visible');
    const hiddenPreview = document.getElementById('preview-text-hidden');
    const seeMoreSpan = document.getElementById('preview-text-more');
    const copyFormattedBtn = document.getElementById('copy-formatted-btn');

    // Unicode mapping tables
    const unicodeMap = (text: string, mode: string) => {
      const maps: Record<string, { startA: number, starta: number }> = {
        'bold-sans': { startA: 0x1D5EA, starta: 0x1D604 },
        'bold-serif': { startA: 0x1D400, starta: 0x1D41A },
        'italic-sans': { startA: 0x1D670, starta: 0x1D68A },
        'italic-serif': { startA: 0x1D434, starta: 0x1D44E },
        'monospace': { startA: 0x1D670, starta: 0x1D68A } // fallback placeholder
      };

      if (mode === 'monospace') {
        // Monospace mapping
        return text.split('').map(char => {
          const code = char.charCodeAt(0);
          if (code >= 65 && code <= 90) return String.fromCodePoint(0x1D670 + (code - 65));
          if (code >= 97 && code <= 122) return String.fromCodePoint(0x1D68A + (code - 97));
          if (code >= 48 && code <= 57) return String.fromCodePoint(0x1D7F6 + (code - 48));
          return char;
        }).join('');
      }

      const cfg = maps[mode] || maps['bold-sans'];
      return text.split('').map(char => {
        const code = char.charCodeAt(0);
        if (code >= 65 && code <= 90) {
          return String.fromCodePoint(cfg.startA + (code - 65));
        }
        if (code >= 97 && code <= 122) {
          return String.fromCodePoint(cfg.starta + (code - 97));
        }
        return char;
      }).join('');
    };

    // Update Stylizer Output dynamically
    const updateStylizer = () => {
      const phrase = stylizeInput?.value || '';
      const mode = stylizeMode?.value || 'bold-sans';
      if (stylizeOutput) {
        stylizeOutput.value = phrase ? unicodeMap(phrase, mode) : '';
      }
    };

    stylizeInput?.addEventListener('input', updateStylizer);
    stylizeMode?.addEventListener('change', updateStylizer);

    // Copy Stylized phrase
    copyStylizedBtn?.addEventListener('click', () => {
      const styled = stylizeOutput?.value || '';
      if (!styled) return alert("Please type a phrase to stylize.");
      navigator.clipboard.writeText(styled).then(() => {
        const originalText = copyStylizedBtn.textContent;
        copyStylizedBtn.textContent = 'Copied! ✓';
        setTimeout(() => {
          copyStylizedBtn.textContent = originalText;
        }, 1500);
      });
    });

    // Cursor position helper for bullet point insertions
    const insertAtCursor = (textarea: HTMLTextAreaElement, value: string) => {
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const text = textarea.value;
      textarea.value = text.substring(0, start) + value + text.substring(end);
      textarea.selectionStart = textarea.selectionEnd = start + value.length;
      textarea.focus();
    };

    bulletButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const bullet = btn.getAttribute('data-bullet') || '';
        if (postInput) {
          insertAtCursor(postInput, bullet);
          updatePreview();
        }
      });
    });

    // Double Space line breaks
    doubleSpaceBtn?.addEventListener('click', () => {
      if (!postInput) return;
      const val = postInput.value;
      // Replace single linebreaks that aren't already double linebreaks with double linebreaks
      const cleaned = val.replace(/([^\n])\n([^\n])/g, '$1\n\n$2');
      postInput.value = cleaned;
      updatePreview();
    });

    const updatePreview = () => {
      const val = postInput?.value || '';
      const charCount = val.length;

      // Update Character limits
      if (charCountVal) {
        charCountVal.textContent = `${charCount} / 3000`;
        charCountVal.style.color = charCount > 3000 ? '#ef4444' : '';
      }

      // LinkedIn mockup see more layout logic (140 characters mobile fold)
      if (visiblePreview && hiddenPreview && seeMoreSpan) {
        if (val.length === 0) {
          visiblePreview.textContent = 'Your formatted post will preview here in real-time...';
          seeMoreSpan.style.display = 'none';
          hiddenPreview.style.display = 'none';
        } else if (val.length <= 140) {
          visiblePreview.textContent = val;
          seeMoreSpan.style.display = 'none';
          hiddenPreview.style.display = 'none';
        } else {
          visiblePreview.textContent = val.substring(0, 140);
          seeMoreSpan.style.display = 'inline';
          hiddenPreview.textContent = val.substring(140);
        }
      }
    };

    // Toggle expand mockup see more click
    seeMoreSpan?.addEventListener('click', () => {
      if (hiddenPreview && seeMoreSpan) {
        hiddenPreview.style.display = 'inline';
        seeMoreSpan.style.display = 'none';
      }
    });

    postInput?.addEventListener('input', updatePreview);

    // Copy formatted full text
    copyFormattedBtn?.addEventListener('click', () => {
      const text = postInput?.value || '';
      if (!text) return alert("Please enter some text in the post box first.");
      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyFormattedBtn.textContent;
        copyFormattedBtn.textContent = 'Post Copied! ✓';
        setTimeout(() => {
          copyFormattedBtn.textContent = originalText;
        }, 1500);
      });
    });

    // Reset Form
    resetBtn?.addEventListener('click', () => {
      if (postInput) postInput.value = '';
      if (stylizeInput) stylizeInput.value = '';
      if (stylizeOutput) stylizeOutput.value = '';
      updatePreview();
    });

    updatePreview();
  };

  setupLinkedinFormatter();
  document.addEventListener('astro:after-swap', setupLinkedinFormatter);
</script>
