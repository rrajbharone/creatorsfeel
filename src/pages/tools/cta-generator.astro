<script>
  const setupCtaGenerator = () => {
    const valueInput = document.getElementById('value-input') as HTMLInputElement;
    const formatSelect = document.getElementById('format-input') as HTMLSelectElement;
    const triggerSelect = document.getElementById('trigger-input') as HTMLSelectElement;
    const toneSelect = document.getElementById('tone-input') as HTMLSelectElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // Mockup elements
    const mockupCtaBtn = document.getElementById('mockup-cta-btn');
    const mockupSubtext = document.getElementById('mockup-subtext');

    // Sandbox workspace
    const sandboxInput = document.getElementById('sandbox-input') as HTMLTextAreaElement;
    const sandboxCounter = document.getElementById('sandbox-counter');
    const progressBarFill = document.getElementById('progress-bar-fill');
    const copyActiveBtn = document.getElementById('copy-active-btn');
    const clearSandboxBtn = document.getElementById('clear-sandbox-btn');

    // Alternative Displays
    const opt1Val = document.getElementById('opt-1-val');
    const opt2Val = document.getElementById('opt-2-val');
    const opt3Val = document.getElementById('opt-3-val');

    const opt1Badge = document.getElementById('opt-1-badge');
    const opt2Badge = document.getElementById('opt-2-badge');
    const opt3Badge = document.getElementById('opt-3-badge');

    // Live Sandbox update
    const updateSandbox = () => {
      const text = sandboxInput?.value || '';
      const len = text.length;

      // Update Mockup button text
      const format = formatSelect?.value || 'Button';
      if (mockupCtaBtn) {
        if (format === 'Button') {
          mockupCtaBtn.textContent = text || 'Get My Free Guide';
          mockupCtaBtn.style.textDecoration = 'none';
          mockupCtaBtn.style.background = 'var(--gradient-brand)';
          mockupCtaBtn.style.color = 'white';
        } else {
          // Link style
          mockupCtaBtn.textContent = text || 'Get My Free Guide';
          mockupCtaBtn.style.textDecoration = 'underline';
          mockupCtaBtn.style.background = 'transparent';
          mockupCtaBtn.style.color = 'var(--color-brand)';
        }
      }

      // Configure length threshold (buttons recommended under 30 characters, hooks under 80 characters)
      const maxLen = format === 'Button' ? 30 : 80;
      if (sandboxCounter) {
        sandboxCounter.textContent = `${len} / ${maxLen} Chars`;
        sandboxCounter.style.color = len > maxLen ? '#f59e0b' : 'var(--color-text-muted)';
      }

      // Update progress bar
      if (progressBarFill) {
        const percent = Math.min((len / maxLen) * 100, 100);
        progressBarFill.style.width = `${percent}%`;
        progressBarFill.style.backgroundColor = len > maxLen ? '#f59e0b' : 'var(--color-brand)';
      }
    };
    sandboxInput?.addEventListener('input', updateSandbox);

    // Dynamic generation
    const generateCta = () => {
      const val = (valueInput?.value || '').trim();
      const format = formatSelect?.value || 'Button';
      const trigger = triggerSelect?.value || 'Benefit';
      const tone = toneSelect?.value || 'Action';

      if (!val) {
        alert("Please specify the goal of your offer.");
        return;
      }

      let options = ['', '', ''];

      // Extract target noun by stripping leading action verbs
      const leadingVerbs = /^(download|get|start|join|buy|grab|claim|subscribe to|register for|schedule|book|unlock|see|reveal)\s+(my\s+|your\s+|the\s+)?/i;
      let noun = val;
      if (leadingVerbs.test(val)) {
        noun = val.replace(leadingVerbs, '').trim();
      }

      // Helper to capitalize words
      const capitalizeWords = (str: string) => {
        return str.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      };
      const capNoun = capitalizeWords(noun);
      const capVal = capitalizeWords(val);

      const hasVerb = /^(download|get|start|join|buy|grab|claim|subscribe|register|schedule|book|unlock|see|reveal)/i.test(val);

      // Dynamic templates mapping inputs
      if (format === 'Button') {
        if (trigger === 'Benefit') {
          options[0] = hasVerb ? capVal : `Get My ${capNoun}`;
          options[1] = `Start Growing My ${capNoun}`;
          options[2] = `Claim My ${capNoun} Now`;
        } else if (trigger === 'Urgency') {
          options[0] = hasVerb ? `${capVal} Today` : `Get ${capNoun} Today`;
          options[1] = `Download ${capNoun} Now (Ends Soon)`;
          options[2] = `Claim ${capNoun} Before Expiring`;
        } else if (trigger === 'Risk') {
          options[0] = `Get Free ${capNoun}`;
          options[1] = `Download ${capNoun} Free (No Signup)`;
          options[2] = `Get ${capNoun} (Cancel Anytime)`;
        } else { // Curiosity
          options[0] = `Reveal My ${capNoun}`;
          options[1] = `Unlock ${capNoun} Now`;
          options[2] = `See ${capNoun} Blueprint`;
        }
      } else if (format === 'Anchor') {
        options[0] = `👉 Click here to ${val.toLowerCase()} now.`;
        options[1] = `Join thousands of creators using this to ${val.toLowerCase()}.`;
        options[2] = `Get instant access to your ${noun} here.`;
      } else { // Social Media Hook
        options[0] = `Comment "${noun.toUpperCase()}" below and I'll send you the link! 👇`;
        options[1] = `Want to ${val.toLowerCase()}? Link is in my bio! 🚀`;
        options[2] = `Save this post and click the bio link to ${val.toLowerCase()}!`;
      }

      // Populate Sandbox with Option 1
      if (sandboxInput) {
        sandboxInput.value = options[0];
        updateSandbox();
      }

      // Update Suggestion displays
      const vals = [opt1Val, opt2Val, opt3Val];
      const badges = [opt1Badge, opt2Badge, opt3Badge];

      options.forEach((opt, idx) => {
        const vBlock = vals[idx];
        const bBlock = badges[idx];

        if (vBlock) vBlock.textContent = opt;
        if (bBlock) {
          const len = opt.length;
          const maxLen = format === 'Button' ? 30 : 80;
          bBlock.textContent = `${len} / ${maxLen}`;
          bBlock.style.color = len > maxLen ? '#f59e0b' : '';
        }
      });

      // Update subtext preview details
      if (mockupSubtext) {
        if (trigger === 'Risk') {
          mockupSubtext.textContent = '100% free download. No registration required.';
        } else if (trigger === 'Urgency') {
          mockupSubtext.textContent = 'Limited time offer. Download today.';
        } else {
          mockupSubtext.textContent = 'Join 4,200+ creators optimizing their channels.';
        }
      }

      // Scroll directly to the results / editor sandbox column
      const editorCol = document.querySelector('.calc-editor-column');
      if (editorCol) {
        editorCol.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    generateBtn?.addEventListener('click', generateCta);

    // Emoji picker click inserter
    const emojiContainer = document.getElementById('emoji-picker-container');
    emojiContainer?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.emoji-btn');
      if (!btn || !sandboxInput) return;
      
      const emoji = btn.textContent || '';
      const start = sandboxInput.selectionStart;
      const end = sandboxInput.selectionEnd;
      const val = sandboxInput.value;

      sandboxInput.value = val.substring(0, start) + emoji + val.substring(end);
      sandboxInput.selectionStart = sandboxInput.selectionEnd = start + emoji.length;
      sandboxInput.focus();
      updateSandbox();
    });

    // Load to sandbox buttons
    document.querySelectorAll('.load-sandbox-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId || !sandboxInput) return;
        const textBlock = document.getElementById(targetId);
        if (textBlock) {
          sandboxInput.value = textBlock.textContent || '';
          updateSandbox();
        }
      });
    });

    // Direct copies buttons
    document.querySelectorAll('.copy-direct-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId) return;
        const textBlock = document.getElementById(targetId);
        const text = textBlock?.textContent || '';
        if (!text) return;

        navigator.clipboard.writeText(text).then(() => {
          const originalText = btn.textContent;
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = originalText;
          }, 1500);
        });
      });
    });

    // Sandbox Copy
    copyActiveBtn?.addEventListener('click', () => {
      const text = sandboxInput?.value || '';
      if (!text) return alert("Sandbox editor is empty!");
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyActiveBtn.textContent;
        copyActiveBtn.textContent = 'Copied to Clipboard! ✓';
        setTimeout(() => {
          copyActiveBtn.textContent = originalText;
        }, 1500);
      });
    });

    // Clear Sandbox
    clearSandboxBtn?.addEventListener('click', () => {
      if (sandboxInput) {
        sandboxInput.value = '';
        updateSandbox();
      }
    });

    // Reset Fields
    resetBtn?.addEventListener('click', () => {
      if (valueInput) valueInput.value = '';
      if (sandboxInput) sandboxInput.value = '';
      updateSandbox();
    });

    // Initialize
    updateSandbox();
  };

  setupCtaGenerator();
  document.addEventListener('astro:after-swap', setupCtaGenerator);
</script>
