          </div>

          <!-- Content Column -->
          <div style="display: flex; flex-direction: column; gap: 0.25rem; width: 100%; min-width: 0;">
            <!-- Header (User handles) -->
            <div style="display: flex; align-items: center; justify-content: space-between; font-size: 0.85rem; font-weight: 700;">
