<script>
  const setupBlueskyCharacterCounter = () => {
    const valueInput = document.getElementById('value-input') as HTMLTextAreaElement;

    // Actions
    const copyBtn = document.getElementById('copy-btn');
    const clearBtn = document.getElementById('clear-btn');

    // Metrics elements
    const charBadge = document.getElementById('char-badge');
    const progressBarFill = document.getElementById('progress-bar-fill');
    
    // Stats cards
    const statsWords = document.getElementById('stats-words');
    const statsSpaces = document.getElementById('stats-spaces');
    const statsLinks = document.getElementById('stats-links');
    const statsLeft = document.getElementById('stats-left');

    // Mockup post text
    const mockupPostBody = document.getElementById('mockup-post-body');

    // Real-Time count checker
    const updateMetrics = () => {
      const text = valueInput?.value || '';
      const len = text.length;

      // 1. Calculate stats metrics
      const wordsCount = text.trim() === '' ? 0 : text.trim().split(/\s+/).length;
      const spacesCount = (text.match(/\s/g) || []).length;
      const linksCount = (text.match(/https?:\/\/[^\s]+|www\.[^\s]+|[a-zA-Z0-9-]+\.[a-zA-Z]{2,6}/g) || []).length;
      const leftCount = Math.max(300 - len, 0);

      // Update badge
      if (charBadge) {
        charBadge.textContent = `${len} / 300 Chars`;
        charBadge.style.background = len > 300 ? '#ef4444' : 'var(--color-brand)';
      }

      // Update visual progress bar fill
      if (progressBarFill) {
        const percent = Math.min((len / 300) * 100, 100);
        progressBarFill.style.width = `${percent}%`;
        progressBarFill.style.backgroundColor = len > 300 ? '#ef4444' : 'var(--color-brand)';
      }

      // Update Stats cards
      if (statsWords) statsWords.textContent = wordsCount.toString();
      if (statsSpaces) statsSpaces.textContent = spacesCount.toString();
      if (statsLinks) statsLinks.textContent = linksCount.toString();
      if (statsLeft) {
        statsLeft.textContent = leftCount.toString();
        statsLeft.style.color = len > 300 ? '#ef4444' : 'var(--color-text)';
      }

      // Update Mockup post body text
      if (mockupPostBody) {
        mockupPostBody.textContent = text || 'Start drafts here and watch them update live. #bluesky #seo';
      }
    };

    valueInput?.addEventListener('input', updateMetrics);

    // Emoji picker click inserter
    const emojiContainer = document.getElementById('emoji-picker-container');
    emojiContainer?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.emoji-btn');
      if (!btn || !valueInput) return;
      
      const emoji = btn.textContent || '';
      const start = valueInput.selectionStart;
      const end = valueInput.selectionEnd;
      const val = valueInput.value;

      valueInput.value = val.substring(0, start) + emoji + val.substring(end);
      valueInput.selectionStart = valueInput.selectionEnd = start + emoji.length;
      valueInput.focus();
      updateMetrics();
    });

    // Copy draft
    copyBtn?.addEventListener('click', () => {
      const text = valueInput?.value || '';
      if (!text) return alert("Write some text first!");
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyBtn.textContent;
        copyBtn.textContent = 'Post Copied! ✓';
        setTimeout(() => {
          copyBtn.textContent = originalText;
        }, 1500);
      });
    });

    // Clear draft
    clearBtn?.addEventListener('click', () => {
      if (valueInput) {
        valueInput.value = '';
        updateMetrics();
      }
    });

    // Initial check
    updateMetrics();
  };

  setupBlueskyCharacterCounter();
  document.addEventListener('astro:after-swap', setupBlueskyCharacterCounter);
</script>
