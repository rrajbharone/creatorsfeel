---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is the character limit on Bluesky?",
    answer: "The maximum limit for a single post on Bluesky is 300 characters. This is slightly longer than Twitter/X's 280-character limit for free accounts."
  },
  {
    question: "How do links affect the character count on Bluesky?",
    answer: "Unlike Twitter which counts all links as 23 characters, Bluesky counts the actual number of characters in the URL string unless you use link cards (rich cards) or the rich text facets API. Our tool counts the exact character length of URLs to be safe."
  },
  {
    question: "What happens if my post exceeds 300 characters?",
    answer: "If your post is longer than 300 characters, the Bluesky app will not allow you to publish it. You will need to shorten the text or split it into multiple posts to create a thread."
  },
  {
    question: "Does Bluesky support formatting like bold or italics?",
    answer: "No, Bluesky's editor does not natively support rich text formatting like bold or italics. However, you can use hashtags, mentions (@handle), and URLs which are converted into clickable links."
  },
  {
    question: "Is there a limit on how many links I can add?",
    answer: "There is no strict limit on the number of links you can add, but each character in the link counts toward your 300-character budget, leaving less space for your main text."
  }
];
---

<ToolLayout
  title="Bluesky Character Counter - Free Post Length Tracker"
  description="Audit your Bluesky posts with our free character limit tracker. Count characters, words, spaces, and parse links in real-time."
  toolName="Bluesky Character Counter"
  toolDescription="Write perfect Bluesky posts. Track the strict 300-character budget in real-time, view stats for words and spaces, and preview your post layout."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Input text area and counter details -->
      <div class="calc-form-column">
        <div class="calc-form">
          <!-- Text Input Workspace -->
          <div class="form-group">
            <label for="value-input" class="icon-label" style="justify-content: space-between;">
