            <button type="button" id="copy-btn" class="calc-btn">Copy Post Text</button>
            <button type="button" id="clear-btn" class="calc-btn-secondary">Clear Text</button>
          </div>
        </div>
      </div>

      <!-- Right Column: Interactive Mockup & Stats counters -->
      <div class="calc-editor-column">
        <!-- Live Bluesky Post Preview Mockup -->
        <div class="bluesky-mockup glass" style="background: #ffffff; color: #0b0f14; border-radius: 20px; padding: 1.25rem; display: flex; gap: 0.75rem; text-align: left; box-shadow: var(--shadow-sm); max-width: 340px; margin: 0 auto; width: 100%; border: 1px solid #e1e8ed;">
