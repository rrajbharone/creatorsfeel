<script>
  const setupTimestampGenerator = () => {
    const activeModeInput = document.getElementById('active-mode') as HTMLInputElement;
    const modeTabs = document.querySelectorAll('.mode-tab');

    // Tab sections refs
    const chaptersBox = document.getElementById('inputs-chapters-box');
    const linkBox = document.getElementById('inputs-link-box');
    const rowsContainer = document.getElementById('chapters-rows-container');

    const addRowBtn = document.getElementById('add-row-btn');
    const submitBtn = document.getElementById('calc-submit-btn');
    const resetBtn = document.getElementById('calc-reset-btn');
    const copyBtn = document.getElementById('copy-output-btn');

    // Outputs refs
    const emptyBox = document.getElementById('res-empty-box');
    const activeBox = document.getElementById('res-active-box');
    const statusTitleVal = document.getElementById('res-status-title');
    const statusDescVal = document.getElementById('res-status-desc');
    const outputTitleVal = document.getElementById('res-output-title');
    const textOutputVal = document.getElementById('res-text-output') as HTMLTextAreaElement;

    // Link tab specific inputs
    const linkUrlInput = document.getElementById('video-url') as HTMLInputElement;
    const linkHoursInput = document.getElementById('link-hours') as HTMLInputElement;
    const linkMinutesInput = document.getElementById('link-minutes') as HTMLInputElement;
    const linkSecondsInput = document.getElementById('link-seconds') as HTMLInputElement;

    // Add a single chapter row UI helper
    const createRowElement = (minutes = '', seconds = '', title = '') => {
      const div = document.createElement('div');
      div.className = 'chapter-row';
      div.innerHTML = `
        <input type="number" class="form-input row-input row-min" placeholder="Min" min="0" value="${minutes}" required />
        <input type="number" class="form-input row-input row-sec" placeholder="Sec" min="0" max="59" value="${seconds}" required />
        <input type="text" class="form-input row-input row-title" placeholder="e.g., Intro" value="${title}" required />
        <button type="button" class="delete-row-btn">&times;</button>
      `;

      // Handle delete button
      div.querySelector('.delete-row-btn')?.addEventListener('click', () => {
        div.remove();
        // If empty, add a default row
        if (rowsContainer && rowsContainer.children.length === 0) {
          addRowUI();
        }
      });

      return div;
    };

    const addRowUI = (min = '', sec = '', title = '') => {
      if (rowsContainer) {
        rowsContainer.appendChild(createRowElement(min, sec, title));
      }
    };

    // Mode tab toggle logic
    modeTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        modeTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const mode = tab.getAttribute('data-mode') || 'chapters';
        if (activeModeInput) activeModeInput.value = mode;

        if (mode === 'chapters') {
          chaptersBox?.classList.remove('hidden');
          linkBox?.classList.add('hidden');
        } else {
          chaptersBox?.classList.add('hidden');
          linkBox?.classList.remove('hidden');
        }

        resetCalculator(false);
      });
    });

    addRowBtn?.addEventListener('click', () => addRowUI());

    const resetCalculator = (clearInputs = true) => {
      if (clearInputs) {
        if (rowsContainer) rowsContainer.innerHTML = '';
        addRowUI('0', '00', 'Introduction');
        addRowUI('1', '30', 'Main Topic');
        addRowUI('3', '00', 'Outro');

        if (linkUrlInput) linkUrlInput.value = '';
        if (linkHoursInput) linkHoursInput.value = '0';
        if (linkMinutesInput) linkMinutesInput.value = '0';
        if (linkSecondsInput) linkSecondsInput.value = '0';
      }

      if (emptyBox) emptyBox.classList.remove('hidden');
      if (activeBox) activeBox.classList.add('hidden');
    };

    const generateOutput = () => {
      const mode = activeModeInput?.value || 'chapters';

      if (mode === 'chapters') {
        // Collect rows
        const rows = document.querySelectorAll('.chapter-row');
        const chaptersList: { seconds: number; text: string }[] = [];
        let formatError = false;

        rows.forEach(row => {
          const minVal = parseInt((row.querySelector('.row-min') as HTMLInputElement)?.value) || 0;
          const secVal = parseInt((row.querySelector('.row-sec') as HTMLInputElement)?.value) || 0;
          const titleText = (row.querySelector('.row-title') as HTMLInputElement)?.value.trim() || '';

          if (!titleText) {
            formatError = true;
            return;
          }

          const totalSeconds = (minVal * 60) + secVal;
          const formattedTime = `${minVal.toString().padStart(2, '0')}:${secVal.toString().padStart(2, '0')}`;
          
          chaptersList.push({
            seconds: totalSeconds,
            text: `${formattedTime} ${titleText}`
          });
        });

        if (formatError || chaptersList.length === 0) {
          return alert("Please fill in all chapter titles and time fields.");
        }

        // Validate rules
        let isValid = true;
        let warningDesc = "All checks passed. Chapters are chronological.";

        // Sort chapters check
        for (let i = 1; i < chaptersList.length; i++) {
          if (chaptersList[i].seconds <= chaptersList[i - 1].seconds) {
            isValid = false;
            warningDesc = "Error: Chapters must be listed in chronological order.";
            break;
          }
        }

        // 00:00 check
        const hasZeroAnchor = chaptersList.some(ch => ch.seconds === 0);
        if (!hasZeroAnchor) {
          isValid = false;
          warningDesc = "Warning: First chapter must start at 00:00 for YouTube player compatibility.";
        }

        // Render Outputs
        if (emptyBox) emptyBox.classList.add('hidden');
        if (activeBox) activeBox.classList.remove('hidden');

        if (statusTitleVal) statusTitleVal.textContent = isValid ? "Pass" : "Warning";
        if (statusDescVal) {
          statusDescVal.textContent = warningDesc;
          statusDescVal.className = isValid ? "grade-badge grade-low" : "grade-badge";
          statusDescVal.style.color = isValid ? "" : "var(--color-danger)";
          statusDescVal.style.background = isValid ? "" : "rgba(220, 38, 38, 0.1)";
        }

        if (outputTitleVal) outputTitleVal.textContent = "Formatted Description Chapters:";
        if (textOutputVal) {
          textOutputVal.value = chaptersList.map(ch => ch.text).join('\n');
        }
      } else {
        // Link mode URL parsing
        const rawUrl = linkUrlInput?.value.trim() || '';
        if (!rawUrl) {
          return alert("Please enter a valid YouTube video URL.");
        }

        const hrs = parseInt(linkHoursInput?.value) || 0;
        const mins = parseInt(linkMinutesInput?.value) || 0;
        const secs = parseInt(linkSecondsInput?.value) || 0;

        const totalSecs = (hrs * 3600) + (mins * 60) + secs;
        if (totalSecs <= 0) {
          return alert("Please enter a target time greater than 0 seconds.");
        }

        // Simple video ID extractor regex
        // Handles youtube.com/watch?v=ID, youtu.be/ID, youtube.com/shorts/ID
        let videoId = '';
        const match = rawUrl.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/ ]{11})/i);
        if (match && match[1]) {
          videoId = match[1];
        } else {
          return alert("Invalid YouTube URL. Please use standard video link share structures.");
        }

        const isShortDomain = rawUrl.includes('youtu.be/');
        let finalShareUrl = "";

        if (isShortDomain) {
          finalShareUrl = `https://youtu.be/${videoId}?t=${totalSecs}`;
        } else {
          finalShareUrl = `https://www.youtube.com/watch?v=${videoId}&t=${totalSecs}s`;
        }

        // Render Outputs
        if (emptyBox) emptyBox.classList.add('hidden');
        if (activeBox) activeBox.classList.remove('hidden');

        if (statusTitleVal) statusTitleVal.textContent = "URL Generated";
        if (statusDescVal) {
          statusDescVal.textContent = `Target time: ${hrs > 0 ? hrs + 'h ' : ''}${mins}m ${secs}s`;
          statusDescVal.className = "grade-badge grade-low";
          statusDescVal.style.color = "";
          statusDescVal.style.background = "";
        }

        if (outputTitleVal) outputTitleVal.textContent = "Share Link with Timestamp Parameter:";
        if (textOutputVal) {
          textOutputVal.value = finalShareUrl;
        }
      }

      // Smooth scroll to the results section
      const resultsWrapper = document.getElementById('results-wrapper');
      if (resultsWrapper) {
        resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    const copyOutputToClipboard = () => {
      if (!textOutputVal || !textOutputVal.value) return;
      
      navigator.clipboard.writeText(textOutputVal.value).then(() => {
        const originalHTML = copyBtn ? copyBtn.innerHTML : '';
        if (copyBtn) {
          copyBtn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="var(--color-success)" style="width: 16px; height: 16px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span style="color: var(--color-success)">Copied!</span>
          `;
          setTimeout(() => {
            copyBtn.innerHTML = originalHTML;
          }, 2000);
        }
      });
    };

    // Initialize with 3 default rows
    resetCalculator(true);

    submitBtn?.addEventListener('click', generateOutput);
    resetBtn?.addEventListener('click', () => resetCalculator(true));
    copyBtn?.addEventListener('click', copyOutputToClipboard);
  };

  setupTimestampGenerator();
  document.addEventListener('astro:after-swap', setupTimestampGenerator);
</script>
