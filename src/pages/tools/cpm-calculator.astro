<script>
  const setupCpmCalculator = () => {
    // DOM selectors
    const tabs = document.querySelectorAll('.mode-tab');
    const costGroup = document.getElementById('cost-group');
    const impressionsGroup = document.getElementById('impressions-group');
    const cpmGroup = document.getElementById('cpm-group');
    const activeModeInput = document.getElementById('active-mode') as HTMLInputElement;

    const costInput = document.getElementById('campaign-cost') as HTMLInputElement;
    const impressionsInput = document.getElementById('total-impressions') as HTMLInputElement;
    const cpmInput = document.getElementById('cpm-rate') as HTMLInputElement;

    const submitBtn = document.getElementById('calc-submit-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    const emptyBox = document.getElementById('res-empty-box');
    const activeBox = document.getElementById('res-active-box');

    const resPrimaryLabel = document.getElementById('res-primary-label');
    const resPrimaryVal = document.getElementById('res-primary-val');
    const resBenchmarkBadge = document.getElementById('res-benchmark-badge');

    const breakdown1 = document.getElementById('breakdown-1');
    const breakdown100 = document.getElementById('breakdown-100');
    const breakdown1000 = document.getElementById('breakdown-1000');
    const breakdown10000 = document.getElementById('breakdown-10000');
    const breakdown100000 = document.getElementById('breakdown-100000');

    const resInsightTitle = document.getElementById('res-insight-title');
    const resInsightDesc = document.getElementById('res-insight-desc');

    if (!submitBtn || !resetBtn) return;

    // Toggle Modes
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');

        const mode = tab.getAttribute('data-mode') || 'cpm';
        if (activeModeInput) activeModeInput.value = mode;

        // Reset display states
        costGroup?.classList.remove('hidden');
        impressionsGroup?.classList.remove('hidden');
        cpmGroup?.classList.remove('hidden');

        // Required updates
        if (costInput) costInput.required = false;
        if (impressionsInput) impressionsInput.required = false;
        if (cpmInput) cpmInput.required = false;

        if (mode === 'cpm') {
          cpmGroup?.classList.add('hidden');
          if (costInput) costInput.required = true;
          if (impressionsInput) impressionsInput.required = true;
        } else if (mode === 'cost') {
          costGroup?.classList.add('hidden');
          if (cpmInput) cpmInput.required = true;
          if (impressionsInput) impressionsInput.required = true;
        } else if (mode === 'impressions') {
          impressionsGroup?.classList.add('hidden');
          if (costInput) costInput.required = true;
          if (cpmInput) cpmInput.required = true;
        }

        // Hide old results
        activeBox?.classList.add('hidden');
        emptyBox?.classList.remove('hidden');
      });
    });

    // Reset Form
    resetBtn.addEventListener('click', () => {
      if (costInput) costInput.value = '';
      if (impressionsInput) impressionsInput.value = '';
      if (cpmInput) cpmInput.value = '';
      activeBox?.classList.add('hidden');
      emptyBox?.classList.remove('hidden');
    });

    // Perform Calculations
    const runCalculation = (showErrors = true) => {
      const mode = activeModeInput ? activeModeInput.value : 'cpm';
      
      const cost = parseFloat(costInput?.value || '0');
      const impressions = parseInt(impressionsInput?.value || '0', 10);
      const cpm = parseFloat(cpmInput?.value || '0');

      let computedCpm = 0;
      let computedCost = 0;
      let computedImpressions = 0;

      if (mode === 'cpm') {
        if (!cost || !impressions || impressions <= 0) {
          if (showErrors) alert('Please enter a valid campaign cost and positive impressions.');
          return;
        }
        computedCpm = (cost / impressions) * 1000;
        computedCost = cost;
        computedImpressions = impressions;

        if (resPrimaryLabel) resPrimaryLabel.textContent = 'Calculated CPM';
        if (resPrimaryVal) resPrimaryVal.textContent = `$${computedCpm.toFixed(2)}`;
      } else if (mode === 'cost') {
        if (!cpm || !impressions || impressions <= 0 || cpm <= 0) {
          if (showErrors) alert('Please enter a valid CPM rate and positive impressions.');
          return;
        }
        computedCost = (impressions * cpm) / 1000;
        computedCpm = cpm;
        computedImpressions = impressions;

        if (resPrimaryLabel) resPrimaryLabel.textContent = 'Estimated Cost';
        if (resPrimaryVal) resPrimaryVal.textContent = `$${computedCost.toFixed(2)}`;
      } else if (mode === 'impressions') {
        if (!cost || !cpm || cost <= 0 || cpm <= 0) {
          if (showErrors) alert('Please enter a valid campaign budget and CPM rate.');
          return;
        }
        computedImpressions = Math.round((cost / cpm) * 1000);
        computedCpm = cpm;
        computedCost = cost;

        if (resPrimaryLabel) resPrimaryLabel.textContent = 'Calculated Impressions';
        if (resPrimaryVal) resPrimaryVal.textContent = computedImpressions.toLocaleString();
      }

      // 1. Benchmark rating for CPM
      if (resBenchmarkBadge) {
        if (computedCpm < 5.00) {
          resBenchmarkBadge.textContent = 'Low CPM';
          resBenchmarkBadge.style.color = 'var(--color-success)';
        } else if (computedCpm >= 5.00 && computedCpm <= 15.00) {
          resBenchmarkBadge.textContent = 'Average CPM';
          resBenchmarkBadge.style.color = 'var(--color-brand)';
        } else {
          resBenchmarkBadge.textContent = 'High CPM';
          resBenchmarkBadge.style.color = 'var(--color-warning)';
        }
      }

      // 2. Breakdown calculations
      const costPerImpression = computedCost / computedImpressions;
      if (breakdown1) breakdown1.textContent = `$${costPerImpression.toFixed(4)}`;
      if (breakdown100) breakdown100.textContent = `$${(costPerImpression * 100).toFixed(4)}`;
      if (breakdown1000) breakdown1000.textContent = `$${computedCpm.toFixed(2)}`;
      if (breakdown10000) breakdown10000.textContent = `$${(computedCpm * 10).toFixed(2)}`;
      if (breakdown100000) breakdown100000.textContent = `$${(computedCpm * 100).toFixed(2)}`;

      // 3. Update Analyst Insights
      if (resInsightTitle && resInsightDesc) {
        resInsightTitle.textContent = 'CreatorsFeel Ad Analyst Insights';
        
        let insight = '';
        if (computedCpm < 5) {
          insight = `A CPM of $${computedCpm.toFixed(2)} is highly cost-efficient. This is typical for broad-interest Facebook/Instagram campaigns targeting Tier 2 or Tier 3 countries. To maintain this, focus on optimizing your click-through rate (CTR).`;
        } else if (computedCpm >= 5 && computedCpm <= 15) {
          insight = `A CPM of $${computedCpm.toFixed(2)} falls within the standard global average. This rate is healthy for targeted demographic advertising on YouTube or standard B2C interest channels.`;
        } else {
          insight = `A CPM of $${computedCpm.toFixed(2)} is premium. This is common in finance, business software (SaaS), healthcare, or micro-targeted campaigns. Ensure your landing pages are optimized to capture leads and justify this cost.`;
        }
        resInsightDesc.textContent = insight;
      }

      // Swap views
      emptyBox?.classList.add('hidden');
      activeBox?.classList.remove('hidden');
    };

    // Calculate on submit click
    submitBtn.addEventListener('click', () => {
      runCalculation(true);
      setTimeout(() => {
        const resultsBox = document.getElementById('results-wrapper');
        if (resultsBox && !resultsBox.classList.contains('hidden')) {
          const headerOffset = 90;
          const elementPosition = resultsBox.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        }
      }, 50);
    });

    // Calculate on real-time typing inputs
    [costInput, impressionsInput, cpmInput].forEach(input => {
      input?.addEventListener('input', () => runCalculation(false));
    });
  };

  setupCpmCalculator();
  document.addEventListener('astro:after-swap', setupCpmCalculator);
</script>
