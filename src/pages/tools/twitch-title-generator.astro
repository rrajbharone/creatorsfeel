<script>
  const setupTwitchTitleGenerator = () => {
    const seedInput = document.getElementById('seed-input') as HTMLInputElement;
    const nicheSelect = document.getElementById('niche-select') as HTMLSelectElement;
    const hookSelect = document.getElementById('hook-select') as HTMLSelectElement;

    // Toggles
    const emojiCheck = document.getElementById('emoji-check') as HTMLInputElement;
    const tagsCheck = document.getElementById('tags-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');
    const generateMoreBtn = document.getElementById('generate-more-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-titles-container');

    // Mockup targets
    const mockupStreamTitle = document.getElementById('mockup-stream-title');
    const mockupStreamGame = document.getElementById('mockup-stream-game');

    // Title construction pools
    const nichesData: Record<string, { baseHooks: string[], emojis: string[], tags: string[] }> = {
      gaming: {
        baseHooks: [
          `Grinding Ranked! Road to top ranks`,
          `Radiant lobby grind. Can we win?`,
          `No backseating, full focus run`,
          `Ranked games only! Streaming live`,
          `Pro matches today. Live highlights`
        ],
        emojis: ['🚀', '🔥', '🏆', '🎮', '💀', '💥'],
        tags: ['[DropsOn]', '[ENG]', '[NoBackseating]', '[PC]', '[Cozy]']
      },
      casual: {
        baseHooks: [
          `First playthrough! Cozy gaming session`,
          `Chill walkthrough. Taking it slow`,
          `Sunday casual streams. Grab a coffee`,
          `Exploring the map! Open lobby session`,
          `Just relaxing with some offline games`
        ],
        emojis: ['☁️', '☕', '✿', '🌱', '🎮', '💫'],
        tags: ['[ENG]', '[Chill]', '[Casual]', '[NewGame]', '[100%]']
      },
      cozy: {
        baseHooks: [
          `Just Chatting! Sunday tea time talk`,
          `AMA and chill discussions with chat`,
          `Reacting to top clips of the week`,
          `Let's talk about tech, music, and life`,
          `Late night cozy vibes, quiet talks`
        ],
        emojis: ['☕', '☁️', '✿', '🌸', '✨', '💛'],
        tags: ['[JustChatting]', '[Cozy]', '[ENG]', '[AMA]', '[VibeCheck]']
      },
      creative: {
        baseHooks: [
          `Developing clean apps in Rust / TS`,
          `Coding tools today. Open source building`,
          `Designing UI screens. Photoshop grind`,
          `Live coding sessions. Ask coding questions`,
          `Pixel art stream! Sketching assets`
        ],
        emojis: ['💻', '🎨', '⚙️', '💡', '✍️', '🚀'],
        tags: ['[Coding]', '[Dev]', '[Art]', '[UI]', '[OpenSource]']
      },
      funny: {
        baseHooks: [
          `Trolling public lobbies. Fun games`,
          `Playing terribly so you feel better`,
          `Troll builds only. Laughs guaranteed`,
          `Ranked but we are playing blindfolded`,
