    const hooksData: Record<string, string[]> = {
      none: [''],
      hype: ['[INSANE]', '[OMG]', '[HYPE]', '[MUST WATCH]', '[UNBELIEVABLE]'],
      question: ['Are we Radiant yet?', 'Can we clear this level?', 'Is this the best weapon?', 'Why does this happen?', 'How did we win this?'],
      challenge: ['[100% Completion]', '[Speedrun]', '[No Damage Run]', '[Hardcore Mode]', '[Permadeath]']
    };

    let currentShuffledPool: string[] = [];
    let currentPoolIndex = 0;

    const buildShuffledPool = () => {
      const topic = (seedInput?.value || '').trim();
      const niche = nicheSelect?.value || 'gaming';
      const hookType = hookSelect?.value || 'none';

      const includeEmojis = emojiCheck?.checked;
      const includeTags = tagsCheck?.checked;

      const nData = nichesData[niche] || nichesData['gaming'];
      const hData = hooksData[hookType] || hooksData['none'];

      const generatedSet = new Set<string>();

      const applyFormat = (hookPrefix: string, base: string, randEmoji: string, tag1: string, tag2: string) => {
        let text = '';
        const topicString = topic || 'Just Chatting';

        // Mix and match prefixes & suffixes
        if (hookType === 'hype') {
          text = `${hookPrefix} ${base} in ${topicString}`;
        } else if (hookType === 'question') {
          text = `${hookPrefix} // ${topicString} gameplay`;
        } else if (hookType === 'challenge') {
          text = `${hookPrefix} - ${base} (${topicString})`;
        } else {
          text = `${base} - ${topicString}`;
        }

        // Apply emoji
        if (includeEmojis && randEmoji) {
          text = `${text} ${randEmoji}`;
        }

        // Apply bracket tags
        if (includeTags && tag1) {
          text = `${text} ${tag1}`;
          if (tag2 && Math.random() > 0.5) {
            text = `${text} ${tag2}`;
          }
        }

        // Trim to Twitch maximum character rules
        return text.trim().substring(0, 140);
      };

      // Generate a pool of 50 possible unique variations
      let iterations = 0;
      while (generatedSet.size < 50 && iterations < 300) {
        iterations++;
        const bIndex = Math.floor(Math.random() * nData.baseHooks.length);
        const hIndex = Math.floor(Math.random() * hData.length);
        const eIndex = Math.floor(Math.random() * nData.emojis.length);
        const t1Index = Math.floor(Math.random() * nData.tags.length);
        const t2Index = Math.floor(Math.random() * nData.tags.length);

        const base = nData.baseHooks[bIndex] || '';
        const prefix = hData[hIndex] || '';
        const emojiVal = nData.emojis[eIndex] || '';
        const tag1 = nData.tags[t1Index] || '';
        const tag2 = nData.tags[t2Index] !== tag1 ? nData.tags[t2Index] : '';

        const formatted = applyFormat(prefix, base, emojiVal, tag1, tag2);
        if (formatted.length >= 5) {
          generatedSet.add(formatted);
        }
      }

      currentShuffledPool = Array.from(generatedSet).sort(() => Math.random() - 0.5);
      currentPoolIndex = 0;
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledPool();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      if (container) {
        container.innerHTML = selected.map(s => {
          return `
            <div class="title-chip" data-name="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
        }).join('');
      }

      resultsWrapper?.classList.remove('hidden');

      // Default the mockup title to the first generated result
      if (mockupStreamTitle && selected.length > 0) {
        mockupStreamTitle.textContent = selected[0];
      }
      if (mockupStreamGame) {
        mockupStreamGame.textContent = (seedInput?.value || '').trim() || 'Just Chatting';
      }
    };

    // Append 5 more unique titles
    const appendMoreTitles = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledPool();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledPool();
      }

      const next = currentShuffledPool.slice(currentPoolIndex, currentPoolIndex + 5);
      currentPoolIndex += 5;

      if (container) {
        const appendHtml = next.map(s => {
          return `
            <div class="title-chip" data-name="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
        }).join('');
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    generateMoreBtn?.addEventListener('click', () => {
      appendMoreTitles();
    });

    // Handle copying individual title chips and update mockup preview
    container?.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest('.title-chip');
      if (!chip) return;

      const titleVal = chip.getAttribute('data-name') || '';

      // Update mockup sidebar
      if (mockupStreamTitle) {
        mockupStreamTitle.textContent = titleVal;
      }

      // Copy to clipboard
      navigator.clipboard.writeText(titleVal).then(() => {
        const btn = chip.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy';
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener('click', () => {
      if (seedInput) seedInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-generate initial list
    generateList();
  };

  setupTwitchTitleGenerator();
  document.addEventListener('astro:after-swap', setupTwitchTitleGenerator);
</script>
