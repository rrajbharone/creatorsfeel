    .rate-range-box {
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      border-radius: 0 !important;
      box-shadow: none !important;
      width: 100% !important;
      border-bottom: 1px dashed var(--color-border) !important;
      padding-bottom: 1rem !important;
      align-items: center !important;
    }
  }

  @media (min-width: 768px) {
    .form-row-2 {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .calc-grid {
      grid-template-columns: 1.2fr 1fr;
      align-items: start;
      gap: 2.5rem;
    }
  }
</style>

<script>
  const setupRoiCalculator = () => {
    // Mode selectors
    const modeTabs = document.querySelectorAll('.mode-tab');
    const activeModeInput = document.getElementById('active-mode') as HTMLInputElement;

    // Inputs groups box references
    const salesGroup = document.getElementById('inputs-sales-box');
    const awarenessGroup = document.getElementById('inputs-awareness-box');

    // Cost Fields
    const feeField = document.getElementById('influencer-fee') as HTMLInputElement;
    const additionalCostsField = document.getElementById('additional-costs') as HTMLInputElement;

    // Sales Fields
    const conversionsField = document.getElementById('conversions-count') as HTMLInputElement;
    const aovField = document.getElementById('avg-order-value') as HTMLInputElement;

    // Awareness Fields
    const impressionsField = document.getElementById('impressions-count') as HTMLInputElement;
    const engagementsField = document.getElementById('engagements-count') as HTMLInputElement;
    const clicksField = document.getElementById('clicks-count') as HTMLInputElement;

    // Buttons
    const submitBtn = document.getElementById('calc-submit-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // Output views
    const emptyBox = document.getElementById('res-empty-box');
    const activeBox = document.getElementById('res-active-box');

    const roiVal = document.getElementById('res-roi-val');
    const statusBadge = document.getElementById('res-status-badge');
    const spendVal = document.getElementById('res-spend-val');
    const returnLabel = document.getElementById('res-return-label');
    const returnVal = document.getElementById('res-return-val');
    const profitVal = document.getElementById('res-profit-val');

    // Dynamic helper rows
    const helperRow = document.getElementById('res-helper-row');
    const helperLabel = document.getElementById('res-helper-label');
    const helperVal = document.getElementById('res-helper-val');

    // Mode tab toggle logic
    modeTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        modeTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const mode = tab.getAttribute('data-mode') || 'sales';
        if (activeModeInput) activeModeInput.value = mode;

        if (mode === 'sales') {
          salesGroup?.classList.remove('hidden');
          awarenessGroup?.classList.add('hidden');
        } else {
          salesGroup?.classList.add('hidden');
          awarenessGroup?.classList.remove('hidden');
        }

        resetCalculator(false);
      });
    });

    const calculateRoi = () => {
      const mode = activeModeInput?.value || 'sales';
      const fee = parseFloat(feeField?.value) || 0;
      const additional = parseFloat(additionalCostsField?.value) || 0;
      const totalCost = fee + additional;

      if (fee <= 0 && additional <= 0) {
        return alert("Please enter your campaign fee or additional costs.");
      }

      let revenue = 0;
      let helperText = "";
      let helperResultVal = "";
      let showHelper = false;

      if (mode === 'sales') {
        const convs = parseFloat(conversionsField?.value) || 0;
        const aov = parseFloat(aovField?.value) || 0;

        if (convs < 0 || aov < 0) {
          return alert("Please enter valid conversions and order values.");
        }

        revenue = convs * aov;
        showHelper = convs > 0;
        helperText = "Customer Acquisition Cost (CAC):";
        helperResultVal = `$${(totalCost / convs).toFixed(2)}`;

      } else {
        const imps = parseFloat(impressionsField?.value) || 0;
        const engs = parseFloat(engagementsField?.value) || 0;
        const clicks = parseFloat(clicksField?.value) || 0;

        if (imps < 0 || engs < 0 || clicks < 0) {
          return alert("Please enter valid impressions, engagements, and clicks.");
        }

        // EMV formulation standard
        // Impressions at $15 CPM ($0.015 each), Engagements at $0.15 CPE each, Clicks at $1.00 CPC each
        revenue = (imps * 0.015) + (engs * 0.15) + (clicks * 1.0);
        showHelper = clicks > 0;
        helperText = "Effective Cost Per Click (eCPC):";
        helperResultVal = `$${(totalCost / clicks).toFixed(2)}`;
      }

      const profit = revenue - totalCost;
      let roiPercent = 0;
      if (totalCost > 0) {
        roiPercent = (profit / totalCost) * 100;
      } else {
        roiPercent = revenue > 0 ? 100 : 0;
      }

      // Activate box displays
      if (emptyBox) emptyBox.classList.add('hidden');
      if (activeBox) activeBox.classList.remove('hidden');

      // Update basic fields
      if (spendVal) spendVal.textContent = `$${totalCost.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
      
      if (returnLabel) {
        returnLabel.textContent = mode === 'sales' ? "Total Revenue:" : "Earned Media Value (EMV):";
      }
      if (returnVal) {
        returnVal.textContent = `$${revenue.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
      }

      // Update Profit Value
      if (profitVal) {
        if (profit >= 0) {
          profitVal.textContent = `$${profit.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
          profitVal.style.color = "var(--color-success)";
        } else {
          profitVal.textContent = `-$${Math.abs(profit).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
          profitVal.style.color = "var(--color-danger)";
        }
      }

      // Update ROI display
      if (roiVal) {
        const sign = roiPercent >= 0 ? "+" : "";
        roiVal.textContent = `${sign}${roiPercent.toFixed(2)}%`;
        if (roiPercent > 10) {
          roiVal.style.color = "var(--color-success)";
        } else if (roiPercent >= -10) {
          roiVal.style.color = "var(--color-warning)";
        } else {
          roiVal.style.color = "var(--color-danger)";
        }
      }

      // ROI Status Badge
      if (statusBadge) {
        statusBadge.className = 'grade-badge';
        if (roiPercent > 20) {
          statusBadge.textContent = "High ROI";
          statusBadge.classList.add('grade-high');
        } else if (roiPercent >= -10) {
          statusBadge.textContent = "Break-Even / Healthy";
          statusBadge.classList.add('grade-medium');
        } else {
          statusBadge.textContent = "Negative ROI";
          statusBadge.classList.add('grade-low');
        }
      }

      // Dynamic helpers CAC/CPC row
      if (helperRow) {
        if (showHelper) {
          helperRow.style.display = 'flex';
          if (helperLabel) helperLabel.textContent = helperText;
          if (helperVal) helperVal.textContent = helperResultVal;
        } else {
          helperRow.style.display = 'none';
        }
      }

      // Smooth scroll to the results section
      const resultsWrapper = document.getElementById('results-wrapper');
      if (resultsWrapper) {
        resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    const resetCalculator = (clearInputs = true) => {
      if (clearInputs) {
        if (feeField) feeField.value = '';
        if (additionalCostsField) additionalCostsField.value = '0';
        if (conversionsField) conversionsField.value = '';
        if (aovField) aovField.value = '';
        if (impressionsField) impressionsField.value = '';
        if (engagementsField) engagementsField.value = '';
        if (clicksField) clicksField.value = '';
      }

      if (emptyBox) emptyBox.classList.remove('hidden');
      if (activeBox) activeBox.classList.add('hidden');
    };

    submitBtn?.addEventListener('click', calculateRoi);
    resetBtn?.addEventListener('click', () => resetCalculator(true));
  };

  setupRoiCalculator();
  document.addEventListener('astro:after-swap', setupRoiCalculator);
</script>
