    padding: 2.5rem !important;
    border-radius: 24px !important;
    box-sizing: border-box;
    max-width: 100%;
  }

  .calculator-mode-selector {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    background: var(--color-bg-alt);
    padding: 0.35rem;
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .mode-tab {
    flex: 1;
    text-align: center;
    padding: 0.6rem 0.5rem;
    font-size: 0.88rem;
    font-weight: 600;
