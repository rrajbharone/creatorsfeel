          <!-- Visual character progress bar -->
          <div class="progress-bar-container" style="background: var(--color-border); height: 6px; border-radius: 4px; overflow: hidden; margin: 0.5rem 0;">
            <div id="progress-bar-fill" style="width: 9.6%; height: 100%; background: var(--color-brand); transition: all var(--transition-fast);"></div>
