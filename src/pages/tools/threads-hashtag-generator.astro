---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "Does Threads support hashtags?",
    answer: "Yes. Threads allows users to tag their posts. Unlike Instagram where you can add up to 30 tags, Threads natively converts hashtags into clickable blue topic links. In addition, you can add single tags without the hash symbol using their native tag feature."
  },
  {
    question: "How many tags should I add to a Threads post?",
    answer: "Threads recommends focusing on 1 to 3 highly targeted tags per post. Adding too many tags can clutter your layout and reduce readability, which affects user engagement."
  },
  {
    question: "What is the character limit for a Threads post?",
    answer: "The character limit for a single post on Threads is 500 characters. Our sandbox editor includes a real-time character tracker to help you stay within this limit."
  },
  {
    question: "Are tags on Threads clickable?",
    answer: "Yes, tags are clickable. When a user clicks a tag on Threads, they are taken to a search results feed containing other posts using the same tag."
  },
  {
    question: "Should I place tags inside the text or at the bottom?",
    answer: "Both methods work. Placing tags at the end of your post keeps the copy clean and easy to read, while placing tags inline can highlight specific keywords."
  }
];
---

<ToolLayout
  title="Threads Hashtag Generator - Free Threads SEO Tag Tool"
  description="Generate highly relevant hashtags for Threads posts. Optimize post keyword tags, audit character limits, and boost your reach on Threads."
  toolName="Threads Hashtag Generator"
  toolDescription="Generate custom, search-optimized tags for your Threads posts. Select your category and tag quantity to write social copies that stand out."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Settings and Input Forms -->
      <div class="calc-form-column">
        <form class="calc-form" id="generator-form" onsubmit="return false;">
          <!-- Topic Input -->
          <div class="form-group">
            <label for="value-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
              </svg>
              What is your post topic / keyword?
            </label>
            <input type="text" id="value-input" class="form-input" placeholder="e.g. productivity habits, social media tips" value="productivity habits" required />
          </div>

          <!-- Category Selection -->
          <div class="form-group">
            <label for="category-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a1.5 1.5 0 0 0 2.122 0l4.318-4.318a1.5 1.5 0 0 0 0-2.122L11.16 3.659A2.25 2.25 0 0 0 9.568 3Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
              </svg>
              Post Category
            </label>
            <select id="category-input" class="form-input" style="height: 48px; border-radius: 8px;">
              <option value="Animals & Pets">Animals & Pets</option>
              <option value="Architecture">Architecture</option>
              <option value="Art">Art</option>
              <option value="Beauty & Makeup">Beauty & Makeup</option>
              <option value="Cars & Motorcycles">Cars & Motorcycles</option>
              <option value="DIY & Crafts">DIY & Crafts</option>
              <option value="Design">Design</option>
              <option value="Education">Education</option>
              <option value="Entertainment">Entertainment</option>
              <option value="Event Planning">Event Planning</option>
              <option value="Fashion (Men)">Fashion (Men)</option>
              <option value="Fashion (Women)">Fashion (Women)</option>
              <option value="Finance">Finance</option>
              <option value="Food & Drink">Food & Drink</option>
              <option value="Gardening">Gardening</option>
              <option value="Hair & Beauty">Hair & Beauty</option>
              <option value="Health & Fitness">Health & Fitness</option>
              <option value="Home Decor">Home Decor & Furniture</option>
              <option value="Kids & Parenting">Kids & Parenting</option>
              <option value="Outdoors & Camping">Outdoors & Camping</option>
              <option value="Photography">Photography</option>
              <option value="Quotes">Quotes</option>
              <option value="Science & Tech" selected>Science & Tech</option>
              <option value="Sports & Outdoors">Sports & Outdoors</option>
              <option value="Travel & Destinations">Travel & Destinations</option>
              <option value="Weddings">Weddings</option>
            </select>
          </div>

          <!-- Tag Count Preference -->
          <div class="form-group">
            <label for="count-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-12.3 1.8 15m-9.75-15 1.8 15" />
              </svg>
              Number of Tags
            </label>
            <select id="count-input" class="form-input" style="height: 48px; border-radius: 8px;">
              <option value="1">1 Tag (Threads recommendation)</option>
              <option value="3" selected>3 Tags (Balanced)</option>
              <option value="5">5 Tags (High visibility)</option>
              <option value="10">10 Tags (Max reach)</option>
            </select>
          </div>

          <div class="form-actions">
            <button type="button" id="generate-btn" class="calc-btn" style="width: 100%;">Generate Tags</button>
            <button type="button" id="calc-reset-btn" class="calc-btn-secondary" style="width: 100%;">Reset Fields</button>
