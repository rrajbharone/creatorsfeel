              </div>
              <span style="color: #616161; font-weight: 400; font-size: 0.78rem;">2h</span>
            </div>

            <!-- Post Text Area -->
            <p id="mockup-post-text" style="margin: 0; font-size: 0.85rem; color: #e5e5e5; line-height: 1.4; white-space: pre-wrap; word-break: break-word;">Start planning your goals today. #productivity #habits</p>

            <!-- Interaction Icons -->
            <div style="display: flex; gap: 1rem; align-items: center; margin-top: 0.5rem; color: #616161; padding-bottom: 0.25rem;">
              <!-- Heart icon -->
              <svg style="width: 18px; height: 18px; fill: currentColor;" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path></svg>
              <!-- Speech bubble icon -->
              <svg style="width: 18px; height: 18px; fill: none; stroke: currentColor; stroke-width: 2;" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.022 9-6.75s-4.03-6.75-9-6.75-9 3.022-9 6.75c0 1.957.87 3.738 2.3 5.02L4.5 20.25l3.87-1.125c1.1.378 2.29.562 3.63.562z"></path></svg>
              <!-- Repost icon -->
              <svg style="width: 18px; height: 18px; fill: none; stroke: currentColor; stroke-width: 2;" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.656 48.656 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3M4.5 12c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l-3 3m3-3l3 3"></path></svg>
              <!-- Send icon -->
              <svg style="width: 18px; height: 18px; fill: none; stroke: currentColor; stroke-width: 2;" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"></path></svg>
            </div>
