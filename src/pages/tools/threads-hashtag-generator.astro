            <div style="width: 2px; flex-grow: 1; background: #262626; border-radius: 1px;"></div>
          </div>

          <!-- Right Column: Content -->
          <div style="display: flex; flex-direction: column; gap: 0.35rem; width: 100%; min-width: 0;">
