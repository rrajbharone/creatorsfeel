---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is the Instagram caption character limit?",
    answer: "The official character limit for an Instagram caption is 2,200 characters. This is a generous limit, but for optimal engagement, it is recommended to keep your core message concise and place important hooks in the first 125 characters."
  },
  {
    question: "How many hashtags can you put in an Instagram caption?",
    answer: "Instagram has recently updated its systems to recommend and limit posts to a maximum of 5 hashtags. Using more than 5 hashtags is ignored or flagged by the algorithm to combat hashtag spam and optimize search results. Keep your hashtags at 5 or fewer."
  },
  {
    question: "What is the 125-character crop rule on Instagram?",
    answer: "In a user's mobile feed, Instagram truncates your caption after the first 125 characters, adding a grey '... more' link. Your first 125 characters must contain an engaging hook or curiosity gap to convince users to click and read the rest."
  },
  {
    question: "Do emojis count toward the caption character limit?",
    answer: "Yes, emojis count as characters. While standard emojis count as 1 character, some complex emojis (like flags, couples, or those with skin tone variations) count as 2 to 4 characters in Instagram's database."
  },
  {
    question: "How do you add line breaks in Instagram captions?",
    answer: "You can type or paste your caption directly inside our counter tool with empty lines, then copy the result. Our tool formats clean line spacing that posts directly to Instagram without needing dots or dash dividers."
  }
];

const breadcrumbs = [
  { name: 'Home', item: '/' },
  { name: 'Tools', item: '/tools' },
  { name: 'Instagram Caption Character Counter', item: '/tools/instagram-caption-character-counter' }
];

const canonicalUrl = "https://creatorsfeel.com/tools/instagram-caption-character-counter";
---

<ToolLayout
  title="Instagram Caption Character Counter - Feed Preview Mockup"
  description="Count characters for your Instagram caption in real-time. Verify the 2,200 character limit, track hashtag counts, and check the 125-character crop preview."
  toolName="Instagram Caption Character Counter"
  toolDescription="Audit caption length boundaries, count hashtags/mentions, preview feed crop truncation, and style text with fancy custom fonts."
  category="Writing Tools"
  faqs={faqs}
>


  <!-- Interactive Counter Interface -->
  <div slot="calculator" class="calc-card glass">
    <div class="calc-grid">
      <!-- Input Panel -->
      <div class="counter-input-section">
        <div class="form-group">
          <label for="caption-textarea">Write or Paste Your Caption</label>
          <div class="textarea-wrapper">
            <textarea 
              id="caption-textarea" 
              class="form-textarea" 
              placeholder="Type your Instagram caption here... e.g. 👇
🚀 Want to build a high-converting creator brand?
Here are 3 simple steps to optimize your profile rates...

#ContentCreator #SocialMediaMarketing #CreatorsFeel"
              maxlength="3000"
              rows="8"
            ></textarea>
            <div class="textarea-actions">
              <button type="button" id="btn-uppercase" class="text-action-btn">UPPER</button>
              <button type="button" id="btn-lowercase" class="text-action-btn">lower</button>
              <button type="button" id="btn-sentence" class="text-action-btn">Sentence</button>
              <button type="button" id="btn-extract-tags" class="text-action-btn-accent">Extract #Tags</button>
              <button type="button" id="btn-clear" class="text-action-btn-danger">Clear</button>
            </div>
          </div>
        </div>

        <!-- Dynamic Extracted Hashtags Input -->
        <div class="form-group hidden" id="extracted-tags-container">
          <label for="extracted-tags-input">Extracted Hashtags</label>
          <div class="input-copy-group">
            <input type="text" id="extracted-tags-input" readonly class="form-input" />
            <button type="button" id="btn-copy-extracted" class="copy-input-btn">Copy Tags</button>
          </div>
        </div>

        <div class="form-actions">
          <button type="button" id="calc-submit-btn" class="calc-btn">Audit Caption Quality</button>
          <button type="button" id="btn-copy-main" class="calc-btn-secondary">Copy Caption</button>
        </div>

        <!-- Font Generator Panel -->
        <div class="font-generator-box">
          <h4 class="font-box-title">Fancy Unicode Fonts Generator</h4>
          <p class="font-box-helper text-muted">Click any variation below to copy it directly to your clipboard:</p>
          
          <div class="fonts-list">
            <div class="font-item" data-font-type="bold" role="button" tabindex="0" title="Click to copy Bold text">
              <span class="font-label">Bold Sans:</span>
              <span class="font-preview" id="font-preview-bold">-</span>
            </div>
            <div class="font-item" data-font-type="italic" role="button" tabindex="0" title="Click to copy Italic text">
              <span class="font-label">Italic Sans:</span>
              <span class="font-preview" id="font-preview-italic">-</span>
            </div>
            <div class="font-item" data-font-type="monospace" role="button" tabindex="0" title="Click to copy Monospace text">
              <span class="font-label">Monospace:</span>
              <span class="font-preview" id="font-preview-monospace">-</span>
            </div>
            <div class="font-item" data-font-type="doubleStruck" role="button" tabindex="0" title="Click to copy Double-Struck text">
              <span class="font-label">Double-Struck:</span>
              <span class="font-preview" id="font-preview-double">-</span>
            </div>
            <div class="font-item" data-font-type="gothic" role="button" tabindex="0" title="Click to copy Gothic text">
              <span class="font-label">Fraktur/Gothic:</span>
              <span class="font-preview" id="font-preview-gothic">-</span>
            </div>
          </div>
          <div class="toast-notification hidden" id="font-toast">Copied styled font to clipboard!</div>
        </div>
      </div>

      <!-- Results & Metrics Audit Panel -->
      <div class="calc-results" id="results-wrapper">
        <!-- Instagram Live Feed Mockup -->
        <div class="instagram-mockup glass">
          <div class="mockup-header">
            <div class="mockup-avatar"></div>
            <div class="mockup-username">
              <span class="username-text">yourname</span>
              <span class="location-text">Sponsored</span>
            </div>
            <div class="mockup-menu">•••</div>
          </div>
          <div class="mockup-media">
            <!-- Pulsing logo graphic representing photo area -->
            <div class="mockup-media-graphic">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mockup-media-icon">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <polyline points="21 15 16 10 5 21" />
              </svg>
              <span class="mockup-media-tag">creatorsfeel.com</span>
            </div>
          </div>
          <div class="mockup-actions">
            <div class="actions-left">
              <span>❤️</span>
              <span>💬</span>
              <span>✈️</span>
            </div>
            <div class="actions-right">
              <span>🔖</span>
            </div>
          </div>
          <div class="mockup-likes">1,245 likes</div>
          <div class="mockup-caption-box">
            <span class="mockup-bold-user">yourname</span>
            <span id="mockup-caption-text" class="mockup-caption-text">Type your caption in the editor to preview layout...</span>
            <span id="mockup-more-btn" class="mockup-more-link hidden">more</span>
          </div>
        </div>

        <div class="rate-range-box" id="progress-card">
          <h4 class="rate-label">Caption Characters</h4>
          <div class="rate-range" id="res-char-count">0 / 2,200</div>
          
          <!-- Visual progress bar -->
          <div class="progress-bar-container">
            <div class="progress-bar-fill" id="char-progress-bar" style="width: 0%;"></div>
          </div>
          <div class="grade-badge" id="res-char-status">2,200 Remaining</div>
        </div>

        <!-- Metrics Audit list -->
        <div class="breakdown-box">
          <h4 class="breakdown-title">Instagram Caption Guidelines Audit</h4>
          <div class="breakdown-list">
            <!-- Hashtags Limit -->
            <div class="audit-item" id="audit-hashtags">
              <div class="audit-meta">
                <span class="audit-icon" id="icon-hashtags">⚪</span>
                <span class="audit-label">Hashtags Count:</span>
              </div>
              <span class="audit-value" id="val-hashtags">0 / 5 tags</span>
            </div>

            <!-- Mentions limit -->
            <div class="audit-item" id="audit-mentions">
              <div class="audit-meta">
                <span class="audit-icon" id="icon-mentions">⚪</span>
                <span class="audit-label">Profile Mentions:</span>
              </div>
              <span class="audit-value" id="val-mentions">0 handles</span>
            </div>

            <!-- Hook crop quality checker -->
            <div class="audit-item" id="audit-hook">
              <div class="audit-meta">
                <span class="audit-icon" id="icon-hook">⚪</span>
                <span class="audit-label">First 125 Characters Hook:</span>
              </div>
              <span class="audit-value" id="val-hook">No hook text</span>
            </div>
          </div>
        </div>

        <!-- Analyst Insights -->
        <div class="insight-box glass">
          <h4 class="insight-title">Caption Optimization Insight</h4>
          <p id="res-insight-desc" class="insight-desc">Type your copy details in the editor to review feed quality suggestions.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Educational SEO Content -->
  <div slot="about" class="editorial-content">
    <h2>What is the Instagram Caption Character Limit?</h2>
    <div style="margin: 1.5rem 0; background: var(--color-bg-alt); padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); border-left: 4px solid var(--color-brand);">
      <p style="margin: 0; font-weight: 600; font-size: 0.95rem;">
        💡 <strong>Want to optimize your metrics?</strong> Read our comprehensive guide on <a href="/blog/instagram-caption-character-limit-guide" style="color: var(--color-brand); text-decoration: underline;">Instagram Caption Limits & Mobile Feed Optimization Rules</a> to learn how to write hooks, manage character limits, and separate hashtags.
      </p>
    </div>

    <p>
      The official limit for an Instagram caption is <strong>2,200 characters</strong>. While this allows for long-form blogging and detailed storytelling, you must keep in mind that Instagram is a visual-first app. Your captions should be structured with line breaks, paragraphs, and engaging hooks.
    </p>
    <p>
      This character limit includes standard letters, numbers, spaces, punctuation, line breaks, and emojis.
    </p>

    <h2>The 125-Character Mobile Crop Rule</h2>
    <p>
      When users scroll through their Instagram feed, they only see the first <strong>125 characters</strong> of your caption. The remaining text is cropped behind a light grey <strong>"... more"</strong> link. 
    </p>
    <p>
      If your first 125 characters do not hook the reader, they will not click "... more" to read your caption, which hurts your post's click-through rates and overall engagement index.
    </p>

    <div class="formula-box">
      Hook (First 125 Chars) = Curiosity Gap / Intriguing Statement + Call to action 👇
    </div>

    <h2>The 5-Hashtag Limit Update</h2>
    <p>
      Instagram has updated its platform guidelines to restrict posts to a maximum of <strong>5 hashtags</strong> per post.
    </p>
    <p>
      <strong>Caution:</strong> If you include more than 5 hashtags inside your caption, the algorithm will flag it as tag spam, reducing your organic search visibility. To maintain optimal reach, keep your hashtags within the 1-5 range.
    </p>

    <h2>Instagram Caption Guidelines and Rules</h2>
    <p>
      Below is a guide to budgeting characters, hashtags, and formatting hooks for maximum reach:
    </p>
    <div class="table-responsive">
      <table style="width: 100%; min-width: 550px; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
        <thead>
          <tr style="border-bottom: 2px solid var(--color-border); background: var(--color-bg-alt);">
            <th style="padding: 0.75rem;">Metric</th>
            <th style="padding: 0.75rem;">Recommended Limit</th>
            <th style="padding: 0.75rem;">Why it Matters</th>
            <th style="padding: 0.75rem;">Risk of Exceeding</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: 0.75rem; font-weight: 600;">Characters Used</td>
            <td style="padding: 0.75rem;">150 - 500 characters</td>
            <td style="padding: 0.75rem;">Optimal density for quick readability.</td>
            <td style="padding: 0.75rem; color: var(--color-danger);">Over 2,200 prevents publishing the post.</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: 0.75rem; font-weight: 600;">First Crop Hook</td>
            <td style="padding: 0.75rem;">First 125 characters</td>
            <td style="padding: 0.75rem;">Determines feed view click-through rate.</td>
            <td style="padding: 0.75rem; color: var(--color-warning);">If boring, users skip the post without reading.</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: 0.75rem; font-weight: 600;">Hashtag Count</td>
            <td style="padding: 0.75rem;">1 - 5 hashtags</td>
            <td style="padding: 0.75rem;">Classifies your post in the algorithm.</td>
            <td style="padding: 0.75rem; color: var(--color-danger);">6+ tags are flagged as spam or ignored.</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: 0.75rem; font-weight: 600;">Line Spacing</td>
            <td style="padding: 0.75rem;">Empty space between paragraphs</td>
            <td style="padding: 0.75rem;">Breaks up text blocks, improving readability.</td>
            <td style="padding: 0.75rem; color: var(--color-text-muted);">Dense walls of text are hard to read.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2>How to Write Better Instagram Captions</h2>
    <ol style="margin-left: 1.5rem; margin-bottom: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; color: var(--color-text-muted);">
      <li><strong>Write a Strong First Line:</strong> Ask a question, share a contrarian opinion, or use numbers (e.g. <em>"3 mistakes costing you followers..."</em>).</li>
      <li><strong>Use Micro-Blogging Structure:</strong> Write short paragraphs of 1-2 sentences. Use emojis as bullet points.</li>
      <li><strong>Place Emojis Strategically:</strong> Emojis add color, but too many emojis look unprofessional. Use them as line breaks or lists.</li>
      <li><strong>Hide Your Hashtags:</strong> Separate your main hashtags from your caption text by placing 4-5 line breaks at the bottom of your caption. E.g. placing a period on each line to hide the hashtags block.</li>
    </ol>
  </div>
</ToolLayout>

<style>
