  }

  .breakdown-box {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    border-radius: var(--radius-md);
  }

  .breakdown-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.5rem;
  }

  .breakdown-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .audit-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    border-bottom: 1px dashed var(--color-border);
    padding-bottom: 0.5rem;
  }

  .audit-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .audit-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .audit-icon {
    font-size: 1rem;
    display: flex;
    align-items: center;
  }

  .audit-label {
    font-weight: 500;
  }

  .audit-value {
    font-weight: 600;
    color: var(--color-text);
  }

  /* Insight Box Styling */
  .insight-box {
    padding: 1.25rem;
    border-radius: var(--radius-md);
  }

  .insight-title {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    color: var(--color-text);
  }

  .insight-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .hidden {
    display: none !important;
  }

  @media (min-width: 640px) {
    .form-actions {
      flex-direction: row;
    }

    .calc-btn, .calc-btn-secondary {
      flex: 1;
    }
  }

  /* Formula and Table responsiveness fixes */
  .formula-box {
    background: var(--color-bg-alt);
    padding: 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin: 1.25rem 0;
    font-family: monospace;
    font-size: clamp(0.85rem, 3.2vw, 1.1rem);
    text-align: center;
    overflow-x: auto;
    white-space: nowrap;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  .table-responsive {
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1.5rem 0;
    box-sizing: border-box;
  }

  code {
    white-space: pre-wrap;
    word-break: break-all;
  }

  /* Mobile styling overrides to remove nested borders and make results high-contrast & responsive */
  @media (max-width: 767px) {
    .calc-results {
      padding: 1.25rem !important;
      background: var(--color-bg-alt) !important;
      border: 1.5px solid var(--color-border) !important;
    }

    .results-active {
      gap: 1rem !important;
    }

    .rate-range-box, 
    .breakdown-box, 
    .insight-box,
    .instagram-mockup {
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      padding: 0 !important;
      margin: 0 !important;
      border-radius: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
    }

    .rate-range-box {
      text-align: center !important;
      padding-bottom: 0.75rem !important;
      border-bottom: 1px dashed var(--color-border) !important;
    }

    .breakdown-box {
      border-bottom: 1px dashed var(--color-border) !important;
      padding-bottom: 0.75rem !important;
    }

    .breakdown-title {
      border-bottom: none !important;
      padding-bottom: 0 !important;
      margin-bottom: 0.5rem !important;
    }

    .instagram-mockup {
      border: 1.5px solid var(--color-border) !important;
      border-radius: var(--radius-md) !important;
      background: var(--color-bg) !important;
      overflow: hidden !important;
      margin-bottom: 0.75rem !important;
    }

    .mockup-caption-box {
      padding: 0.75rem !important;
    }

    .insight-box {
      padding: 0.5rem 0 0 !important;
    }
  }

  /* Responsive Rules */
  @media (min-width: 1024px) {
    .calc-grid {
      grid-template-columns: 1.2fr 1fr;
      align-items: start;
    }
  }

  /* Slotted editorial heading spacing fixes */
  .editorial-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    color: var(--color-text);
  }
</style>

<script>
  const setupCaptionCounter = () => {
    // Selectors
    const textarea = document.getElementById('caption-textarea') as HTMLTextAreaElement;
    
    // Actions
    const btnUpper = document.getElementById('btn-uppercase');
    const btnLower = document.getElementById('btn-lowercase');
    const btnSentence = document.getElementById('btn-sentence');
    const btnExtractTags = document.getElementById('btn-extract-tags');
    const btnClear = document.getElementById('btn-clear');
    const btnSubmit = document.getElementById('calc-submit-btn');
    const btnCopyMain = document.getElementById('btn-copy-main');
    const btnCopyExtracted = document.getElementById('btn-copy-extracted');

    // Outputs
    const resCharCount = document.getElementById('res-char-count');
    const charProgressBar = document.getElementById('char-progress-bar');
    const resCharStatus = document.getElementById('res-char-status');

    // Extracted tags
    const extractedTagsContainer = document.getElementById('extracted-tags-container');
    const extractedTagsInput = document.getElementById('extracted-tags-input') as HTMLInputElement;

    // Audit checklist outputs
    const valHashtags = document.getElementById('val-hashtags');
    const valMentions = document.getElementById('val-mentions');
    const valHook = document.getElementById('val-hook');

    const iconHashtags = document.getElementById('icon-hashtags');
    const iconMentions = document.getElementById('icon-mentions');
    const iconHook = document.getElementById('icon-hook');

    const resInsightDesc = document.getElementById('res-insight-desc');

    // Font Previews
    const previewBold = document.getElementById('font-preview-bold');
    const previewItalic = document.getElementById('font-preview-italic');
    const previewMonospace = document.getElementById('font-preview-monospace');
    const previewDouble = document.getElementById('font-preview-double');
    const previewGothic = document.getElementById('font-preview-gothic');
    const toast = document.getElementById('font-toast');
    const fontItems = document.querySelectorAll('.font-item');

    // Mockup Feed Outputs
    const mockupCaptionText = document.getElementById('mockup-caption-text');
    const mockupMoreBtn = document.getElementById('mockup-more-btn');

    if (!textarea) return;

    // Unicode mapping offset constants
    const mapUnicode = (text: string, type: string): string => {
      const charCodes: Record<string, { A: number; a: number; '0'?: number }> = {
        bold: { A: 120276, a: 120302, '0': 120812 },
        italic: { A: 120328, a: 120354 },
        doubleStruck: { A: 120120, a: 120146, '0': 120782 },
        gothic: { A: 120068, a: 120094 },
        monospace: { A: 120432, a: 120458, '0': 120822 }
      };

      const map = charCodes[type];
      if (!map) return text;

      return Array.from(text).map(char => {
        const code = char.charCodeAt(0);
        if (code >= 65 && code <= 90) { // A-Z
          return String.fromCodePoint(map.A + (code - 65));
        } else if (code >= 97 && code <= 122) { // a-z
          return String.fromCodePoint(map.a + (code - 97));
        } else if (code >= 48 && code <= 57 && map['0'] !== undefined) { // 0-9
          return String.fromCodePoint(map['0'] + (code - 48));
        }
        return char;
      }).join('');
    };

    let isExpanded = false;

    // Perform audit
    const updateAudit = () => {
      const text = textarea.value || '';
      const charLen = text.length;

      // 1. Character count display & progress bar
      if (resCharCount) resCharCount.textContent = `${charLen.toLocaleString()} / 2,200`;
      
      const pct = Math.min(100, (charLen / 2,200) * 100);
      if (charProgressBar) {
        charProgressBar.style.width = `${pct}%`;
        if (charLen > 2200) {
          charProgressBar.style.background = 'var(--color-danger)';
        } else if (charLen > 2000) {
          charProgressBar.style.background = 'var(--color-warning)';
        } else {
          charProgressBar.style.background = 'var(--gradient-brand)';
        }
      }

      if (resCharStatus) {
        if (charLen > 2200) {
          resCharStatus.textContent = `${(charLen - 2200).toLocaleString()} Over Limit`;
          resCharStatus.style.color = 'var(--color-danger)';
        } else {
          resCharStatus.textContent = `${(2200 - charLen).toLocaleString()} Remaining`;
          resCharStatus.style.color = 'var(--color-brand)';
        }
      }

      // 2. Hashtags Count (Instagram limit is max 5)
      const hashtags = text.match(/#[\w\d]+/g) || [];
      const hashtagCount = hashtags.length;
      if (valHashtags) valHashtags.textContent = `${hashtagCount} / 5 tags`;
      if (iconHashtags) {
        if (hashtagCount > 5) {
          iconHashtags.textContent = '❌';
          iconHashtags.style.color = 'var(--color-danger)';
        } else if (hashtagCount > 0) {
          iconHashtags.textContent = '✅';
          iconHashtags.style.color = 'var(--color-success)';
        } else {
          iconHashtags.textContent = '⚪';
        }
      }

      // 3. Profile Mentions
      const mentions = text.match(/@[\w\d_]+/g) || [];
      const mentionCount = mentions.length;
      if (valMentions) valMentions.textContent = `${mentionCount} tags`;
      if (iconMentions) {
        if (mentionCount > 10) {
          iconMentions.textContent = '⚠️';
          iconMentions.style.color = 'var(--color-warning)';
        } else if (mentionCount > 0) {
          iconMentions.textContent = '✅';
          iconMentions.style.color = 'var(--color-success)';
        } else {
          iconMentions.textContent = '⚪';
        }
      }

      // 4. Hook crop quality checker (first 125 characters)
      const firstLine = text.slice(0, 125);
      const firstLineTrimmed = firstLine.trim();
      
      if (valHook) {
        if (text === '') {
          valHook.textContent = 'No hook text';
        } else {
          valHook.textContent = `${Math.min(125, firstLineTrimmed.length)} chars`;
        }
      }

      if (iconHook) {
        if (text === '') {
          iconHook.textContent = '⚪';
        } else if (firstLineTrimmed.length < 30) {
          iconHook.textContent = '⚠️';
          iconHook.style.color = 'var(--color-warning)';
        } else {
          iconHook.textContent = '✅';
          iconHook.style.color = 'var(--color-success)';
        }
      }

      // 5. Mockup Live Feed Rendering with Crop more/less toggle
      if (mockupCaptionText) {
        if (text.trim() === '') {
          mockupCaptionText.textContent = 'Type your caption in the editor to preview layout...';
          mockupMoreBtn?.classList.add('hidden');
        } else {
          if (charLen > 125) {
            mockupMoreBtn?.classList.remove('hidden');
            if (isExpanded) {
              mockupCaptionText.textContent = text;
              if (mockupMoreBtn) mockupMoreBtn.textContent = 'less';
            } else {
              mockupCaptionText.textContent = text.slice(0, 125) + '...';
              if (mockupMoreBtn) mockupMoreBtn.textContent = 'more';
            }
          } else {
            mockupCaptionText.textContent = text;
            mockupMoreBtn?.classList.add('hidden');
          }
        }
      }

      // 6. Font Generator Preview Updates
      const sampleText = text.trim() === '' ? 'Preview Font' : text.slice(0, 40) + (text.length > 40 ? '...' : '');
      if (previewBold) previewBold.textContent = mapUnicode(sampleText, 'bold');
      if (previewItalic) previewItalic.textContent = mapUnicode(sampleText, 'italic');
      if (previewMonospace) previewMonospace.textContent = mapUnicode(sampleText, 'monospace');
      if (previewDouble) previewDouble.textContent = mapUnicode(sampleText, 'doubleStruck');
      if (previewGothic) previewGothic.textContent = mapUnicode(sampleText, 'gothic');

      // 7. Update Analyst Insights
      if (resInsightDesc) {
        if (text === '') {
          resInsightDesc.textContent = 'Type your caption details in the editor to review feed quality suggestions.';
        } else if (charLen > 2200) {
          resInsightDesc.textContent = `Warning: Your caption exceeds the 2,200 limit by ${charLen - 2200} characters. Instagram will reject publishing this post. Condense your text.`;
        } else if (hashtagCount > 5) {
          resInsightDesc.textContent = `Alert: You have used ${hashtagCount} hashtags (limit is 5). Instagram now limits posts to just 5 hashtags. Please remove at least ${hashtagCount - 5} hashtags immediately.`;
        } else if (firstLineTrimmed.length > 0 && firstLineTrimmed.length < 50) {
          resInsightDesc.textContent = 'Insight: Your first line is too short. Try to write an attention-grabbing statement or curiosity hook in the first 125 characters to drive clicks.';
        } else {
          resInsightDesc.textContent = 'Excellent! Your caption is within bounds, respects hashtag limits, and has a formatted preview. Ready to copy-paste directly to Instagram!';
        }
      }
    };

    // Toggle more/less in Instagram Mockup
    mockupMoreBtn?.addEventListener('click', () => {
      isExpanded = !isExpanded;
      updateAudit();
    });

    // Text modifiers
    btnUpper?.addEventListener('click', () => {
      textarea.value = textarea.value.toUpperCase();
      updateAudit();
    });

    btnLower?.addEventListener('click', () => {
      textarea.value = textarea.value.toLowerCase();
      updateAudit();
    });

    // Sentence case (Capitalize first letter of sentences)
    btnSentence?.addEventListener('click', () => {
      const text = textarea.value;
      const sentenceCased = text.replace(/(^\s*|[.!?]\s+)([a-z])/g, (m, g1, g2) => g1 + g2.toUpperCase());
      textarea.value = sentenceCased;
      updateAudit();
    });

    // Extract Hashtags
    btnExtractTags?.addEventListener('click', () => {
      const text = textarea.value || '';
      const tags = text.match(/#[\w\d]+/g) || [];
      if (tags.length === 0) {
        alert('No hashtags found in the caption.');
        return;
      }
      
      if (extractedTagsContainer && extractedTagsInput) {
        extractedTagsInput.value = tags.join(' ');
        extractedTagsContainer.classList.remove('hidden');
        // Scroll to container
        extractedTagsContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });

    btnClear?.addEventListener('click', () => {
      textarea.value = '';
      if (extractedTagsContainer) extractedTagsContainer.classList.add('hidden');
      updateAudit();
    });

    // Copy original bio
    btnCopyMain?.addEventListener('click', () => {
      if (textarea.value.trim() === '') {
        alert('Please enter caption text first.');
        return;
      }
      textarea.select();
      navigator.clipboard.writeText(textarea.value);
      alert('Copied caption to clipboard!');
    });

    // Copy Extracted Tags
    btnCopyExtracted?.addEventListener('click', () => {
      if (extractedTagsInput) {
        extractedTagsInput.select();
        navigator.clipboard.writeText(extractedTagsInput.value);
        alert('Copied hashtags list!');
      }
    });

    // Audit and Scroll down to results
    btnSubmit?.addEventListener('click', () => {
      updateAudit();
      setTimeout(() => {
        const resultsBox = document.getElementById('results-wrapper');
        if (resultsBox) {
          const headerOffset = 90;
          const elementPosition = resultsBox.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        }
      }, 50);
    });

    // Real-time audit triggers on typing
    textarea.addEventListener('input', updateAudit);

    // Font Items copy handler
    fontItems.forEach(item => {
      item.addEventListener('click', () => {
        const fontType = item.getAttribute('data-font-type') || 'bold';
        const rawText = textarea.value.trim() === '' ? 'CreatorsFeel' : textarea.value;
        const styledText = mapUnicode(rawText, fontType);

        navigator.clipboard.writeText(styledText).then(() => {
          if (toast) {
            toast.textContent = `Copied ${fontType.toUpperCase()} styled text!`;
            toast.classList.remove('hidden');
            setTimeout(() => {
              toast.classList.add('hidden');
            }, 1500);
          }
        });
      });
    });

    // Initial load run
    updateAudit();
  };

  setupCaptionCounter();
  document.addEventListener('astro:after-swap', setupCaptionCounter);
</script>
