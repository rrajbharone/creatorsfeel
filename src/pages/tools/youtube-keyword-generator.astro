---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "What is a YouTube Keyword Generator and how does it work?",
    answer: "A YouTube Keyword Generator is an advanced SEO tool that analyzes search intent, autocomplete trends, and competition levels to discover high-traffic keywords for your YouTube video titles, descriptions, and tags."
  },
  {
    question: "Why are long-tail keywords important for new YouTube channels?",
    answer: "Long-tail keywords (3 to 5-word phrases like 'best budget gaming PC build 2026') have lower competition and higher search intent. Targeting long-tail keywords allows smaller channels to rank at the top of YouTube search results much faster."
  },
  {
    question: "Where should I place keywords in my YouTube videos?",
    answer: "Incorporate your target keywords in your video title (within the first 40 characters), the first two lines of your video description, spoken aloud during your video recording (for auto-captions), and inside your video tags."
  },
  {
    question: "How does YouTube's search algorithm determine keyword rankings?",
    answer: "YouTube ranks videos based on metadata relevancy (title, description, tags), click-through rate (CTR), audience retention, and watch time. Ranking for a high-volume keyword requires both metadata alignment and strong viewer retention."
  },
  {
    question: "Is this YouTube Keyword Generator free to use?",
    answer: "Yes, our YouTube Keyword Generator is 100% free with unlimited keyword searches, intent filters, opportunity score calculations, and copy-paste export tools."
  }
];
---

<ToolLayout
  title="YouTube Keyword Generator - Free Video SEO Research Tool"
  description="Generate high-volume, low-competition keywords for YouTube titles, tags, and descriptions. Analyze search intent, opportunity scores, and auto-suggest trends."
  toolName="YouTube Keyword Generator"
  toolDescription="Discover high-ranking video keywords for YouTube SEO. Filter by search intent, target audience, and preview live YouTube search auto-suggest mockups."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Generator Inputs -->
      <div class="calc-form-column">
        <div class="calc-form">
          <!-- Seed Keyword Input -->
          <div class="form-group">
            <label for="seed-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.637 10.637Z" />
              </svg>
              Topic or Seed Keyword
            </label>
            <input type="text" id="seed-input" class="form-input" placeholder="e.g. gaming PC build, AI video editing" value="gaming PC build" />
          </div>

          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
            <!-- Search Intent Select -->
            <div class="form-group">
              <label for="intent-select" class="icon-label">Search Intent</label>
              <select id="intent-select" class="form-input" style="height: 48px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0 12px; color: var(--color-text);">
                <option value="broad">All Intents (Broad)</option>
                <option value="howto">How-To / Tutorials</option>
                <option value="review">Product Reviews & vs</option>
                <option value="vlog">Vlogs & Entertainment</option>
                <option value="shorts">Shorts & Trending</option>
              </select>
            </div>

            <!-- Target Audience Select -->
            <div class="form-group">
              <label for="audience-select" class="icon-label">Target Audience</label>
              <select id="audience-select" class="form-input" style="height: 48px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0 12px; color: var(--color-text);">
                <option value="beginners">Beginners & Starter</option>
                <option value="pros">Intermediates & Pros</option>
                <option value="budget">Budget & Savings</option>
                <option value="general">General Audience</option>
              </select>
            </div>
          </div>

          <!-- Formatting Checkboxes -->
          <div style="display: flex; flex-direction: column; gap: 0.75rem; background: var(--color-bg-alt); padding: 0.75rem 1rem; border-radius: 12px; border: 1px solid var(--color-border);">
            <span style="font-size: 0.72rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Keyword Metrics & Options</span>
            
            <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.88rem;">
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="metrics-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Include Search Volume & Competition Metrics
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="questions-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Include Question Keywords (How to, Why, Best way)
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--color-text);">
                <input type="checkbox" id="longtail-check" checked style="accent-color: var(--color-brand); width: 16px; height: 16px;" />
                Include Long-Tail Keyword Phrases (3-5 words)
              </label>
            </div>
          </div>

          <!-- Actions -->
          <div class="form-actions">
            <button type="button" id="generate-btn" class="calc-btn">Generate Keywords</button>
            <button type="button" id="reset-btn" class="calc-btn-secondary">Reset Inputs</button>
          </div>
        </div>
      </div>

      <!-- Right Column: Live Mockup Card -->
      <div class="calc-editor-column">
        <!-- Live YouTube Search Bar & Auto-Suggest Dropdown Mockup -->
        <div class="youtube-search-card glass" style="background: #0f0f0f; color: #ffffff; border-radius: 16px; overflow: hidden; max-width: 320px; margin: 0 auto; width: 100%; border: 1px solid #272727; text-align: left; box-shadow: var(--shadow-md); font-family: var(--font-body); padding: 1.25rem;">
          <!-- YouTube Top Search Input Field -->
          <div style="background: #121212; border: 1px solid #303030; border-radius: 20px; padding: 8px 14px; display: flex; align-items: center; gap: 8px; margin-bottom: 0.85rem;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="#aaaaaa" style="width: 16px; height: 16px; flex-shrink: 0;">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.637 10.637Z" />
            </svg>
            <span id="mockup-search-text" style="font-size: 0.8rem; color: #ffffff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 600;">
              how to build a gaming PC for beginners
            </span>
          </div>

          <!-- Auto-Suggest Predictions Header -->
          <div style="font-size: 0.68rem; font-weight: 700; color: #aaaaaa; text-transform: uppercase; margin-bottom: 0.5rem; display: flex; justify-content: space-between;">
            <span>YouTube Search Auto-Suggest</span>
            <span style="color: #ff0000; font-weight: 800;">● LIVE SEO</span>
          </div>

          <!-- Auto-Suggest Predictions List -->
          <div id="mockup-suggest-list" style="display: flex; flex-direction: column; gap: 6px; font-size: 0.76rem; color: #f1f1f1;">
