<script>
  const setupYoutubeKeywordGenerator = () => {
    const seedInput = document.getElementById('seed-input') as HTMLInputElement;
    const intentSelect = document.getElementById('intent-select') as HTMLSelectElement;
    const audienceSelect = document.getElementById('audience-select') as HTMLSelectElement;

    const metricsCheck = document.getElementById('metrics-check') as HTMLInputElement;
    const questionsCheck = document.getElementById('questions-check') as HTMLInputElement;
    const longtailCheck = document.getElementById('longtail-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');
    const generateMoreBtn = document.getElementById('generate-more-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-keywords-container');

    // Mockup targets
    const mockupSearchText = document.getElementById('mockup-search-text');
    const mockupSuggestList = document.getElementById('mockup-suggest-list');

    // Keyword Modifiers
    const intentModifiers: Record<string, { prefixes: string[], suffixes: string[] }> = {
      howto: {
        prefixes: ['how to', 'step by step guide to', 'easy way to', 'how to start'],
        suffixes: ['for beginners', 'tutorial 2026', 'explained simply', 'from scratch']
      },
      review: {
        prefixes: ['best', 'top 5', 'honest review of', 'is it worth buying'],
        suffixes: ['review 2026', 'vs comparison', 'unboxing and setup', 'pros and cons']
      },
      vlog: {
        prefixes: ['a day in the life of', 'trying', 'my official', 'behind the scenes of'],
        suffixes: ['vlog', 'challenge', 'experience', 'reaction']
      },
      shorts: {
        prefixes: ['quick tip for', 'viral', 'secret hack for', 'do not do this'],
        suffixes: ['shorts', 'in 60 seconds', 'hacks', 'tips']
      },
      broad: {
        prefixes: ['complete guide to', 'everything about', 'best', 'mastering'],
        suffixes: ['explained', 'tutorial', 'guide 2026', 'tips and tricks']
      }
    };

    let currentShuffledPool: Array<{ phrase: string, vol: number, comp: number, intent: string }> = [];
    let currentPoolIndex = 0;

    const buildShuffledPool = () => {
      const topic = (seedInput?.value || '').trim() || 'gaming PC build';
      const intent = intentSelect?.value || 'broad';
      const audience = audienceSelect?.value || 'beginners';

      const includeQuestions = questionsCheck?.checked;
      const includeLongtail = longtailCheck?.checked;

      const modifiers = intentModifiers[intent] || intentModifiers['broad'];
      const generatedSet = new Set<string>();

      const applyFormat = (prefix: string, body: string, suffix: string) => {
        let text = `${prefix} ${body} ${suffix}`;

        if (includeQuestions && Math.random() > 0.5) {
          text = `how to ${body} ${suffix}`;
        }

        if (includeLongtail && audience === 'beginners') {
          text = `${text} for beginners 2026`;
        } else if (includeLongtail && audience === 'budget') {
          text = `cheap ${text} on a budget`;
        }

        return text.replace(/\s+/g, ' ').trim();
      };

      let iterations = 0;
      while (generatedSet.size < 50 && iterations < 300) {
        iterations++;
        const pIndex = Math.floor(Math.random() * modifiers.prefixes.length);
        const sIndex = Math.floor(Math.random() * modifiers.suffixes.length);

        const prefix = modifiers.prefixes[pIndex];
        const suffix = modifiers.suffixes[sIndex];

        const formatted = applyFormat(prefix, topic, suffix);
        if (formatted.length >= 5) {
          generatedSet.add(formatted);
        }
      }

      const items = Array.from(generatedSet).map(phrase => {
        const vol = Math.floor(Math.random() * 45 + 50); // 50 to 95
        const comp = Math.floor(Math.random() * 40 + 20); // 20 to 60
        return { phrase, vol, comp, intent };
      });

      currentShuffledPool = items.sort(() => Math.random() - 0.5);
      currentPoolIndex = 0;
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledPool();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      const includeMetrics = metricsCheck?.checked;

      if (container) {
        container.innerHTML = selected.map(item => {
          const metricsHtml = includeMetrics ? `
            <div class="metrics-badge-row">
              <span class="metric-pill high">Vol: ${item.vol}/100</span>
              <span class="metric-pill low-comp">Comp: ${item.comp}/100 (Low)</span>
              <span class="metric-pill">Intent: ${item.intent}</span>
            </div>
          ` : '';

          return `
            <div class="keyword-card" data-phrase="${item.phrase}">
              <div class="keyword-header-row">
                <span class="keyword-title-text">${item.phrase}</span>
              </div>
              ${metricsHtml}
              <button class="chip-btn">Copy Keyword</button>
            </div>
          `;
        }).join('');
      }

      resultsWrapper?.classList.remove('hidden');

      // Default mockup search
      if (selected.length > 0) {
        if (mockupSearchText) mockupSearchText.textContent = selected[0].phrase;
        if (mockupSuggestList) {
          mockupSuggestList.innerHTML = selected.slice(0, 3).map((s, idx) => {
            const bg = idx === 0 ? '#212121' : '#181818';
            const color = idx === 0 ? '#2ba640' : '#aaaaaa';
            return `
              <div style="padding: 6px 8px; background: ${bg}; border-radius: 6px; display: flex; justify-content: space-between; align-items: center;">
                <span>${s.phrase}</span>
                <span style="font-size: 0.65rem; color: ${color}; font-weight: 700;">${s.vol}/100 Vol</span>
              </div>
            `;
          }).join('');
        }
      }
    };

    // Append 5 more unique items
    const appendMoreTitles = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledPool();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledPool();
      }

      const next = currentShuffledPool.slice(currentPoolIndex, currentPoolIndex + 5);
      currentPoolIndex += 5;

      const includeMetrics = metricsCheck?.checked;

      if (container) {
        const appendHtml = next.map(item => {
          const metricsHtml = includeMetrics ? `
            <div class="metrics-badge-row">
              <span class="metric-pill high">Vol: ${item.vol}/100</span>
              <span class="metric-pill low-comp">Comp: ${item.comp}/100 (Low)</span>
              <span class="metric-pill">Intent: ${item.intent}</span>
            </div>
          ` : '';

          return `
            <div class="keyword-card" data-phrase="${item.phrase}">
              <div class="keyword-header-row">
                <span class="keyword-title-text">${item.phrase}</span>
              </div>
              ${metricsHtml}
              <button class="chip-btn">Copy Keyword</button>
            </div>
          `;
        }).join('');
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    generateMoreBtn?.addEventListener('click', () => {
      appendMoreTitles();
    });

    // Handle copying individual keyword cards and update mockup preview
    container?.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.keyword-card');
      if (!card) return;

      const phraseVal = card.getAttribute('data-phrase') || '';

      // Update mockup sidebar
      if (mockupSearchText) {
        mockupSearchText.textContent = phraseVal;
      }

      // Copy to clipboard
      navigator.clipboard.writeText(phraseVal).then(() => {
        const btn = card.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy Keyword';
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener('click', () => {
      if (seedInput) seedInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-generate initial list
    generateList();
  };

  setupYoutubeKeywordGenerator();
  document.addEventListener('astro:after-swap', setupYoutubeKeywordGenerator);
</script>
