<script>
  const setupDiscordUsernameGenerator = () => {
    const seedInput = document.getElementById('seed-input') as HTMLInputElement;
    const styleSelect = document.getElementById('style-select') as HTMLSelectElement;
    const formatSelect = document.getElementById('format-select') as HTMLSelectElement;

    // Buttons
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-usernames-container');

    // Mockup targets
    const mockupDisplayName = document.getElementById('mockup-display-name');
    const mockupUsername = document.getElementById('mockup-username');

    // Niche details databases
    const styleNiches: Record<string, { prefixes: string[], suffixes: string[], displays: string[] }> = {
      cyber: {
        prefixes: ['cyber', 'neon', 'glitch', 'pixel', 'net', 'matrix', 'proxy', 'hack', 'bit', 'code'],
        suffixes: ['spark', 'grid', 'wire', 'ghost', 'hacker', 'node', 'core', 'system', 'wave', 'cyber'],
        displays: ['Neon Pulse', 'Glitch Core', 'Net Ghost', 'Pixel Proxy', 'Matrix Byte']
      },
      gaming: {
        prefixes: ['pro', 'esport', 'alpha', 'apex', 'vortex', 'tactic', 'rapid', 'lethal', 'reflex', 'vandal'],
        suffixes: ['gg', 'gamer', 'player', 'xp', 'fps', 'clutch', 'carry', 'scope', 'mvp', 'esport'],
        displays: ['Alpha Esports', 'Vortex Gamer', 'Lethal Carry', 'Apex Reflex', 'MVP Scope']
      },
      cozy: {
        prefixes: ['cozy', 'luna', 'haze', 'cloud', 'mist', 'cozy', 'dawn', 'dusk', 'calm', 'soft'],
        suffixes: ['vibes', 'dream', 'bloom', 'glow', 'mood', 'space', 'haze', 'luna', 'light', 'cozy'],
        displays: ['Cozy Vibes', 'Luna Bloom', 'Cloud Haze', 'Calm Dusk', 'Soft Glow']
      },
      cute: {
        prefixes: ['bubble', 'honey', 'peach', 'cherry', 'fluffy', 'sweet', 'plush', 'pastel', 'tiny', 'mochi'],
        suffixes: ['bear', 'kitten', 'mochi', 'bunny', 'sweet', 'peach', 'chibi', 'plush', 'cute', 'cherry'],
        displays: ['Sweet Mochi', 'Peach Kitten', 'Pastel Bunny', 'Tiny Cherry', 'Fluffy Bear']
      },
      minimalist: {
        prefixes: ['pure', 'null', 'void', 'mono', 'raw', 'zero', 'cold', 'pale', 'dark', 'sole'],
        suffixes: ['mind', 'axis', 'line', 'mode', 'grid', 'void', 'pure', 'mono', 'zero', 'pale'],
        displays: ['Pure Void', 'Mono Axis', 'Zero Mind', 'Pale Line', 'Sole Mode']
      }
    };

    const generateList = () => {
      const rawSeed = (seedInput?.value || '').trim();
      const seed = rawSeed.toLowerCase().replace(/[^a-z0-9]/g, ''); // Convert to lowercase and strip invalid characters
      const style = styleSelect?.value || 'cyber';
      const format = formatSelect?.value || 'clean';

      const database = styleNiches[style] || styleNiches['cyber'];
      const generatedSet = new Set<string>();

      // Utility to format separation
      const applyFormat = (prefix: string, body: string, suffix: string) => {
        let text = '';
        if (format === 'underscore') {
          text = `${prefix}_${body}_${suffix}`.replace(/^_+|_+$/g, '').replace(/_+/g, '_');
        } else if (format === 'period') {
          text = `${prefix}.${body}.${suffix}`.replace(/^\.+|\.+$/g, '').replace(/\.+/g, '.');
        } else {
          text = `${prefix}${body}${suffix}`;
        }

        if (format === 'numbers') {
          const num = Math.floor(Math.random() * 90) + 10;
          text = `${text}${num}`;
        }

        // Clean double dots/underscores and fit limit
        return text.substring(0, 32);
      };

      // Generate 15 distinct options
      let iterations = 0;
      while (generatedSet.size < 15 && iterations < 150) {
        iterations++;
        const pIndex = Math.floor(Math.random() * database.prefixes.length);
        const sIndex = Math.floor(Math.random() * database.suffixes.length);
        
        const prefix = database.prefixes[pIndex];
        const suffix = database.suffixes[sIndex];

        // Randomly combine seed name with prefix/suffix or both
        let formatted = '';
        const pattern = Math.floor(Math.random() * 3);
        if (pattern === 0 && seed) {
          formatted = applyFormat(prefix, seed, '');
        } else if (pattern === 1 && seed) {
          formatted = applyFormat('', seed, suffix);
        } else {
          formatted = applyFormat(prefix, seed || 'user', suffix);
        }

        // Validate final rules
        if (formatted.length >= 2 && !formatted.includes('..') && !formatted.includes('__')) {
          generatedSet.add(formatted);
        }
      }

      // Convert to array
      const usernames = Array.from(generatedSet);

      // Render to DOM
      if (container) {
        container.innerHTML = usernames.map(u => {
          return `
            <div class="username-chip" data-name="${u}">
              <span class="username-text">@${u}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
        }).join('');
      }

      // Display the wrapper
      resultsWrapper?.classList.remove('hidden');

      // Update Mockup Display Name based on niche
      if (mockupDisplayName) {
        const displayList = database.displays;
        const dIndex = Math.floor(Math.random() * displayList.length);
        mockupDisplayName.textContent = displayList[dIndex];
      }

      // Default the mockup username to the first result
      if (mockupUsername && usernames.length > 0) {
        mockupUsername.textContent = `@${usernames[0]}`;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();
      
      // Auto-scroll down to focus results grid
      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    // Handle copying individual username row click
    container?.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest('.username-chip');
      if (!chip) return;

      const username = chip.getAttribute('data-name') || '';
      
      // Update Mockup card to display this username on click
      if (mockupUsername) {
        mockupUsername.textContent = `@${username}`;
      }

      // Copy to clipboard
      navigator.clipboard.writeText(username).then(() => {
        const btn = chip.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy';
          }, 1200);
        }
      });
    });

    // Reset fields
    resetBtn?.addEventListener('click', () => {
      if (seedInput) seedInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-generate initial list
    generateList();
  };

  setupDiscordUsernameGenerator();
  document.addEventListener('astro:after-swap', setupDiscordUsernameGenerator);
</script>
