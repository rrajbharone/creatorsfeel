<script>
  const setupTwitterCalculator = () => {
    const activeModeInput = document.getElementById('active-mode') as HTMLInputElement;
    const modeTabs = document.querySelectorAll('.mode-tab');

    // Tab sections references
    const followersBox = document.getElementById('inputs-followers-box');
    const impressionsBox = document.getElementById('inputs-impressions-box');

    // Followers Mode inputs
    const followersInput = document.getElementById('followers-count') as HTMLInputElement;
    const likesFollowers = document.getElementById('likes-followers') as HTMLInputElement;
    const repostsFollowers = document.getElementById('reposts-followers') as HTMLInputElement;
    const repliesFollowers = document.getElementById('replies-followers') as HTMLInputElement;
    const bookmarksFollowers = document.getElementById('bookmarks-followers') as HTMLInputElement;

    // Impressions Mode inputs
    const impressionsInput = document.getElementById('impressions-count') as HTMLInputElement;
    const likesImpressions = document.getElementById('likes-impressions') as HTMLInputElement;
    const repostsImpressions = document.getElementById('reposts-impressions') as HTMLInputElement;
    const repliesImpressions = document.getElementById('replies-impressions') as HTMLInputElement;
    const bookmarksImpressions = document.getElementById('bookmarks-impressions') as HTMLInputElement;
    const clicksImpressions = document.getElementById('clicks-impressions') as HTMLInputElement;

    // Outputs references
    const emptyBox = document.getElementById('res-empty-box');
    const activeBox = document.getElementById('res-active-box');

    const rateVal = document.getElementById('res-rate-val');
    const tierVal = document.getElementById('res-tier-val');
    const totalEngVal = document.getElementById('res-total-eng');
    const ratioVal = document.getElementById('res-ratio-val');

    const submitBtn = document.getElementById('calc-submit-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // Mode tab toggle logic
    modeTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        modeTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const mode = tab.getAttribute('data-mode') || 'followers';
        if (activeModeInput) activeModeInput.value = mode;

        if (mode === 'followers') {
          followersBox?.classList.remove('hidden');
          impressionsBox?.classList.add('hidden');
        } else {
          followersBox?.classList.add('hidden');
          impressionsBox?.classList.remove('hidden');
        }

        resetCalculator(false);
      });
    });

    const resetCalculator = (clearInputs = true) => {
      if (clearInputs) {
        if (followersInput) followersInput.value = '';
        if (likesFollowers) likesFollowers.value = '0';
        if (repostsFollowers) repostsFollowers.value = '0';
        if (repliesFollowers) repliesFollowers.value = '0';
        if (bookmarksFollowers) bookmarksFollowers.value = '0';

        if (impressionsInput) impressionsInput.value = '';
        if (likesImpressions) likesImpressions.value = '0';
        if (repostsImpressions) repostsImpressions.value = '0';
        if (repliesImpressions) repliesImpressions.value = '0';
        if (bookmarksImpressions) bookmarksImpressions.value = '0';
        if (clicksImpressions) clicksImpressions.value = '0';
      }

      if (emptyBox) emptyBox.classList.remove('hidden');
      if (activeBox) activeBox.classList.add('hidden');
    };

    const calculateEngagement = () => {
      const mode = activeModeInput?.value || 'followers';
      let totalInteractions = 0;
      let baseCount = 0;
      let rate = 0;

      if (mode === 'followers') {
        baseCount = parseFloat(followersInput?.value) || 0;
        const l = parseFloat(likesFollowers?.value) || 0;
        const rep = parseFloat(repostsFollowers?.value) || 0;
        const repl = parseFloat(repliesFollowers?.value) || 0;
        const b = parseFloat(bookmarksFollowers?.value) || 0;

        totalInteractions = l + rep + repl + b;

        if (baseCount < 10) {
          return alert("Please enter a valid followers count (minimum 10).");
        }
      } else {
        baseCount = parseFloat(impressionsInput?.value) || 0;
        const l = parseFloat(likesImpressions?.value) || 0;
        const rep = parseFloat(repostsImpressions?.value) || 0;
        const repl = parseFloat(repliesImpressions?.value) || 0;
        const b = parseFloat(bookmarksImpressions?.value) || 0;
        const c = parseFloat(clicksImpressions?.value) || 0;

        totalInteractions = l + rep + repl + b + c;

        if (baseCount < 10) {
          return alert("Please enter a valid impressions count (minimum 10).");
        }
      }

      rate = (totalInteractions / baseCount) * 100;

      // Rate Classification benchmarks
      let tierLabel = "Average Engagement";
      if (mode === 'followers') {
        if (rate < 0.5) {
          tierLabel = "Low Engagement (Competitor Benchmarks)";
        } else if (rate >= 0.5 && rate < 1.5) {
          tierLabel = "Good Engagement (Competitor Benchmarks)";
        } else if (rate >= 1.5 && rate < 3.5) {
          tierLabel = "High Engagement (Competitor Benchmarks)";
        } else {
          tierLabel = "Premium Engagement (Competitor Benchmarks)";
        }
      } else {
        if (rate < 0.2) {
          tierLabel = "Low Engagement (Self Tweet Views)";
        } else if (rate >= 0.2 && rate < 1.0) {
          tierLabel = "Good Engagement (Self Tweet Views)";
        } else if (rate >= 1.0 && rate < 2.5) {
          tierLabel = "High Engagement (Self Tweet Views)";
        } else {
          tierLabel = "Premium Engagement (Self Tweet Views)";
        }
      }

      // Render Outputs
      if (emptyBox) emptyBox.classList.add('hidden');
      if (activeBox) activeBox.classList.remove('hidden');

      if (rateVal) rateVal.textContent = `${rate.toFixed(2)}%`;
      if (tierVal) tierVal.textContent = tierLabel;
      if (totalEngVal) totalEngVal.textContent = totalInteractions.toLocaleString();

      if (ratioVal) {
        const ratio = (totalInteractions / baseCount) * 1000;
        ratioVal.textContent = `${Math.round(ratio)} Interactions`;
      }

      // Smooth scroll to the results section
      const resultsWrapper = document.getElementById('results-wrapper');
      if (resultsWrapper) {
        resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    submitBtn?.addEventListener('click', calculateEngagement);
    resetBtn?.addEventListener('click', () => resetCalculator(true));
  };

  setupTwitterCalculator();
  document.addEventListener('astro:after-swap', setupTwitterCalculator);
</script>
