---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "Do hashtags work on Pinterest?",
    answer: "Yes, hashtags work on Pinterest. They help the search index classify fresh Pins immediately. However, Pinterest recommends focusing heavily on descriptive keyword copywriting alongside a few targeted tags."
  },
  {
    question: "How many hashtags should I add to a Pin?",
    answer: "Pinterest recommends adding between 2 to 5 highly relevant hashtags per Pin description. Adding too many tags can look spammy and distract users from clicking your links."
  },
  {
    question: "Where should I put hashtags in my Pin?",
    answer: "Place your hashtags at the very bottom of your Pin description. This keeps your main descriptive hook paragraphs clean and easy to read."
  },
  {
    question: "What is the character limit for a Pinterest Pin description?",
    answer: "Pinterest Pin descriptions have a strict character limit of 500 characters. Our sandbox tracks this limit in real-time, showing a progress bar to prevent your text from getting cropped."
  },
  {
    question: "Should I use broad tags or niche-specific tags?",
    answer: "Use a mix of both. Broad tags (like #homedecor) help place your Pin in large categories, while niche-specific tags (#midcenturymodernliving) help you rank for targeted long-tail searches."
  }
];
---

<ToolLayout
  title="Pinterest Hashtag Generator - Free Pin SEO Tag Tool"
  description="Generate highly relevant hashtags for Pinterest Pins. Optimize Pin description keywords, audit character limits, and boost your monthly views."
  toolName="Pinterest Hashtag Generator"
  toolDescription="Generate custom, search-optimized hashtags for your Pinterest Pins. Select your category and tag style to write Pin descriptions that rank."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Settings and Input Forms -->
      <div class="calc-form-column">
        <form class="calc-form" id="generator-form" onsubmit="return false;">
          <!-- Topic Input -->
          <div class="form-group">
            <label for="value-input" class="icon-label">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="field-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
