<script>
  const setupPinterestHashtagGenerator = () => {
    const valueInput = document.getElementById('value-input') as HTMLInputElement;
    const categorySelect = document.getElementById('category-input') as HTMLSelectElement;
    const countSelect = document.getElementById('count-input') as HTMLSelectElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // Preview elements
    const mockupTitle = document.getElementById('mockup-pin-title');
    const mockupDescription = document.getElementById('mockup-pin-description');

    // Sandbox workspace
    const sandboxInput = document.getElementById('sandbox-input') as HTMLTextAreaElement;
    const sandboxCounter = document.getElementById('sandbox-counter');
    const sandboxHashtags = document.getElementById('sandbox-hashtags');
    const progressBarFill = document.getElementById('progress-bar-fill');
    const copyActiveBtn = document.getElementById('copy-active-btn');
    const clearSandboxBtn = document.getElementById('clear-sandbox-btn');

    // Helper to capitalize words
    const capitalizeWords = (str: string) => {
      return str.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    };

    // Live Sandbox update
    const updateSandbox = () => {
      const text = sandboxInput?.value || '';
      const len = text.length;

      // Extract and count hashtags
      const tags = (text.match(/#[a-zA-Z0-9_]+/g) || []).length;
      const targetTags = parseInt(countSelect?.value || '5', 10);

      // Update Mockup Pin description
      if (mockupDescription) {
        mockupDescription.textContent = text || 'Your Pin description and hashtags will preview here...';
      }

      // Update counters
      if (sandboxCounter) {
        sandboxCounter.textContent = `${len} / 500 Chars`;
        sandboxCounter.style.color = len > 500 ? '#ef4444' : 'var(--color-text-muted)';
      }

      if (sandboxHashtags) {
        sandboxHashtags.textContent = `${tags} / ${targetTags} Tags`;
        sandboxHashtags.style.color = tags > targetTags ? '#f59e0b' : 'var(--color-text-muted)';
      }

      // Update progress bar
      if (progressBarFill) {
        const percent = Math.min((len / 500) * 100, 100);
        progressBarFill.style.width = `${percent}%`;
        
        if (len > 500) {
          progressBarFill.style.backgroundColor = '#ef4444';
        } else if (tags > targetTags) {
          progressBarFill.style.backgroundColor = '#f59e0b';
        } else {
          progressBarFill.style.backgroundColor = 'var(--color-brand)';
        }
      }
    };
    sandboxInput?.addEventListener('input', updateSandbox);
    countSelect?.addEventListener('change', updateSandbox);

    // Generation logic
    const generateHashtags = () => {
      const topic = (valueInput?.value || '').trim();
      const category = categorySelect?.value || 'Home Decor';
      const targetTagsCount = parseInt(countSelect?.value || '5', 10);

      if (!topic) {
        alert("Please enter a Pin topic.");
        return;
      }

      // Predefined hashtag category database covering all 26 categories
      const tagDb: Record<string, string[]> = {
        'Animals & Pets': ['animals', 'pets', 'doglovers', 'catsofinstagram', 'animalphotography', 'cutepets', 'petcare', 'dogs', 'cats', 'petlife', 'puppylove', 'kittens', 'animallife', 'funnyanimals', 'wildlife'],
        'Architecture': ['architecture', 'design', 'building', 'modernhome', 'architecturedesign', 'interiorarchitecture', 'archilovers', 'exterior', 'minimalistarchitecture', 'historicbuildings', 'housegoals', 'facade'],
        'Art': ['art', 'drawing', 'painting', 'sketchbook', 'illustration', 'digitalart', 'watercolor', 'artistsoninstagram', 'acrylicpainting', 'artinspiration', 'fineart', 'artistic', 'abstractart'],
        'Beauty & Makeup': ['makeup', 'beauty', 'skincare', 'makeupideas', 'makeuptutorial', 'beautytips', 'glowingskin', 'makeuplook', 'cleanbeauty', 'selfcare', 'cosmetics', 'beautyblogger', 'glam'],
        'Cars & Motorcycles': ['cars', 'motorcycles', 'supercars', 'classiccars', 'bikelife', 'automotive', 'luxurycars', 'carguy', 'moto', 'racing', 'carsofinstagram', 'speed', 'customcars'],
        'DIY & Crafts': ['diyprojects', 'craftideas', 'homediy', 'dollartreediy', 'woodworking', 'craftymom', 'sewingprojects', 'upcycled', 'handmade', 'crafting', 'kidscrafts', 'diycrafts', 'diyhomedecor'],
        'Design': ['graphicdesign', 'uxdesign', 'interiordesign', 'branding', 'typography', 'illustration', 'uidesign', 'minimalistdesign', 'creatives', 'artdirection', 'webdesign', 'logodesign'],
        'Education': ['education', 'learning', 'teaching', 'school', 'studygram', 'homeschooling', 'teacherlife', 'classroomideas', 'studytips', 'stem', 'educationalactivities', 'infographics', 'collegelife'],
        'Entertainment': ['movies', 'tvshows', 'popculture', 'memes', 'gaming', 'anime', 'cosplay', 'celebrities', 'music', 'funnyvideos', 'bookshelf', 'playlist', 'booktok'],
        'Event Planning': ['eventplanning', 'partyideas', 'decorations', 'balloongarland', 'birthdayparty', 'babyshower', 'tablescape', 'eventdecor', 'partydecor', 'catering', 'partyplanner', 'dinnerparty'],
        'Fashion (Men)': ['mensfashion', 'menstyle', 'mensoutfit', 'streetstyle', 'gentstyle', 'menswear', 'casualmenswear', 'suits', 'sneakers', 'mensstyleinspo', 'menslook', 'streetwear'],
        'Fashion (Women)': ['styleinspiration', 'outfitgoals', 'streetwear', 'capsulewardrobe', 'casualoutfits', 'summerlooks', 'vintageaesthetic', 'accessories', 'styleinspo', 'womenstyle', 'fashioninspo', 'springfashion'],
        'Finance': ['personalfinance', 'investing', 'moneytips', 'budgeting', 'savingmoney', 'financialfreedom', 'stocks', 'realestate', 'passiveincome', 'wealthbuilding', 'moneyhacks', 'sidehustles'],
        'Food & Drink': ['easyrecipes', 'healthycooking', 'bakinglove', 'mealprep', 'comfortfood', 'foodinspiration', 'quickmeals', 'dinnerideas', 'glutenfree', 'veganrecipes', 'cocktails', 'healthyfood', 'desserts'],
        'Gardening': ['gardening', 'plants', 'indoorplants', 'gardeninspiration', 'backyardgarden', 'plantmom', 'gardentips', 'succulents', 'vegetablegarden', 'urbanjungle', 'greenhouse', 'plantinspo'],
        'Hair & Beauty': ['hairstyles', 'haircare', 'haircolor', 'braids', 'curlyhair', 'beautytips', 'naturalhair', 'hairinspo', 'salonstyle', 'skincareroutine', 'hairtrends', 'hairroutine'],
        'Health & Fitness': ['fitnessgoals', 'workoutmotivation', 'healthyhabits', 'yogalife', 'weightlossjourney', 'cleanloading', 'gymmotivation', 'mentalhealth', 'wellness', 'cardio', 'fitfam', 'workoutroutine'],
        'Home Decor': ['homedecor', 'decorideas', 'homeinspiration', 'roomdecor', 'interiorstyling', 'neutralaesthetic', 'apartmentgoals', 'cozyhome', 'budgetdecor', 'bohohome', 'modernfarmhouse', 'renovations'],
        'Kids & Parenting': ['parenting', 'toddlerlife', 'kidsactivities', 'parentingtips', 'babyroom', 'sensoryplay', 'momlife', 'dadlife', 'nurserydecor', 'schoolcrafts', 'motherhood', 'familytime'],
        'Outdoors & Camping': ['hiking', 'camping', 'backpacking', 'wilderness', 'adventure', 'naturelovers', 'nationalparks', 'campingtips', 'outdoorphotography', 'climbing', 'glamping', 'trekking'],
        'Photography': ['photography', 'portrait', 'landscape', 'travelphotography', 'photooftheday', 'cameras', 'lightroom', 'streetphotography', 'aestheticphotography', 'iphoneography', 'photoshoot', 'cinematic'],
        'Quotes': ['inspirationalquotes', 'motivation', 'quotesoftheday', 'positivevibes', 'affirmations', 'lifequotes', 'lovequotes', 'selflovequotes', 'wisewords', 'mindfulness', 'dailymotivation'],
        'Science & Tech': ['technology', 'gadgets', 'coding', 'science', 'futuretech', 'ai', 'space', 'developer', 'software', 'programming', 'stemnews', 'robotics', 'datascience'],
        'Sports & Outdoors': ['sports', 'football', 'basketball', 'soccer', 'running', 'outdoors', 'athletictraining', 'golf', 'cycling', 'activewear', 'gymnastics', 'surfing'],
        'Travel & Destinations': ['travelguides', 'wanderlust', 'bucketlistplaces', 'solotravel', 'hiddengems', 'roadtripideas', 'europetravel', 'budgettravel', 'naturephotography', 'islandlife', 'honeymoon', 'wanderer'],
        'Weddings': ['weddinginspiration', 'weddingdress', 'bridalmakeup', 'weddingdecor', 'weddingflowers', 'bridesmaids', 'elopement', 'weddingphotography', 'engagementring', 'bridetobe', 'weddingvenue', 'diywedding']
      };

      // Extract cleaned keywords from topic
      const cleanTopic = topic.toLowerCase().replace(/[^a-z0-9\s]/g, '');
      const topicWords = cleanTopic.split(/\s+/).filter(w => w.length > 2);

      // Select category database list
      const dbTags = tagDb[category] || tagDb['Home Decor'];
      
      // Dynamic tags list
      let finalTags: string[] = [];

      // 1. Generate topic keyword variations
      if (topicWords.length >= 2) {
        finalTags.push(topicWords.join(''));
      }
      topicWords.forEach(w => {
        finalTags.push(w);
      });

      // 2. Add category tags
      finalTags.push(...dbTags);

      // 3. Fallback tags if we need more (up to 30)
      const generalFallbacks = ['inspiration', 'ideas', 'aesthetic', 'trendy', 'creative', 'viral', 'pinoftheday', 'foryou', 'pinspire', 'instastyle', 'diy', 'how-to', 'designinspo', 'weeklygoals'];
      finalTags.push(...generalFallbacks);

      // Deduplicate tags
      const uniqueTagsSet = Array.from(new Set(finalTags.map(t => t.toLowerCase().replace(/\s+/g, ''))));

      // Append prefix # symbol
      const uniqueTags = uniqueTagsSet.slice(0, targetTagsCount).map(t => `#${t}`);

      // Update Pin Mockup Title
      if (mockupTitle) {
        mockupTitle.textContent = capitalizeWords(topic) + ' Ideas';
      }

      // Construct output text containing only space-separated hashtags
      const formattedOutput = uniqueTags.join(' ');

      if (sandboxInput) {
        sandboxInput.value = formattedOutput;
        updateSandbox();
      }

      // Scroll directly to the results / editor sandbox column
      const editorCol = document.querySelector('.calc-editor-column');
      if (editorCol) {
        editorCol.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    generateBtn?.addEventListener('click', generateHashtags);

    // Emoji picker click inserter
    const emojiContainer = document.getElementById('emoji-picker-container');
    emojiContainer?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.emoji-btn');
      if (!btn || !sandboxInput) return;
      
      const emoji = btn.textContent || '';
      const start = sandboxInput.selectionStart;
      const end = sandboxInput.selectionEnd;
      const val = sandboxInput.value;

      sandboxInput.value = val.substring(0, start) + emoji + val.substring(end);
      sandboxInput.selectionStart = sandboxInput.selectionEnd = start + emoji.length;
      sandboxInput.focus();
      updateSandbox();
    });

    // Sandbox Copy
    copyActiveBtn?.addEventListener('click', () => {
      const text = sandboxInput?.value || '';
      if (!text) return alert("Sandbox editor is empty!");
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyActiveBtn.textContent;
        copyActiveBtn.textContent = 'Copied to Clipboard! ✓';
        setTimeout(() => {
          copyActiveBtn.textContent = originalText;
        }, 1500);
      });
    });

    // Clear Sandbox
    clearSandboxBtn?.addEventListener('click', () => {
      if (sandboxInput) {
        sandboxInput.value = '';
        updateSandbox();
      }
    });

    // Reset Fields
    resetBtn?.addEventListener('click', () => {
      if (valueInput) valueInput.value = '';
      if (sandboxInput) sandboxInput.value = '';
      updateSandbox();
    });

    // Initialize
    updateSandbox();
  };

  setupPinterestHashtagGenerator();
  document.addEventListener('astro:after-swap', setupPinterestHashtagGenerator);
</script>
