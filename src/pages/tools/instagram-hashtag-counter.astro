    border-radius: var(--radius-md);
  }

  .step-item h3 {
    margin-top: 0 !important;
    font-size: 1.1rem;
    color: var(--color-brand);
    margin-bottom: 0.5rem;
  }

  .step-item p {
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .step-item ul {
    margin-bottom: 0 !important;
    margin-left: 1.25rem !important;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .hidden {
    display: none !important;
  }

  /* Responsive Mobile Overrides */
  @media (max-width: 767px) {
    .calc-card {
      padding: 1.25rem !important;
      border-radius: 18px !important;
    }

    .form-actions {
      flex-direction: column;
      gap: 0.75rem;
    }

    .calc-results {
      padding: 0 !important;
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      gap: 1.5rem !important;
      margin-top: 0.5rem !important;
      min-height: auto;
    }

    .metrics-grid {
      grid-template-columns: 1fr !important;
      gap: 0.75rem;
    }
  }

  @media (min-width: 1024px) {
    .calc-grid {
      grid-template-columns: 1.2fr 1fr;
      align-items: start;
      gap: 2.5rem;
    }
  }

  /* Slotted editorial heading spacing fixes */
  .editorial-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    color: var(--color-text);
  }
</style>

<script>
  const setupHashtagCounter = () => {
    const captionInput = document.getElementById('caption-input') as HTMLTextAreaElement;
    const submitBtn = document.getElementById('calc-submit-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    const emptyBox = document.getElementById('res-empty-box');
    const activeBox = document.getElementById('res-active-box');

    const dupWarning = document.getElementById('duplicate-warning');
    const limitWarning = document.getElementById('limit-warning');

    const hashtagCountVal = document.getElementById('res-hashtag-count');
    const charCountVal = document.getElementById('res-char-count');
    const tagsWrapper = document.getElementById('tags-chips-wrapper');

    const copyTagsBtn = document.getElementById('copy-clean-tags-btn');
    const copyCaptionBtn = document.getElementById('copy-clean-caption-btn');

    let extractedTagsList: string[] = [];
    let uniqueTagsList: string[] = [];

    const analyzeCaption = () => {
      const text = captionInput?.value || '';
      const charCount = text.length;

      // Extract hashtags using regex matching letters, digits, and underscores
      const regex = /#[\p{L}\p{N}_]+/gu;
      const matches = text.match(regex) || [];
      extractedTagsList = matches.map(tag => tag.toLowerCase());

      // Detect duplicates
      const seen = new Set<string>();
      const duplicatesList = new Set<string>();
      
      extractedTagsList.forEach(tag => {
        if (seen.has(tag)) {
          duplicatesList.add(tag);
        }
        seen.add(tag);
      });

      uniqueTagsList = Array.from(seen);

      // Render Outputs
      if (emptyBox) emptyBox.classList.add('hidden');
      if (activeBox) activeBox.classList.remove('hidden');

      // Update counters
      if (charCountVal) {
        charCountVal.textContent = `${charCount} / 2200`;
        charCountVal.style.color = charCount > 2200 ? '#ef4444' : '';
      }

      if (hashtagCountVal) {
        hashtagCountVal.textContent = `${extractedTagsList.length} / 5`;
        if (extractedTagsList.length > 5) {
          hashtagCountVal.style.color = '#ef4444';
        } else if (extractedTagsList.length >= 3 && extractedTagsList.length <= 5) {
          hashtagCountVal.style.color = 'var(--color-success)';
        } else {
          hashtagCountVal.style.color = '';
        }
      }

      // Display warning flags
      if (dupWarning) {
        if (duplicatesList.size > 0) dupWarning.classList.remove('hidden');
        else dupWarning.classList.add('hidden');
      }

      if (limitWarning) {
        if (extractedTagsList.length > 5) limitWarning.classList.remove('hidden');
        else limitWarning.classList.add('hidden');
      }

      // Populate tags grid
      if (tagsWrapper) {
        if (extractedTagsList.length === 0) {
          tagsWrapper.innerHTML = `<span class="text-muted" style="font-size: 0.88rem;">No hashtags found in text.</span>`;
        } else {
          // Render tags showing duplicate badges
          const tagsSeen = new Set<string>();
          tagsWrapper.innerHTML = extractedTagsList.map(tag => {
            const isDup = tagsSeen.has(tag);
            tagsSeen.add(tag);
            return `
              <span class="tag-chip ${isDup ? 'duplicate' : ''}">
                <span>${tag}</span>
                ${isDup ? '<span class="dup-badge">DUP</span>' : ''}
              </span>
            `;
          }).join('');
        }
      }

      // Smooth scroll to the results section
      const resultsWrapper = document.getElementById('results-wrapper');
      if (resultsWrapper) {
        resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    const copyTagsOnly = () => {
      if (uniqueTagsList.length === 0) return alert("No hashtags found to copy.");
      const tagsText = uniqueTagsList.join(' ');
      navigator.clipboard.writeText(tagsText).then(() => {
        if (copyTagsBtn) {
          const originalText = copyTagsBtn.textContent;
          copyTagsBtn.textContent = 'Copied unique tags! ✓';
          setTimeout(() => {
            copyTagsBtn.textContent = originalText;
          }, 1500);
        }
      });
    };

    const copyCleanCaption = () => {
      const text = captionInput?.value || '';
      if (!text) return alert("Please enter caption text.");

      // Split words and strip out duplicates
      // To preserve layout but strip duplicate hashtags:
      // We look at each word starting with '#' and filter duplicates
      const seen = new Set<string>();
      const words = text.split(/(\s+)/); // Keep whitespace delimiters
      const cleanWords = words.map(word => {
        if (word.startsWith('#')) {
          const cleaned = word.toLowerCase().trim();
          if (seen.has(cleaned)) {
            return ''; // strip out repeated tag
          }
          seen.add(cleaned);
        }
        return word;
      });

      // Join and clean double spacing caused by stripped tags
      let cleanText = cleanWords.join('');
      // Clean up multiple trailing empty spaces or empty brackets
      cleanText = cleanText.replace(/[ \t]{2,}/g, ' ').trim();

      navigator.clipboard.writeText(cleanText).then(() => {
        if (copyCaptionBtn) {
          const originalText = copyCaptionBtn.textContent;
          copyCaptionBtn.textContent = 'Copied clean caption! ✓';
          setTimeout(() => {
            copyCaptionBtn.textContent = originalText;
          }, 1500);
        }
      });
    };

    const resetForm = () => {
      if (captionInput) captionInput.value = '';
      extractedTagsList = [];
      uniqueTagsList = [];
      if (emptyBox) emptyBox.classList.remove('hidden');
      if (activeBox) activeBox.classList.add('hidden');
    };

    submitBtn?.addEventListener('click', analyzeCaption);
    resetBtn?.addEventListener('click', resetForm);
    copyTagsBtn?.addEventListener('click', copyTagsOnly);
    copyCaptionBtn?.addEventListener('click', copyCleanCaption);
  };

  setupHashtagCounter();
  document.addEventListener('astro:after-swap', setupHashtagCounter);
</script>
