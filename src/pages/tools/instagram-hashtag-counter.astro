  }

  .breakdown-box {
    width: 100%;
  }

  .breakdown-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  /* Extracted chips container */
  .tags-chips-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
