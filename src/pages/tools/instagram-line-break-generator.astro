---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: "Why does Instagram collapse line breaks in captions?",
    answer: "Instagram's default text parsing engine collapses consecutive empty lines and trailing spaces to save screen space on mobile feeds. This tool solves this by inserting invisible spacer characters (like the U+2800 Braille space) at the start of newlines."
  },
  {
    question: "What is the invisible spacer character?",
    answer: "The U+2800 Braille pattern blank space (⠀) is a special Unicode character that browsers and apps render as completely empty space. Because it is technically a character and not a standard whitespace space key, Instagram is forced to preserve the line break without collapsing it."
  },
  {
    question: "Will this tool make my captions look spammy?",
    answer: "No. Since this generator uses truly invisible spacers, your captions will look clean and professional, without the need for bullet points (•) or dots (.) that creators historically used to separate paragraphs."
  },
  {
    question: "How many hashtags can I format with this tool?",
    answer: "Instagram has a strict limit of 30 hashtags per post. Our tool includes an active hashtag counter that highlights your hashtag count in red if you exceed this limit."
  },
  {
    question: "Is there a character limit for Instagram captions?",
    answer: "Yes, Instagram captions have a character limit of 2,200 characters. The sandbox workspace tracks this in real-time, showing a progress bar to prevent your caption from getting cut off."
  }
];
---

<ToolLayout
  title="Instagram Line Break Generator - Free Caption Spacer Tool"
  description="Generate clean, invisible line breaks for Instagram captions. Format post layouts, verify character limits, and count hashtags in real-time."
  toolName="Instagram Line Break Generator"
  toolDescription="Format your Instagram captions with clean, invisible spaces. Stop using dots or dashes to separate paragraphs—our tool injects clean spacer characters instantly."
  category="Writing Tools"
  faqs={faqs}
>
  <div slot="calculator" class="calc-card glass">
    <!-- Main Advanced Grid Layout -->
    <div class="calc-grid">
      <!-- Left Column: Settings and Input Forms -->
      <div class="calc-form-column">
        <form class="calc-form" id="generator-form" onsubmit="return false;">
