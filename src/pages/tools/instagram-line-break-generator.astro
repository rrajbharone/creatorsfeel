<script>
  const setupInstagramLineBreakGenerator = () => {
    const handleInput = document.getElementById('handle-input') as HTMLInputElement;
    const valueInput = document.getElementById('value-input') as HTMLTextAreaElement;
    const spacerSelect = document.getElementById('spacer-input') as HTMLSelectElement;
    const cleanSpacesCheck = document.getElementById('clean-spaces-check') as HTMLInputElement;
    const capitalizeCheck = document.getElementById('capitalize-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // Preview Mockup Elements
    const mockupHandle = document.getElementById('mockup-handle-display');
    const mockupCaptionHandle = document.getElementById('mockup-caption-handle');
    const mockupCaptionText = document.getElementById('mockup-caption-text');
    const mockupMoreLink = document.getElementById('mockup-more-link');

    // Sandbox workspace
    const sandboxInput = document.getElementById('sandbox-input') as HTMLTextAreaElement;
    const sandboxCounter = document.getElementById('sandbox-counter');
    const sandboxHashtags = document.getElementById('sandbox-hashtags');
    const progressBarFill = document.getElementById('progress-bar-fill');
    const copyActiveBtn = document.getElementById('copy-active-btn');
    const clearSandboxBtn = document.getElementById('clear-sandbox-btn');

    // Live Handle Mockup Update
    const updateHandleMockup = () => {
      const handle = (handleInput?.value || 'creators_feel').trim().toLowerCase().replace(/\s+/g, '_');
      if (mockupHandle) mockupHandle.textContent = handle;
      if (mockupCaptionHandle) mockupCaptionHandle.textContent = handle;
    };
    handleInput?.addEventListener('input', updateHandleMockup);

    // Live Sandbox update
    const updateSandbox = () => {
      const text = sandboxInput?.value || '';
      const len = text.length;

      // Extract and count hashtags
      const tags = (text.match(/#[a-zA-Z0-9_]+/g) || []).length;

      // Update Mockup Caption (with truncation simulation)
      if (mockupCaptionText) {
        if (len > 125) {
          mockupCaptionText.textContent = text.substring(0, 125);
          mockupMoreLink?.classList.remove('hidden');
        } else {
          mockupCaptionText.textContent = text || 'Your formatted caption will preview here...';
          mockupMoreLink?.classList.add('hidden');
        }
      }

      // Update counters
      if (sandboxCounter) {
        sandboxCounter.textContent = `${len} / 2200 Chars`;
        sandboxCounter.style.color = len > 2200 ? '#ef4444' : 'var(--color-text-muted)';
      }

      if (sandboxHashtags) {
        sandboxHashtags.textContent = `${tags} / 30 Tags`;
        sandboxHashtags.style.color = tags > 30 ? '#ef4444' : 'var(--color-text-muted)';
      }

      // Update progress bar
      if (progressBarFill) {
        const percent = Math.min((len / 2200) * 100, 100);
        progressBarFill.style.width = `${percent}%`;
        
        if (len > 2200 || tags > 30) {
          progressBarFill.style.backgroundColor = '#ef4444';
        } else if (percent > 85) {
          progressBarFill.style.backgroundColor = '#f59e0b';
        } else {
          progressBarFill.style.backgroundColor = 'var(--color-brand)';
        }
      }
    };
    sandboxInput?.addEventListener('input', updateSandbox);

    // Expand mockup caption
    mockupMoreLink?.addEventListener('click', () => {
      if (mockupCaptionText && sandboxInput) {
        mockupCaptionText.textContent = sandboxInput.value;
        mockupMoreLink.classList.add('hidden');
      }
    });

    // Formatting logic
    const formatCaption = () => {
      let text = (valueInput?.value || '');
      const spacerType = spacerSelect?.value || 'invisible';
      const cleanSpaces = cleanSpacesCheck?.checked || false;
      const capitalize = capitalizeCheck?.checked || false;

      if (!text) {
        alert("Please enter caption text to format.");
        return;
      }

      // 1. Clean spaces
      if (cleanSpaces) {
        text = text.replace(/[ \t]+/g, ' ');
      }

      // 2. Capitalize sentences
      if (capitalize) {
        text = text.replace(/(^\s*|[.!?]\s+)([a-z])/g, (m, p1, p2) => p1 + p2.toUpperCase());
      }

      // 3. Spacers replacement
      // Define spacer symbol
      let spacer = '⠀'; // U+2800 Invisible braille space
      if (spacerType === 'bullet') spacer = '•';
      if (spacerType === 'dash') spacer = '—';
      if (spacerType === 'star') spacer = '★';

      // Split lines, map line spacing
      const lines = text.split('\n');
      const formattedLines = lines.map((line, idx) => {
        const trimmed = line.trim();
        // If line is empty (consecutive newline), inject spacer
        if (trimmed === '') {
          return spacer;
        }
        return line;
      });

      const formattedResult = formattedLines.join('\n');

      if (sandboxInput) {
        sandboxInput.value = formattedResult;
        updateSandbox();
      }

      // Scroll directly to the results / editor sandbox column
      const editorCol = document.querySelector('.calc-editor-column');
      if (editorCol) {
        editorCol.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    generateBtn?.addEventListener('click', formatCaption);

    // Emoji quick click inserter
    const emojiContainer = document.getElementById('emoji-picker-container');
    emojiContainer?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.emoji-btn');
      if (!btn || !sandboxInput) return;
      
      const emoji = btn.textContent || '';
      const start = sandboxInput.selectionStart;
      const end = sandboxInput.selectionEnd;
      const val = sandboxInput.value;

      sandboxInput.value = val.substring(0, start) + emoji + val.substring(end);
      
      // Reset cursor position
      sandboxInput.selectionStart = sandboxInput.selectionEnd = start + emoji.length;
      sandboxInput.focus();
      updateSandbox();
    });

    // Sandbox Copy
    copyActiveBtn?.addEventListener('click', () => {
      const text = sandboxInput?.value || '';
      if (!text) return alert("Sandbox editor is empty!");
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyActiveBtn.textContent;
        copyActiveBtn.textContent = 'Copied to Clipboard! ✓';
        setTimeout(() => {
          copyActiveBtn.textContent = originalText;
        }, 1500);
      });
    });

    // Clear Sandbox
    clearSandboxBtn?.addEventListener('click', () => {
      if (sandboxInput) {
        sandboxInput.value = '';
        updateSandbox();
      }
    });

    // Reset Fields
    resetBtn?.addEventListener('click', () => {
      if (valueInput) valueInput.value = '';
      if (sandboxInput) sandboxInput.value = '';
      updateSandbox();
    });

    // Initialize
    updateHandleMockup();
    updateSandbox();
  };

  setupInstagramLineBreakGenerator();
  document.addEventListener('astro:after-swap', setupInstagramLineBreakGenerator);
</script>
