---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';

// Structured list of all tools for easy scaling
const tools = [
  {
    title: 'Instagram Engagement Calculator',
    description: 'Analyze average post likes, comments, and followers to calculate your real audience engagement rate.',
    href: '/tools/instagram-engagement-calculator',
    category: 'Calculators',
    badge: 'Popular',
    badgeType: 'success' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z" /></svg>`
  },
  {
    title: 'Influencer Rate Calculator',
    description: 'Input your metrics to estimate your earnings per post, calculate CPM, and generate a brand pitch template.',
    href: '/tools/influencer-rate-calculator',
    category: 'Calculators',
    badge: 'Trending',
    badgeType: 'brand' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`
  },
  {
    title: 'YouTube Title Checker',
    description: 'Type your YouTube title to get real-time previews for desktop/mobile layouts, character checklists, and SEO scores.',
    href: '/tools/youtube-title-length-checker',
    category: 'Writing Tools',
    badge: 'New',
    badgeType: 'info' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>`
  },
  {
    title: 'CPM Calculator',
    description: 'Calculate campaign cost, ad impressions, or Cost Per Mille (CPM) instantly with detailed metrics breakdown.',
    href: '/tools/cpm-calculator',
    category: 'Calculators',
    badge: 'New',
    badgeType: 'brand' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0h.5m-.5 0h-9.5m0 0h-.5" /></svg>`
  },
  {
    title: 'Instagram Bio Character Counter',
    description: 'Count characters and lines, audit Call-to-Actions, and generate fancy copy-paste fonts for your Instagram profile.',
    href: '/tools/instagram-bio-character-counter',
    category: 'Writing Tools',
    badge: 'New',
    badgeType: 'brand' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg>`
  },
  {
    title: 'Instagram Caption Character Counter',
    description: 'Verify the 2,200 character limit, track hashtag limits, and preview the 125-character mobile feed crop in real-time.',
    href: '/tools/instagram-caption-character-counter',
    category: 'Writing Tools',
    badge: 'New',
    badgeType: 'brand' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501c1.153-.086 2.294-.213 3.423-.379 1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v5.78Z" /></svg>`
  },
  {
    title: 'LinkedIn Headline Generator',
    description: 'Generate high-converting, keyword-optimized LinkedIn profile headlines with presets for students, engineers, doctors, and business owners.',
    href: '/tools/linkedin-headline-generator',
    category: 'Writing Tools',
    badge: 'New',
    badgeType: 'brand' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Zm6-10.5h.008v.008H10.5V9Zm0 3h.008v.008H10.5v-.008Zm0 3h.008v.008H10.5v-.008Z" /></svg>`
  },
  {
    title: 'LinkedIn Bio Generator',
    description: 'Generate recruiter-approved, keyword-rich LinkedIn About summaries with pre-built templates for students, engineers, doctors, and business owners.',
    href: '/tools/linkedin-bio-generator',
    category: 'Writing Tools',
    badge: 'New',
    badgeType: 'brand' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>`
  },
  {
    title: 'Cost Per Engagement Calculator',
    description: 'Calculate Cost Per Engagement (CPE), campaign budgets, or total engagements instantly with simple or detailed interaction inputs.',
    href: '/tools/cost-per-engagement-calculator',
    category: 'Calculators',
    badge: 'New',
    badgeType: 'brand' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`
  },
  {
    title: 'Instagram Story & Reel Rate Calculator',
    description: 'Calculate sponsored post rates for Instagram Stories and Reels dynamically based on followers, niche, views, and engagement benchmarks.',
    href: '/tools/instagram-story-reel-calculator',
    category: 'Calculators',
    badge: 'New',
    badgeType: 'brand' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316A2.192 2.192 0 0 0 14.53 4H9.47c-.527 0-1.026.262-1.332.712l-.822 1.316Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Z" /></svg>`
  },
  {
    title: 'Brand Deal Calculator',
    description: 'Calculate brand deal values for YouTube, TikTok, and Instagram campaigns using custom deliverables and platforms benchmarks.',
    href: '/tools/brand-deal-calculator',
    category: 'Calculators',
    badge: 'New',
    badgeType: 'brand' as const,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5h16.5M4.5 19.5h15M12 6.75v10.5m-3.75-3h7.5" /></svg>`
  }
];

const categories = ['All', 'Calculators', 'Writing Tools'];

const breadcrumbs = [
  { name: 'Home', item: '/' },
  { name: 'Tools', item: '/tools' }
];
---

<BaseLayout 
  title="Creator Tools Directory - CreatorsFeel"
  description="Explore our suite of premium creator tools. Audit Instagram engagement, calculate sponsorship rates, and optimize YouTube video titles."
  breadcrumbs={breadcrumbs}
>
  <section class="tools-directory-container container">
    <header class="directory-header text-center">
      <h1 class="directory-title">Creator Tools Directory</h1>
      <p class="directory-desc text-muted">A collection of free, high-performance analytics and marketing tools for modern social media creators.</p>
    </header>

    <!-- Search & Filter Controls -->
    <div class="search-filter-bar glass">
      <div class="search-input-wrapper">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.637 10.637Z" />
        </svg>
        <input 
          type="search" 
          id="tools-search" 
          placeholder="Search by tool name or description..." 
          aria-label="Search tools"
          class="directory-search-input"
        />
      </div>

      <div class="category-tabs" role="tablist" aria-label="Tool Categories">
        {categories.map((cat, idx) => (
          <button 
            role="tab" 
            aria-selected={idx === 0 ? "true" : "false"} 
            class:list={["cat-tab", { active: idx === 0 }]}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Tools Grid -->
    <div class="tools-grid-wrapper">
      <div class="tools-grid" id="tools-grid">
        {tools.map(tool => (
          <div class="tool-card-item" data-title={tool.title.toLowerCase()} data-desc={tool.description.toLowerCase()} data-category={tool.category}>
            <Card 
              title={tool.title} 
              description={tool.description} 
              href={tool.href}
              badge={tool.badge}
              badgeType={tool.badgeType}
              icon={tool.icon}
            />
          </div>
        ))}
      </div>

      <!-- Search Empty State -->
      <div class="search-empty-state text-center glass hidden" id="search-empty">
        <svg class="empty-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 15.75-2.489-2.489m0 0a3.375 3.375 0 1 0-4.773-4.773 3.375 3.375 0 0 0 4.774 4.774ZM21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <h3>No Tools Found</h3>
        <p class="text-muted">We couldn't find any tools matching your search query. Try broadening your keywords.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tools-directory-container {
    padding-top: var(--space-md);
    padding-bottom: var(--space-xl);
  }

  .directory-header {
    margin-bottom: var(--space-lg);
  }

  .directory-title {
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .directory-desc {
    max-width: var(--max-width-text);
    margin-left: auto;
    margin-right: auto;
    font-size: 1.15rem;
  }

  /* Search and Category Filter Bar */
  .search-filter-bar {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border-radius: var(--radius-lg);
    gap: 1.25rem;
    margin-bottom: var(--space-lg);
  }

  .search-input-wrapper {
    position: relative;
    width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .directory-search-input {
    width: 100%;
    height: 48px;
    padding: 0 1rem 0 3rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    transition: all var(--transition-fast);
  }

  .directory-search-input:focus {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
  }

  .category-tabs {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
  }

  .category-tabs::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .cat-tab {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .cat-tab:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
  }

  .cat-tab.active {
    background: var(--gradient-brand);
    color: var(--color-text-inverse);
    border-color: transparent;
  }

  /* Tools Grid */
  .tools-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .search-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl) var(--space-md);
    border-radius: var(--radius-lg);
    gap: 0.75rem;
  }

  .empty-icon {
    width: 48px;
    height: 48px;
    color: var(--color-text-muted);
  }

  .hidden {
    display: none !important;
  }

  /* Responsive Rules */
  @media (min-width: 640px) {
    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .search-filter-bar {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .search-input-wrapper {
      max-width: 450px;
    }

    .tools-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  const setupDirectorySearch = () => {
    const searchInput = document.getElementById('tools-search') as HTMLInputElement;
    const tabs = document.querySelectorAll('.cat-tab');
    const cards = document.querySelectorAll('.tool-card-item');
    const emptyState = document.getElementById('search-empty');

    if (!searchInput) return;

    let activeCategory = 'All';
    let searchQuery = '';

    const filterTools = () => {
      let visibleCount = 0;

      cards.forEach(cardEl => {
        const card = cardEl as HTMLElement;
        const title = card.getAttribute('data-title') || '';
        const desc = card.getAttribute('data-desc') || '';
        const cat = card.getAttribute('data-category') || '';

        const matchesSearch = title.includes(searchQuery) || desc.includes(searchQuery);
        const matchesCategory = activeCategory === 'All' || cat === activeCategory;

        if (matchesSearch && matchesCategory) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
      } else {
        emptyState?.classList.add('hidden');
      }
    };

    // Read category from URL parameter on load
    const urlParams = new URLSearchParams(window.location.search);
    const catParam = urlParams.get('cat');
    if (catParam) {
      const matchingTab = Array.from(tabs).find(tab => tab.getAttribute('data-category') === catParam) as HTMLButtonElement | undefined;
      if (matchingTab) {
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        matchingTab.classList.add('active');
        matchingTab.setAttribute('aria-selected', 'true');
        activeCategory = catParam;
        filterTools();
      }
    }

    // Search Input Event
    searchInput.addEventListener('input', () => {
      searchQuery = searchInput.value.toLowerCase().trim();
      filterTools();
    });

    // Category Tabs Click Events
    tabs.forEach(tabEl => {
      const tab = tabEl as HTMLButtonElement;
      tab.addEventListener('click', () => {
        // Toggle Active styles
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');

        activeCategory = tab.getAttribute('data-category') || 'All';
        filterTools();
      });
    });
  };

  setupDirectorySearch();
  document.addEventListener('astro:after-swap', setupDirectorySearch);
</script>
