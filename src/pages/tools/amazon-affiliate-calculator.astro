    }

    .rate-range-box {
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      border-radius: 0 !important;
      box-shadow: none !important;
      width: 100% !important;
      border-bottom: 1px dashed var(--color-border) !important;
      padding-bottom: 1rem !important;
      align-items: center !important;
    }
  }

  @media (min-width: 768px) {
    .form-row-2 {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .calc-grid {
      grid-template-columns: 1.2fr 1fr;
      align-items: start;
      gap: 2.5rem;
    }
  }
</style>

<script>
  const setupAmazonCalculator = () => {
    const clicksInput = document.getElementById('monthly-clicks') as HTMLInputElement;
    const priceInput = document.getElementById('item-price') as HTMLInputElement;
    const categorySelect = document.getElementById('product-category') as HTMLSelectElement;
    const customRateBox = document.getElementById('custom-rate-box');
    const customCommissionInput = document.getElementById('custom-commission') as HTMLInputElement;
    const convInput = document.getElementById('conversion-rate') as HTMLInputElement;

    const submitBtn = document.getElementById('calc-submit-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    const emptyBox = document.getElementById('res-empty-box');
    const activeBox = document.getElementById('res-active-box');

    const earningsVal = document.getElementById('res-earnings-val');
    const rangeVal = document.getElementById('res-range-val');
    const clicksVal = document.getElementById('res-clicks-val');
    const itemsVal = document.getElementById('res-items-val');
    const grossVal = document.getElementById('res-gross-val');
    const yearlyVal = document.getElementById('res-yearly-val');

    // Toggle custom commission input field
    categorySelect?.addEventListener('change', () => {
      if (categorySelect.value === 'custom') {
        if (customRateBox) customRateBox.style.display = 'flex';
      } else {
        if (customRateBox) customRateBox.style.display = 'none';
        if (customCommissionInput) customCommissionInput.value = '';
      }
    });

    const calculateEarnings = () => {
      const clicks = parseFloat(clicksInput?.value) || 0;
      const price = parseFloat(priceInput?.value) || 0;
      const conv = parseFloat(convInput?.value) || 5.0;

      if (clicks <= 0 || price <= 0) {
        return alert("Please enter valid monthly clicks and average item price.");
      }

      // Settle commission percentage rate
      let rate = 0;
      if (categorySelect?.value === 'custom') {
        rate = parseFloat(customCommissionInput?.value) || 0;
        if (rate <= 0) {
          return alert("Please enter your custom commission percentage.");
        }
      } else {
        rate = parseFloat(categorySelect?.value) || 4.5;
      }

      // Calculations math
      const itemsSold = Math.round(clicks * (conv / 100));
      const grossSales = itemsSold * price;
      const monthlyCommission = grossSales * (rate / 100);
      const yearlyCommission = monthlyCommission * 12;

      const lowRange = Math.round(monthlyCommission * 0.9);
      const highRange = Math.round(monthlyCommission * 1.1);

      // Render Outputs
      if (emptyBox) emptyBox.classList.add('hidden');
      if (activeBox) activeBox.classList.remove('hidden');

      if (earningsVal) earningsVal.textContent = `$${monthlyCommission.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
      if (rangeVal) rangeVal.textContent = `$${lowRange} - $${highRange} monthly range`;

      if (clicksVal) clicksVal.textContent = clicks.toLocaleString();
      if (itemsVal) itemsVal.textContent = itemsSold.toLocaleString();
      if (grossVal) grossVal.textContent = `$${grossSales.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
      if (yearlyVal) yearlyVal.textContent = `$${yearlyCommission.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;

      // Smooth scroll to the results section
      const resultsWrapper = document.getElementById('results-wrapper');
      if (resultsWrapper) {
        resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    const resetCalculator = () => {
      if (clicksInput) clicksInput.value = '';
      if (priceInput) priceInput.value = '';
      if (categorySelect) categorySelect.selectedIndex = 0;
      if (customRateBox) customRateBox.style.display = 'none';
      if (customCommissionInput) customCommissionInput.value = '';
      if (convInput) convInput.value = '5.0';

      if (emptyBox) emptyBox.classList.remove('hidden');
      if (activeBox) activeBox.classList.add('hidden');
    };

    submitBtn?.addEventListener('click', calculateEarnings);
    resetBtn?.addEventListener('click', resetCalculator);
  };

  setupAmazonCalculator();
  document.addEventListener('astro:after-swap', setupAmazonCalculator);
</script>
