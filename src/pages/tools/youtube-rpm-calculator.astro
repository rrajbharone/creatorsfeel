</style>

<script>
  const setupRpmCalculator = () => {
    const activeModeInput = document.getElementById('active-mode') as HTMLInputElement;
    const modeTabs = document.querySelectorAll('.mode-tab');

    // Tab sections references
    const simpleBox = document.getElementById('inputs-simple-box');
    const detailedBox = document.getElementById('inputs-detailed-box');

    // Simple Mode inputs
    const viewsSimpleInput = document.getElementById('views-simple') as HTMLInputElement;
    const earningsSimpleInput = document.getElementById('earnings-simple') as HTMLInputElement;

    // Detailed Mode inputs
    const viewsDetailedInput = document.getElementById('views-detailed') as HTMLInputElement;
    const earningsAdsInput = document.getElementById('earnings-ads') as HTMLInputElement;
    const earningsPremiumInput = document.getElementById('earnings-premium') as HTMLInputElement;
    const earningsSupersInput = document.getElementById('earnings-supers') as HTMLInputElement;

    // Outputs references
    const emptyBox = document.getElementById('res-empty-box');
    const activeBox = document.getElementById('res-active-box');

    const rpmVal = document.getElementById('res-rpm-val');
    const tierVal = document.getElementById('res-tier-val');

    const proj10k = document.getElementById('proj-10k');
    const proj50k = document.getElementById('proj-50k');
    const proj100k = document.getElementById('proj-100k');
    const proj500k = document.getElementById('proj-500k');
    const proj1m = document.getElementById('proj-1m');

    const submitBtn = document.getElementById('calc-submit-btn');
    const resetBtn = document.getElementById('calc-reset-btn');

    // Mode tab toggle logic
    modeTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        modeTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const mode = tab.getAttribute('data-mode') || 'simple';
        if (activeModeInput) activeModeInput.value = mode;

        if (mode === 'simple') {
          simpleBox?.classList.remove('hidden');
          detailedBox?.classList.add('hidden');
        } else {
          simpleBox?.classList.add('hidden');
          detailedBox?.classList.remove('hidden');
        }

        resetCalculator(false);
      });
    });

    const resetCalculator = (clearInputs = true) => {
      if (clearInputs) {
        if (viewsSimpleInput) viewsSimpleInput.value = '';
        if (earningsSimpleInput) earningsSimpleInput.value = '';
        if (viewsDetailedInput) viewsDetailedInput.value = '';
        if (earningsAdsInput) earningsAdsInput.value = '0';
        if (earningsPremiumInput) earningsPremiumInput.value = '0';
        if (earningsSupersInput) earningsSupersInput.value = '0';
      }

      if (emptyBox) emptyBox.classList.remove('hidden');
      if (activeBox) activeBox.classList.add('hidden');
    };

    const calculateRpm = () => {
      const mode = activeModeInput?.value || 'simple';
      let views = 0;
      let netRevenue = 0;

      if (mode === 'simple') {
        views = parseFloat(viewsSimpleInput?.value) || 0;
        netRevenue = parseFloat(earningsSimpleInput?.value) || 0;
      } else {
        views = parseFloat(viewsDetailedInput?.value) || 0;
        const ads = parseFloat(earningsAdsInput?.value) || 0;
        const premium = parseFloat(earningsPremiumInput?.value) || 0;
        const supers = parseFloat(earningsSupersInput?.value) || 0;
        netRevenue = ads + premium + supers;
      }

      if (views < 100) {
        return alert("Please enter a valid views count (minimum 100).");
      }
      if (netRevenue < 0) {
        return alert("Please enter positive earnings metrics.");
      }

      // Calculate RPM
      const rpm = (netRevenue / views) * 1000;

      // Classify RPM Tier
      let tierLabel = "Average RPM";
      if (rpm < 1.50) {
        tierLabel = "Low RPM (Shorts/Gaming/Comedy)";
      } else if (rpm >= 1.50 && rpm < 5.00) {
        tierLabel = "Average RPM (Lifestyle/Vlogs/Food)";
      } else if (rpm >= 5.00 && rpm < 12.00) {
        tierLabel = "High RPM (Tech/Fitness/Tutorials)";
      } else {
        tierLabel = "Premium RPM (Finance/SaaS/Business)";
      }

      // Render Outputs
      if (emptyBox) emptyBox.classList.add('hidden');
      if (activeBox) activeBox.classList.remove('hidden');

      if (rpmVal) rpmVal.textContent = `$${rpm.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
      if (tierVal) tierVal.textContent = tierLabel;

      // Project Milestones
      if (proj10k) proj10k.textContent = `$${Math.round((rpm * 10000) / 1000).toLocaleString()}`;
      if (proj50k) proj50k.textContent = `$${Math.round((rpm * 50000) / 1000).toLocaleString()}`;
      if (proj100k) proj100k.textContent = `$${Math.round((rpm * 100000) / 1000).toLocaleString()}`;
      if (proj500k) proj500k.textContent = `$${Math.round((rpm * 500000) / 1000).toLocaleString()}`;
      if (proj1m) proj1m.textContent = `$${Math.round((rpm * 1000000) / 1000).toLocaleString()}`;

      // Smooth scroll to the results section
      const resultsWrapper = document.getElementById('results-wrapper');
      if (resultsWrapper) {
        resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    submitBtn?.addEventListener('click', calculateRpm);
    resetBtn?.addEventListener('click', () => resetCalculator(true));
  };

  setupRpmCalculator();
  document.addEventListener('astro:after-swap', setupRpmCalculator);
</script>
