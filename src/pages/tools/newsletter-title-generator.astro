<script>
  const setupNewsletterTitleGenerator = () => {
    const seedInput = document.getElementById('seed-input') as HTMLInputElement;
    const nicheSelect = document.getElementById('niche-select') as HTMLSelectElement;
    const formatSelect = document.getElementById('format-select') as HTMLSelectElement;

    // Checkboxes
    const emojiCheck = document.getElementById('emoji-check') as HTMLInputElement;
    const personalizationCheck = document.getElementById('personalization-check') as HTMLInputElement;

    // Actions
    const generateBtn = document.getElementById('generate-btn');
    const resetBtn = document.getElementById('reset-btn');
    const generateMoreBtn = document.getElementById('generate-more-btn');

    // Layout slots
    const resultsWrapper = document.getElementById('results-wrapper');
    const container = document.getElementById('generated-titles-container');

    // Mockup targets
    const mockupSubjectText = document.getElementById('mockup-subject-text');
    const mockupSnippetText = document.getElementById('mockup-snippet-text');

    // Vibe Templates Database
    const vibesData: Record<string, { templates: string[], emojis: string[] }> = {
      edu: {
        templates: [
          `How to level up your workflow using {topic}`,
          `The ultimate guide to mastering {topic}`,
          `5 simple hacks to save hours on {topic}`,
          `What nobody tells you about {topic}`,
          `How we scaled our results with {topic}`
        ],
        emojis: ['🎓', '💡', '📈', '🚀', '🧠']
      },
      curiosity: {
        templates: [
          `The hidden secret behind {topic} revealed`,
          `Is it really possible to double your results with {topic}?`,
          `Why most creators are completely wrong about {topic}`,
          `This small change in {topic} makes a massive difference`,
          `What if you could automate all your {topic} today?`
        ],
        emojis: ['🤔', '🤫', '👀', '🔮', '✨']
      },
      scarcity: {
        templates: [
          `Only 24 hours left to secure your guide on {topic}`,
          `Stop missing out on critical {topic} opportunities`,
          `This is your last warning regarding {topic}`,
          `Closing soon: Get our complete checklist for {topic}`,
          `Why you need to update your {topic} strategy today`
        ],
        emojis: ['⏳', '⚠️', '🚨', '⏰', '🔥']
      },
      direct: {
        templates: [
          `Weekly update: What is new with {topic}`,
          `Our honest review of {topic} configurations`,
          `Case study: How we optimized {topic} from scratch`,
          `Important announcement regarding your {topic}`,
          `Top trends: Everything happening in {topic} this week`
        ],
        emojis: ['📰', '📢', '💬', '📊', '💻']
      },
      humorous: {
        templates: [
          `We spent 48 hours reviewing {topic} (so you do not have to)`,
          `My boss thinks I am working, but I am just researching {topic}`,
          `Can {topic} save your productivity? Let us find out`,
          `The absolute worst way to get started with {topic}`,
          `Is it just me, or is {topic} getting out of hand?`
        ],
        emojis: ['🫠', '🤷', '💀', '🤡', '😂']
      }
    };

    let currentShuffledPool: string[] = [];
    let currentPoolIndex = 0;

    const buildShuffledPool = () => {
      const topic = (seedInput?.value || '').trim();
      const niche = nicheSelect?.value || 'edu';
      const format = formatSelect?.value || 'sentence';

      const includeEmojis = emojiCheck?.checked;
      const includePersonalization = personalizationCheck?.checked;

      const database = vibesData[niche] || vibesData['edu'];
      const generatedSet = new Set<string>();

      const applyCapitalization = (text: string) => {
        if (format === 'lowercase') {
          return text.toLowerCase();
        }
        if (format === 'title') {
          return text.replace(/\b\w/g, c => c.toUpperCase());
        }
        // Sentence case: capitalize first letter
        return text.charAt(0).toUpperCase() + text.slice(1);
      };

      const applyFormat = (template: string, emoji: string) => {
        const topicVal = topic || 'AI tools';
        let rawSubject = template.replace(/{topic}/g, topicVal);

        // Apply capitalization filters
        rawSubject = applyCapitalization(rawSubject);

        // Apply personalization tag
        if (includePersonalization) {
          rawSubject = `[First Name], ${rawSubject}`;
        }

        // Apply emoji
        if (includeEmojis && emoji) {
          rawSubject = `${rawSubject} ${emoji}`;
        }

        // Trim subject to 150 characters maximum
        return rawSubject.substring(0, 150);
      };

      // Generate a pool of 50 possible unique variations
      let iterations = 0;
      while (generatedSet.size < 50 && iterations < 300) {
        iterations++;
        const tIndex = Math.floor(Math.random() * database.templates.length);
        const eIndex = Math.floor(Math.random() * database.emojis.length);

        const template = database.templates[tIndex] || '';
        const emojiVal = database.emojis[eIndex] || '';

        const formatted = applyFormat(template, emojiVal);
        if (formatted.length >= 5) {
          generatedSet.add(formatted);
        }
      }

      currentShuffledPool = Array.from(generatedSet).sort(() => Math.random() - 0.5);
      currentPoolIndex = 0;
    };

    // Clean initial list generation
    const generateList = () => {
      buildShuffledPool();

      const selected = currentShuffledPool.slice(0, 15);
      currentPoolIndex = 15;

      if (container) {
        container.innerHTML = selected.map(s => {
          return `
            <div class="title-chip" data-name="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
        }).join('');
      }

      resultsWrapper?.classList.remove('hidden');

      // Default the mockup subject to the first generated result
      if (mockupSubjectText && selected.length > 0) {
        mockupSubjectText.textContent = selected[0];
      }

      // Update snippet preview personalization if checked
      if (mockupSnippetText) {
        const isPersonalized = personalizationCheck?.checked;
        mockupSnippetText.textContent = isPersonalized 
          ? "Hey [First Name], in this week's issue we are diving deep into the latest..."
          : "Hey there, in this week's issue we are diving deep into the latest...";
      }
    };

    // Append 5 more unique titles
    const appendMoreTitles = () => {
      if (currentShuffledPool.length === 0) {
        buildShuffledPool();
      }

      if (currentPoolIndex >= currentShuffledPool.length) {
        buildShuffledPool();
      }

      const next = currentShuffledPool.slice(currentPoolIndex, currentPoolIndex + 5);
      currentPoolIndex += 5;

      if (container) {
        const appendHtml = next.map(s => {
          return `
            <div class="title-chip" data-name="${s}">
              <span class="title-text">${s}</span>
              <button class="chip-btn">Copy</button>
            </div>
          `;
        }).join('');
        container.innerHTML += appendHtml;
      }
    };

    generateBtn?.addEventListener('click', () => {
      generateList();

      const resultsSection = document.getElementById('results-wrapper');
      if (resultsSection) {
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    generateMoreBtn?.addEventListener('click', () => {
      appendMoreTitles();
    });

    // Handle copying individual title chips and update mockup preview
    container?.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest('.title-chip');
      if (!chip) return;

      const titleVal = chip.getAttribute('data-name') || '';

      // Update mockup sidebar
      if (mockupSubjectText) {
        mockupSubjectText.textContent = titleVal;
      }

      // Copy to clipboard
      navigator.clipboard.writeText(titleVal).then(() => {
        const btn = chip.querySelector('.chip-btn') as HTMLElement;
        if (btn) {
          btn.textContent = 'Copied! ✓';
          setTimeout(() => {
            btn.textContent = 'Copy';
          }, 1200);
        }
      });
    });

    // Reset inputs
    resetBtn?.addEventListener('click', () => {
      if (seedInput) seedInput.value = '';
      resultsWrapper?.classList.add('hidden');
    });

    // Auto-generate initial list
    generateList();
  };

  setupNewsletterTitleGenerator();
  document.addEventListener('astro:after-swap', setupNewsletterTitleGenerator);
</script>
