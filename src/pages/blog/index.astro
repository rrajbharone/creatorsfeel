---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbs = [
  { name: 'Home', item: '/' },
  { name: 'Blog', item: '/blog' }
];
---

<BaseLayout 
  title="Blog & Creator Insights - CreatorsFeel"
  description="Explore our blog for creator guidelines, title optimization tips, social media growth strategies, and marketing blueprints."
  breadcrumbs={breadcrumbs}
>
  <section class="blog-archive-container container">
    <header class="blog-header text-center">
      <h1 class="blog-archive-title">Creator Insights & Blog</h1>
      <p class="blog-archive-desc text-muted">
        Practical advice, platform tips, copy formulas, and growth blueprints to help you scale your brand.
      </p>
    </header>

    <!-- Blog Posts Grid -->
    <div class="blog-posts-grid">
      {sortedPosts.map(post => {
        const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });

        return (
          <article class="blog-card glass">
            {post.data.image && (
              <a href={`/blog/${post.id}`} class="blog-card-image-link">
                <img src={post.data.image} alt={post.data.title} class="blog-card-img" loading="lazy" />
              </a>
            )}
            <div class="blog-card-content">
              <div class="blog-card-meta">
                <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                <span class="meta-dot">&bull;</span>
                <span class="author">By {post.data.author}</span>
              </div>
              
              <h2 class="blog-card-title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h2>
              
              <p class="blog-card-desc text-muted">{post.data.description}</p>
              
              <div class="blog-card-footer">
                <a href={`/blog/${post.id}`} class="blog-read-more">Read Article &rarr;</a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-archive-container {
    padding-top: var(--space-md);
    padding-bottom: var(--space-xl);
  }

  .blog-header {
    margin-bottom: var(--space-lg);
  }

  .blog-archive-title {
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .blog-archive-desc {
    max-width: var(--max-width-text);
    margin-left: auto;
    margin-right: auto;
    font-size: 1.15rem;
  }

  /* Blog Grid styling */
  .blog-posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .blog-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .blog-card:hover {
    border-color: var(--color-brand);
    transform: translateY(-4px);
    box-shadow: 0 10px 25px var(--color-shadow-hover);
  }

  .blog-card-image-link {
    display: block;
    width: 100%;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .blog-card:hover .blog-card-img {
    transform: scale(1.03);
  }

  .blog-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .blog-card-title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .blog-card-title a:hover {
    color: var(--color-brand);
  }

  .blog-card-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    flex-grow: 1;
  }

  .blog-card-footer {
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .blog-read-more {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-brand);
    display: inline-block;
    transition: transform var(--transition-fast);
  }

  .blog-card:hover .blog-read-more {
    transform: translateX(4px);
  }

  /* Responsive Rules */
  @media (min-width: 640px) {
    .blog-posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-posts-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.25rem;
    }
  }
</style>
