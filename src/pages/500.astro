---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="500 - Server Error | CreatorsFeel"
  description="Something went wrong on our end. Please try reloading the page, or browse our creator tools directory."
>
  <div class="error-page container text-center">
    <div class="error-card glass">
      <span class="error-code">500</span>
      <h1 class="error-title">Internal Server Error</h1>
      <p class="error-desc text-muted">
        Something went wrong on our servers. Don't worry, our team has been notified. Try reloading or return to safety.
      </p>
      
      <div class="action-buttons">
        <a href="/" class="primary-btn">Go to Homepage</a>
        <a href="/tools" class="secondary-btn">Browse Tools Directory</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 250px);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .error-card {
    max-width: 500px;
    padding: 3rem 2rem;
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .error-code {
    font-family: var(--font-heading);
    font-size: 5rem;
    font-weight: 800;
    line-height: 1;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .error-title {
    font-size: 2rem;
    letter-spacing: -0.01em;
  }

  .error-desc {
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .action-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    margin-top: 1rem;
  }

  .primary-btn {
    height: 48px;
    background: var(--gradient-brand);
    color: var(--color-text-inverse);
    font-weight: 600;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-normal);
  }

  .primary-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 15px var(--color-shadow-hover);
  }

  .secondary-btn {
    height: 48px;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: var(--color-bg-card);
    font-weight: 600;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-normal);
  }

  .secondary-btn:hover {
    border-color: var(--color-brand);
    background: var(--color-bg-card-hover);
  }

  /* Responsive Rules */
  @media (min-width: 480px) {
    .action-buttons {
      flex-direction: row;
      justify-content: center;
    }
    
    .primary-btn, .secondary-btn {
      padding: 0 1.5rem;
      width: auto;
    }
  }
</style>
