---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  image?: string;
  tags?: string[];
  faqs?: { question: string; answer: string }[];
}

const { title, description, pubDate, author, image = '/blog/default.jpg', tags = [], faqs = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const breadcrumbs = [
  { name: 'Home', item: '/' },
  { name: 'Blog', item: '/blog' },
  { name: title, item: Astro.url.pathname }
];

const origin = Astro.site ? Astro.site.origin : "https://creatorsfeel.com";
const canonicalUrl = new URL(Astro.url.pathname, origin).href;

const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${canonicalUrl}#article`,
      "headline": title,
      "description": description,
      "image": [new URL(image, origin).href],
      "datePublished": pubDate.toISOString(),
      "author": [{
        "@type": "Person",
        "name": author,
        "url": `${origin}/about`
      }],
      "publisher": {
        "@type": "Organization",
        "name": "CreatorsFeel",
        "logo": {
          "@type": "ImageObject",
          "url": `${origin}/favicon.svg`
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonicalUrl
      }
    },
    ...(faqs && faqs.length > 0 ? [{
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }] : [])
  ]
};
---

<BaseLayout 
  title={title} 
  description={description} 
  type="article"
  breadcrumbs={breadcrumbs}
>
  <!-- Schema structured markup injected in head -->
  <script type="application/ld+json" slot="meta" set:html={JSON.stringify(articleSchema)} />
  <!-- Forward meta slot to BaseLayout head -->
  <slot name="meta" slot="meta" />
  
  <article class="blog-post-container container">
    <!-- Reusable Breadcrumbs Navigation -->
    <Breadcrumbs items={breadcrumbs} />

    <!-- Post Header -->
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span class="meta-dot">&bull;</span>
        <span class="author">By {author}</span>
      </div>
      
      <h1 class="post-title">{title}</h1>
      <p class="post-description text-muted">{description}</p>
      
      {tags.length > 0 && (
        <div class="tags-list">
          {tags.map(tag => (
            <span class="tag-badge">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Featured Image -->
    {image && (
      <div class="featured-image-wrapper">
        <img src={image} alt={`Featured image for: ${title}`} class="featured-image" loading="eager" />
      </div>
    )}

    <!-- Main Content -->
    <div class="post-body">
      <slot />
    </div>

    <!-- Back to Blog Link -->
    <footer class="post-footer">
      <a href="/blog" class="back-link">&larr; Back to all blog posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-post-container {
    max-width: var(--max-width-text);
    padding-top: var(--space-md);
    padding-bottom: var(--space-xl);
  }

  /* Post Header */
  .post-header {
    margin-bottom: var(--space-lg);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .post-title {
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .post-description {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-badge {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-brand);
    background: var(--gradient-glow);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--glass-border);
  }

  /* Featured Image */
  .featured-image-wrapper {
    margin-bottom: var(--space-lg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: 0 10px 30px var(--color-shadow);
  }

  .featured-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
  }

  /* Body Content Styling */
  .post-body {
    line-height: 1.8;
    color: var(--color-text);
    font-size: 1.05rem;
  }

  .post-body :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.75rem;
    letter-spacing: -0.01em;
  }

  .post-body :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.35rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-body :global(ul), .post-body :global(ol) {
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-body :global(li) {
    color: var(--color-text-muted);
  }

  .post-body :global(a) {
    color: var(--color-brand);
    text-decoration: underline;
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .post-body :global(a:hover) {
    color: var(--color-brand-hover);
  }

  .post-body :global(blockquote) {
    border-left: 4px solid var(--color-brand);
    padding-left: 1.25rem;
    font-style: italic;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
  }

  .post-body :global(pre) {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  /* Footer */
  .post-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-weight: 600;
    color: var(--color-brand);
    display: inline-block;
    transition: transform var(--transition-fast);
  }

  .back-link:hover {
    transform: translateX(-4px);
  }
</style>
