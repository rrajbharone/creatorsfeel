---
interface Props {
  title: string;
  description: string;
  href?: string;
  badge?: string;
  badgeType?: 'brand' | 'success' | 'warning' | 'info';
  icon?: string; // We can pass SVG markup or inline content
}

const { title, description, href, badge, badgeType = 'brand', icon } = Astro.props;

const CardElement = href ? 'a' : 'div';
---

<CardElement href={href} class:list={["card glass", { "interactive": !!href }]}>
  <div class="card-inner">
    <div class="card-header">
      {icon && (
        <div class="card-icon" set:html={icon} />
      )}
      {badge && (
        <span class:list={["card-badge", `badge-${badgeType}`]}>{badge}</span>
      )}
    </div>
    
    <div class="card-body">
      <h3 class="card-title">{title}</h3>
      <p class="card-desc text-muted">{description}</p>
    </div>

    {href && (
      <div class="card-footer">
        <span class="action-text">Try Tool &rarr;</span>
      </div>
    )}
  </div>
</CardElement>

<style>
  .card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    padding: 1.5rem;
    position: relative;
    display: block;
    height: 100%;
    border: 1.5px solid var(--color-border) !important;
    transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 1rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 40px;
  }

  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--gradient-glow);
    border: 1px solid var(--glass-border);
    color: var(--color-brand);
  }

  .card-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .card-badge {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-full);
  }

  .badge-brand {
    background: rgba(99, 102, 241, 0.1);
    color: var(--color-brand);
    border: 1px solid rgba(99, 102, 241, 0.2);
  }

  .badge-success {
    background: rgba(16, 185, 129, 0.1);
    color: var(--color-success);
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .badge-warning {
    background: rgba(245, 158, 11, 0.1);
    color: var(--color-warning);
    border: 1px solid rgba(245, 158, 11, 0.2);
  }

  .badge-info {
    background: rgba(14, 165, 233, 0.1);
    color: var(--color-info);
    border: 1px solid rgba(14, 165, 233, 0.2);
  }

  .card-body {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .card-desc {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .card-footer {
    display: flex;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-brand);
    margin-top: auto;
  }

  .action-text {
    transition: transform var(--transition-fast);
  }

  /* Interactive Cards */
  .interactive {
    cursor: pointer;
  }

  .interactive:hover {
    border-color: var(--color-brand) !important;
    transform: translateY(-4px);
    box-shadow: 0 10px 25px var(--color-shadow-hover);
    background: var(--color-bg-card-hover);
  }

  .interactive:hover .action-text {
    transform: translateX(4px);
  }
</style>
