---
interface Props {
  title: string;
  description: string;
  icon: string;
  count?: number;
  href?: string;
}

const { title, description, icon, count, href = "/tools" } = Astro.props;
---

<a href={href} class="category-card glass">
  <div class="category-icon-box" set:html={icon} />
  
  <div class="category-content">
    <div class="category-header">
      <h3 class="category-title">{title}</h3>
      {count !== undefined && (
        <span class="category-count">{count} {count === 1 ? 'tool' : 'tools'}</span>
      )}
    </div>
    <p class="category-desc text-muted">{description}</p>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .category-card:hover {
    border-color: var(--color-brand);
    transform: translateY(-4px);
    box-shadow: 0 10px 25px var(--color-shadow-hover);
    background: var(--color-bg-card-hover);
  }

  .category-icon-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--gradient-glow);
    border: 1px solid var(--glass-border);
    color: var(--color-brand);
    flex-shrink: 0;
  }

  .category-icon-box :global(svg) {
    width: 24px;
    height: 24px;
  }

  .category-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex-grow: 1;
  }

  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .category-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .category-count {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-brand);
    background: rgba(99, 102, 241, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  .category-desc {
    font-size: 0.88rem;
    line-height: 1.5;
  }
</style>
